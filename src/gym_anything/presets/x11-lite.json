{
  "id": "preset.x11-lite@1",
  "version": "1.0",
  "description": "Lightweight X11 desktop with fluxbox and xterm",
  "dockerfile": "gym_anything/presets/x11_lite/Dockerfile",
  "entrypoint": "/workspace/start_app.sh",
  "resources": {"cpu": 1, "mem_gb": 2, "gpu": 0, "net": false},
  "observation": [
    {"type": "rgb_screen", "fps": 10, "resolution": [1280, 720]},
    {"type": "audio_waveform", "sample_rate": 16000, "channels": 1, "chunk_duration_ms": 200}
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "recording": {"enable": true, "output_dir": "./artifacts"},
  "vnc": {"enable": false, "host_port": 5901, "view_only": true},
  "security": {"user": "root", "cap_drop": ["ALL"]},
  "hooks": {"pre_start": "/workspace/hooks/pre_start.sh", "post_start": "/workspace/hooks/post_start.sh"}
}

