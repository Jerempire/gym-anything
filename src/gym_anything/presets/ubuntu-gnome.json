{
  "id": "preset.ubuntu-gnome@1",
  "version": "1.0",
  "description": "Ubuntu base with GNOME session and VNC",
  "dockerfile": "gym_anything/presets/ubuntu_gnome/Dockerfile",
  "entrypoint": "/workspace/start_gnome.sh",
  "resources": {"cpu": 2, "mem_gb": 4, "gpu": 0, "net": false},
  "observation": [
    {"type": "rgb_screen", "fps": 10, "resolution": [1920, 1080]},
    {"type": "audio_waveform", "sample_rate": 16000, "channels": 1, "chunk_duration_ms": 200}
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "recording": {"enable": true, "output_dir": "./artifacts"},
  "vnc": {"enable": true, "host_port": 5901, "view_only": true},
  "security": {"user": "1000:1000", "cap_drop": ["ALL"]}
}
