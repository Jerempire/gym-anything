{
  "id": "preset.ubuntu-gnome-systemd_highres@1",
  "version": "1.0",
  "description": "Ubuntu with GNOME + systemd (PID 1)",
  "dockerfile": "gym_anything/presets/ubuntu_gnome_systemd_highres/Dockerfile",
  "resources": {"cpu": 2, "mem_gb": 4, "gpu": 0, "net": true},
  "observation": [
    {"type": "rgb_screen", "fps": 10, "resolution": [1920, 1080]}
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "recording": {"enable": true, "output_dir": "./artifacts"},
  "vnc": {"enable": true, "host_port": 5901, "view_only": true},
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true,
    "runtime": "sysbox-runc"
  }
}

