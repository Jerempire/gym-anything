{
  "id": "preset.android-14@1",
  "version": "1.0",
  "description": "Android 14 (BlissOS 17) Desktop for QEMU/Apptainer runner (ADB)",
  "os_type": "android",
  "runner": "qemu",
  "base_qcow2": "base_android_14.qcow2",
  "base_iso": "blissos-17.iso",
  "resources": {"cpu": 4, "mem_gb": 4, "gpu": 0, "net": true},
  "observation": [
    {"type": "rgb_screen", "fps": 10, "resolution": [1920, 1080]}
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "recording": {"enable": true, "output_dir": "./artifacts"},
  "vnc": {"enable": true, "host_port": -1, "view_only": false, "password": "password"},
  "adb": {
    "host_port": -1,
    "guest_port": 5555,
    "timeout": 180
  },
  "security": {
    "user": "root",
    "privileged": true
  }
}
