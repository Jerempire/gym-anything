{
  "id": "preset.windows-11@1",
  "version": "1.0",
  "description": "Windows 11 Desktop for QEMU/Apptainer runner (SSH + pyautogui)",
  "os_type": "windows",
  "base_qcow2": "base_windows_11.qcow2",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {"type": "rgb_screen", "fps": 10, "resolution": [1920, 1080]}
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "recording": {
    "enable": true,
    "output_dir": "./artifacts"
  },
  "vnc": {
    "enable": true,
    "host_port": -1,
    "password": "password",
    "view_only": false
  },
  "ssh": {
    "user": "Docker",
    "password": "GymAnything123!",
    "shell": "powershell",
    "note": "SSH requires OpenSSH Server to be installed on Windows"
  },
  "security": {
    "user": "root",
    "privileged": true
  },
  "user_accounts": [
    {
      "name": "Docker",
      "password": "GymAnything123!",
      "role": "developer",
      "note": "Default dockur/windows user with password set by setup script",
      "permissions": {
        "sudo": true,
        "groups": ["Administrators"]
      }
    }
  ],
  "tags": ["windows", "windows-11", "desktop", "qemu", "ssh", "pyautogui"]
}
