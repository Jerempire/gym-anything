{
  "id": "preset.apptainer-xfce-gpu@1",
  "version": "1.0",
  "description": "GPU-enabled Apptainer environment with fluxbox desktop (no systemd required)",
  "os_type": "linux",
  "runner": "apptainer",
  "apptainer": {
    "definition": "gym_anything/presets/apptainer_xfce_gpu/apptainer.def",
    "cache_dir": "~/.cache/gym-anything/apptainer",
    "contain": true,
    "writable_tmpfs": true,
    "enable_gpu": true,
    "env": {
      "DISPLAY": ":99",
      "HOME": "/home/ga",
      "USER": "ga"
    }
  },
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 1,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": true,
    "output_dir": "./artifacts",
    "video_fps": 10,
    "video_resolution": [1920, 1080],
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": true,
    "host_port": -1,
    "container_port": 5900,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "1000:1000",
    "cap_drop": [],
    "privileged": false,
    "use_systemd": false
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input", "render"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":99"
        }
      }
    }
  ]
}
