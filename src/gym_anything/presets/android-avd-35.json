{
  "id": "preset.android-avd-35@1",
  "version": "1.0",
  "description": "Android 15 (API 35) via official AVD emulator with Google Play",
  "os_type": "android",
  "runner": "avd",
  "avd": {
    "api_level": 35,
    "variant": "google_apis_playstore",
    "arch": "x86_64",
    "device": "pixel_6"
  },
  "resources": {"cpu": 4, "mem_gb": 4, "gpu": 0, "net": true},
  "observation": [
    {"type": "rgb_screen", "fps": 10, "resolution": [1080, 2400]}
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "recording": {"enable": true, "output_dir": "./artifacts"},
  "vnc": {"enable": true, "host_port": -1, "view_only": false, "password": "password"},
  "security": {
    "user": "shell",
    "privileged": false
  }
}
