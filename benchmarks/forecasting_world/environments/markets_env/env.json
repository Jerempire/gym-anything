{
  "id": "markets_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Frozen market-simulation workspace for forecasting and decision tasks built around replay packets, scenario dossiers, and structured forecast exports.",
  "category": ["forecasting", "markets", "finance", "desktop"],
  "tags": ["forecasting", "markets", "simulation", "research", "finance"],
  "resources": {
    "cpu": 2,
    "mem_gb": 4,
    "gpu": 0,
    "net": false
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": true,
    "output_dir": "benchmarks/forecasting_world/environments/markets_env/artifacts"
  },
  "vnc": {
    "enable": true,
    "host_port": 5965,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true,
    "runtime": "sysbox-runc"
  },
  "mounts": [
    {
      "source": "benchmarks/forecasting_world/environments/markets_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/forecasting_world/environments/markets_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_markets_env.sh",
    "post_start": "/workspace/scripts/setup_markets_env.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "researcher",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1"
        }
      }
    }
  ]
}
