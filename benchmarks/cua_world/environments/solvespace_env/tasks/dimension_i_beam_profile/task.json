  "init": {
    "timeout_sec": 700,
    "max_steps": 90
  },
  "hooks": {
    "pre_task": "/workspace/tasks/dimension_i_beam_profile/setup_task.sh",
    "post_task": "/workspace/tasks/dimension_i_beam_profile/export_result.sh"
  },
