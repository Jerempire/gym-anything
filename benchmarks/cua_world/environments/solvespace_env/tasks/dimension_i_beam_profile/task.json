{
  "id": "dimension_i_beam_profile@1",
  "version": "1.0",
  "env_id": "solvespace_env@0.1",
  "description": "You are a structural design engineer at a steel fabrication firm. A colleague has started a CAD sketch for a custom asymmetric I-beam cross-section in /home/ga/Documents/SolveSpace/i_beam_profile.slvs. Fully define the sketch using the dimensional constraints specified in the structural cross-section schedule on the desktop. Save the constrained file to /home/ga/Documents/SolveSpace/i_beam_constrained.slvs.",
