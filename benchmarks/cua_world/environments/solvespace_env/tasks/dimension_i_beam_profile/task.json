      {
        "type": 30,
        "valA": 90.0,
        "label": "overall section height 90mm"
      },
      {
        "type": 30,
        "valA": 12.0,
        "label": "bottom flange thickness 12mm"
      },
      {
        "type": 30,
        "valA": 18.0,
        "label": "top flange thickness 18mm"
      },
      {
        "type": 30,
        "valA": 40.0,
        "label": "right flange overhang 40mm"
      },
      {
        "type": 30,
        "valA": 30.0,
        "label": "left flange overhang 30mm"
      },
      {
        "type": 30,
        "valA": 60.0,
        "label": "web clear height 60mm"
      },
      {
        "type": 30,
        "valA": 50.0,
        "label": "web thickness 50mm"
      }
