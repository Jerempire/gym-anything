{
  "id": "extrude_sketch@1",
  "version": "1.0",
  "env_id": "solvespace_env@0.1",
  "description": "Create a 3D solid block with a 40mm by 30mm rectangular base in SolveSpace. Save the model to /home/ga/Documents/SolveSpace/block.slvs.",
  "init": {
    "timeout_sec": 360,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/extrude_sketch/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_extrude_sketch"
    }
  }
}
