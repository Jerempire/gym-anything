{
  "id": "reuleaux_rotor_parametric@1",
  "version": "1.0",
  "env_id": "solvespace_env@0.1",
  "description": "Model a 3D Reuleaux triangle rotor in SolveSpace with a constant width of 60 mm, a 15 mm central hole, and an extrusion thickness of 12 mm. Save the project to /home/ga/Documents/SolveSpace/reuleaux_rotor.slvs and export the 3D model as a triangle mesh (STL) to /home/ga/Documents/SolveSpace/reuleaux_rotor.stl.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/reuleaux_rotor_parametric/setup_task.sh",
    "post_task": "/workspace/tasks/reuleaux_rotor_parametric/export_result.sh"
  },
  "metadata": {
    "expected_slvs_path": "/home/ga/Documents/SolveSpace/reuleaux_rotor.slvs",
    "expected_stl_path": "/home/ga/Documents/SolveSpace/reuleaux_rotor.stl",
    "expected_width": 60.0,
    "expected_thickness": 12.0,
    "expected_volume_mm3": 28325.5,
    "volume_tolerance_percent": 5.0,
    "dimension_tolerance_mm": 1.5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reuleaux_rotor"
    }
  }
}
