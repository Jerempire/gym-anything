{
  "id": "bookcase_equal_spacing@1",
  "version": "1.0",
  "env_id": "solvespace_env@0.1",
  "description": "Create a 2D parametric layout of a bookcase that is 600 mm wide and 1800 mm high. The layout must include 4 interior shelves that are perfectly equally spaced. Save the parametric model to /home/ga/Documents/SolveSpace/bookcase.slvs and export the 2D view as a DXF to /home/ga/Documents/SolveSpace/bookcase.dxf.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bookcase_equal_spacing/setup_task.sh",
    "post_task": "/workspace/tasks/bookcase_equal_spacing/export_result.sh"
  },
  "metadata": {
    "expected_dxf": "/home/ga/Documents/SolveSpace/bookcase.dxf",
    "expected_slvs": "/home/ga/Documents/SolveSpace/bookcase.slvs",
    "expected_width": 600,
    "expected_height": 1800,
    "expected_gap": 360,
    "num_shelves": 4
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bookcase_equal_spacing"
    }
  }
}
