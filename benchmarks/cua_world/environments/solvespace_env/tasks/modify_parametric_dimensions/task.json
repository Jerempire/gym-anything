    "expected_output_path": "/home/ga/Documents/SolveSpace/base_enlarged.slvs",
    "expected_width": 150.0,
    "expected_height": 120.0,
    "original_width": 100.0,
    "original_height": 80.0,
    "min_act_x_threshold": 60.0,
    "min_act_y_threshold": 50.0
