{
  "id": "constrained_triangle@1",
  "version": "1.0",
  "env_id": "solvespace_env@0.1",
  "description": "Create a fully-constrained right triangle in a 2D sketch with legs measuring exactly 30mm and 40mm. Save the resulting file to /home/ga/Documents/SolveSpace/right_triangle.slvs.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/constrained_triangle/setup_task.sh",
    "post_task": "/workspace/tasks/constrained_triangle/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/SolveSpace/right_triangle.slvs",
    "expected_leg1": 30.0,
    "expected_leg2": 40.0,
    "min_file_size_bytes": 500
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_constrained_triangle"
    }
  }
}
