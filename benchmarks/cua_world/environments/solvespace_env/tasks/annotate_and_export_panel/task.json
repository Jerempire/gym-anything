{
  "id": "annotate_and_export_panel@1",
  "version": "1.0",
  "env_id": "solvespace_env@0.1",
  "description": "You are a CAD drafter preparing shop drawings for a CNC router operator. Add dimension annotations to the wooden box divider panel drawing (/home/ga/Documents/SolveSpace/divider_annotate.slvs) based on the requirements in the specification file on the desktop. Save the annotated drawing to /home/ga/Documents/SolveSpace/divider_annotated.slvs and export the dimensioned 2D view as a DXF file to /home/ga/Documents/SolveSpace/divider_shop_drawing.dxf.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 800,
    "max_steps": 100
  },
  "hooks": {
    "pre_task": "/workspace/tasks/annotate_and_export_panel/setup_task.sh",
    "post_task": "/workspace/tasks/annotate_and_export_panel/export_result.sh"
  },
  "metadata": {
    "target_slvs": "/home/ga/Documents/SolveSpace/divider_annotated.slvs",
    "spec_file": "/home/ga/Desktop/panel_spec.txt",
    "target_dxf": "/home/ga/Documents/SolveSpace/divider_shop_drawing.dxf",
    "required_constraints": [
      {
        "type": 30,
        "valA": 150.0,
        "label": "overall width 150mm"
      },
      {
        "type": 30,
        "valA": 100.0,
        "label": "overall height 100mm"
      },
      {
        "type": 30,
        "valA": 25.0,
        "label": "notch depth 25mm"
      }
    ],
    "constraint_tolerance_mm": 1.0,
    "occupation": "CAD Drafter / Manufacturing Engineer",
    "domain": "Woodworking / CNC routing shop drawings",
    "source_file": "/opt/solvespace_samples/divider.slvs"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_annotate_and_export_panel"
    }
  }
}
