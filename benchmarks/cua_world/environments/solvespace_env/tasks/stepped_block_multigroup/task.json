{
  "id": "stepped_block_multigroup@1",
  "version": "1.0",
  "env_id": "solvespace_env@0.1",
  "description": "Create a 3D stepped rectangular block in SolveSpace. The model consists of an 80 mm by 60 mm base extruded to a thickness of 20 mm, with a centered 40 mm by 30 mm rectangular boss extruded 15 mm from the top surface. Save the final model as /home/ga/Documents/SolveSpace/stepped_block.slvs.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/stepped_block_multigroup/setup_task.sh",
    "post_task": "/workspace/tasks/stepped_block_multigroup/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/SolveSpace/stepped_block.slvs",
    "base_width": 80,
    "base_height": 60,
    "base_extrude": 20,
    "boss_width": 40,
    "boss_height": 30,
    "boss_extrude": 15,
    "tolerance": 2.5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_stepped_block"
    }
  }
}
