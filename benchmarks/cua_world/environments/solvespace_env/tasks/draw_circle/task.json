{
  "id": "draw_circle@1",
  "version": "1.0",
  "env_id": "solvespace_env@0.1",
  "description": "In SolveSpace, create a circle with a radius of 25 mm in the default XY workplane. Save the design to /home/ga/Documents/SolveSpace/circle.slvs.",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/draw_circle/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_draw_circle"
    }
  }
}
