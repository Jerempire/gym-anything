{
  "id": "export_2d_orthographic_views@1",
  "version": "1.0",
  "env_id": "solvespace_env@0.1",
  "description": "Export two 2D SVG drawings of the 3D part '/opt/solvespace_samples/side.slvs' to '~/Documents/SolveSpace/'. Save the flat face view as 'side_face.svg' and the thin edge view as 'side_edge.svg'. Both exports must use a 1:1 scale and exclude hidden lines and axes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_2d_orthographic_views/setup_task.sh",
    "post_task": "/workspace/tasks/export_2d_orthographic_views/export_result.sh"
  },
  "metadata": {
    "expected_face_file": "/home/ga/Documents/SolveSpace/side_face.svg",
    "expected_edge_file": "/home/ga/Documents/SolveSpace/side_edge.svg",
    "part_source": "/opt/solvespace_samples/side.slvs"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_2d_orthographic_views"
    }
  }
}
