{
  "id": "pentagon_prism@1",
  "version": "1.0",
  "env_id": "solvespace_env@0.1",
  "description": "Create a fully constrained regular pentagonal prism in SolveSpace. The base must be a regular pentagon with side lengths of 25 mm. Set the extrusion depth to 15 mm. Save the resulting 3D model to /home/ga/Documents/SolveSpace/pentagon_prism.slvs.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/pentagon_prism/setup_task.sh",
    "post_task": "/workspace/tasks/pentagon_prism/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/SolveSpace/pentagon_prism.slvs",
    "expected_side_length": 25,
    "expected_angle": 108,
    "expected_extrude_depth": 15
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_pentagon_prism"
    }
  }
}
