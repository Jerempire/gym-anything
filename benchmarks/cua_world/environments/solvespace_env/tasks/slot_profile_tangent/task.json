{
  "id": "slot_profile_tangent@1",
  "version": "1.0",
  "env_id": "solvespace_env@0.1",
  "description": "Create a fully constrained 2D slot profile (stadium shape) centered at the origin in SolveSpace. The profile must have a total horizontal length of 40.00 mm and a vertical width of 12.00 mm. Save the design to /home/ga/Documents/SolveSpace/slot_profile.slvs.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/slot_profile_tangent/setup_task.sh",
    "post_task": "/workspace/tasks/slot_profile_tangent/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/SolveSpace/slot_profile.slvs",
    "expected_length": 40.0,
    "expected_width": 12.0,
    "expected_radius": 6.0,
    "tolerance_mm": 2.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_slot_profile"
    }
  }
}
