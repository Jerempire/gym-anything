{
  "id": "hex_prism_standoff@1",
  "version": "1.0",
  "env_id": "solvespace_env@0.1",
  "description": "Create a fully-constrained regular hexagonal prism in SolveSpace with an across-flats dimension of 10.0 mm and an extrusion height of 15.0 mm. Save the project to /home/ga/Documents/SolveSpace/hex_standoff.slvs and export the 3D model to /home/ga/Documents/SolveSpace/hex_standoff.stl.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/hex_prism_standoff/setup_task.sh",
    "post_task": "/workspace/tasks/hex_prism_standoff/export_result.sh"
  },
  "metadata": {
    "expected_slvs": "/home/ga/Documents/SolveSpace/hex_standoff.slvs",
    "expected_stl": "/home/ga/Documents/SolveSpace/hex_standoff.stl",
    "target_volume_min": 800,
    "target_volume_max": 1800
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_hex_prism"
    }
  }
}
