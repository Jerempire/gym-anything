{
  "id": "assemble_box_parts@1",
  "version": "1.0",
  "env_id": "solvespace_env@0.1",
  "description": "Create a SolveSpace assembly file by linking the part files located at /home/ga/Documents/SolveSpace/parts/base.slvs and /home/ga/Documents/SolveSpace/parts/side.slvs. You do not need to add constraints to align them perfectly. Save the assembly as /home/ga/Documents/SolveSpace/box_assembly.slvs.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/assemble_box_parts/setup_task.sh",
    "post_task": "/workspace/tasks/assemble_box_parts/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/SolveSpace/box_assembly.slvs",
    "part1_path": "/home/ga/Documents/SolveSpace/parts/base.slvs",
    "part2_path": "/home/ga/Documents/SolveSpace/parts/side.slvs",
    "part1_filename": "base.slvs",
    "part2_filename": "side.slvs"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_assemble_box_parts"
    }
  }
}
