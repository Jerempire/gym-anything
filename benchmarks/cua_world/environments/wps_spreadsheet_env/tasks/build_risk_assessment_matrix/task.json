{
  "id": "build_risk_assessment_matrix@1",
  "version": "1.0",
  "env_id": "wps_spreadsheet_env@0.1",
  "description": "You are a construction site safety officer preparing for a weekly safety meeting. Update the hazard register at /home/ga/Documents/hazard_register.xlsx. In the 'Hazards' sheet (rows 2-31), calculate the Risk Score in Column G (Likelihood × Severity), the Risk Level in Column H (1-4: Low, 5-9: Medium, 10-15: High, 16-25: Critical), and the Controls Required in Column I (Low: Monitor, Medium: Action Plan, High: Immediate Action, Critical: Stop Work). Create a new sheet named \"Risk Matrix\" with the title \"Risk Assessment Matrix\" in A1, Likelihood headers (L=1 to L=5) in B2:F2, Severity labels (S=5 to S=1) in A3:A7, and the count of hazards from the Hazards sheet for each Likelihood/Severity intersection in B3:F7. Create a new sheet named \"Summary\" containing a \"Risk Level Summary\" (A1) with counts for Critical, High, Medium, and Low risk levels (A3:B6), and a \"Category Summary\" (A8) with counts for Falls, Struck-by, Caught-in/between, and Electrocution categories (A10:B13). Save the updated workbook to /home/ga/Documents/hazard_register.xlsx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
