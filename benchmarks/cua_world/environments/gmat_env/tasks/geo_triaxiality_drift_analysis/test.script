Create Spacecraft Sat;
GMAT Sat.DateFormat = UTCGregorian;
GMAT Sat.Epoch = '01 Jan 2026 00:00:00.000';
GMAT Sat.CoordinateSystem = EarthFixed;
GMAT Sat.DisplayStateType = Spherical;
GMAT Sat.RMAG = 42164.17;
GMAT Sat.RA = 350.0;
GMAT Sat.DEC = 0.0;
GMAT Sat.VMAG = 0.0;
GMAT Sat.AZI = 90.0;
GMAT Sat.FPA = 0.0;

Create ForceModel FM;
GMAT FM.CentralBody = Earth;
GMAT FM.PrimaryBodies = {Earth};
GMAT FM.GravityField.Earth.Degree = 4;
GMAT FM.GravityField.Earth.Order = 4;
GMAT FM.GravityField.Earth.PotentialFile = 'JGM2.cof';

Create Propagator Prop;
GMAT Prop.FM = FM;
GMAT Prop.Type = PrinceDormand78;

Create CoordinateSystem EarthFixedCS;
GMAT EarthFixedCS.Origin = Earth;
GMAT EarthFixedCS.Axes = BodyFixed;

Create ReportFile Rep;
GMAT Rep.Filename = 'report.txt';
GMAT Rep.Add = {Sat.EarthFixed.X, Sat.EarthFixed.Y, Sat.EarthFixed.Z, Sat.EarthFixed.RMAG, Sat.EarthFixed.RA, Sat.EarthFixed.DEC};

BeginMissionSequence;

Propagate Prop(Sat) {Sat.ElapsedDays = 730};
