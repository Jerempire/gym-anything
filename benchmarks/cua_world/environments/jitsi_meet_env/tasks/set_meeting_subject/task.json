{
  "id": "set_meeting_subject@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "Join the Jitsi Meet conference room at http://localhost:8080/WeeklySync and change the meeting subject to 'Q4 2024 Quarterly Ops Review - Budget and Headcount'.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/set_meeting_subject/setup_task.sh",
    "post_task": "/workspace/tasks/set_meeting_subject/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "room_url": "http://localhost:8080/WeeklySync",
    "expected_subject": "Q4 2024 Quarterly Ops Review - Budget and Headcount",
    "expected_partial_subject": "Q4 2024 Quarterly Ops Review"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_meeting_subject"
    }
  }
}
