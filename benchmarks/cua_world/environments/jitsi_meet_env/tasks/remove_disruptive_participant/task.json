{
  "id": "remove_disruptive_participant@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "A disruptive participant named 'DisruptiveUser' has joined your meeting 'GovernanceMeeting'. As the moderator, identify and remove this user from the meeting while remaining in the session yourself.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/remove_disruptive_participant/setup_task.sh",
    "post_task": "/workspace/tasks/remove_disruptive_participant/export_result.sh",
    "pre_task_timeout": 180
  },
  "metadata": {
    "meeting_url": "http://localhost:8080/GovernanceMeeting",
    "disruptive_name": "DisruptiveUser",
    "agent_name": "Moderator"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_remove_disruptive_participant"
    }
  }
}
