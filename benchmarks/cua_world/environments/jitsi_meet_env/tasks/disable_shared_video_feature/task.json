{
  "id": "disable_shared_video_feature@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "Globally disable the 'Share a YouTube video' feature in the Jitsi Meet instance running at http://localhost:8080. The 'Share video' button must be removed from the 'More actions' menu. Keep the 'More actions' menu open in the browser for the final state.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/disable_shared_video_feature/setup_task.sh",
    "post_task": "/workspace/tasks/disable_shared_video_feature/export_result.sh"
  },
  "metadata": {
    "container_name_pattern": "jitsi-web",
    "config_path": "/config/config.js",
    "feature_flag": "sharedvideo"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_disable_shared_video"
    }
  }
}
