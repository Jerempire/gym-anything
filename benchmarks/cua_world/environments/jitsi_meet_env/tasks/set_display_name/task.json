{
  "id": "set_display_name@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "Join the active 'ProductReview' meeting in Firefox and set your display name to 'Alex Johnson'.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 35,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/set_display_name/setup_task.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "room_name": "ProductReview",
    "display_name": "Alex Johnson",
    "jitsi_url": "http://localhost:8080"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_display_name"
    }
  }
}
