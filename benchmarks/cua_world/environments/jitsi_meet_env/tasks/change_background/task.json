{
  "id": "change_background@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "Jitsi Meet is open in Firefox at the home page (http://localhost:8080). Activate a virtual background, such as a blur effect or an image, within the application.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/change_background/setup_task.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "jitsi_url": "http://localhost:8080"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_change_background"
    }
  }
}
