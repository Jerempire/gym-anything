{
  "id": "pin_participant@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "You are moderating the 'AnnualTownHall' meeting. The 'Keynote Speaker' (a guest participant) is about to begin their address. Pin the 'Keynote Speaker' to your screen to ensure they remain the main focus in Stage View regardless of who is speaking.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/pin_participant/setup_task.sh",
    "post_task": "/workspace/tasks/pin_participant/export_result.sh",
    "pre_task_timeout": 180
  },
  "metadata": {
    "target_participant": "Keynote Speaker",
    "room_name": "AnnualTownHall",
    "jitsi_url": "http://localhost:8080"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_pin_participant"
    }
  }
}
