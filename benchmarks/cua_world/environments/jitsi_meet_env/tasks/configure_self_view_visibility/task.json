{
  "id": "configure_self_view_visibility@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "Join the Jitsi Meet room 'WebinarPrep' and hide your own video feed (Self View) while keeping the camera active.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_self_view_visibility/setup_task.sh",
    "post_task": "/workspace/tasks/configure_self_view_visibility/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "room_name": "WebinarPrep",
    "jitsi_url": "http://localhost:8080",
    "expected_setting_key": "disableSelfView",
    "expected_setting_value": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_self_view_visibility"
    }
  }
}
