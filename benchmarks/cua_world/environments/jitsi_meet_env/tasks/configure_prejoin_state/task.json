{
  "id": "configure_prejoin_state@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "Join the Jitsi Meet room 'TownHall_2024_Auditor' using the display name 'Silent_Observer'. You must enter the meeting with both your camera and microphone disabled.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_prejoin_state/setup_task.sh",
    "post_task": "/workspace/tasks/configure_prejoin_state/export_result.sh"
  },
  "metadata": {
    "target_room": "TownHall_2024_Auditor",
    "target_name": "Silent_Observer",
    "jitsi_url": "http://localhost:8080"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_prejoin_state"
    }
  }
}
