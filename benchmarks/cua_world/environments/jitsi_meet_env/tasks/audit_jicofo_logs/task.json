{
  "id": "audit_jicofo_logs@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "Join a meeting room named 'MergerDiscussion' in Jitsi Meet. Locate the log entry in the 'jicofo' container recording the creation or allocation of this conference and save the raw log line to /home/ga/merger_audit_log.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/audit_jicofo_logs/setup_task.sh",
    "post_task": "/workspace/tasks/audit_jicofo_logs/export_result.sh"
  },
  "metadata": {
    "meeting_name": "MergerDiscussion",
    "output_file": "/home/ga/merger_audit_log.txt",
    "container_name": "jitsi-jicofo",
    "expected_keywords": [
      "MergerDiscussion",
      "created",
      "allocated",
      "FocusManager"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_audit_jicofo_logs"
    }
  }
}
