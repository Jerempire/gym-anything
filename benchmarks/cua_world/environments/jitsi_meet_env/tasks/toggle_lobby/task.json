{
  "id": "toggle_lobby@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "Enable the Lobby feature for the active Jitsi Meet room \"SecurityMeeting\" in Firefox so that new participants must wait for approval before joining.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/toggle_lobby/setup_task.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "room_name": "SecurityMeeting",
    "jitsi_url": "http://localhost:8080"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_toggle_lobby"
    }
  }
}
