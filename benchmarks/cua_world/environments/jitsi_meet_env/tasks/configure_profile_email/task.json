{
  "id": "configure_profile_email@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "You are in a Jitsi meeting. Configure the user profile email to 'alex.manager@corp.global'. Ensure the email is correctly saved and visible in the profile settings.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_profile_email/setup_task.sh",
    "post_task": "/workspace/tasks/configure_profile_email/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_email": "alex.manager@corp.global",
    "room_name": "ManagementSync",
    "jitsi_url": "http://localhost:8080"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_profile_email"
    }
  }
}
