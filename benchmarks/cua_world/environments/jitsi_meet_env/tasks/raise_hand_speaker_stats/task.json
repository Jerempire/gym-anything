{
  "id": "raise_hand_speaker_stats@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "Join the Jitsi Meet room 'InterpreterSession2024' using the name 'Maria Interpreter'. Raise your hand and keep the Speaker Stats panel open.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/raise_hand_speaker_stats/setup_task.sh",
    "post_task": "/workspace/tasks/raise_hand_speaker_stats/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "meeting_url": "http://localhost:8080/InterpreterSession2024",
    "display_name": "Maria Interpreter",
    "expected_text_elements": [
      "Speaker Stats",
      "Maria Interpreter"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_raise_hand_speaker_stats"
    }
  }
}
