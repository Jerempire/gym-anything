{
  "id": "adjust_video_quality@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "Join the Jitsi Meet conference room 'VirtualFitnessQ4' using the display name 'Coach Martinez'. Set the video quality to 'Low definition' and ensure the quality settings panel remains open and visible.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/adjust_video_quality/setup_task.sh",
    "post_task": "/workspace/tasks/adjust_video_quality/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "room_name": "VirtualFitnessQ4",
    "target_display_name": "Coach Martinez",
    "target_quality": "Low definition",
    "jitsi_url": "http://localhost:8080"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_adjust_video_quality"
    }
  }
}
