{
  "id": "share_invite_link@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "Jitsi Meet is open in Firefox with an active meeting in the room \"DesignReview\". Copy the meeting invitation link to the clipboard.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/share_invite_link/setup_task.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "room_name": "DesignReview",
    "jitsi_url": "http://localhost:8080"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_share_invite_link"
    }
  }
}
