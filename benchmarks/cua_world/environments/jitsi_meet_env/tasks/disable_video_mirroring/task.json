{
  "id": "disable_video_mirroring@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "Join the Jitsi meeting room 'MathTutoringSession' with the display name 'Tutor Alex'. Disable the 'Mirror local video' option and ensure the Video settings tab remains open to display the current configuration.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/disable_video_mirroring/setup_task.sh",
    "post_task": "/workspace/tasks/disable_video_mirroring/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "room_name": "MathTutoringSession",
    "display_name": "Tutor Alex",
    "target_setting": "Mirror local video",
    "target_state": "unchecked/disabled"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_disable_video_mirroring"
    }
  }
}
