{
  "id": "configure_breakout_rooms@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "Join the Jitsi Meet meeting 'QuarterlyPlanning' in Firefox. Create three breakout rooms named 'Revenue Strategy', 'Operations Review', and 'Product Roadmap'. Save a screenshot of the breakout rooms panel showing these names to /home/ga/breakout_rooms_evidence.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_breakout_rooms/setup_task.sh",
    "post_task": "/workspace/tasks/configure_breakout_rooms/export_result.sh",
    "pre_task_timeout": 300
  },
  "metadata": {
    "meeting_url": "http://localhost:8080/QuarterlyPlanning",
    "evidence_file": "/home/ga/breakout_rooms_evidence.png",
    "expected_rooms": [
      "Revenue Strategy",
      "Operations Review",
      "Product Roadmap"
    ],
    "min_evidence_size_kb": 50
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_breakout_rooms"
    }
  }
}
