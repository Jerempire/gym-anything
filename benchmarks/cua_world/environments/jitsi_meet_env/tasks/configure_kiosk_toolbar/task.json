{
  "id": "configure_kiosk_toolbar@1",
  "version": "1.0",
  "env_id": "jitsi_meet_env@0.1",
  "description": "Configure the Jitsi Meet instance to use a restricted 'Kiosk Mode' toolbar by modifying the configuration at /home/ga/.jitsi-meet-cfg/web/custom-config.js. The toolbar must be restricted to display only these five buttons: 'microphone', 'camera', 'hangup', 'tileview', and 'fullscreen'. Ensure the changes are applied and verified in the meeting interface.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_kiosk_toolbar/setup_task.sh",
    "post_task": "/workspace/tasks/configure_kiosk_toolbar/export_result.sh"
  },
  "metadata": {
    "config_path": "/home/ga/.jitsi-meet-cfg/web/custom-config.js",
    "required_buttons": [
      "microphone",
      "camera",
      "hangup",
      "tileview",
      "fullscreen"
    ],
    "prohibited_buttons": [
      "chat",
      "desktop",
      "invite",
      "raisehand",
      "security",
      "videoquality",
      "filmstrip",
      "shortcuts",
      "stats",
      "feedback"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_kiosk_toolbar"
    }
  }
}
