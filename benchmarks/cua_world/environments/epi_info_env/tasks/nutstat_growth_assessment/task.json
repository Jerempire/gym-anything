{
  "id": "nutstat_growth_assessment@1",
  "version": "1.0",
  "env_id": "epi_info_env@0.1",
  "description": "Assess the nutritional status of four children using the CDC 2000 growth reference in Epi Info 7's NutStat module. Create a report file at C:\\Users\\Docker\\Documents\\nutstat_results.txt containing the calculated Z-scores, percentiles, and nutritional classification for each child based on the following data:\n\n1. Child A (Male, DOB: 06/15/2021, Date of Msmt: 06/15/2024, Height: 96.1 cm, Weight: 14.3 kg)\n2. Child B (Female, DOB: 03/01/2022, Date of Msmt: 03/01/20",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\nutstat_growth_assessment\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\nutstat_growth_assessment\\export_result.ps1"
  },
  "metadata": {
    "output_path": "C:\\Users\\Docker\\Documents\\nutstat_results.txt",
    "expected_children": {
      "Child A": {
        "haz_target": 0.0,
        "waz_target": 0.0,
        "bmiz_target": 0.0,
        "status": "Normal"
      },
      "Child B": {
        "haz_target": -2.0,
        "waz_target": -1.0,
        "bmiz_target": 1.2,
        "status": "Stunted"
      },
      "Child C": {
        "haz_target": 1.0,
        "waz_target": 2.0,
        "bmiz_target": 1.8,
        "status": "Overweight"
      },
      "Child D": {
        "haz_target": 0.5,
        "waz_target": -2.0,
        "bmiz_target": -2.0,
        "status": "Underweight"
      }
    },
    "tolerance_z": 0.5,
    "pass_threshold": 60
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_nutstat_growth_assessment"
    }
  }
}
