{
  "id": "tcl_tk_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Tcl/Tk programming environment with the Tcl scripting language and Tk GUI toolkit for creating and modifying graphical applications",
  "resources": {
    "cpu": 4,
    "mem_gb": 4,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/tcl_tk_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/tcl_tk_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/tcl_tk_env/data", "target": "/workspace/data", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_tcl_tk.sh",
    "post_start": "/workspace/scripts/setup_tcl_tk.sh"
  },
  "vnc": {
    "password": "password"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ]
}
