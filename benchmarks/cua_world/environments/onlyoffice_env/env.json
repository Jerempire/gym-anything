{
  "id": "onlyoffice_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "ONLYOFFICE Desktop Editors environment for document editing, spreadsheet analysis, and presentation creation tasks with full MS Office compatibility",
  "category": "office",
  "tags": [
    "linux",
    "office",
    "document-editor",
    "spreadsheet",
    "presentation",
    "onlyoffice",
    "desktop",
    "productivity"
  ],
  "licence": "AGPL-3.0",
  "authors": [
    "gym-anything team"
  ],
  "upstream_url": "https://www.onlyoffice.com/",
  "resources": {
    "cpu": 4,
    "mem_gb": 6,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [
        1920,
        1080
      ],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/onlyoffice_env/artifacts",
    "video_fps": 10,
    "video_resolution": [
      1920,
      1080
    ],
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": false,
    "host_port": 5954,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": [
      "ALL"
    ],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true,
    "runtime": "sysbox-runc"
  },
  "shm_size": "2gb",
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/onlyoffice_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/onlyoffice_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/onlyoffice_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/onlyoffice_env/utils",
      "target": "/workspace/utils",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_onlyoffice.sh",
    "post_start": "/workspace/scripts/setup_onlyoffice.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": [
          "sudo",
          "audio",
          "video",
          "input"
        ],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "ONLYOFFICE_USER": "ga"
        }
      }
    }
  ]
}
