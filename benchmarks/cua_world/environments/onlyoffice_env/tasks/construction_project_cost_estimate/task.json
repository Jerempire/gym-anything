{
  "id": "construction_project_cost_estimate@1",
  "version": "1.0",
  "env_id": "onlyoffice_env@0.1",
  "description": "You have been retained by Lakewood Medical Partners to prepare a detailed construction cost estimate for their 4,200 sq ft medical office build-out at 550 Commerce Drive. Create a cost estimate workbook using the specifications at ~/Documents/project_specifications.txt, material pricing at ~/Documents/Spreadsheets/material_prices.csv, and labor rates at ~/Documents/Spreadsheets/labor_rates.csv. Save the final workbook to ~/Documents/Spreadsheets/medical_office_estimate.xlsx",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 800,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "metadata": {
    "data_sources": [
      "RSMeans 2024 Square Foot Costs",
      "DOL Davis-Bacon Prevailing Wage Determinations"
    ],
    "building_type": "Medical Office, 1-Story",
    "area_sf": 4200,
    "reference_cost_per_sf": 236.56,
    "ground_truth_hints": {
      "estimate_range_low": 350000,
      "estimate_range_high": 800000,
      "building_size_sf": 4200,
      "building_type": "Medical Office, 1-Story",
      "rsmeans_full_build_per_sf": 236.56,
      "rsmeans_full_build_total": 993552,
      "ti_factor_range": "40-80% of full construction",
      "direct_cost_range": "$280K-$550K",
      "with_markups_range": "$350K-$750K",
      "grand_total_range": "$350K-$800K",
      "expected_divisions": [
        "concrete",
        "metal",
        "wood",
        "millwork",
        "door",
        "finish",
        "mechanical",
        "hvac",
        "plumbing",
        "electrical",
        "fire",
        "specialty",
        "ceiling",
        "flooring",
        "paint"
      ]
    }
  },
  "hooks": {
    "pre_task": "/workspace/tasks/construction_project_cost_estimate/setup_task.sh",
    "post_task": "/workspace/tasks/construction_project_cost_estimate/export_result.sh",
    "pre_task_timeout": 120
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_cost_estimate"
    }
  }
}
