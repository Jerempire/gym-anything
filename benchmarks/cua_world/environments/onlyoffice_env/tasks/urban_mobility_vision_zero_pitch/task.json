{
  "id": "urban_mobility_vision_zero_pitch@1",
  "version": "1.0",
  "env_id": "onlyoffice_env@0.1",
  "description": "Create a 5-slide professional presentation pitching the Vision Zero initiative. Distribute the text from ~/Documents/Presentations/Vision_Zero/outline.txt across the slides, incorporating daylighting.jpg on Slide 3 and protected_bike_lane.jpg on Slide 5 from the ~/Documents/Presentations/Vision_Zero/images/ directory. Save the presentation to ~/Documents/Presentations/Vision_Zero/vision_zero_pitch.pptx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/urban_mobility_vision_zero_pitch/setup_task.sh",
    "post_task": "/workspace/tasks/urban_mobility_vision_zero_pitch/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/Presentations/Vision_Zero/vision_zero_pitch.pptx",
    "slide_count_min": 5,
    "keywords": {
      "slide_1": [
        "hoboken",
        "vision zero"
      ],
      "slide_2": [
        "vulnerable",
        "fatalities"
      ],
      "slide_3": [
        "daylighting",
        "infrastructure"
      ],
      "slide_4": [
        "implementation",
        "timeline"
      ],
      "slide_5": [
        "adopt resolution",
        "commit"
      ]
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_vision_zero_pitch"
    }
  }
}
