{
  "id": "add_branch@1",
  "version": "1.0",
  "env_id": "attendhrm_env@0.1",
  "description": "Add a new branch location to the AttendHRM system with the following details:\n\n- Branch Name: Downtown Office\n- Branch Code: DTN\n- Address: 450 Market Street\n- City: San Francisco\n- State: CA\n- Zip Code: 94105\n- Phone: 415-555-0198\n- Email: downtown@meridian-solutions.com",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\add_branch\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\add_branch\\export_result.ps1",
    "pre_task_timeout": 180
  },
  "metadata": {
    "expected_name": "Downtown Office",
    "expected_code": "DTN",
    "expected_city": "San Francisco",
    "expected_phone": "415-555-0198",
    "db_query_name_pattern": "%DOWNTOWN%OFFICE%"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_branch"
    }
  }
}
