{
  "id": "configure_leave_policy@1",
  "version": "1.0",
  "env_id": "attendhrm_env@0.1",
  "description": "Create a new Leave Policy in AttendHRM named \"Grade A - Annual Leave Policy 2025\" for employees in \"Grade A\" for the year 2025. Configure the entitlements with the following specifications: Casual Leave (12 days, no carry forward), Sick Leave (10 days, no carry forward), and Earned Leave (15 days, with carry forward). Ensure all values are entered exactly as specified.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_leave_policy\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_leave_policy\\export_result.ps1",
    "pre_task_timeout": 120
  },
  "metadata": {
    "policy_name": "Grade A - Annual Leave Policy 2025",
    "target_grade": "Grade A",
    "entitlements": {
      "Casual Leave": {
        "days": 12,
        "carry_forward": false
      },
      "Sick Leave": {
        "days": 10,
        "carry_forward": false
      },
      "Earned Leave": {
        "days": 15,
        "carry_forward": true
      }
    },
    "db_path_hint": "C:\\ProgramData\\Lenvica\\AttendHRM\\Data\\AttendHRM.fdb"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_leave_policy"
    }
  }
}
