{
  "id": "search_security_events@1",
  "version": "1.0",
  "env_id": "splunk_env@0.1",
  "description": "Search for failed SSH login attempts in the security_logs index at http://localhost:8000. Credentials: admin / SplunkAdmin1!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/search_security_events/setup_task.sh",
    "post_task": "/workspace/tasks/search_security_events/export_result.sh"
  },
  "metadata": {
    "search_index": "security_logs",
    "search_keyword": "Failed password",
    "expected_sourcetype": "linux_secure",
    "min_event_count": 10,
    "splunk_user": "admin",
    "splunk_pass": "SplunkAdmin1!"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_search_security_events"
    }
  }
}
