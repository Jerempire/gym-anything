{
  "id": "session_hijacking_detection@1",
  "version": "1.0",
  "env_id": "splunk_env@0.1",
  "description": "Investigate web access logs in the 'tutorial' index to detect potential session hijacking. Create a scheduled alert named 'Session_Hijacking_Alert' that identifies instances where a single web session ID is associated with more than one distinct IP address. Access the system at http://localhost:8000 (username: admin, password: SplunkAdmin1!).",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/session_hijacking_detection/setup_task.sh",
    "post_task": "/workspace/tasks/session_hijacking_detection/export_result.sh"
  },
  "metadata": {
    "expected_alert_name": "Session_Hijacking_Alert",
    "expected_index_keywords": [
      "tutorial",
      "web",
      "access"
    ],
    "expected_session_keywords": [
      "jsessionid",
      "session",
      "cookie"
    ],
    "splunk_user": "admin",
    "splunk_pass": "SplunkAdmin1!"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_session_hijacking_detection"
    }
  }
}
