{
  "id": "inventory_scrap_processing@1",
  "version": "1.0",
  "env_id": "odoo_env@0.1",
  "description": "A warehouse damage incident has occurred. Log into Odoo (admin@example.com / admin) and process scrap orders for the damaged items identified in the report at '/home/ga/Desktop/damage_assessment_report.txt'. Ensure all items listed in the report are scrapped in the system with the correct quantities.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/inventory_scrap_processing/setup_task.sh",
    "post_task": "/workspace/tasks/inventory_scrap_processing/export_result.sh"
  },
  "metadata": {
    "report_path": "/home/ga/Desktop/damage_assessment_report.txt",
    "products": [
      {
        "name": "Industrial Safety Helmet - Class E",
        "scrap_qty": 25,
        "initial_qty": 120
      },
      {
        "name": "Heavy Duty Pallet Jack - 5500lb",
        "scrap_qty": 4,
        "initial_qty": 18
      },
      {
        "name": "Corrugated Shipping Box - 24x18x12",
        "scrap_qty": 85,
        "initial_qty": 500
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_inventory_scrap_processing"
    }
  }
}
