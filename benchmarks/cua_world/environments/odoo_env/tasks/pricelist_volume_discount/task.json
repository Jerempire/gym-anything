{
  "id": "pricelist_volume_discount@1",
  "version": "1.0",
  "env_id": "odoo_env@0.1",
  "description": "Log into Odoo (admin@example.com / admin) and configure a volume-based price list for a wholesale customer. Enable the multiple prices per product feature and create a new pricelist named 'Wholesale Partner - Tier 2' in USD. Add price rules for the Industrial Shelving Unit (1 @ $299.00, 10 @ $269.00, 50 @ $239.00), Ergonomic Office Chair (1 @ $199.00, 10 @ $179.00, 50 @ $159.00), and Corrugated Shipping Box - Large (1 @ $9.50, 25 @ $8.00, 100 @ $6.50). Finally, assign this pricelist to the customer 'Cascade Distribution Partners'.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/pricelist_volume_discount/setup_task.sh",
    "post_task": "/workspace/tasks/pricelist_volume_discount/export_result.sh"
  },
  "metadata": {
    "pricelist_name": "Wholesale Partner - Tier 2",
    "customer_name": "Cascade Distribution Partners",
    "products": [
      {
        "name": "Industrial Shelving Unit",
        "tiers": [
          {
            "min_qty": 1,
            "price": 299.0
          },
          {
            "min_qty": 10,
            "price": 269.0
          },
          {
            "min_qty": 50,
            "price": 239.0
          }
        ]
      },
      {
        "name": "Ergonomic Office Chair",
        "tiers": [
          {
            "min_qty": 1,
            "price": 199.0
          },
          {
            "min_qty": 10,
            "price": 179.0
          },
          {
            "min_qty": 50,
            "price": 159.0
          }
        ]
      },
      {
        "name": "Corrugated Shipping Box - Large",
        "tiers": [
          {
            "min_qty": 1,
            "price": 9.5
          },
          {
            "min_qty": 25,
            "price": 8.0
          },
          {
            "min_qty": 100,
            "price": 6.5
          }
        ]
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_pricelist_volume_discount"
    }
  }
}
