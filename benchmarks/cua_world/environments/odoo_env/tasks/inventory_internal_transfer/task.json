{
  "id": "inventory_internal_transfer@1",
  "version": "1.0",
  "env_id": "odoo_env@0.1",
  "description": "A quality assurance batch needs to be moved to the inspection zone. Using the items, quantities, and reference specified in /home/ga/Desktop/transfer_request.txt, process an internal transfer in Odoo (admin@example.com / admin, database: odoo_demo) from WH/Stock to WH/Stock/Quality Inspection Zone. Ensure the transfer is validated and the reference matches the one provided in the file.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/inventory_internal_transfer/setup_task.sh",
    "post_task": "/workspace/tasks/inventory_internal_transfer/export_result.sh"
  },
  "metadata": {
    "task_name": "inventory_internal_transfer",
    "request_file_path": "/home/ga/Desktop/transfer_request.txt",
    "source_loc_suffix": "Stock",
    "dest_loc_suffix": "Quality Inspection Zone",
    "required_reference": "QC-BATCH-2025-001",
    "products": [
      {
        "name": "Industrial Safety Helmet - Class E",
        "qty": 20
      },
      {
        "name": "High-Visibility Reflective Vest - XL",
        "qty": 30
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_inventory_internal_transfer"
    }
  }
}
