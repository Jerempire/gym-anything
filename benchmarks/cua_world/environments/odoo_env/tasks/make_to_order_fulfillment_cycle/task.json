{
  "id": "make_to_order_fulfillment_cycle@1",
  "version": "1.0",
  "env_id": "odoo_env@0.1",
  "description": "TechWorld Distributors has placed an order for 10 ProVision 4K Conference Cameras at $425.00 each. Process this order through the complete make-to-order fulfillment cycle: confirm the sales order, produce the cameras (checking raw material availability and procuring any out-of-stock components from the designated vendor), deliver the finished products to the customer, and collect full payment against a posted invoice.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 1500,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/make_to_order_fulfillment_cycle/setup_task.sh",
    "post_task": "/workspace/tasks/make_to_order_fulfillment_cycle/export_result.sh"
  },
  "metadata": {
    "customer_name": "TechWorld Distributors",
    "finished_product_name": "ProVision 4K Conference Camera",
    "finished_product_ref": "PV4K-CAM",
    "camera_qty": 10,
    "camera_unit_price": 425.00,
    "expected_so_total": 4250.00,
    "vendor_name": "ShenZhen MicroElectronics Co.",
    "missing_component": "USB-C Controller Board",
    "missing_component_ref": "USBC-CTL",
    "missing_component_price": 28.50,
    "components": [
      {"name": "4K CMOS Sensor Module", "ref": "CMOS-4K", "qty_per_unit": 1, "initial_stock": 20},
      {"name": "Aluminum Housing Unit", "ref": "ALU-HSG", "qty_per_unit": 1, "initial_stock": 50},
      {"name": "USB-C Controller Board", "ref": "USBC-CTL", "qty_per_unit": 1, "initial_stock": 0},
      {"name": "Pan-Tilt Motor Assembly", "ref": "PTM-ASSY", "qty_per_unit": 1, "initial_stock": 15},
      {"name": "IR Emitter Array", "ref": "IR-EMIT", "qty_per_unit": 1, "initial_stock": 30}
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_make_to_order_fulfillment_cycle"
    }
  }
}
