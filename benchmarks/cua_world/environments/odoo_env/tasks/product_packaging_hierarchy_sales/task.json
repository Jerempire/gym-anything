{
  "id": "product_packaging_hierarchy_sales@1",
  "version": "1.0",
  "env_id": "odoo_env@0.1",
  "description": "Configure wholesale packaging for the 'Bamboo Fiber Bento Box' by setting up two packaging formats: 'Retail Pack' (12 units) and 'Master Case' (48 units). Create and confirm a Sales Order for the customer 'GreenLife Retailers' consisting of 3 Master Cases, 5 Retail Packs, and 7 individual units.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/product_packaging_hierarchy_sales/setup_task.sh",
    "post_task": "/workspace/tasks/product_packaging_hierarchy_sales/export_result.sh"
  },
  "metadata": {
    "product_name": "Bamboo Fiber Bento Box",
    "customer_name": "GreenLife Retailers",
    "packaging_1_name": "Retail Pack",
    "packaging_1_qty": 12,
    "packaging_2_name": "Master Case",
    "packaging_2_qty": 48,
    "target_qty": 211
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_product_packaging_hierarchy_sales"
    }
  }
}
