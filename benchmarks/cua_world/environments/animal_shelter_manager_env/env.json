{
  "id": "animal_shelter_manager_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Animal Shelter Manager (ASM3) environment for managing animal intake, adoption, medical records, and shelter operations",
  "resources": {
    "cpu": 4,
    "mem_gb": 6,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/animal_shelter_manager_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/animal_shelter_manager_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/animal_shelter_manager_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/animal_shelter_manager_env/data", "target": "/workspace/data", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_asm.sh",
    "post_start": "/workspace/scripts/setup_asm.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ]
}
