{
  "id": "sheet_metal_flat_pattern@1",
  "version": "1.0",
  "env_id": "librecad_env@0.1",
  "description": "Create a DXF flat pattern drawing for a sheet metal chassis following the specifications, dimensions, and layer requirements (CUT_EXTERIOR, BEND_LINES, CUT_HOLES) found in '~/Documents/LibreCAD/work_order_001.txt'. The drawing must include the base, flanges, bend lines, and mounting holes. Save the final drawing to '~/Documents/LibreCAD/chassis_flat_pattern.dxf'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sheet_metal_flat_pattern/setup_task.sh",
    "post_task": "/workspace/tasks/sheet_metal_flat_pattern/export_result.sh"
  },
  "metadata": {
    "work_order_path": "/home/ga/Documents/LibreCAD/work_order_001.txt",
    "expected_output_path": "/home/ga/Documents/LibreCAD/chassis_flat_pattern.dxf",
    "specs": {
      "base_width": 120.0,
      "base_depth": 80.0,
      "flange_height": 25.0,
      "hole_diameter": 6.0,
      "hole_offset": 15.0,
      "total_width": 170.0,
      "total_height": 130.0
    },
    "layers": {
      "CUT_EXTERIOR": {
        "color": 7
      },
      "BEND_LINES": {
        "color": 2,
        "linetype_check": true
      },
      "CUT_HOLES": {
        "color": 1
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_sheet_metal_flat_pattern"
    }
  }
}
