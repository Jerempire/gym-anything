{
  "id": "export_axial_tiff_stack@1",
  "version": "1.0",
  "env_id": "invesalius3_env@0.1",
  "description": "The CT Cranium DICOM dataset is loaded in InVesalius 3. Export all axial slices of this dataset as individual TIFF images to /home/ga/Documents/axial_tiff_stack/.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_axial_tiff_stack/setup_task.sh",
    "post_task": "/workspace/tasks/export_axial_tiff_stack/export_result.sh"
  },
  "metadata": {
    "expected_directory": "/home/ga/Documents/axial_tiff_stack",
    "expected_extension": ".tif",
    "min_count": 100,
    "max_count": 120,
    "min_file_size_bytes": 10240,
    "dicom_series": "ct_cranium/0051"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_axial_tiff_stack"
    }
  }
}
