  "init": {
    "timeout_sec": 240,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/scroll_axial_slice/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_scroll_axial_slice"
    }
  }
}
