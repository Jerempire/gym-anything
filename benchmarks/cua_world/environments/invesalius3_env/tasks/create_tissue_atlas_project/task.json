{
  "id": "create_tissue_atlas_project@1",
  "version": "1.0",
  "env_id": "invesalius3_env@0.1",
  "description": "Create a standardized tissue atlas project in InVesalius 3 using the loaded CT Cranium dataset. Create three segmentation masks with exact names and Hounsfield Unit (HU) threshold ranges: 'Dense_Bone' (662 to 3071 HU), 'Spongy_Bone' (148 to 661 HU), and 'Soft_Tissue' (-700 to 147 HU). Save the project to /home/ga/Documents/tissue_atlas.inv3.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_tissue_atlas_project/setup_task.sh",
    "post_task": "/workspace/tasks/create_tissue_atlas_project/export_result.sh"
  },
  "metadata": {
    "output_path": "/home/ga/Documents/tissue_atlas.inv3",
    "expected_masks": [
      {
        "name": "Dense_Bone",
        "min_hu": 662,
        "max_hu": 3071,
        "tolerance": 50
      },
      {
        "name": "Spongy_Bone",
        "min_hu": 148,
        "max_hu": 661,
        "tolerance": 50
      },
      {
        "name": "Soft_Tissue",
        "min_hu": -700,
        "max_hu": 147,
        "tolerance": 50
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_tissue_atlas_project"
    }
  }
}
