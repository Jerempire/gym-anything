{
  "id": "threshold_sensitivity_study_export@1",
  "version": "1.0",
  "env_id": "invesalius3_env@0.1",
  "description": "Perform a sensitivity analysis on the loaded CT Cranium dataset by exporting three 3D surface models of the skull at different Hounsfield Unit (HU) thresholds. Export binary STL files for the following threshold ranges (with a constant maximum of 3071 HU): 200 HU minimum to /home/ga/Documents/skull_200HU.stl, 400 HU minimum to /home/ga/Documents/skull_400HU.stl, and 600 HU minimum to /home/ga/Documents/skull_600HU.stl.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/threshold_sensitivity_study_export/setup_task.sh",
    "post_task": "/workspace/tasks/threshold_sensitivity_study_export/export_result.sh"
  },
  "metadata": {
    "files": [
      {
        "path": "/home/ga/Documents/skull_200HU.stl",
        "label": "200HU",
        "expected_order": 0
      },
      {
        "path": "/home/ga/Documents/skull_400HU.stl",
        "label": "400HU",
        "expected_order": 1
      },
      {
        "path": "/home/ga/Documents/skull_600HU.stl",
        "label": "600HU",
        "expected_order": 2
      }
    ],
    "min_triangle_count": 10000,
    "relationship": "decreasing_triangles"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_threshold_sensitivity"
    }
  }
}
