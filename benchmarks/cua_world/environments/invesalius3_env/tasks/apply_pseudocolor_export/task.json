{
  "id": "apply_pseudocolor_export@1",
  "version": "1.0",
  "env_id": "invesalius3_env@0.1",
  "description": "The CT Cranium DICOM series is already loaded in InVesalius 3. Apply a pseudocolor colormap (Lookup Table) to an axial slice showing cranial anatomy to visualize tissue density differences. Export the resulting view as a PNG image to /home/ga/Documents/pseudocolor_view.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/apply_pseudocolor_export/setup_task.sh",
    "post_task": "/workspace/tasks/apply_pseudocolor_export/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/pseudocolor_view.png",
    "min_file_size_kb": 50,
    "min_width": 800,
    "min_height": 600,
    "dicom_series": "ct_cranium/0051"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_apply_pseudocolor_export"
    }
  }
}
