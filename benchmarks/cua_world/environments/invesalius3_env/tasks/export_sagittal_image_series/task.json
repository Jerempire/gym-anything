{
  "id": "export_sagittal_image_series@1",
  "version": "1.0",
  "env_id": "invesalius3_env@0.1",
  "description": "The CT Cranium DICOM dataset is loaded in InVesalius. A craniofacial surgeon needs a complete set of sagittal slices to evaluate the midline facial profile. Export the full dataset re-sliced in the Sagittal plane as a series of PNG images to /home/ga/Documents/sagittal_series/.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_sagittal_image_series/setup_task.sh",
    "post_task": "/workspace/tasks/export_sagittal_image_series/export_result.sh"
  },
  "metadata": {
    "output_dir": "/home/ga/Documents/sagittal_series",
    "expected_file_extension": "png",
    "min_file_count": 450,
    "max_file_count": 600,
    "axial_slice_count": 108,
    "sagittal_slice_count": 512
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_sagittal_series"
    }
  }
}
