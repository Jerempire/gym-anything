[qt]
qt-privacy-ask=0
qt-updates-notif=0
qt-start-minimized=0
qt-continue=0
qt-notification=0
qt-system-tray=0

[core]
metadata-network-access=0
loop=0
repeat=0
video-title-show=0
video-title-timeout=1000
file-caching=300
network-caching=1000

[video]
video-on-top=0
snapshot-path=/home/ga/Pictures/vlc
snapshot-format=png
snapshot-prefix=vlc-snap
snapshot-sequential=1

[audio]
audio-volume=256

[sout]
sout-all=1

[stream_out]
sout-keep=1

[hotkeys]
key-play-pause=Space
key-next=n
key-prev=p
key-vol-up=Ctrl+Up
key-vol-down=Ctrl+Down
key-snapshot=Shift+s
key-quit=Ctrl+q
key-faster=]
key-slower=[
key-jump+short=Shift+Right
key-jump-short=Shift+Left
key-jump+medium=Ctrl+Right
key-jump-medium=Ctrl+Left
