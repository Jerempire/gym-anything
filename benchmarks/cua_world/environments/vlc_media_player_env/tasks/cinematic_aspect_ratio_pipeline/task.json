{
  "id": "cinematic_aspect_ratio_pipeline@1",
  "version": "1.0",
  "env_id": "vlc_env@0.1",
  "description": "You are a film studies student writing a comparative essay on aspect ratios. Center-crop the 1920x1080 source video at /home/ga/Videos/source_clip.mp4 into five cinematic aspect ratios and save the outputs to /home/ga/Videos/aspect_ratios/.\n\nRequired outputs (MP4 container, H.264 video, AAC stereo audio, matching source duration, ±4px resolution tolerance):\n- cinemascope.mp4 (2.39:1, 1920x804)\n- academy_flat.mp4 (1.85:1, 1920x1038)\n- classic_tv.mp4 (4:3, 1",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "dense"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/cinematic_aspect_ratio_pipeline/setup_task.sh",
    "post_task": "/workspace/tasks/cinematic_aspect_ratio_pipeline/export_result.sh"
  },
  "metadata": {
    "source_file": "/home/ga/Videos/source_clip.mp4",
    "output_dir": "/home/ga/Videos/aspect_ratios",
    "catalog_file": "/home/ga/Videos/aspect_ratios/aspect_catalog.json",
    "expected_outputs": {
      "cinemascope.mp4": {
        "width": 1920,
        "height": 804
      },
      "academy_flat.mp4": {
        "width": 1920,
        "height": 1038
      },
      "classic_tv.mp4": {
        "width": 1440,
        "height": 1080
      },
      "square_social.mp4": {
        "width": 1080,
        "height": 1080
      },
      "vertical_mobile.mp4": {
        "width": 608,
        "height": 1080
      }
    },
    "expected_vcodec": "h264",
    "expected_acodec": "aac",
    "expected_duration_sec": 60.0,
    "duration_tolerance_sec": 2.0,
    "resolution_tolerance_px": 4
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_cinematic_aspect_ratio_pipeline"
    }
  }
}
