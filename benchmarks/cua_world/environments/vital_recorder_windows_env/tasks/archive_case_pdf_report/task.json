{
  "id": "archive_case_pdf_report@1",
  "version": "1.0",
  "env_id": "vital_recorder_windows_env@0.1",
  "description": "Configure the Vital Recorder display for VitalDB Case #3 to show only the essential vital sign trends: Heart Rate (HR), Mean Arterial Pressure (ART_MBP or MBP), Oxygen Saturation (SPO2), and End-Tidal CO2 (ETCO2 or CO2). Adjust the view to encompass the entire recording duration and export the resulting summary as a PDF to C:\\Users\\Docker\\Documents\\case3_summary.pdf.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\archive_case_pdf_report\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\archive_case_pdf_report\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\Users\\Docker\\Documents\\case3_summary.pdf",
    "required_text": [
      "HR",
      "SPO2",
      "MBP",
      "CO2"
    ],
    "forbidden_text": [
      "ECG",
      "PLETH",
      "AWP"
    ],
    "case_file": "0003.vital",
    "case_url": "https://api.vitaldb.net/0003.vital"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_archive_case_pdf_report"
    }
  }
}
