{
  "id": "navigate_timeline_window@1",
  "version": "1.0",
  "env_id": "vital_recorder_windows_env@0.1",
  "description": "Prepare a view of VitalDB Case #6 in Vital Recorder for review. Adjust the timeline to show a 5-minute window centered at the 20-minute mark (00:20:00) with vital sign waveforms visible. Save a screenshot of this view to C:\\Users\\Docker\\Desktop\\case_review_capture.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\navigate_timeline_window\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\navigate_timeline_window\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\Users\\Docker\\Desktop\\case_review_capture.png",
    "case_id": "6",
    "target_time_center": "00:20:00",
    "target_window_duration_min": 5,
    "download_url": "https://api.vitaldb.net/6"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_navigate_timeline_window"
    }
  }
}
