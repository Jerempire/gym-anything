{
  "id": "download_vitaldb_case@1",
  "version": "1.0",
  "env_id": "vital_recorder_windows_env@0.1",
  "description": "Download Case ID 1 from the VitalDB open dataset using Vital Recorder. Ensure the download includes standard tracks (ECG, ART, etc.) and save the file to C:\\Users\\Docker\\Documents\\VitalRecorder\\vitaldb_case1.vital.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\download_vitaldb_case\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\download_vitaldb_case\\export_result.ps1",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_output_path": "C:\\Users\\Docker\\Documents\\VitalRecorder\\vitaldb_case1.vital",
    "min_file_size_bytes": 1048576,
    "dataset_url": "https://vitaldb.net",
    "case_id": "1",
    "required_workflow_elements": [
      "VitalDB Browser",
      "Case List",
      "Download"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_download_vitaldb_case"
    }
  }
}
