{
  "id": "osw_chrome_password_manager@1",
  "version": "1.0",
  "env_id": "example.chrome_env@0.1",
  "description": "Computer, please navigate to the area in my browser settings where my passwords are stored. I want to check my login information for Etsy without revealing it just yet.",
  "difficulty": "easy",
  "tags": ["chrome", "navigation", "url", "settings", "osworld"],
  "init": {
    "timeout_sec": 180,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_chrome_password_manager/setup_task.sh",
    "post_task": "/workspace/tasks/osw_chrome_password_manager/export_result.sh"
  },
  "metadata": {
    "osworld_id": "12086550-11c0-466b-b367-1d9e75b3910e",
    "expected_url": "chrome://password-manager/passwords",
    "comparison_mode": "approximate"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_task"
    }
  }
}
