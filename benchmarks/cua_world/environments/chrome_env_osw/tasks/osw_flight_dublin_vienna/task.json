{
  "id": "osw_flight_dublin_vienna@1",
  "version": "1.0",
  "env_id": "example.chrome_env@0.1",
  "description": "Search for a one way flight from Dublin to Vienna on 10th next month for 2 adults.",
  "difficulty": "hard",
  "tags": ["chrome", "flight", "relative-time", "url-parse", "osworld"],
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_flight_dublin_vienna/setup_task.sh",
    "post_task": "/workspace/tasks/osw_flight_dublin_vienna/export_result.sh"
  },
  "metadata": {
    "osworld_id": "f79439ad-3ee8-4f99-a518-0eb60e5652b0",
    "evaluator_type": "check_direct_json_object",
    "result_type": "active_tab_url_parse",
    "relative_time": "10th next month"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_task"
    }
  }
}
