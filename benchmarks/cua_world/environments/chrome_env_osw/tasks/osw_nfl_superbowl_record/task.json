{
  "id": "osw_nfl_superbowl_record@1",
  "version": "1.0",
  "env_id": "example.chrome_env@0.1",
  "description": "Please help me find the score record for the Super Bowl of the 2019 NFL season (played in 2020) in the NFL website.",
  "difficulty": "easy",
  "tags": ["chrome", "navigation", "url", "osworld"],
  "init": {
    "timeout_sec": 180,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_nfl_superbowl_record/setup_task.sh",
    "post_task": "/workspace/tasks/osw_nfl_superbowl_record/export_result.sh"
  },
  "metadata": {
    "osworld_id": "f0b971a1-6831-4b9b-a50e-22a6e47f45ba",
    "expected_url": "https://www.nfl.com/scores/2019/post4"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_task"
    }
  }
}
