{
  "id": "osw_boston_logan_cars@1",
  "version": "1.0",
  "env_id": "example.chrome_env@0.1",
  "description": "On the current website, show me the cars available for pickup at Boston Logan Intl Airport from the 10th to the 11th of next month, sorted by the number of seats to find the largest capacity.",
  "difficulty": "hard",
  "tags": ["chrome", "car-rental", "relative-time", "multi-eval", "osworld"],
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_boston_logan_cars/setup_task.sh",
    "post_task": "/workspace/tasks/osw_boston_logan_cars/export_result.sh"
  },
  "metadata": {
    "osworld_id": "47543840-672a-467d-80df-8f7c3b9788c9",
    "evaluator_type": "multi_eval",
    "conjunction": "and",
    "checks": [
      "is_expected_url_pattern_match",
      "check_direct_json_object",
      "check_direct_json_object"
    ],
    "relative_time_from": "10th next month",
    "relative_time_to": "11th next month"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_task"
    }
  }
}
