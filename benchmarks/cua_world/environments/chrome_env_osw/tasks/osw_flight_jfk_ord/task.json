{
  "id": "osw_flight_jfk_ord@1",
  "version": "1.0",
  "env_id": "example.chrome_env@0.1",
  "description": "Find flights from New York\u2013Kennedy Airport to Chicago O'Hare Airport for tomorrow.",
  "difficulty": "hard",
  "tags": ["chrome", "flight", "relative-time", "html-parse", "osworld"],
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_flight_jfk_ord/setup_task.sh",
    "post_task": "/workspace/tasks/osw_flight_jfk_ord/export_result.sh"
  },
  "metadata": {
    "osworld_id": "fc6d8143-9452-4171-9459-7f515143419a",
    "evaluator_type": "check_direct_json_object",
    "result_type": "active_tab_html_parse",
    "relative_time": "tomorrow"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_task"
    }
  }
}
