{
  "id": "osw_flight_mumbai_stockholm@1",
  "version": "1.0",
  "env_id": "example.chrome_env@0.1",
  "description": "On next Monday, look up a flight from Mumbai to Stockholm.",
  "difficulty": "hard",
  "tags": ["chrome", "flight", "relative-time", "url-parse", "osworld"],
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_flight_mumbai_stockholm/setup_task.sh",
    "post_task": "/workspace/tasks/osw_flight_mumbai_stockholm/export_result.sh"
  },
  "metadata": {
    "osworld_id": "82bc8d6a-36eb-4d2d-8801-ef714fb1e55a",
    "evaluator_type": "check_direct_json_object",
    "result_type": "active_tab_url_parse",
    "relative_time": "next Monday",
    "expect_in_result": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_task"
    }
  }
}
