{
  "id": "osw_weather_manchester@1",
  "version": "1.0",
  "env_id": "example.chrome_env@0.1",
  "description": "Find the Monthly forecast for Manchester, GB for this month",
  "difficulty": "hard",
  "tags": ["chrome", "weather", "relative-time", "multi-eval", "osworld"],
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_weather_manchester/setup_task.sh",
    "post_task": "/workspace/tasks/osw_weather_manchester/export_result.sh"
  },
  "metadata": {
    "osworld_id": "368d9ba4-203c-40c1-9fa3-da2f1430ce63",
    "evaluator_type": "multi_eval",
    "checks": [
      "check_direct_json_object",
      "is_expected_url_pattern_match"
    ],
    "relative_time": "this month"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_task"
    }
  }
}
