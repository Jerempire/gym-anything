{
  "id": "osw_flight_seattle_nyc@1",
  "version": "1.0",
  "env_id": "example.chrome_env@0.1",
  "description": "Find flights from Seattle to New York on 5th next month and only show those that can be purchased with miles.",
  "difficulty": "hard",
  "tags": ["chrome", "flight", "relative-time", "html-parse", "osworld"],
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_flight_seattle_nyc/setup_task.sh",
    "post_task": "/workspace/tasks/osw_flight_seattle_nyc/export_result.sh"
  },
  "metadata": {
    "osworld_id": "6c4c23a1-42a4-43cc-9db1-2f86ff3738cc",
    "evaluator_type": "check_direct_json_object",
    "result_type": "active_tab_html_parse",
    "relative_time": "5th next month"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_task"
    }
  }
}
