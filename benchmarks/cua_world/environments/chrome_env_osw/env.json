{
  "id": "example.chrome_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Google Chrome browser environment with CDP (Chrome DevTools Protocol) support for automation and testing",
  "resources": {
    "cpu": 4,
    "mem_gb": 4,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [
        1920,
        1080
      ],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/chrome_env_osw/artifacts"
  },
  "vnc": {
    "enable": false,
    "host_port": 5951,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": [
      "ALL"
    ],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true,
    "runtime": "sysbox-runc"
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/chrome_env_osw/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/chrome_env_osw/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/chrome_env_osw/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/chrome_env_osw/utils",
      "target": "/workspace/utils",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_chrome.sh",
    "post_start": "/workspace/scripts/setup_chrome.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": [
          "sudo",
          "audio",
          "video",
          "input"
        ],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "CHROME_USER": "ga"
        }
      }
    },
    {
      "name": "webuser",
      "password": "webuser123",
      "uid": 1001,
      "role": "user",
      "permissions": {
        "sudo": false,
        "groups": [
          "audio",
          "video",
          "input"
        ],
        "shell": "/bin/bash",
        "env_vars": {
          "CHROME_USER": "webuser"
        }
      }
    }
  ],
  "tags": [
    "linux",
    "browser",
    "web",
    "chrome",
    "desktop",
    "cdp"
  ]
}