{
  "id": "deregister_civilian_weapon@1",
  "version": "1.0",
  "env_id": "opencad_env@0.1",
  "description": "As the administrator (Email: admin@opencad.local, Password: Admin123!), permanently deregister the 'Combat Pistol' (Serial: DSL-882) from Michael DeSanta's record in OpenCAD. Ensure the 'Pump Shotgun' (Serial: KEE-456) remains registered to his identity.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/deregister_civilian_weapon/setup_task.sh",
    "post_task": "/workspace/tasks/deregister_civilian_weapon/export_result.sh"
  },
  "metadata": {
    "civilian_name": "Michael DeSanta",
    "target_serial": "DSL-882",
    "safe_serial": "KEE-456",
    "target_weapon_name": "Combat Pistol"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_deregister_civilian_weapon"
    }
  }
}
