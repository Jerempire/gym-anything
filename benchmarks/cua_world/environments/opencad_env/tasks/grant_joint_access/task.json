{
  "id": "grant_joint_access@1",
  "version": "1.0",
  "env_id": "opencad_env@0.1",
  "description": "As the administrator (admin@opencad.local / Admin123!), update the 'Dispatch Officer' account (dispatch@opencad.local) so that it is assigned to exactly three departments: Communications, Sheriff, and Highway.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/grant_joint_access/setup_task.sh",
    "post_task": "/workspace/tasks/grant_joint_access/export_result.sh"
  },
  "metadata": {
    "target_user_email": "dispatch@opencad.local",
    "target_user_id": 3,
    "required_dept_ids": [
      1,
      3,
      4
    ],
    "dept_names": {
      "1": "Communications",
      "3": "Highway",
      "4": "Sheriff"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_grant_joint_access"
    }
  }
}
