{
  "id": "revoke_civilian_warrant@1",
  "version": "1.0",
  "env_id": "opencad_env@0.1",
  "description": "Log in to OpenCAD as admin (admin@opencad.local / Admin123!) and revoke the 'Failure to Appear' warrant from the record of Marcus Vance (DOB: 1980-05-12). Ensure the civilian identity itself is not deleted.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/revoke_civilian_warrant/setup_task.sh",
    "post_task": "/workspace/tasks/revoke_civilian_warrant/export_result.sh"
  },
  "metadata": {
    "target_civilian": "Marcus Vance",
    "target_warrant_reason": "Failure to Appear",
    "admin_email": "admin@opencad.local",
    "admin_pass": "Admin123!"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_revoke_civilian_warrant"
    }
  }
}
