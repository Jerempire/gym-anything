{
  "id": "update_arrest_report@1",
  "version": "1.0",
  "env_id": "opencad_env@0.1",
  "description": "Log in to OpenCAD (admin@opencad.local / Admin123!). In the Police Dashboard, update the 'Petty Theft' arrest report for civilian 'Elena Fisher' to 'Grand Larceny'. Ensure all other report details remain unchanged.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_arrest_report/setup_task.sh",
    "post_task": "/workspace/tasks/update_arrest_report/export_result.sh"
  },
  "metadata": {
    "target_civilian": "Elena Fisher",
    "old_charge": "Petty Theft",
    "new_charge": "Grand Larceny",
    "expected_narrative_snippet": "Suspect apprehended at jewelry store"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_arrest_report"
    }
  }
}
