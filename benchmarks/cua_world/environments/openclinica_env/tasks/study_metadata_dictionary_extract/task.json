{
  "id": "study_metadata_dictionary_extract@1",
  "version": "1.0",
  "env_id": "openclinica_env@0.1",
  "description": "Login to OpenClinica (username 'root', password 'Admin123!') for the Phase II Diabetes Trial (DM-TRIAL-2024). Download the CDISC ODM XML Study Metadata to /home/ga/study_metadata.xml. Extract the precise code list mappings for the Adverse Event 'Severity' and 'Relationship' variables from the metadata and save them to /home/ga/ae_codelists.json using the following structure:\n\n{\n  \"Severity\": {\n    \"1\": \"...\",\n    \"2\": \"...\"\n  },\n  \"Relationship\": {\n    \"1\": \"...\",\n    \"2\": \"...\"\n  }\n}",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/study_metadata_dictionary_extract/setup_task.sh",
    "post_task": "/workspace/tasks/study_metadata_dictionary_extract/export_result.sh"
  },
  "metadata": {
    "expected_study_oid": "S_DM2024",
    "expected_json_path": "/home/ga/ae_codelists.json",
    "expected_xml_path": "/home/ga/study_metadata.xml",
    "ground_truth_codelists": {
      "Severity": {
        "1": "Grade 1 (Mild - No intervention)",
        "2": "Grade 2 (Moderate - Local intervention)",
        "3": "Grade 3 (Severe - Hospitalization)",
        "4": "Grade 4 (Life-threatening)",
        "5": "Grade 5 (Fatal)"
      },
      "Relationship": {
        "1": "Not Related (Unlikely)",
        "2": "Possibly Related",
        "3": "Probably Related",
        "4": "Definitely Related"
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_metadata_extraction"
    }
  }
}
