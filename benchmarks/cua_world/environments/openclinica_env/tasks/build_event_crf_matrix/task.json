{
  "id": "build_event_crf_matrix@1",
  "version": "1.0",
  "env_id": "openclinica_env@0.1",
  "description": "You are the Clinical Data Manager for the Phase II Diabetes Trial (DM-TRIAL-2024). Log in to OpenClinica (Username: root / Password: Admin123!) and ensure 'Phase II Diabetes Trial' is your active study. Configure the Event-CRF matrix by mapping the 'Demographics' CRF (not required) and 'Vital Signs' CRF (required) to the 'Screening Visit' event. Map the 'Vital Signs' CRF (required) and 'Lab Results' CRF (required) to both the 'Baseline Visit' and 'Week 12 Final Visit' events. Use default versions for all CRFs.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/build_event_crf_matrix/setup_task.sh",
    "post_task": "/workspace/tasks/build_event_crf_matrix/export_result.sh"
  },
  "metadata": {
    "study_identifier": "DM-TRIAL-2024",
    "matrix": [
      {
        "event": "Screening Visit",
        "crf": "Demographics",
        "required": false
      },
      {
        "event": "Screening Visit",
        "crf": "Vital Signs",
        "required": true
      },
      {
        "event": "Baseline Visit",
        "crf": "Vital Signs",
        "required": true
      },
      {
        "event": "Baseline Visit",
        "crf": "Lab Results",
        "required": true
      },
      {
        "event": "Week 12 Final Visit",
        "crf": "Vital Signs",
        "required": true
      },
      {
        "event": "Week 12 Final Visit",
        "crf": "Lab Results",
        "required": true
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_build_event_crf_matrix"
    }
  }
}
