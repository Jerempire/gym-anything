{
  "id": "connect_to_database@1",
  "version": "1.0",
  "env_id": "dbeaver_env@0.1",
  "description": "Connect to the SQLite database located at /home/ga/Documents/databases/chinook.db using DBeaver. Name the connection exactly 'Chinook'.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/connect_to_database/setup_task.sh",
    "post_task": "/workspace/tasks/connect_to_database/export_result.sh"
  },
  "metadata": {
    "expected_db_path": "/home/ga/Documents/databases/chinook.db",
    "expected_connection_name": "Chinook",
    "expected_db_type": "sqlite",
    "require_exact_name": true,
    "require_connection_expanded": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_connect_to_database"
    }
  }
}
