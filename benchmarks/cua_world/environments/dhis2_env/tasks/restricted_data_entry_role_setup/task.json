{
  "id": "restricted_data_entry_role_setup@1",
  "version": "1.0",
  "env_id": "dhis2_env@0.1",
  "description": "Create a new DHIS2 User Role named 'Clerk - Entry Only' that enforces a least-privilege security policy for data entry clerks. The role must grant access to the 'Data Entry' application and allow adding/updating data values, but it must not grant the authority to delete data values.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/restricted_data_entry_role_setup/setup_task.sh",
    "post_task": "/workspace/tasks/restricted_data_entry_role_setup/export_result.sh"
  },
  "metadata": {
    "target_role_name": "Clerk - Entry Only",
    "required_authorities": [
      "F_DATAVALUE_ADD",
      "M_dhis-web-dataentry"
    ],
    "forbidden_authorities": [
      "F_DATAVALUE_DELETE",
      "ALL"
    ],
    "task_focus": "security and access control"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_restricted_role"
    }
  }
}
