{
  "id": "configure_multistep_routes@1",
  "version": "1.0",
  "env_id": "odoo_inventory_env@0.1",
  "description": "Configure the main warehouse (code: WH) in Odoo Inventory (admin/admin) to use multi-step fulfillment routes. Set outgoing shipments to a 3-step process (Pick, Pack, and Ship) and incoming shipments to a 3-step process (Receive, Quality, and Stock).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_multistep_routes/setup_task.sh",
    "post_task": "/workspace/tasks/configure_multistep_routes/export_result.sh"
  },
  "metadata": {
    "warehouse_code": "WH",
    "expected_delivery_steps": "pick_pack_ship",
    "expected_reception_steps": "three_steps"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_multistep_routes"
    }
  }
}
