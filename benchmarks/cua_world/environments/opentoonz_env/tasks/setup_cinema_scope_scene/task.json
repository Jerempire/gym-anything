{
  "id": "setup_cinema_scope_scene@1",
  "version": "1.0",
  "env_id": "opentoonz_env@0.1",
  "description": "Create a new OpenToonz scene for a DCI 2K Scope theatrical project with a resolution of 2048 x 858 pixels, a frame rate of 24 fps, and a frame range from 1 to 120. Save the scene to /home/ga/OpenToonz/projects/cinema_short/cinema_short.tnz and render the first frame as a PNG to /home/ga/OpenToonz/output/cinema_scope_test/.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/setup_cinema_scope_scene/setup_task.sh",
    "post_task": "/workspace/tasks/setup_cinema_scope_scene/export_result.sh"
  },
  "metadata": {
    "expected_scene_path": "/home/ga/OpenToonz/projects/cinema_short/cinema_short.tnz",
    "expected_output_dir": "/home/ga/OpenToonz/output/cinema_scope_test",
    "target_width": 2048,
    "target_height": 858,
    "target_fps": 24,
    "target_frame_count": 120
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_setup_cinema_scope_scene"
    }
  }
}
