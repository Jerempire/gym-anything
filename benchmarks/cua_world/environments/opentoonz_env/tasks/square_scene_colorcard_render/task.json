{
  "id": "square_scene_colorcard_render@1",
  "version": "1.0",
  "env_id": "opentoonz_env@0.1",
  "difficulty": "very_hard",
  "description": "Create a new scene in OpenToonz configured for Instagram-style output. The scene must be 1080x1080 resolution at 30 fps with a solid blue background (Hex #0066CC). Render a 60-frame PNG sequence to /home/ga/OpenToonz/output/square_scene/.",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/square_scene_colorcard_render/setup_task.sh",
    "post_task": "/workspace/tasks/square_scene_colorcard_render/export_result.sh"
  },
