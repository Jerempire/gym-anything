    "output_dir": "/home/ga/OpenToonz/output/square_scene",
    "expected_width": 1080,
    "expected_height": 1080,
    "min_frames": 60,
    "expected_color_rgb": [
      0,
      102,
      204
    ],
    "color_tolerance": 40
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_square_scene_colorcard_render"
    }
  }
