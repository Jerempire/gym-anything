{
  "id": "reverse_animation_xsheet_render@1",
  "version": "1.0",
  "env_id": "opentoonz_env@0.1",
  "difficulty": "hard",
  "description": "Open the scene '/home/ga/OpenToonz/samples/dwanko_run.tnz'. The animation currently plays forward. Reverse the animation order in the Xsheet so the character walks backwards. Render the reversed animation as a PNG sequence of at least 10 frames to '/home/ga/OpenToonz/output/reversed_animation/'.",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/reverse_animation_xsheet_render/setup_task.sh",
    "post_task": "/workspace/tasks/reverse_animation_xsheet_render/export_result.sh"
  },
  "metadata": {
    "scene_path": "/home/ga/OpenToonz/samples/dwanko_run.tnz",
    "output_dir": "/home/ga/OpenToonz/output/reversed_animation",
    "min_frame_count": 10,
    "min_total_size_kb": 100
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reverse_animation"
    }
  }
}
