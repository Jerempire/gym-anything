{
  "id": "create_character_color_palette@1",
  "version": "1.0",
  "env_id": "opentoonz_env@0.1",
  "description": "Create a character color palette for a 'Cyberpunk Detective'. Create an OpenToonz Palette file (.tpl) containing three styles: 'Skin_Base' (RGB: 255, 218, 193), 'Trench_Coat' (RGB: 44, 62, 80), and 'Neon_Trim' (RGB: 0, 255, 204). Save the palette to /home/ga/OpenToonz/outputs/cyber_detective.tpl.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_character_color_palette/setup_task.sh",
    "post_task": "/workspace/tasks/create_character_color_palette/export_result.sh"
  },
  "metadata": {
    "output_path": "/home/ga/OpenToonz/outputs/cyber_detective.tpl",
    "required_styles": [
      {
        "name": "Skin_Base",
        "rgb": [
          255,
          218,
          193
        ],
        "tolerance": 2
      },
      {
        "name": "Trench_Coat",
        "rgb": [
          44,
          62,
          80
        ],
        "tolerance": 2
      },
      {
        "name": "Neon_Trim",
        "rgb": [
          0,
          255,
          204
        ],
        "tolerance": 2
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_character_color_palette"
    }
  }
}
