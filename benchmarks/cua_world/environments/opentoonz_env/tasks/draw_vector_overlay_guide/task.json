{
  "id": "draw_vector_overlay_guide@1",
  "version": "1.0",
  "env_id": "opentoonz_env@0.1",
  "description": "Create a red circle guide framing the character on a new Toonz Vector Level (PLI) in the scene '/home/ga/OpenToonz/samples/dwanko_run.tnz'. The new level should be positioned in a column above the character animation. Render Frame 1 of the resulting scene as a PNG to '/home/ga/OpenToonz/output/guide_overlay/'.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/draw_vector_overlay_guide/setup_task.sh",
    "post_task": "/workspace/tasks/draw_vector_overlay_guide/export_result.sh"
  },
  "metadata": {
    "scene_path": "/home/ga/OpenToonz/samples/dwanko_run.tnz",
    "output_dir": "/home/ga/OpenToonz/output/guide_overlay",
    "target_color_name": "Red",
    "target_color_rgb": [
      255,
      0,
      0
    ],
    "min_red_pixel_count": 500
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_draw_vector_overlay_guide"
    }
  }
}
