{
  "id": "animate_ghibli_scene@1",
  "version": "1.0",
  "env_id": "opentoonz_env@0.1",
  "difficulty": "hard",
  "description": "Animate the Studio Ghibli scene using the image at /home/ga/OpenToonz/task/ghibli_scene.jpg, matching the animation effects (such as water sparkles, subtle waves, and camera movement) shown in the reference video at /home/ga/OpenToonz/task/reference_animation.mp4. Export the final animation to /home/ga/OpenToonz/task/agent_output/",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/animate_ghibli_scene/setup_task.sh",
    "post_task": "/workspace/tasks/animate_ghibli_scene/export_result.sh"
  },
  "metadata": {
    "ghibli_image_url": "https://www.ghibli.jp/gallery/chihiro050.jpg",
    "ghibli_image_name": "Spirited Away - Train Scene",
    "scene_type": "water_scene",
    "animation_recipe": {
      "description": "Calm water scene with subtle wave animation and floating particles",
      "particles": {
        "type": "sparkles",
        "count": 10,
        "speed": 5
      },
      "camera": {
        "type": "subtle_pan",
        "speed": 1,
        "direction": "right"
      },
      "plastic": {
        "target": "water_surface",
        "type": "wave",
        "amplitude": 0.01,
        "frequency": 0.3
      }
    },
    "frame_count": 60,
    "fps": 30,
    "expected_output_dir": "/home/ga/OpenToonz/task/agent_output",
    "reference_video": "/home/ga/OpenToonz/task/reference_animation.mp4",
    "clean_project": "/home/ga/OpenToonz/task/clean_project.tnz",
    "min_output_size_kb": 50,
    "min_motion_score": 0.3,
    "min_visual_similarity": 0.5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_animate_ghibli_scene"
    }
  }
}
