{
  "id": "storyboard_animatic_assembly@1",
  "version": "1.0",
  "env_id": "opentoonz_env@0.1",
  "description": "Create a 60-frame animatic using the storyboard panels in /home/ga/OpenToonz/storyboards/. The sequence must use key_setup.png for frames 1-24, key_anticip.png for frames 25-36, and key_action.png for frames 37-60. Render the animatic as PNG files to /home/ga/OpenToonz/output/animatic/.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/storyboard_animatic_assembly/setup_task.sh",
    "post_task": "/workspace/tasks/storyboard_animatic_assembly/export_result.sh"
  },
  "metadata": {
    "source_dir": "/home/ga/OpenToonz/storyboards",
    "output_dir": "/home/ga/OpenToonz/output/animatic",
    "total_frames": 60,
    "timing": [
      {
        "image": "key_setup.png",
        "start": 1,
        "end": 24
      },
      {
        "image": "key_anticip.png",
        "start": 25,
        "end": 36
      },
      {
        "image": "key_action.png",
        "start": 37,
        "end": 60
      }
    ],
    "match_threshold": 0.1
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_animatic_assembly"
    }
  }
}
