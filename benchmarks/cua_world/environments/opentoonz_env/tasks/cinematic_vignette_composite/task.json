{
  "id": "cinematic_vignette_composite@1",
  "version": "1.0",
  "env_id": "opentoonz_env@0.1",
  "difficulty": "very_hard",
  "description": "Apply a 'Vignette' effect to the scene '/home/ga/OpenToonz/samples/dwanko_run.tnz' so that the image corners are darkened to frame the subject while the center remains bright. Render at least 24 frames of the resulting animation as a PNG sequence to /home/ga/OpenToonz/output/vignette/.",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/cinematic_vignette_composite/setup_task.sh",
    "post_task": "/workspace/tasks/cinematic_vignette_composite/export_result.sh"
  },
  "metadata": {
    "scene_path": "/home/ga/OpenToonz/samples/dwanko_run.tnz",
    "output_dir": "/home/ga/OpenToonz/output/vignette",
    "min_frames": 24,
    "vignette_threshold_ratio": 0.85,
    "min_center_brightness": 20
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_cinematic_vignette_composite"
    }
  }
