{
  "id": "opentoonz_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "OpenToonz 2D animation environment for creating and editing animations",
  "observation": [
    {"type": "rgb_screen", "fps": 10, "resolution": [1920, 1080], "inline": false}
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "recording": {
    "enable": true,
    "output_dir": "benchmarks/cua_world/environments/opentoonz_env/artifacts"
  },
  "vnc": {
    "enable": true,
    "host_port": 5950,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/opentoonz_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/opentoonz_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/opentoonz_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_opentoonz.sh",
    "post_start": "/workspace/scripts/setup_opentoonz.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1"
        }
      }
    }
  ],
  "tags": ["linux", "animation", "2d-animation", "opentoonz", "desktop", "creative"]
}
