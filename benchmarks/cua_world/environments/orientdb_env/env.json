{
  "id": "orientdb_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "OrientDB multi-model (graph + document) database environment with Studio web UI and DemoDB travel agency dataset",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/orientdb_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/orientdb_env/tasks",   "target": "/workspace/tasks",   "mode": "ro"}
  ],
  "hooks": {
    "pre_start":  "/workspace/scripts/install_orientdb.sh",
    "post_start": "/workspace/scripts/setup_orientdb.sh"
  },
  "vnc": {
    "password": "password"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ]
}
