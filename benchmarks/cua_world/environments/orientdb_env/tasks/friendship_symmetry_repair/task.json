{
  "id": "friendship_symmetry_repair@1",
  "version": "1.0",
  "env_id": "orientdb_env@0.1",
  "description": "The travel agency's social graph has a data quality issue: some 'HasFriend' relationships are one-way, but friendships should be mutual. Audit the 'demodb' database (User: admin, Pass: admin) and repair these asymmetric relationships by creating the missing reverse edges. Every 'HasFriend' relationship must be bidirectional; do not delete existing edges or create duplicates.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/friendship_symmetry_repair/setup_task.sh",
    "post_task": "/workspace/tasks/friendship_symmetry_repair/export_result.sh"
  },
  "metadata": {
    "target_edge_count": 10,
    "initial_edge_count": 7,
    "missing_pairs": [
      {
        "from": "maria.garcia@example.com",
        "to": "john.smith@example.com"
      },
      {
        "from": "sophie.martin@example.com",
        "to": "david.jones@example.com"
      },
      {
        "from": "james.brown@example.com",
        "to": "yuki.tanaka@example.com"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_friendship_symmetry_repair"
    }
  }
}
