{
  "id": "schema_migration@1",
  "version": "1.0",
  "env_id": "orientdb_env@0.1",
  "description": "Perform a schema migration on the 'demodb' database (user: admin, pass: admin) at http://localhost:2480/studio/index.html. The migration includes adding a 'Rating' property (type DOUBLE) to the 'Restaurants' class and a 'Capacity' property (type INTEGER) to the 'Hotels' class. Configure 'Hotels.Name' as MANDATORY and enforce constraints on 'Hotels.Stars' with a MIN of 1 and a MAX of 5. Create a NOTUNIQUE composite index named 'Hotels_Country_Stars_idx' on the 'Hotels' class covering 'Country' and 'Stars'. Backfill the database by setting 'Rating' to 3.5 for all restaurants, and setting 'Capacity' to 500 for 5-star hotels and 200 for all other hotels.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/schema_migration/setup_task.sh",
    "post_task": "/workspace/tasks/schema_migration/export_result.sh"
  },
  "metadata": {
    "database": "demodb",
    "checks": {
      "properties": [
        {
          "class": "Restaurants",
          "name": "Rating",
          "type": "DOUBLE"
        },
        {
          "class": "Hotels",
          "name": "Capacity",
          "type": "INTEGER"
        }
      ],
      "constraints": [
        {
          "class": "Hotels",
          "property": "Name",
          "attribute": "mandatory",
          "value": true
        },
        {
          "class": "Hotels",
          "property": "Stars",
          "attribute": "min",
          "value": "1"
        },
        {
          "class": "Hotels",
          "property": "Stars",
          "attribute": "max",
          "value": "5"
        }
      ],
      "indexes": [
        {
          "name": "Hotels_Country_Stars_idx",
          "type": "NOTUNIQUE",
          "fields": [
            "Country",
            "Stars"
          ]
        }
      ],
      "data_backfill": {
        "restaurants_rating": 3.5,
        "hotels_capacity_5star": 500,
        "hotels_capacity_others": 200
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_schema_migration"
    }
  }
}
