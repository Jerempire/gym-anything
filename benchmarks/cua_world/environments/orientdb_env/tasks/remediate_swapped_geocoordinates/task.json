{
  "id": "remediate_swapped_geocoordinates@1",
  "version": "1.0",
  "env_id": "orientdb_env@0.1",
  "description": "A coordinate-ingest regression swapped latitude and longitude for flagship hotels in the demodb database. Repair the affected geospatial fields using OrientDB Studio (http://localhost:2480/studio/index.html, credentials: root / GymAnything123!) and materialize a GeoFixAudit evidence class populated with batch-tagged before/after records for each corrected hotel.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 90,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/remediate_swapped_geocoordinates/setup_task.sh",
    "post_task": "/workspace/tasks/remediate_swapped_geocoordinates/export_result.sh"
  },
  "metadata": {
    "expected_coordinates": {
      "The Plaza Hotel": {
        "Latitude": 40.7645,
        "Longitude": -73.9744
      },
      "Park Hyatt Tokyo": {
        "Latitude": 35.6858,
        "Longitude": 139.6909
      },
      "Four Seasons Sydney": {
        "Latitude": -33.8611,
        "Longitude": 151.2112
      }
    },
    "required_fix_batch": "geo_swap_2026q1"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_remediate_swapped_geocoordinates"
    }
  }
}
