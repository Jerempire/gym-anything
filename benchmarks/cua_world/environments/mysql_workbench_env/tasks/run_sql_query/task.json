{
  "id": "run_sql_query@1",
  "version": "1.0",
  "env_id": "mysql_workbench_env@0.1",
  "description": "Connect to the local MySQL server (host: localhost, user: ga, password: password123) and query the Sakila database to find all films with a rental rate strictly greater than 2.99. The query must return the title and rental_rate columns from the sakila.film table. Export the results to /home/ga/Documents/exports/expensive_films.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/run_sql_query/setup_task.sh",
    "post_task": "/workspace/tasks/run_sql_query/export_result.sh"
  },
  "metadata": {
    "expected_database": "sakila",
    "expected_table": "film",
    "expected_film_count": 336,
    "expected_output_file": "/home/ga/Documents/exports/expensive_films.csv",
    "filter_condition": "rental_rate > 2.99",
    "known_film_titles": [
      "ACE GOLDFINGER",
      "AIRPLANE SIERRA",
      "AIRPORT POLLOCK",
      "ALADDIN CALENDAR",
      "ALI FOREVER",
      "AMELIE HELLFIGHTERS",
      "AMERICAN CIRCUS",
      "ANTHEM LUKE",
      "APACHE DIVINE",
      "APOCALYPSE FLAMINGOS"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_run_sql_query"
    }
  }
}
