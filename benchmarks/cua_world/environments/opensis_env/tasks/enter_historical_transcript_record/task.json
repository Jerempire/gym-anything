{
  "id": "enter_historical_transcript_record@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Enter a historical transcript record for student 'Leo Vance' to backfill his academic history from a previous school. Use the following details: School Year 2023-2024, Course Title 'Biology', Grade 92, and Credit 1.0. Login credentials: Username 'admin', Password 'Admin@123'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/enter_historical_transcript_record/setup_task.sh",
    "post_task": "/workspace/tasks/enter_historical_transcript_record/export_result.sh"
  },
  "metadata": {
    "student_first": "Leo",
    "student_last": "Vance",
    "target_course": "Biology",
    "target_grade": "92",
    "target_year": "2023-2024",
    "target_credit": "1.0"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enter_historical_transcript_record"
    }
  }
}
