{
  "id": "set_section_seat_limit@1",
  "version": "1.0",
  "env_id": "opensis_env@0.1",
  "description": "Update the enrollment capacity for 'Introduction to Ceramics' (ART-205), Section 01, to exactly 12 seats due to room constraints. Use the OpenSIS credentials (Username: admin, Password: Admin@123). Do not modify any other courses or sections.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/set_section_seat_limit/setup_task.sh",
    "post_task": "/workspace/tasks/set_section_seat_limit/export_result.sh"
  },
  "metadata": {
    "target_course_code": "ART-205",
    "target_section": "01",
    "target_seats": 12,
    "control_course_code": "ART-101",
    "control_seats": 25,
    "login_user": "admin",
    "login_pass": "Admin@123"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_section_seat_limit"
    }
  },
  "tags": [
    "scheduling",
    "administrative",
    "forms",
    "data-integrity"
  ]
}
