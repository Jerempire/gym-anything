{
  "id": "re_enroll_withdrawn_student@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Re-enroll the inactive student 'Emily Blunt' into Grade 11 effective today using the enrollment code 'Re-Enrollment'. Do not modify or delete her previous withdrawal history. Login credentials: Username: admin, Password: Admin@123",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/re_enroll_withdrawn_student/setup_task.sh",
    "post_task": "/workspace/tasks/re_enroll_withdrawn_student/export_result.sh"
  },
  "metadata": {
    "student_first": "Emily",
    "student_last": "Blunt",
    "target_grade": "11",
    "enrollment_code_text": "Re-Enrollment"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_re_enrollment"
    }
  }
}
