{
  "id": "search_student@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Search for and display the information for 'Sample Student' in OpenSIS. Login credentials: Username: admin, Password: admin123.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/search_student/setup_task.sh",
    "post_task": "/workspace/tasks/search_student/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_search_student"
    }
  }
}
