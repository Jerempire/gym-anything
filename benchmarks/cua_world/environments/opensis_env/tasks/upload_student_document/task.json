{
  "id": "upload_student_document@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Login to OpenSIS (Username: admin, Password: Admin@123) and upload the student transcript file located at '/home/ga/Desktop/transcript_source.pdf' to the student record of 'Robert Transfer'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/upload_student_document/setup_task.sh",
    "post_task": "/workspace/tasks/upload_student_document/export_result.sh"
  },
  "metadata": {
    "student_first": "Robert",
    "student_last": "Transfer",
    "filename": "transcript_source.pdf",
    "source_path": "/home/ga/Desktop/transcript_source.pdf",
    "server_search_dirs": [
      "/var/www/html/opensis/files",
      "/var/www/html/opensis/assets",
      "/var/www/html/opensis/modules/students/student_files"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_upload_student_document"
    }
  },
  "tags": [
    "file_upload",
    "student_records",
    "administrative",
    "navigation"
  ]
}
