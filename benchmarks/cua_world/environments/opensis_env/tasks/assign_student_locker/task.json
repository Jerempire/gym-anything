{
  "id": "assign_student_locker@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Assign locker number '555' to the student 'Kenny McCormick' (Grade 10) in OpenSIS. Use the credentials Username: admin and Password: Admin@123.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/assign_student_locker/setup_task.sh",
    "post_task": "/workspace/tasks/assign_student_locker/export_result.sh"
  },
  "metadata": {
    "target_student_first": "Kenny",
    "target_student_last": "McCormick",
    "target_locker_number": "555",
    "login_username": "admin",
    "login_password": "Admin@123"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_assign_student_locker"
    }
  }
}
