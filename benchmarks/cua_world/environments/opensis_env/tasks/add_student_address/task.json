{
  "id": "add_student_address@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Log into OpenSIS (username: admin, password: Admin@123) and add a primary residential address for the student Alondra Reyes (Grade 10). Use the following details: 4712 Magnolia Boulevard, Houston, TX 77033, Phone: 713-555-0198.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_student_address/setup_task.sh",
    "post_task": "/workspace/tasks/add_student_address/export_result.sh"
  },
  "metadata": {
    "target_student_first": "Alondra",
    "target_student_last": "Reyes",
    "expected_street": "4712 Magnolia Boulevard",
    "expected_city": "Houston",
    "expected_state": "TX",
    "expected_zip": "77033",
    "expected_phone": "713-555-0198"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_student_address"
    }
  },
  "tags": [
    "student_management",
    "data_entry",
    "administrative",
    "opensis"
  ]
}
