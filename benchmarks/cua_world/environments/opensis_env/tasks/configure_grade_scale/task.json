{
  "id": "configure_grade_scale@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Configure a new Report Card Grade Scale in OpenSIS named 'Standard 4.0 Scale' using the following 11 letter grades, GPA values, breakoff percentages, and comments. Log in with username 'admin' and password 'Admin@123' if not already logged in.\n\n| Grade | GPA | Breakoff | Comment |\n|---|---|---|---|\n| A | 4.0 | 93 | Excellent |\n| A- | 3.7 | 90 | Excellent |\n| B+ | 3.3 | 87 | Good |\n| B | 3.0 | 83 | Good |\n| B- | 2.7 | 80 | Satisfactory |\n| C+ | 2.3 | 77 | Satisfactory |\n| C | 2.0 | 73 | Average |\n| C- | 1.7 | 70 | Below Average |\n| D+ | 1.3 | 67 | Poor |\n| D | 1.0 | 63 | Poor |\n| F | 0.0 | 0 | Failing |",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_grade_scale/setup_task.sh",
    "post_task": "/workspace/tasks/configure_grade_scale/export_result.sh"
  },
  "metadata": {
    "target_scale_name": "Standard 4.0 Scale",
    "expected_grades": [
      {
        "title": "A",
        "gpa": 4.0,
        "breakoff": 93,
        "comment": "Excellent"
      },
      {
        "title": "A-",
        "gpa": 3.7,
        "breakoff": 90,
        "comment": "Excellent"
      },
      {
        "title": "B+",
        "gpa": 3.3,
        "breakoff": 87,
        "comment": "Good"
      },
      {
        "title": "B",
        "gpa": 3.0,
        "breakoff": 83,
        "comment": "Good"
      },
      {
        "title": "B-",
        "gpa": 2.7,
        "breakoff": 80,
        "comment": "Satisfactory"
      },
      {
        "title": "C+",
        "gpa": 2.3,
        "breakoff": 77,
        "comment": "Satisfactory"
      },
      {
        "title": "C",
        "gpa": 2.0,
        "breakoff": 73,
        "comment": "Average"
      },
      {
        "title": "C-",
        "gpa": 1.7,
        "breakoff": 70,
        "comment": "Below Average"
      },
      {
        "title": "D+",
        "gpa": 1.3,
        "breakoff": 67,
        "comment": "Poor"
      },
      {
        "title": "D",
        "gpa": 1.0,
        "breakoff": 63,
        "comment": "Poor"
      },
      {
        "title": "F",
        "gpa": 0.0,
        "breakoff": 0,
        "comment": "Failing"
      }
    ],
    "tolerances": {
      "gpa": 0.05,
      "breakoff": 2
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_grade_scale"
    }
  }
}
