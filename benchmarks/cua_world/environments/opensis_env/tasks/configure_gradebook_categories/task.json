{
  "id": "configure_gradebook_categories@1",
  "version": "1.0",
  "env_id": "opensis_env@0.1",
  "description": "Configure the gradebook for the course section 'Mathematics 101' (Period 1) taught by Alan Turing. Create three weighted assignment categories: 'Homework' (20%), 'Quizzes' (30%), and 'Exams' (50%), ensuring the weights total 100%. Login as admin (username: admin, password: Admin@123).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_gradebook_categories/setup_task.sh",
    "post_task": "/workspace/tasks/configure_gradebook_categories/export_result.sh"
  },
  "metadata": {
    "course_name": "Mathematics 101",
    "teacher_name": "Alan Turing",
    "expected_categories": [
      {
        "title": "Homework",
        "weight": 20
      },
      {
        "title": "Quizzes",
        "weight": 30
      },
      {
        "title": "Exams",
        "weight": 50
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_gradebook_config"
    }
  }
}
