{
  "id": "generate_class_roster_pdf@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Generate a PDF class roster for the 'Algebra I' course (Section 1) in OpenSIS (Credentials: admin/Admin@123). Save the final roster to /home/ga/Documents/algebra_roster.pdf.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_class_roster_pdf/setup_task.sh",
    "post_task": "/workspace/tasks/generate_class_roster_pdf/export_result.sh"
  },
  "metadata": {
    "expected_file_path": "/home/ga/Documents/algebra_roster.pdf",
    "expected_course_name": "Algebra I",
    "expected_student_1": "John Smith",
    "expected_student_2": "Jane Doe",
    "min_file_size_bytes": 1000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_roster_pdf"
    }
  }
}
