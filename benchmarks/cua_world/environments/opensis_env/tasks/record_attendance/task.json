{
  "id": "record_attendance@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Record attendance for 'Sample Student' as 'Present' for today's date. Login credentials: Username: admin, Password: admin123.",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_attendance/setup_task.sh",
    "post_task": "/workspace/tasks/record_attendance/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_attendance"
    }
  }
}
