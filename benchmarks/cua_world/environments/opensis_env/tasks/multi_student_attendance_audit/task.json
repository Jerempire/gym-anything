{
  "id": "multi_student_attendance_audit@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "You are an attendance coordinator performing a retroactive attendance audit. The principal has asked you to enter the missing attendance records for three 10th-grade students for November 4, 2024, in OpenSIS. Record Miguel Santos as Present, Aisha Patel as Absent, and Dmitri Volkov as Tardy for that date. Do not change any other existing attendance records. Login credentials: Username: admin, Password: Admin@123",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/multi_student_attendance_audit/setup_task.sh",
    "post_task": "/workspace/tasks/multi_student_attendance_audit/export_result.sh"
  },
  "metadata": {
    "attendance_date": "2024-11-04",
    "students": [
      {
        "first": "Miguel",
        "last": "Santos",
        "grade": "10",
        "expected_status": "Present"
      },
      {
        "first": "Aisha",
        "last": "Patel",
        "grade": "10",
        "expected_status": "Absent"
      },
      {
        "first": "Dmitri",
        "last": "Volkov",
        "grade": "10",
        "expected_status": "Tardy"
      }
    ],
    "pass_threshold": 60
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_multi_student_attendance_audit"
    }
  }
}
