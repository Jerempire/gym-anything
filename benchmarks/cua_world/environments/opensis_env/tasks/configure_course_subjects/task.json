{
  "id": "configure_course_subjects@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Configure the course catalog in OpenSIS by adding two new Subject Areas: 'Computer Science' and 'Fine Arts'. Log in using the administrator credentials (Username: admin, Password: Admin@123).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_course_subjects/setup_task.sh",
    "post_task": "/workspace/tasks/configure_course_subjects/export_result.sh"
  },
  "metadata": {
    "targets": [
      "Computer Science",
      "Fine Arts"
    ],
    "db_user": "opensis_user",
    "db_pass": "opensis_password_123",
    "db_name": "opensis"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_course_subjects"
    }
  }
}
