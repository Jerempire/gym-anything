{
  "id": "add_school_calendar_event@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Log into OpenSIS as an administrator (Username: admin, Password: Admin@123) and add the 'Annual Science Fair' to the school calendar for May 20, 2026. The event should include the description 'Student project presentations in the gym (1PM - 4PM)' and be categorized as an Event type (not a Holiday).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_school_calendar_event/setup_task.sh",
    "post_task": "/workspace/tasks/add_school_calendar_event/export_result.sh"
  },
  "metadata": {
    "expected_title": "Annual Science Fair",
    "expected_date": "2026-05-20",
    "expected_description_keywords": [
      "gym",
      "presentations"
    ],
    "should_be_holiday": false
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_school_calendar_event"
    }
  }
