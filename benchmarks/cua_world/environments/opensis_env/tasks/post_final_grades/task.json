{
  "id": "post_final_grades@1",
  "version": "1.0",
  "env_id": "opensis_env@0.1",
  "description": "Log in to OpenSIS as an administrator and post final grades for the 'World History' course (Period 1) for the 'Full Year' (FY) marking period. Record the following entries: James Miller (92%, Grade A), Sarah Wilson (85%, Grade B), and Robert Chen (76%, Grade C) with the comment 'Needs improvement in homework submission.'",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/post_final_grades/setup_task.sh",
    "post_task": "/workspace/tasks/post_final_grades/export_result.sh"
  },
  "metadata": {
    "course_name": "World History",
    "students": [
      {
        "first_name": "James",
        "last_name": "Miller",
        "expected_percent": 92,
        "expected_letter": "A"
      },
      {
        "first_name": "Sarah",
        "last_name": "Wilson",
        "expected_percent": 85,
        "expected_letter": "B"
      },
      {
        "first_name": "Robert",
        "last_name": "Chen",
        "expected_percent": 76,
        "expected_letter": "C",
        "expected_comment_fragment": "Needs improvement"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_post_final_grades"
    }
  }
}
