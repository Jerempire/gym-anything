{
  "id": "reschedule_course_section@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "The facilities manager at Demo School has reported that Room 101 will undergo HVAC repairs. As the school administrator (username: admin, password: Admin@123), update the 'Introduction to Literature' (ENG101) course section by changing its assignment from Room 101 / Period 1 to Room 205 / Period 3.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/reschedule_course_section/setup_task.sh",
    "post_task": "/workspace/tasks/reschedule_course_section/export_result.sh"
  },
  "metadata": {
    "target_course_code": "ENG101",
    "target_room": "205",
    "target_period_short": "3",
    "target_period_title": "Period 3",
    "initial_room": "101",
    "initial_period_short": "1"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reschedule_course_section"
    }
  },
  "tags": [
    "scheduling",
    "opensis",
    "admin",
    "database-verification"
  ]
}
