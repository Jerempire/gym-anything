{
  "id": "mark_student_retention@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Update the enrollment status for student 'Robert Failson' (Grade 9) in OpenSIS to mark him for retention (non-promotion) for the upcoming school year by setting his rolling option to 'Retain'. Login credentials: Username: admin, Password: Admin@123.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/mark_student_retention/setup_task.sh",
    "post_task": "/workspace/tasks/mark_student_retention/export_result.sh"
  },
  "metadata": {
    "target_student_first": "Robert",
    "target_student_last": "Failson",
    "target_grade_level": "9",
    "expected_rolling_option": "Retain"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mark_student_retention"
    }
  }
}
