{
  "id": "update_school_gpa_scale@1",
  "version": "1.0",
  "env_id": "opensis_env@0.1",
  "description": "Log in to OpenSIS as an administrator and update the 'Reporting GP Scale' for 'Demo School' to 5.00 to reflect a new weighted GPA policy. \n\nLogin credentials:\n- URL: http://localhost/opensis/\n- Username: admin\n- Password: Admin@123",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_school_gpa_scale/setup_task.sh",
    "post_task": "/workspace/tasks/update_school_gpa_scale/export_result.sh"
  },
  "metadata": {
    "target_school": "Demo School",
    "initial_scale": 4.0,
    "target_scale": 5.0,
    "db_table": "schools",
    "db_column": "reporting_gp_scale"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_school_gpa_scale"
    }
  }
}
