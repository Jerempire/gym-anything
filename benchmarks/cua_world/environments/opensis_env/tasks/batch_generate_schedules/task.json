{
  "id": "batch_generate_schedules@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Generate a PDF batch report of student schedule cards for all 9th-grade students in OpenSIS (admin/Admin@123). The report must include schedules for Freshman One, Freshman Two, and Freshman Three, but must not include 10th-grade students such as Senior Student.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/batch_generate_schedules/setup_task.sh",
    "post_task": "/workspace/tasks/batch_generate_schedules/export_result.sh"
  },
  "metadata": {
    "target_grade": "9",
    "target_students": [
      "Freshman One",
      "Freshman Two",
      "Freshman Three"
    ],
    "excluded_students": [
      "Senior Student"
    ],
    "download_dir": "/home/ga/Downloads",
    "expected_extension": ".pdf"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_batch_generate_schedules"
    }
  }
}
