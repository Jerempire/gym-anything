{
  "id": "batch_assign_homeroom@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Batch assign the homeroom 'Room 101' to a specific cohort of Grade 9 students. Update the 'Homeroom' field for Jason Miller, Ashley Davis, and Michael Wilson to 'Room 101'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/batch_assign_homeroom/setup_task.sh",
    "post_task": "/workspace/tasks/batch_assign_homeroom/export_result.sh"
  },
  "metadata": {
    "target_room": "Room 101",
    "students": [
      {
        "first_name": "Jason",
        "last_name": "Miller"
      },
      {
        "first_name": "Ashley",
        "last_name": "Davis"
      },
      {
        "first_name": "Michael",
        "last_name": "Wilson"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_batch_assign_homeroom"
    }
  }
}
