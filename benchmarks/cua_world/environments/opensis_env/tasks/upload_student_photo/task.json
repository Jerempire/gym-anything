{
  "id": "upload_student_photo@1",
  "version": "1.0",
  "env_id": "opensis_env@0.1",
  "description": "You are the school registrar. A new student, Jason Miller (Grade 10), needs his ID photo added to the system. Update his profile in OpenSIS (URL: http://localhost/opensis, Username: admin, Password: Admin@123) using the photo file located at /home/ga/Documents/jason_miller.jpg.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/upload_student_photo/setup_task.sh",
    "post_task": "/workspace/tasks/upload_student_photo/export_result.sh"
  },
  "metadata": {
    "student_first": "Jason",
    "student_last": "Miller",
    "photo_path": "/home/ga/Documents/jason_miller.jpg",
    "expected_extensions": [
      "jpg",
      "jpeg",
      "png",
      "gif"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_upload_student_photo"
    }
  }
}
