{
  "id": "configure_enrollment_codes@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Configure student enrollment codes in OpenSIS.\n\nLogin Credentials:\n- URL: http://localhost/opensis/\n- Username: admin\n- Password: Admin@123\n\nAdd the following Entry (Add) codes:\n- Title: 'New Enrollment', Short Name: 'NEW'\n- Title: 'Transfer from Another District', Short Name: 'TRAN_IN'\n- Title: 'Re-enrollment After Withdrawal', Short Name: 'RE_ENROLL'\n\nAdd the following Withdrawal (Drop) codes:\n- Title: 'Graduated', Short Name: 'GRAD'\n- Title: 'Transferred to Another District', Short Name: 'TRAN_OUT'\n- Title: 'Expelled', Short Name: 'EXPEL'",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_enrollment_codes/setup_task.sh",
    "post_task": "/workspace/tasks/configure_enrollment_codes/export_result.sh"
  },
  "metadata": {
    "expected_entry_codes": [
      {
        "title": "New Enrollment",
        "short_name": "NEW",
        "type_keyword": "add"
      },
      {
        "title": "Transfer from Another District",
        "short_name": "TRAN_IN",
        "type_keyword": "add"
      },
      {
        "title": "Re-enrollment After Withdrawal",
        "short_name": "RE_ENROLL",
        "type_keyword": "add"
      }
    ],
    "expected_exit_codes": [
      {
        "title": "Graduated",
        "short_name": "GRAD",
        "type_keyword": "drop"
      },
      {
        "title": "Transferred to Another District",
        "short_name": "TRAN_OUT",
        "type_keyword": "drop"
      },
      {
        "title": "Expelled",
        "short_name": "EXPEL",
        "type_keyword": "drop"
      }
    ],
    "min_codes_required": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enrollment_codes"
    }
  }
}
