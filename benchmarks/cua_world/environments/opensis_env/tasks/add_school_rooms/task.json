{
  "id": "add_school_rooms@1",
  "version": "1.0",
  "env_id": "example.opensis_env@0.1",
  "description": "Using the administrator credentials (username: admin, password: Admin@123), add two rooms to Demo School in OpenSIS. The first room is SCI-201 with a capacity of 30, and the second room is COMP-305 with a capacity of 25.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_school_rooms/setup_task.sh",
    "post_task": "/workspace/tasks/add_school_rooms/export_result.sh"
  },
  "metadata": {
    "admin_user": "admin",
    "admin_pass": "Admin@123",
    "school_id": 1,
    "rooms": [
      {
        "title": "SCI-201",
        "capacity": 30
      },
      {
        "title": "COMP-305",
        "capacity": 25
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_school_rooms"
    }
  }
}
