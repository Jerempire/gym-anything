{
  "id": "relocate_default_logbook@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Create a folder hierarchy at '~/Sync/DiveLogs/' and save the current logbook as 'main_log.ssrf' in that location. Configure Subsurface to use '~/Sync/DiveLogs/main_log.ssrf' as the default logbook file on startup.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/relocate_default_logbook/setup_task.sh",
    "post_task": "/workspace/tasks/relocate_default_logbook/export_result.sh"
  },
  "metadata": {
    "expected_directory": "/home/ga/Sync/DiveLogs",
    "expected_file": "/home/ga/Sync/DiveLogs/main_log.ssrf",
    "min_file_size_bytes": 100000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_relocate_default_logbook"
    }
  }
}
