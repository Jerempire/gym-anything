{
  "id": "configure_profile_graph_overlays@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Customize the dive profile graph in Subsurface by enabling the 'Tissue heat map' and 'Average depth' visual overlays. Ensure these overlays are active and visible on the profile graph for the selected dive.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_profile_graph_overlays/setup_task.sh",
    "post_task": "/workspace/tasks/configure_profile_graph_overlays/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_overlays": [
      "Tissue heat map",
      "Average depth"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_profile_graph_overlays"
    }
  }
}
