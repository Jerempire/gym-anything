{
  "id": "migrate_logbook_sqlite@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Save the current dive log as a SQLite database to /home/ga/Documents/dive_data.sqlite. Configure Subsurface's preferences to use this new database file as the default logbook on startup.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/migrate_logbook_sqlite/setup_task.sh",
    "post_task": "/workspace/tasks/migrate_logbook_sqlite/export_result.sh"
  },
  "metadata": {
    "expected_sqlite_path": "/home/ga/Documents/dive_data.sqlite",
    "expected_conf_path": "/home/ga/.config/Subsurface/Subsurface.conf"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_migrate_logbook_sqlite"
    }
  }
}
