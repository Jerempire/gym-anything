{
  "id": "configure_mixed_units_personalize@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Configure Subsurface's unit preferences to a personalized mixed measurement setup. Set the units to Pressure in PSI, Temperature in Fahrenheit, Length/Depth in Meters, Volume in Liters, and Weight in Kilograms.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_mixed_units_personalize/setup_task.sh",
    "post_task": "/workspace/tasks/configure_mixed_units_personalize/export_result.sh"
  },
  "metadata": {
    "expected_units": {
      "pressure": "1",
      "temperature": "1",
      "length": "0",
      "volume": "0",
      "weight": "0"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mixed_units_configuration"
    }
  }
}
