{
  "id": "tag_personal_record_dives@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Analyze the loaded dive log to identify personal records. Tag the single deepest dive (by Max Depth) with 'Record-Deep' and the single longest dive (by Duration) with 'Record-Long'. Ensure no other dives are tagged with these labels and save the updated logbook.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/tag_personal_record_dives/setup_task.sh",
    "post_task": "/workspace/tasks/tag_personal_record_dives/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "deep_tag": "Record-Deep",
    "long_tag": "Record-Long",
    "log_file": "/home/ga/Documents/dives.ssrf"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_tag_personal_record_dives"
    }
  }
}
