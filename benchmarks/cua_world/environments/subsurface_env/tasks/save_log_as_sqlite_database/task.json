{
  "id": "save_log_as_sqlite_database@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Save the currently open Subsurface XML dive log as a native Subsurface SQLite database named 'dives_database.sqlite' in the /home/ga/Documents/ directory.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/save_log_as_sqlite_database/setup_task.sh",
    "post_task": "/workspace/tasks/save_log_as_sqlite_database/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/dives_database.sqlite",
    "expected_dive_count": 8
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_save_log_as_sqlite_database"
    }
  }
}
