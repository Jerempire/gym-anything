{
  "id": "set_default_dive_computer@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Configure the default dive computer to be a Shearwater Perdix on /dev/rfcomm0. Ensure the settings are saved as the default and persisted by closing the application.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/set_default_dive_computer/setup_task.sh",
    "post_task": "/workspace/tasks/set_default_dive_computer/export_result.sh"
  },
  "metadata": {
    "expected_vendor": "Shearwater",
    "expected_product": "Perdix",
    "expected_device": "/dev/rfcomm0"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_default_dive_computer"
    }
  }
}
