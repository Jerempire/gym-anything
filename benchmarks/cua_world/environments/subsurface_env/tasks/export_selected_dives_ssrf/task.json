{
  "id": "export_selected_dives_ssrf@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Export all dives from the 'Yellow House, WA' trip (September 2011) to a Subsurface XML file at /home/ga/Documents/yellow_house.ssrf. The exported file must contain only the dives from that specific trip.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_selected_dives_ssrf/setup_task.sh",
    "post_task": "/workspace/tasks/export_selected_dives_ssrf/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/yellow_house.ssrf",
    "expected_dive_count": 4,
    "expected_date_prefix": "2011-09"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_selected_dives_ssrf"
    }
  }
}
