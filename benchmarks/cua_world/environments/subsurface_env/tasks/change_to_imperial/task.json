{
  "id": "change_to_imperial@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Change the display units in Subsurface from metric to imperial. Ensure that depth is displayed in feet (ft), pressure in psi, temperature in Fahrenheit (°F), and weight in lbs.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/change_to_imperial/setup_task.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_length_unit": "imperial",
    "expected_pressure_unit": "psi",
    "expected_temperature_unit": "fahrenheit",
    "expected_weight_unit": "lbs"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_change_to_imperial"
    }
  }
}
