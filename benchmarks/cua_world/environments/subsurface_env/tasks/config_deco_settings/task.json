{
  "id": "config_deco_settings@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Configure the decompression calculation settings for technical dive planning in Subsurface. Set the GF Low to 30%, GF High to 70%, Bottom SAC to 20 L/min, and Deco SAC to 17 L/min. Save the dive log to persist these settings.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/config_deco_settings/setup_task.sh",
    "post_task": "/workspace/tasks/config_deco_settings/export_result.sh"
  },
  "metadata": {
    "expected_gf_low": 30,
    "expected_gf_high": 70,
    "expected_bottom_sac": 20,
    "expected_deco_sac": 17,
    "config_file_path": "/home/ga/.config/Subsurface/Subsurface.conf"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_config_deco_settings"
    }
  }
}
