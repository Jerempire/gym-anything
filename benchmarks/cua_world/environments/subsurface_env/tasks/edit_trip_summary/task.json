{
  "id": "edit_trip_summary@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Update the December 2010 trip (currently named 'Sund Rock, WA') by changing its location to 'Hood Canal Winter Retreat' and adding the note 'Instructor training weekend'. Save the updated dive log.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/edit_trip_summary/setup_task.sh",
    "post_task": "/workspace/tasks/edit_trip_summary/export_result.sh"
  },
  "metadata": {
    "expected_location": "Hood Canal Winter Retreat",
    "expected_notes": "Instructor training weekend",
    "target_trip_date_prefix": "2010-12"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_edit_trip_summary"
    }
  }
}
