{
  "id": "rename_dive_computer_nickname@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Assign the custom nickname 'My Primary OSTC' to the 'OSTC 3' dive computer in Subsurface and save the changes to the dive log.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rename_dive_computer_nickname/setup_task.sh",
    "post_task": "/workspace/tasks/rename_dive_computer_nickname/export_result.sh"
  },
  "metadata": {
    "target_model": "ostc 3",
    "expected_nickname": "My Primary OSTC",
    "expected_file_path": "/home/ga/Documents/dives.ssrf"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rename_dive_computer_nickname"
    }
  }
}
