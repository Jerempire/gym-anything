{
  "id": "migrate_logbook_to_sqlite@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Migrate the currently loaded Subsurface XML dive logbook to an SQLite database. Save the file as 'dives.db' in SQLite format to /home/ga/Documents/dives.db while ensuring the original XML logbook remains unchanged.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/migrate_logbook_to_sqlite/setup_task.sh",
    "post_task": "/workspace/tasks/migrate_logbook_to_sqlite/export_result.sh"
  },
  "metadata": {
    "expected_db_path": "/home/ga/Documents/dives.db",
    "expected_dive_count": 8,
    "original_ssrf_path": "/home/ga/Documents/dives.ssrf"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_migrate_logbook_to_sqlite"
    }
  }
}
