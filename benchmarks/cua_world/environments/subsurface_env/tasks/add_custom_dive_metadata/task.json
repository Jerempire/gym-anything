{
  "id": "add_custom_dive_metadata@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "A marine archaeologist needs to record specific custom information for an excavation dive. For Dive #4 (December 4, 2010 at Sund Rock, WA), add two custom fields: 'Permit_Number' with value 'ARCH-2011-042' and 'Artifact_Count' with value '3'. Save the changes to the dive log.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_custom_dive_metadata/setup_task.sh",
    "post_task": "/workspace/tasks/add_custom_dive_metadata/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "target_dive_number": 4,
    "target_dive_date": "2010-12-04",
    "target_dive_location": "Sund Rock",
    "expected_fields": [
      {
        "key": "Permit_Number",
        "value": "ARCH-2011-042"
      },
      {
        "key": "Artifact_Count",
        "value": "3"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_custom_metadata"
    }
  }
}
