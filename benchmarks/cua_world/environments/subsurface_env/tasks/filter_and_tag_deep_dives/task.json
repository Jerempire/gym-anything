{
  "id": "filter_and_tag_deep_dives@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Identify all dives with a maximum depth strictly greater than 20 meters. Add the tag 'DeepTech' to these dives and save the updated dive log to /home/ga/Documents/dives.ssrf.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/filter_and_tag_deep_dives/setup_task.sh",
    "post_task": "/workspace/tasks/filter_and_tag_deep_dives/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_tag": "DeepTech",
    "depth_threshold_m": 20.0,
    "target_file": "/home/ga/Documents/dives.ssrf"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_filter_and_tag_deep_dives"
    }
  }
}
