{
  "id": "migrate_log_to_git_backup@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Migrate your current dive log to a version-controlled backup. Save the log as a Local Git repository named 'dives.git' within a new folder at ~/Documents/SubsurfaceBackup/.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/migrate_log_to_git_backup/setup_task.sh",
    "post_task": "/workspace/tasks/migrate_log_to_git_backup/export_result.sh"
  },
  "metadata": {
    "expected_backup_dir": "/home/ga/Documents/SubsurfaceBackup",
    "expected_git_name": "dives.git",
    "expected_format": "Local Git repository"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_migrate_log_to_git_backup"
    }
  }
}
