{
  "id": "batch_tag_deep_dives_filter@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Identify all dives in the logbook with a maximum depth of 18.0 meters or greater. Add the tag 'Deep' to only these dives. Save the updated dive log to /home/ga/Documents/dives.ssrf.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/batch_tag_deep_dives_filter/setup_task.sh",
    "post_task": "/workspace/tasks/batch_tag_deep_dives_filter/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_tag": "Deep",
    "depth_threshold_m": 18.0,
    "target_file": "/home/ga/Documents/dives.ssrf"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_batch_tag_deep_dives"
    }
  }
}
