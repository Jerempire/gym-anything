{
  "id": "edit_dive_site_gps@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Identify the dive site in the logbook that is missing its GPS coordinates. Update the site with the coordinates 47.39170°N, 122.57694°W and save the dive log file.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/edit_dive_site_gps/setup_task.sh",
    "post_task": "/workspace/tasks/edit_dive_site_gps/export_result.sh"
  },
  "metadata": {
    "target_lat": 47.3917,
    "target_lon": -122.5769,
    "tolerance": 0.01
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_edit_dive_site_gps"
    }
  }
}
