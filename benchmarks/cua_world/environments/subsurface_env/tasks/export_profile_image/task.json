{
  "id": "export_profile_image@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Select Dive #4 (the deepest dive in the log) and export its dive profile graph as an image. Save the image to ~/Documents/deep_dive_profile.png (filenames with automatically appended dive numbers like 'deep_dive_profile_4.png' are also acceptable).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_profile_image/setup_task.sh",
    "post_task": "/workspace/tasks/export_profile_image/export_result.sh"
  },
  "metadata": {
    "expected_directory": "/home/ga/Documents/",
    "expected_filename_pattern": "*deep_dive_profile*",
    "min_file_size_bytes": 15000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_profile_image"
    }
  }
}
