{
  "id": "extract_location_extremes@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Identify the deepest and longest dives at the 'Sund Rock' location from the dive log. Record these findings in a text file at /home/ga/Documents/sund_rock_records.txt using the following format:\n\nDeepest: YYYY-MM-DD, XX.X m\nLongest: YYYY-MM-DD, YY:ZZ min",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/extract_location_extremes/setup_task.sh",
    "post_task": "/workspace/tasks/extract_location_extremes/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/sund_rock_records.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_extract_location_extremes"
    }
  }
}
