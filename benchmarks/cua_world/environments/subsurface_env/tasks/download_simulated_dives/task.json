{
  "id": "download_simulated_dives@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Download a simulated dive using 'Simulator' as the vendor and 'Simulator' as the dive computer. Save the dive log to ensure the changes are written to disk.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/download_simulated_dives/setup_task.sh",
    "post_task": "/workspace/tasks/download_simulated_dives/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_vendor": "Simulator",
    "min_dive_count": 9
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_download_simulated_dives"
    }
  }
}
