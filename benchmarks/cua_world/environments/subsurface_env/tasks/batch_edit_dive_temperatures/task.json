{
  "id": "batch_edit_dive_temperatures@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Batch-edit the four dives in the 'Sund Rock' trip (December 2010) in Subsurface to set the Air Temperature to 15°C and the Water Temperature to 9°C. Do not modify the temperatures for dives in the 'Yellow House' trip. Save the dive log after the updates are complete.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/batch_edit_dive_temperatures/setup_task.sh",
    "post_task": "/workspace/tasks/batch_edit_dive_temperatures/export_result.sh"
  },
  "metadata": {
    "expected_air_temp": 15.0,
    "expected_water_temp": 9.0,
    "target_trip_date_prefix": "2010-12",
    "control_trip_date_prefix": "2011-09",
    "expected_total_dives": 8,
    "expected_target_dives": 4
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_batch_edit_dive_temperatures"
    }
  }
}
