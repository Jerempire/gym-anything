{
  "id": "print_dive_log_pdf@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Print all dives from the loaded dive log to a PDF file. Use either the 'Table print' or 'Two dives per page' template and save the document to /home/ga/Documents/printed_log.pdf.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/print_dive_log_pdf/setup_task.sh",
    "post_task": "/workspace/tasks/print_dive_log_pdf/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/printed_log.pdf",
    "min_file_size_bytes": 1024,
    "required_text_keywords": [
      "Sund Rock",
      "Yellow House",
      "Hoodsport",
      "Washington"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_print_pdf"
    }
  }
}
