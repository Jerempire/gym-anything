{
  "id": "set_dive_rating_visibility@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Subsurface is open with a dive log containing 8 dives from trips to Washington state. For dive #2 in the log, set the dive rating to 4 stars and the visibility rating to 3 stars. Save the changes to the dive log file at /home/ga/Documents/dives.ssrf.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/set_dive_rating_visibility/setup_task.sh",
    "post_task": "/workspace/tasks/set_dive_rating_visibility/export_result.sh"
  },
  "metadata": {
    "target_dive_number": 2,
    "expected_rating": 4,
    "expected_visibility": 3,
    "dive_log_path": "/home/ga/Documents/dives.ssrf",
    "expected_total_dives": 8
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_dive_rating_visibility"
    }
  }
}
