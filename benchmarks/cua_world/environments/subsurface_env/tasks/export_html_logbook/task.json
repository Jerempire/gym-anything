{
  "id": "export_html_logbook@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Export the currently loaded dive log including all dives as an interactive HTML web page to ~/Documents/WebLog/divelog.html.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_html_logbook/setup_task.sh",
    "post_task": "/workspace/tasks/export_html_logbook/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_dir": "/home/ga/Documents/WebLog",
    "expected_file": "divelog.html",
    "expected_file_path": "/home/ga/Documents/WebLog/divelog.html",
    "expected_content_string": "Sund Rock",
    "min_file_size_bytes": 10000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_html_logbook"
    }
  }
}
