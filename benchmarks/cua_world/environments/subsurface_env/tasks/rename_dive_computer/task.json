{
  "id": "rename_dive_computer@1",
  "version": "1.0",
  "env_id": "subsurface_env@0.1",
  "description": "Assign the nickname 'Primary OSTC' to the 'OSTC 3' dive computer in the log's device registry. The log file currently contains dives from this computer, but it lacks a friendly nickname. Save the changes to the dive log file.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rename_dive_computer/setup_task.sh",
    "post_task": "/workspace/tasks/rename_dive_computer/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_nickname": "Primary OSTC",
    "target_model": "OSTC 3"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rename_dive_computer"
    }
  }
}
