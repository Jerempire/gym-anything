{
  "id": "implement_tag_based_organization@1",
  "version": "1.0",
  "env_id": "nx_witness_vms_env@0.1",
  "description": "Apply functional metadata tags to the facility's cameras and create a 'Storm Watch' layout containing only the outdoor-facing cameras.\n\nTarget Cameras and Tags:\n- 'Parking Lot Camera': Outdoor, Vehicle\n- 'Loading Dock Camera': Outdoor, Logistics\n- 'Entrance Camera': Outdoor, Pedestrian\n- 'Server Room Camera': Indoor, Restricted\n- 'Lobby Camera': Indoor, Public\n\nThe 'Storm Watch' layout must contain only the cameras tagged as 'Outdoor'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/implement_tag_based_organization/setup_task.sh",
    "post_task": "/workspace/tasks/implement_tag_based_organization/export_result.sh"
  },
  "metadata": {
    "expected_layout_name": "Storm Watch",
    "tag_schema": {
      "Parking Lot Camera": [
        "Outdoor",
        "Vehicle"
      ],
      "Loading Dock Camera": [
        "Outdoor",
        "Logistics"
      ],
      "Entrance Camera": [
        "Outdoor",
        "Pedestrian"
      ],
      "Server Room Camera": [
        "Indoor",
        "Restricted"
      ],
      "Lobby Camera": [
        "Indoor",
        "Public"
      ]
    },
    "outdoor_cameras": [
      "Parking Lot Camera",
      "Loading Dock Camera",
      "Entrance Camera"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_implement_tag_based_organization"
    }
  }
}
