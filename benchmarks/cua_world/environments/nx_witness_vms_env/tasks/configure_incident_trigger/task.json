{
  "id": "configure_incident_trigger@1",
  "version": "1.0",
  "env_id": "nx_witness_vms_env@0.1",
  "description": "Configure a Soft Trigger for the 'Entrance Camera'. The trigger should be a button named 'Flag Suspect' that, when clicked, creates a bookmark named 'Suspicious Activity' on the 'Entrance Camera' for a fixed duration of 30 seconds.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_incident_trigger/setup_task.sh",
    "post_task": "/workspace/tasks/configure_incident_trigger/export_result.sh"
  },
  "metadata": {
    "target_camera_name": "Entrance Camera",
    "trigger_name": "Flag Suspect",
    "bookmark_title": "Suspicious Activity",
    "expected_duration_sec": 30
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_incident_trigger"
    }
  }
}
