{
  "id": "create_incident_bookmarks@1",
  "version": "1.0",
  "env_id": "nx_witness_vms_env@0.1",
  "description": "A shoplifting incident occurred 30 minutes ago. Document the event by creating three bookmarks on the relevant camera feeds using the Nx Witness REST API. Use the base timestamp (T) from /home/ga/incident_start_time.txt to define the bookmark start times.\n\nRequired Bookmarks:\n- Entrance Camera (at T+0ms): Name 'Suspect Entry', Description 'Individual matching suspect description enters through main entrance wearing dark hoodie', Duration 120000 ms, Tags 'theft', 'suspect', 'entrance'.\n- Lobby Camera (at T+180000ms): Name 'Suspicious Behavior in Lobby', Description 'Suspect observed loitering near high-value display cases and concealing merchandise', Duration 3000",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_incident_bookmarks/setup_task.sh",
    "post_task": "/workspace/tasks/create_incident_bookmarks/export_result.sh"
  },
  "metadata": {
    "expected_bookmarks": [
      {
        "camera_name": "Entrance Camera",
        "name": "Suspect Entry",
        "description_keywords": [
          "enters",
          "hoodie",
          "suspect"
        ],
        "offset_ms": 0,
        "duration_ms": 120000,
        "tags": [
          "theft",
          "suspect",
          "entrance"
        ]
      },
      {
        "camera_name": "Lobby Camera",
        "name": "Suspicious Behavior in Lobby",
        "description_keywords": [
          "loitering",
          "concealing",
          "display"
        ],
        "offset_ms": 180000,
        "duration_ms": 300000,
        "tags": [
          "theft",
          "suspect",
          "loitering"
        ]
      },
      {
        "camera_name": "Parking Lot Camera",
        "name": "Suspect Vehicle Departure",
        "description_keywords": [
          "vehicle",
          "sedan",
          "license"
        ],
        "offset_ms": 600000,
        "duration_ms": 180000,
        "tags": [
          "theft",
          "suspect",
          "vehicle"
        ]
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_incident_bookmarks"
    }
  }
}
