{
  "id": "visual_forensic_bookmarking@1",
  "version": "1.0",
  "env_id": "nx_witness_vms_env@0.1",
  "description": "A 'CRITICAL ALERT' visual warning (red screen with text) appears briefly in the footage of the 'Conveyor Camera' once every minute. Locate this event and create a bookmark named 'Jam Event' that covers the duration of the alert.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/visual_forensic_bookmarking/setup_task.sh",
    "post_task": "/workspace/tasks/visual_forensic_bookmarking/export_result.sh"
  },
  "metadata": {
    "camera_name": "Conveyor Camera",
    "bookmark_name": "Jam Event",
    "video_loop_length_sec": 60,
    "tolerance_sec": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_visual_forensic_bookmarking"
    }
  }
}
