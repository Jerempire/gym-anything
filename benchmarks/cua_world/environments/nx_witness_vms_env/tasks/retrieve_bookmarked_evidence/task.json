{
  "id": "retrieve_bookmarked_evidence@1",
  "version": "1.0",
  "env_id": "nx_witness_vms_env@0.1",
  "description": "Locate the 'Staff Altercation' bookmark in the Nx Witness VMS system. Export the footage from the associated camera, including a 10-second buffer before and after the bookmark's duration, to /home/ga/Documents/evidence_export.mkv.",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/retrieve_bookmarked_evidence/setup_task.sh",
    "post_task": "/workspace/tasks/retrieve_bookmarked_evidence/export_result.sh"
  },
  "metadata": {
    "target_bookmark_name": "Staff Altercation",
    "bookmark_duration_ms": 10000,
    "buffer_seconds": 10,
    "expected_filename": "evidence_export.mkv",
    "expected_path": "/home/ga/Documents/evidence_export.mkv"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_retrieve_bookmarked_evidence"
    }
  }
}
