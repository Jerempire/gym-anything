{
  "id": "investigate_video_access_leak@1",
  "version": "1.0",
  "env_id": "nx_witness_vms_env@0.1",
  "description": "A security breach has occurred. Confidential footage from the 'Secure Lab Camera' was leaked. Identify the internal user who accessed this camera's video feed using the Nx Witness Web Admin interface. Write only the username of the suspect to /home/ga/leak_report.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/investigate_video_access_leak/setup_task.sh",
    "post_task": "/workspace/tasks/investigate_video_access_leak/export_result.sh"
  },
  "metadata": {
    "report_path": "/home/ga/leak_report.txt",
    "ground_truth_path": "/root/ground_truth_suspect.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_investigate_video_access_leak"
    }
  }
}
