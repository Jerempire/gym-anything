{
  "id": "configure_corridor_mode@1",
  "version": "1.0",
  "env_id": "nx_witness_vms_env@0.1",
  "description": "Configure the 'Server Room Camera' and 'Entrance Camera' for Corridor Mode in Nx Witness VMS (https://localhost:7001) using credentials admin / Admin1234!. Rotate 'Server Room Camera' 90 degrees clockwise and 'Entrance Camera' 270 degrees counter-clockwise. Rename both cameras by appending ' [Corridor]' to their original names.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_corridor_mode/setup_task.sh",
    "post_task": "/workspace/tasks/configure_corridor_mode/export_result.sh"
  },
  "metadata": {
    "targets": [
      {
        "original_name": "Server Room Camera",
        "target_rotation": "90",
        "target_suffix": " [Corridor]"
      },
      {
        "original_name": "Entrance Camera",
        "target_rotation": "270",
        "target_suffix": " [Corridor]"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_corridor_mode"
    }
  }
}
