{
  "id": "import_external_evidence@1",
  "version": "1.0",
  "env_id": "nx_witness_vms_env@0.1",
  "description": "Import bystander_clip_01.mp4 and drone_survey_clip.mp4 from /home/ga/Downloads/Evidence/ into the Nx Witness VMS for an investigation. Rename the clips to 'Exhibit A - Bystander' and 'Exhibit B - Drone' respectively. Create and save a layout named 'Case #4492-Investigation' that displays both video files simultaneously.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/import_external_evidence/setup_task.sh",
    "post_task": "/workspace/tasks/import_external_evidence/export_result.sh"
  },
  "metadata": {
    "evidence_dir": "/home/ga/Downloads/Evidence",
    "file_1": "bystander_clip_01.mp4",
    "file_2": "drone_survey_clip.mp4",
    "target_name_1": "Exhibit A - Bystander",
    "target_name_2": "Exhibit B - Drone",
    "layout_name": "Case #4492-Investigation"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_import_external_evidence"
    }
  }
}
