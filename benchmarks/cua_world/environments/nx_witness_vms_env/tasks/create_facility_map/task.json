{
  "id": "create_facility_map@1",
  "version": "1.0",
  "env_id": "nx_witness_vms_env@0.1",
  "description": "Create a facility map layout named 'Warehouse Map' in the Nx Witness Desktop Client (admin/Admin1234!). Use the floor plan at /home/ga/Documents/warehouse_plan.png as the background. Position the 'Entrance Camera' at the bottom center of the map and the 'Server Room Camera' at the top right. Save the layout.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_facility_map/setup_task.sh",
    "post_task": "/workspace/tasks/create_facility_map/export_result.sh"
  },
  "metadata": {
    "layout_name": "Warehouse Map",
    "background_filename": "warehouse_plan.png",
    "cameras": [
      {
        "name": "Entrance Camera",
        "position": "bottom"
      },
      {
        "name": "Server Room Camera",
        "position": "top_right"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_facility_map"
    }
  }
}
