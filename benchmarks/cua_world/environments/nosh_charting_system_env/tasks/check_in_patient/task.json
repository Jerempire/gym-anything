{
  "id": "check_in_patient@1",
  "version": "1.0",
  "env_id": "nosh_env@0.1",
  "description": "A patient, Arthur Dent, has arrived for his appointment today. Log into NOSH ChartingSystem (user: admin, pass: Admin1234!) and check him in by updating his appointment status to 'Arrived' and setting the reason for visit to 'Severe migraine with aura'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/check_in_patient/setup_task.sh",
    "post_task": "/workspace/tasks/check_in_patient/export_result.sh"
  },
  "metadata": {
    "patient_firstname": "Arthur",
    "patient_lastname": "Dent",
    "required_status_excludes": [
      "Pending",
      "No Show",
      "Cancelled"
    ],
    "required_reason_keywords": [
      "migraine",
      "aura"
    ],
    "appointment_time_slot": "10:00:00"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_check_in_patient"
    }
  }
}
