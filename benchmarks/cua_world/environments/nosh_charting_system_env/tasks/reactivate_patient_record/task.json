{
  "id": "reactivate_patient_record@1",
  "version": "1.0",
  "env_id": "nosh_env@0.1",
  "description": "Reactivate the archival patient record for 'Maria Garcia' (DOB: 1980-03-25) by changing her status to 'Active'. The record is currently marked inactive and will not appear in standard searches. Log in using the 'admin' account (password: 'Admin1234!'). Do not create a new patient record.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/reactivate_patient_record/setup_task.sh",
    "post_task": "/workspace/tasks/reactivate_patient_record/export_result.sh"
  },
  "metadata": {
    "target_patient": {
      "firstname": "Maria",
      "lastname": "Garcia",
      "dob": "1980-03-25"
    },
    "credentials": {
      "username": "admin",
      "password": "Admin1234!"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reactivate_patient"
    }
  }
}
