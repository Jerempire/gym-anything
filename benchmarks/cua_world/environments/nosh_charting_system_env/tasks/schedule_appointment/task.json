{
  "id": "schedule_appointment@1",
  "version": "1.0",
  "env_id": "nosh_env@0.1",
  "description": "Schedule an 'Office Visit' appointment in the NOSH ChartingSystem (http://localhost) using the patient, provider, date, and time details specified in /home/ga/Desktop/scheduling_request.txt. System credentials: admin / Admin1234!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/schedule_appointment/setup_task.sh",
    "post_task": "/workspace/tasks/schedule_appointment/export_result.sh"
  },
  "metadata": {
    "admin_user": "admin",
    "admin_pass": "Admin1234!",
    "provider_name": "Dr. James Carter",
    "visit_type": "Office Visit",
    "tolerance_minutes": 15
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_schedule_appointment"
    }
  }
}
