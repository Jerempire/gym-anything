{
  "id": "change_user_role@1",
  "version": "1.0",
  "env_id": "nosh_env@0.1",
  "description": "Log in as the root admin (username: admin, password: Admin1234!) to the Hillside Family Medicine practice and promote the user 'Dr. James Carter' (username: demo_provider) to an Administrator.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/change_user_role/setup_task.sh",
    "post_task": "/workspace/tasks/change_user_role/export_result.sh"
  },
  "metadata": {
    "target_username": "demo_provider",
    "target_group_id": 1,
    "initial_group_id": 2,
    "admin_group_name": "admin",
    "provider_group_name": "provider"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_change_user_role"
    }
  }
}
