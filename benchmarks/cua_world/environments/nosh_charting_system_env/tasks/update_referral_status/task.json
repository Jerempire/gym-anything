{
  "id": "update_referral_status@1",
  "version": "1.0",
  "env_id": "nosh_env@0.1",
  "description": "Log in to NOSH ChartingSystem (admin/Admin1234!) and update the status of the pending 'Cardiology Consult' referral order for patient Alice Vance (DOB: 05/15/1980) to 'Completed' or 'Received' to document that the consult has occurred.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_referral_status/setup_task.sh",
    "post_task": "/workspace/tasks/update_referral_status/export_result.sh"
  },
  "metadata": {
    "patient_fname": "Alice",
    "patient_lname": "Vance",
    "patient_dob": "1980-05-15",
    "order_description": "Cardiology Consult",
    "initial_status": "pending",
    "acceptable_final_statuses": [
      "complete",
      "completed",
      "received",
      "closed",
      "done"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_referral_status"
    }
  }
}
