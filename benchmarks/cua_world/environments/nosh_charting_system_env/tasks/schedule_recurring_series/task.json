{
  "id": "schedule_recurring_series@1",
  "version": "1.0",
  "env_id": "nosh_env@0.1",
  "description": "Schedule a series of recurring 'Smoking Cessation Counseling' appointments for patient Eulalia Hammes (DOB: 1974-04-14). Log in as admin (password: Admin1234!). The series must start on Monday, April 6, 2026, at 09:00 AM and repeat weekly for a total of 4 visits.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/schedule_recurring_series/setup_task.sh",
    "post_task": "/workspace/tasks/schedule_recurring_series/export_result.sh"
  },
  "metadata": {
    "patient_name": "Eulalia Hammes",
    "patient_dob": "1974-04-14",
    "start_date": "2026-04-06",
    "start_time": "09:00:00",
    "count": 4,
    "interval_days": 7,
    "reason_keywords": [
      "smoking",
      "cessation",
      "counseling"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_schedule_series"
    }
  }
}
