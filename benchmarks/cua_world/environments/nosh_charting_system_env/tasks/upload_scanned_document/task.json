{
  "id": "upload_scanned_document@1",
  "version": "1.0",
  "env_id": "nosh_env@0.1",
  "description": "You are a Medical Assistant at Hillside Family Medicine. Upload the cardiology consultation report for patient Robert Baker (DOB: 1958-05-14), located at /home/ga/Documents/Consult_Report.pdf, to his chart in the NOSH ChartingSystem (admin / Admin1234!). Label the document as 'Cardiology Consult' in the patient's Documents section.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/upload_scanned_document/setup_task.sh",
    "post_task": "/workspace/tasks/upload_scanned_document/export_result.sh"
  },
  "metadata": {
    "target_patient_fname": "Robert",
    "target_patient_lname": "Baker",
    "target_dob": "1958-05-14",
    "target_file_name": "Consult_Report.pdf",
    "target_file_path": "/home/ga/Documents/Consult_Report.pdf",
    "expected_description_keywords": [
      "cardiology",
      "consult"
    ],
    "credentials": {
      "username": "admin",
      "password": "Admin1234!"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_upload_scanned_document"
    }
  }
}
