{
  "id": "schedule_patient_reminder@1",
  "version": "1.0",
  "env_id": "nosh_env@0.1",
  "description": "Log into NOSH ChartingSystem (Username: admin, Password: Admin1234!) and schedule a clinical reminder for patient Lucinda Haag (PID 3). The reminder should be for a 'Mammogram' with a due date of 'October 1, 2025'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/schedule_patient_reminder/setup_task.sh",
    "post_task": "/workspace/tasks/schedule_patient_reminder/export_result.sh"
  },
  "metadata": {
    "target_pid": 3,
    "target_patient_name": "Lucinda Haag",
    "reminder_content": "Mammogram",
    "target_date": "2025-10-01"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_schedule_patient_reminder"
    }
  }
}
