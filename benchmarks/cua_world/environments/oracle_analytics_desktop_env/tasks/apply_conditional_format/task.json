{
  "id": "apply_conditional_format@1",
  "version": "1.0",
  "env_id": "oracle_analytics_desktop_env@0.1",
  "description": "Create a Table visualization titled 'Product Profitability by Sub-Category' in Oracle Analytics Desktop using the 'Sample Order Lines' dataset. The table must display 'Product Sub Category', 'Profit', and 'Sales'. Apply conditional formatting to the 'Profit' column: Red for values < 0, Yellow/Amber for values ≥ 0 and < 5000, and Green for values ≥ 5000. Save the workbook as 'Supply_Chain_Profit_Analysis'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\apply_conditional_format\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\apply_conditional_format\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "Supply_Chain_Profit_Analysis.dva",
    "expected_title": "Product Profitability by Sub-Category",
    "columns": [
      "Product Sub Category",
      "Profit",
      "Sales"
    ],
    "formatting_rules": [
      {
        "condition": "< 0",
        "color": "Red"
      },
      {
        "condition": ">= 0 and < 5000",
        "color": "Yellow"
      },
      {
        "condition": ">= 5000",
        "color": "Green"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_apply_conditional_format"
    }
  }
}
