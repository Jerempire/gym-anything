{
  "id": "create_ytd_pacing_chart@1",
  "version": "1.0",
  "env_id": "oracle_analytics_desktop_env@0.1",
  "description": "Create a Year-over-Year Pacing Chart in Oracle Analytics Desktop using the 'Sample Order Lines' dataset. The visualization must be a line chart showing the cumulative running total of 'Sales' by 'Month', with a separate line for each 'Year' to compare Year-to-Date performance. Save the workbook as 'YTD_Pacing_Analysis' in the default My Folders location.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_ytd_pacing_chart\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_ytd_pacing_chart\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "YTD_Pacing_Analysis.dva",
    "expected_location": "C:\\Users\\Docker\\Documents\\Oracle Analytics Desktop\\",
    "required_columns": [
      "Month",
      "Year",
      "Sales"
    ],
    "required_keywords": [
      "RSUM",
      "MSUM",
      "Running Sum",
      "Cumulative"
    ],
    "min_file_size_bytes": 5000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ytd_pacing_chart"
    }
  }
}
