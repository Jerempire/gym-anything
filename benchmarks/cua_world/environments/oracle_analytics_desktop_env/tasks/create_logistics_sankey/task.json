{
  "id": "create_logistics_sankey@1",
  "version": "1.0",
  "env_id": "oracle_analytics_desktop_env@0.1",
  "description": "Create a Sankey Diagram in Oracle Analytics Desktop using the 'Sample Order Lines' dataset to visualize the flow of orders. The visualization must show the flow from 'Order Priority' to 'Ship Mode' to 'Customer Segment', sized by 'Quantity'. Title the visualization 'Order Priority Flow Analysis' and save the workbook as 'Logistics_Flow.dva' in the Documents folder.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_logistics_sankey\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_logistics_sankey\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "Logistics_Flow.dva",
    "expected_path": "C:\\Users\\Docker\\Documents\\Logistics_Flow.dva",
    "chart_type": "sankey",
    "required_dimensions": [
      "Order Priority",
      "Ship Mode",
      "Customer Segment"
    ],
    "required_measure": "Quantity",
    "title_keyword": "Flow Analysis"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_logistics_sankey"
    }
  }
}
