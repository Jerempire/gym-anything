{
  "id": "analyze_unprofitable_orders@1",
  "version": "1.0",
  "env_id": "oracle_analytics_desktop_env@0.1",
  "description": "Calculate and visualize the 'Loss Rate' (percentage of unprofitable orders where Profit < 0) by Region using the 'Sample Order Lines' dataset in Oracle Analytics Desktop. Create a bar chart showing the 'Loss Rate' formatted as a percentage for each 'Region'. Save the workbook as 'Regional_Loss_Analysis' and export it as a DVA package to C:\\Users\\Docker\\Documents\\Regional_Loss_Analysis.dva.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\analyze_unprofitable_orders\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\analyze_unprofitable_orders\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "Regional_Loss_Analysis.dva",
    "expected_path": "C:\\Users\\Docker\\Documents\\Regional_Loss_Analysis.dva",
    "calc_keywords": [
      "CASE",
      "Profit",
      "<",
      "0",
      "FILTER"
    ],
    "viz_type": "bar",
    "min_loss_rate": 0.1,
    "max_loss_rate": 0.4
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_analyze_unprofitable_orders"
    }
  }
}
