{
  "id": "create_market_chord_diagram@1",
  "version": "1.0",
  "env_id": "oracle_analytics_desktop_env@0.1",
  "description": "Create a market segmentation analysis in Oracle Analytics Desktop using the 'Sample Order Lines' dataset. Visualize the flow of Sales between 'Customer Segment' (Source) and 'Product Category' (Target) using a Chord Diagram. Set the visualization title to 'Segment-Category Sales Flow' and save the workbook as 'Market_Chord_Analysis'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_market_chord_diagram\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_market_chord_diagram\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "Market_Chord_Analysis.dva",
    "expected_viz_type": "chord",
    "required_columns": [
      "Customer Segment",
      "Product Category",
      "Sales"
    ],
    "expected_title": "Segment-Category Sales Flow",
    "save_directory": "C:\\Users\\Docker\\Documents"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_market_chord_diagram"
    }
  }
}
