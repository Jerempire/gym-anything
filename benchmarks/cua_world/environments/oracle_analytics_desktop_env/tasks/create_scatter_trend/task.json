{
  "id": "create_scatter_trend@1",
  "version": "1.0",
  "env_id": "oracle_analytics_desktop_env@0.1",
  "description": "Analyze shipping costs in Oracle Analytics Desktop using the 'Sample Order Lines' dataset. Create a scatter plot on a new canvas named 'Shipping Analysis' to visualize the relationship between 'Revenue' (X-Axis) and 'Shipping Cost' (Y-Axis), colored by 'Product Category'. Include a linear trend line to show the correlation. Save the workbook as 'shipping_analysis'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_scatter_trend\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_scatter_trend\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "shipping_analysis.dva",
    "expected_canvas_name": "Shipping Analysis",
    "x_axis": "Revenue",
    "y_axis": "Shipping Cost",
    "color_category": "Product Category",
    "chart_type": "scatter",
    "feature_requirement": "trend line"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_scatter_trend"
    }
  }
}
