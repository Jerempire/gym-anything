{
  "id": "create_language_narrative@1",
  "version": "1.0",
  "env_id": "oracle_analytics_desktop_env@0.1",
  "description": "Create a workbook in Oracle Analytics Desktop using the 'Sample Order Lines' dataset. Generate a 'Language Narrative' visualization that summarizes the relationship between 'Sales' and 'Profit' broken down by 'Product Category'. Ensure the 'Level of Detail' is set to the maximum (7) for a verbose summary. Save the workbook as 'Category_Narrative'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_language_narrative\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_language_narrative\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "Category_Narrative.dva",
    "expected_viz_type": "narrative",
    "required_measures": [
      "Sales",
      "Profit"
    ],
    "required_dimension": "Product Category",
    "output_path": "C:\\Users\\Docker\\Documents\\Category_Narrative.dva"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_language_narrative"
    }
  }
}
