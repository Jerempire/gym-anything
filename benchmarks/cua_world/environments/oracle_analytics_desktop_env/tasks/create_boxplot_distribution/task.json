{
  "id": "create_boxplot_distribution@1",
  "version": "1.0",
  "env_id": "oracle_analytics_desktop_env@0.1",
  "description": "Using Oracle Analytics Desktop and the 'Sample Order Lines' dataset, create a Box Plot visualization titled 'Profit Distribution by Sub-Category' to analyze profit distribution. The chart should display 'Product Sub Category' on the Category (X-axis) and 'Profit' on the Values (Y-axis). Save the workbook as 'ProfitBoxPlot.dva' to C:\\Users\\Docker\\Documents\\.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_boxplot_distribution\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_boxplot_distribution\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "ProfitBoxPlot.dva",
    "expected_path": "C:\\Users\\Docker\\Documents\\ProfitBoxPlot.dva",
    "expected_chart_type": "boxPlot",
    "required_columns": [
      "Profit",
      "Product Sub Category"
    ],
    "expected_title": "Profit Distribution by Sub-Category"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_boxplot"
    }
  }
}
