{
  "id": "create_area_trend@1",
  "version": "1.0",
  "env_id": "oracle_analytics_desktop_env@0.1",
  "description": "Using the 'Sample Order Lines' dataset, create a workbook named 'Quarterly_Revenue_Analysis' containing a Stacked Area visualization titled 'Quarterly Revenue by Product Category'. Configure the chart with 'Order Date' (at the Quarter time grain) on the X-Axis, 'Revenue' on the Y-Axis, and 'Product Category' for Color. Rename the canvas tab to 'Revenue Trends'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_area_trend\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_area_trend\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "Quarterly_Revenue_Analysis.dva",
    "expected_location": "C:\\Users\\Docker\\Documents\\Oracle Analytics Desktop",
    "required_chart_type": "stacked_area",
    "x_axis_grain": "quarter",
    "color_category": "Product Category",
    "canvas_name": "Revenue Trends",
    "min_file_size_kb": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_area_trend"
    }
  }
}
