{
  "id": "configure_map_tooltips@1",
  "version": "1.0",
  "env_id": "oracle_analytics_desktop_env@0.1",
  "description": "Create a workbook named 'State_Insights' in Oracle Analytics Desktop using the 'Sample Order Lines' dataset. Generate a Map visualization of 'Sales' by 'State' that includes 'Profit' and the 'Average' of 'Discount' in the tooltips. Save the workbook to My Folders or Documents.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_map_tooltips\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_map_tooltips\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "State_Insights.dva",
    "required_viz_type": "map",
    "required_grammar_fields": [
      "State",
      "Sales",
      "Profit",
      "Discount"
    ],
    "required_aggregation": "avg",
    "target_measure": "Discount"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_map_tooltips"
    }
  }
}
