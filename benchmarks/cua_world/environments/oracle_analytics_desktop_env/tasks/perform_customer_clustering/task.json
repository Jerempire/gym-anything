{
  "id": "perform_customer_clustering@1",
  "version": "1.0",
  "env_id": "oracle_analytics_desktop_env@0.1",
  "description": "Oracle Analytics Desktop is open with the 'Sample Order Lines' dataset loaded. Perform a customer segmentation analysis by creating a scatter plot of 'Sales' versus 'Profit' for each 'Customer Name'. Apply clustering to the visualization to identify exactly 5 customer segments. Save the resulting workbook as 'Customer_Segmentation.dva' in 'C:\\Users\\Docker\\Documents\\'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\perform_customer_clustering\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\perform_customer_clustering\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "Customer_Segmentation.dva",
    "expected_path": "C:\\Users\\Docker\\Documents\\Customer_Segmentation.dva",
    "required_analytics": [
      "cluster",
      "clusters"
    ],
    "required_columns": [
      "Sales",
      "Profit",
      "Customer Name"
    ],
    "cluster_count": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_perform_customer_clustering"
    }
  }
}
