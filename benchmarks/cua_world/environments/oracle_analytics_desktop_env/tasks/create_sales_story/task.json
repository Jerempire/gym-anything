{
  "id": "create_sales_story@1",
  "version": "1.0",
  "env_id": "oracle_analytics_desktop_env@0.1",
  "description": "Create a data story in Oracle Analytics Desktop using the 'Sample Order Lines' dataset to present sales insights. The story must include a bar chart showing 'Sales' by 'Product Category' and a text annotation with the exact text: \"Technology generates the highest revenue\". Save the workbook as 'Sales_Story_Presentation'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_sales_story\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_sales_story\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "Sales_Story_Presentation.dva",
    "annotation_text": "Technology generates the highest revenue",
    "chart_type": "bar",
    "dimensions": [
      "Product Category"
    ],
    "measures": [
      "Sales"
    ],
    "output_dir": "C:\\Users\\Docker\\Documents",
    "dataset_name": "Sample Order Lines"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_sales_story"
    }
  }
}
