{
  "id": "create_parallel_coordinates_profile@1",
  "version": "1.0",
  "env_id": "oracle_analytics_desktop_env@0.1",
  "description": "Create a Parallel Coordinates visualization in Oracle Analytics Desktop to profile shipping modes using the 'Sample Order Lines' dataset. Configure the visualization with 'Ship Mode' as the Color/Category and 'Sales', 'Quantity', 'Discount', and 'Profit' (in that order) as the Y-Axis values. Title the visualization 'Shipping Mode Profile Analysis' and save the workbook as 'Shipping_Profile_Analysis.dva' in the Documents folder.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_parallel_coordinates_profile\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_parallel_coordinates_profile\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "Shipping_Profile_Analysis.dva",
    "expected_title": "Shipping Mode Profile Analysis",
    "required_columns": [
      "Ship Mode",
      "Sales",
      "Quantity",
      "Discount",
      "Profit"
    ],
    "chart_type_keywords": [
      "parallel",
      "coord"
    ],
    "output_path": "C:\\Users\\Docker\\Documents\\Shipping_Profile_Analysis.dva"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_parallel_coordinates_profile"
    }
  }
}
