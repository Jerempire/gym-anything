{
  "id": "analyze_yoy_growth@1",
  "version": "1.0",
  "env_id": "oracle_analytics_desktop_env@0.1",
  "description": "Analyze the Year-Over-Year (YoY) revenue growth using the 'Sample Order Lines' dataset. Create a Combo Chart (Dual Axis) visualization that displays 'Order Date' (Year) on the X-axis, 'Revenue' as bars, and a calculated 'YoY Revenue Growth %' metric (formatted as a percentage) as a line. Save the workbook as 'Annual_Growth_Analysis'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\analyze_yoy_growth\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\analyze_yoy_growth\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "Annual_Growth_Analysis.dva",
    "expected_path": "C:\\Users\\Docker\\Documents\\Annual_Growth_Analysis.dva",
    "required_terms": [
      "Revenue",
      "Growth",
      "Year"
    ],
    "min_file_size_kb": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_analyze_yoy_growth"
    }
  }
}
