{
  "id": "compose_profiles_multi_team@1",
  "version": "1.0",
  "env_id": "docker_desktop_env@0.1",
  "description": "Configure Docker Compose profiles for a multi-service e-commerce platform located at /home/ga/ecommerce-platform/docker-compose.yml. Assign the following profiles to the services while ensuring postgres and redis remain as base services with no profile:\n- 'frontend': nginx, storefront\n- 'backend': api, worker\n- 'debug': test-runner, prometheus\n- 'full': nginx, storefront, api, worker, test-runner, prometheus\n\nDo not modify existing port mappings, image names, or depends_on relations.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/compose_profiles_multi_team/setup_task.sh",
    "post_task": "/workspace/tasks/compose_profiles_multi_team/export_result.sh"
  },
  "metadata": {
    "project_dir": "/home/ga/ecommerce-platform",
    "compose_file": "docker-compose.yml",
    "profiles": {
      "frontend": [
        "nginx",
        "storefront",
        "postgres",
        "redis"
      ],
      "backend": [
        "api",
        "worker",
        "postgres",
        "redis"
      ],
      "debug": [
        "test-runner",
        "prometheus",
        "postgres",
        "redis"
      ],
      "full": [
        "nginx",
        "storefront",
        "api",
        "worker",
        "test-runner",
        "prometheus",
        "postgres",
        "redis"
      ]
    },
    "base_services": [
      "postgres",
      "redis"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_compose_profiles"
    }
  }
}
