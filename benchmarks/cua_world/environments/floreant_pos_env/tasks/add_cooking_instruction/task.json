{
  "id": "add_cooking_instruction@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "A restaurant manager needs to standardize kitchen communication. Access the Floreant POS Back Office using PIN '1111' and add two new cooking instructions: 'No Onions' and 'Extra Crispy'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_cooking_instruction/setup_task.sh",
    "post_task": "/workspace/tasks/add_cooking_instruction/export_result.sh"
  },
  "metadata": {
    "target_strings": [
      "No Onions",
      "Extra Crispy"
    ],
    "db_path": "/opt/floreantpos/database/derby-server",
    "pin": "1111"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_cooking_instruction"
    }
  }
}
