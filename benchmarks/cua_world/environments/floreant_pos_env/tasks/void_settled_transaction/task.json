{
  "id": "void_settled_transaction@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "Perform a complete order lifecycle correction by creating a new DINE IN order with at least one item, settling the payment with CASH, and then voiding the settled ticket. Use Manager PIN '1111' for the void operation.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/void_settled_transaction/setup_task.sh",
    "post_task": "/workspace/tasks/void_settled_transaction/export_result.sh"
  },
  "metadata": {
    "expected_void_state": true,
    "min_items": 1,
    "require_payment": true,
    "manager_pin": "1111"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_void_settled_transaction"
    }
  }
}
