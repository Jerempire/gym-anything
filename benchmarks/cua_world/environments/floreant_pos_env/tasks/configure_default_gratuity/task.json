{
  "id": "configure_default_gratuity@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "Configure the Floreant POS system to use a default gratuity rate of 18% using the administrator PIN 1111. Ensure you are modifying the 'Default Gratuity' setting and not the 'Service Charge'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_default_gratuity/setup_task.sh",
    "post_task": "/workspace/tasks/configure_default_gratuity/export_result.sh"
  },
  "metadata": {
    "expected_gratuity": 18.0,
    "tolerance": 0.1,
    "db_table": "RESTAURANT",
    "db_column": "DEFAULT_GRATUITY"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_default_gratuity"
    }
  }
}
