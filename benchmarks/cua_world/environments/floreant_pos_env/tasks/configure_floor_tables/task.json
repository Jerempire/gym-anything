{
  "id": "configure_floor_tables@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "Navigate to the Floreant POS Back Office (PIN: 1111) and configure a new Shop Floor named 'Patio' containing four tables: Table 20 (Capacity: 2), Table 21 (Capacity: 4), Table 22 (Capacity: 6), and Table 23 (Capacity: 8).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_floor_tables/setup_task.sh",
    "post_task": "/workspace/tasks/configure_floor_tables/export_result.sh"
  },
  "metadata": {
    "expected_floor_name": "Patio",
    "expected_tables": [
      {
        "number": 20,
        "capacity": 2
      },
      {
        "number": 21,
        "capacity": 4
      },
      {
        "number": 22,
        "capacity": 6
      },
      {
        "number": 23,
        "capacity": 8
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_floor_tables"
    }
  }
}
