{
  "id": "perform_cash_payout@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "Record a petty cash payout of $12.50 for 'Emergency Limes' to cover emergency supplies for the bar. Use manager PIN 1111 if prompted to authorize the transaction.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/perform_cash_payout/setup_task.sh",
    "post_task": "/workspace/tasks/perform_cash_payout/export_result.sh"
  },
  "metadata": {
    "expected_amount": 12.5,
    "expected_reason": "Emergency Limes",
    "manager_pin": "1111",
    "transaction_type": "PAY_OUT"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_perform_cash_payout"
    }
  }
}
