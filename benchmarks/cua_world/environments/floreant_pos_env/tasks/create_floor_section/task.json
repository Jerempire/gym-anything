{
  "id": "create_floor_section@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "Create a new floor plan section named 'Patio' in Floreant POS (Back Office PIN: 1111). Add three tables to this section: Table 201, Table 202, and Table 203, each with a capacity of 4 seats.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_floor_section/setup_task.sh",
    "post_task": "/workspace/tasks/create_floor_section/export_result.sh"
  },
  "metadata": {
    "expected_floor_name": "Patio",
    "expected_tables": [
      {
        "name": "201",
        "capacity": 4
      },
      {
        "name": "202",
        "capacity": 4
      },
      {
        "name": "203",
        "capacity": 4
      }
    ],
    "database_path": "/opt/floreantpos/database/derby-server/posdb"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_floor_section"
    }
  }
}
