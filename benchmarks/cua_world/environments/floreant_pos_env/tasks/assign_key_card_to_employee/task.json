{
  "id": "assign_key_card_to_employee@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "A restaurant is upgrading to swipe-card logins. Assign the magnetic key card number '9876543210' to the employee 'John Doe' in the Back Office (PIN: 1111).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/assign_key_card_to_employee/setup_task.sh",
    "post_task": "/workspace/tasks/assign_key_card_to_employee/export_result.sh"
  },
  "metadata": {
    "target_user": "John Doe",
    "target_key": "9876543210",
    "db_path": "/opt/floreantpos/database/derby-server/posdb"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_assign_key_card_to_employee"
    }
  }
}
