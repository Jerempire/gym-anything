{
  "id": "configure_printer_routing@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "Create a virtual printer named 'Bar Printer' and configure the 'Beverages' menu category to route its tickets to this printer. Back Office PIN: 1111.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_printer_routing/setup_task.sh",
    "post_task": "/workspace/tasks/configure_printer_routing/export_result.sh"
  },
  "metadata": {
    "printer_name": "Bar Printer",
    "category_name": "Beverages",
    "pin": "1111"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_printer_routing"
    }
  }
}
