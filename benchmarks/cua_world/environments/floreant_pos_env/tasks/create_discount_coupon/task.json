{
  "id": "create_discount_coupon@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "Create a new percentage-based discount coupon named 'Weekend Special' with a 20% discount value in the Floreant POS Back Office (PIN: 1111). Ensure the coupon is saved and appears in the discount list.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_discount_coupon/setup_task.sh",
    "post_task": "/workspace/tasks/create_discount_coupon/export_result.sh"
  },
  "metadata": {
    "expected_name": "Weekend Special",
    "expected_value": 20.0,
    "expected_type_indicators": [
      "0",
      "1",
      "PERCENT"
    ],
    "manager_pin": "1111"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_discount_coupon"
    }
  }
}
