{
  "id": "systematic_price_revision@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "Your restaurant's quarterly food cost analysis requires price updates and the introduction of a new premium tier. Update the prices for 'HAMMER COFFEE' to $3.75, 'SMK HOUS B FAST' to $10.50, and 'OLD TIMER B FAST' to $9.75. Create a new menu category named 'PREMIUM SELECTIONS' and add three new items to it: 'WAGYU BEEF BURGER' at $24.95, 'TRUFFLE FRIES' at $12.95, and 'ARTISAN CHEESE PLATE' at $18.50. Back Office PIN is 1111.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/systematic_price_revision/setup_task.sh",
    "post_task": "/workspace/tasks/systematic_price_revision/export_result.sh"
  },
  "metadata": {
    "price_updates": [
      {
        "name": "HAMMER COFFEE",
        "old_price": 2.0,
        "new_price": 3.75
      },
      {
        "name": "SMK HOUS B FAST",
        "new_price": 10.5
      },
      {
        "name": "OLD TIMER B FAST",
        "new_price": 9.75
      }
    ],
    "new_category": "PREMIUM SELECTIONS",
    "new_items": [
      {
        "name": "WAGYU BEEF BURGER",
        "price": 24.95
      },
      {
        "name": "TRUFFLE FRIES",
        "price": 12.95
      },
      {
        "name": "ARTISAN CHEESE PLATE",
        "price": 18.5
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_systematic_price_revision"
    }
  }
}
