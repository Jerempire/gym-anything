{
  "id": "disable_home_delivery@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "Discontinue the 'HOME DELIVERY' service in Floreant POS (Administrator PIN: 1111). Ensure the 'HOME DELIVERY' order type is disabled so it no longer appears on the main terminal screen, while 'DINE IN' and 'TAKE OUT' remain available.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/disable_home_delivery/setup_task.sh",
    "post_task": "/workspace/tasks/disable_home_delivery/export_result.sh"
  },
  "metadata": {
    "target_order_type": "HOME DELIVERY",
    "required_visible_types": [
      "DINE IN",
      "TAKE OUT"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_disable_home_delivery"
    }
  }
}
