{
  "id": "configure_shift@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "A restaurant manager needs to define a new shift for the upcoming breakfast service. In the Back Office (PIN: 1111), create a new shift named 'Early Bird' with a start time of 05:00 AM and an end time of 10:00 AM.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_shift/setup_task.sh",
    "post_task": "/workspace/tasks/configure_shift/export_result.sh"
  },
  "metadata": {
    "target_shift_name": "Early Bird",
    "target_start_time": "05:00",
    "target_end_time": "10:00",
    "db_path": "jdbc:derby:/opt/floreantpos/database/derby-server/posdb"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_shift"
    }
  }
}
