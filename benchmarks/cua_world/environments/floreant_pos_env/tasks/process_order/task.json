{
  "id": "process_order@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "Using the Floreant POS terminal, place a food order for Table 1 consisting of two menu items.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/process_order/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_process_order"
    }
  }
}
