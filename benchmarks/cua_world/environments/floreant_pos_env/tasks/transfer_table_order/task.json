{
  "id": "transfer_table_order@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "Perform a table transfer in Floreant POS. Start a DINE IN order for Table 3 containing at least two different items. Transfer the open ticket from Table 3 to Table 7 and ensure the order is saved and visible on the new table.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/transfer_table_order/setup_task.sh",
    "post_task": "/workspace/tasks/transfer_table_order/export_result.sh"
  },
  "metadata": {
    "initial_table": 3,
    "target_table": 7,
    "min_item_count": 2,
    "db_path": "/opt/floreantpos/database/derby-server/posdb"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_transfer_table_order"
    }
  }
}
