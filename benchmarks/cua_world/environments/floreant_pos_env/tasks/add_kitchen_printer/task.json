{
  "id": "add_kitchen_printer@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "Configure a new kitchen printer named 'Kitchen-Expo-1' in the Floreant POS system (PIN: 1111). The printer must be designated for kitchen output and configured as a Virtual Printer.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_kitchen_printer/setup_task.sh",
    "post_task": "/workspace/tasks/add_kitchen_printer/export_result.sh"
  },
  "metadata": {
    "expected_printer_name": "Kitchen-Expo-1",
    "expected_printer_type": "Virtual Printer",
    "db_connection": "jdbc:derby:/opt/floreantpos/database/derby-server/posdb"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_kitchen_printer"
    }
  }
}
