{
  "id": "rename_terminal@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "Rename the default POS terminal to 'Front Counter' using the administrative settings (PIN: 1111).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rename_terminal/setup_task.sh",
    "post_task": "/workspace/tasks/rename_terminal/export_result.sh"
  },
  "metadata": {
    "target_terminal_name": "Front Counter",
    "default_pin": "1111",
    "db_path_hint": "/opt/floreantpos/database/derby-server"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rename_terminal"
    }
  }
}
