{
  "id": "create_custom_order_type@1",
  "version": "1.0",
  "env_id": "floreant_pos_env@0.1",
  "description": "Create a new Order Type in the Floreant POS Back Office named 'Curbside' (case-sensitive) to handle prepaid contactless pickups. Configure the order type with Show Table Selection and Show Guest Selection disabled, and Require Customer Data and Prepaid enabled. The Back Office PIN is 1111.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_custom_order_type/setup_task.sh",
    "post_task": "/workspace/tasks/create_custom_order_type/export_result.sh"
  },
  "metadata": {
    "expected_name": "Curbside",
    "expected_config": {
      "SHOW_TABLE_SELECTION": 0,
      "SHOW_GUEST_SELECTION": 0,
      "REQUIRED_CUSTOMER_DATA": 1,
      "PREPAID": 1
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_custom_order_type"
    }
  }
