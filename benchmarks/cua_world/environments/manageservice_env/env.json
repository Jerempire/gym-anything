{
  "id": "manageservice_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "ManageEngine ServiceDesk Plus ITSM environment for helpdesk ticket management, IT asset management, problem/change management, and service catalog tasks.",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080]
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "vnc": {
    "enable": false,
    "host_port": 5961,
    "password": "password"
  },
  "security": {
    "user": "root",
    "privileged": true,
    "use_systemd": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/manageservice_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/manageservice_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/manageservice_env/tasks", "target": "/workspace/tasks", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_servicedesk.sh",
    "post_start": "/workspace/scripts/setup_servicedesk.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"]
      }
    }
  ],
  "tags": ["linux", "itsm", "helpdesk", "service-management", "manageengine", "web-application", "it-asset-management"]
}
