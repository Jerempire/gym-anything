{
  "id": "create_category_subcategory@1",
  "version": "1.0",
  "env_id": "manageservice_env@0.1",
  "description": "Log in to ManageEngine ServiceDesk Plus as 'administrator' (password: 'administrator'). Configure the incident categorization hierarchy by creating a top-level category named 'Cloud Services' with three subcategories: 'Provisioning', 'Performance Issues', and 'Access Management'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_category_subcategory/setup_task.sh",
    "post_task": "/workspace/tasks/create_category_subcategory/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_category": "Cloud Services",
    "target_subcategories": [
      "Provisioning",
      "Performance Issues",
      "Access Management"
    ],
    "category_table": "categorydefinition",
    "subcategory_table": "subcategorydefinition"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_category_subcategory"
    }
  }
}
