{
  "id": "configure_request_archiving@1",
  "version": "1.0",
  "env_id": "manageservice_env@0.1",
  "description": "Configure the Data Archiving policy in ManageEngine ServiceDesk Plus to archive 'Requests' that have been closed for more than 365 days.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_request_archiving/setup_task.sh",
    "post_task": "/workspace/tasks/configure_request_archiving/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_days": 365,
    "expected_module": "Request",
    "expected_status": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_request_archiving"
    }
  }
}
