{
  "id": "configure_attachment_security@1",
  "version": "1.0",
  "env_id": "manageservice_env@0.1",
  "description": "Configure ManageEngine ServiceDesk Plus to improve security by blocking dangerous file attachments. Explicitly block the following file extensions: 'exe', 'bat', 'cmd', 'vbs', and 'sh'. Log in with username: administrator, password: administrator.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_attachment_security/setup_task.sh",
    "post_task": "/workspace/tasks/configure_attachment_security/export_result.sh",
    "pre_task_timeout": 3600
  },
  "metadata": {
    "forbidden_extensions": [
      "exe",
      "bat",
      "cmd",
      "vbs",
      "sh"
    ],
    "target_param_pattern": "RestrictedExtensions",
    "admin_user": "administrator",
    "admin_pass": "administrator"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_attachment_security"
    }
  }
}
