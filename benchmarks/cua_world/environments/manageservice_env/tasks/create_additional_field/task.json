{
  "id": "create_additional_field@1",
  "version": "1.0",
  "env_id": "manageservice_env@0.1",
  "description": "Add a new additional field to the Incident Request form in ServiceDesk Plus with the following configuration:\n- Label: Affected Network Segment\n- Type: Pick List (Single Select)\n- Mandatory: No\n- Description: Network VLAN segment affected by this incident\n- Pick List Values: VLAN-10-Corporate, VLAN-20-Guest, VLAN-30-VoIP, VLAN-40-Servers, and VLAN-50-DMZ",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_additional_field/setup_task.sh",
    "post_task": "/workspace/tasks/create_additional_field/export_result.sh",
    "pre_task_timeout": 3600
  },
  "metadata": {
    "field_label": "Affected Network Segment",
    "field_type_indicators": [
      "picklist",
      "dropdown",
      "select"
    ],
    "is_mandatory": false,
    "values": [
      "VLAN-10-Corporate",
      "VLAN-20-Guest",
      "VLAN-30-VoIP",
      "VLAN-40-Servers",
      "VLAN-50-DMZ"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_additional_field"
    }
  }
}
