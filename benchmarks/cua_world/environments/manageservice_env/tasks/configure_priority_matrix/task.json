{
  "id": "configure_priority_matrix@1",
  "version": "1.0",
  "env_id": "manageservice_env@0.1",
  "description": "Reconfigure the ServiceDesk Plus Priority Matrix to align with the new ITSM policy using the administrator credentials (administrator/administrator). Configure the matrix with the following mappings:\n\n- High Impact + High Urgency → High Priority\n- High Impact + Medium Urgency → High Priority\n- High Impact + Low Urgency → Medium Priority\n- Medium Impact + High Urgency → High Priority\n- Medium Impact + Medium Urgency → Medium Priority\n- Medium Impact + Low Urgency → Low Priority\n- Low Impact + High Urgency → Medium Priority\n- Low Impact + Medium Urgency → Low Priority\n- Low Impact + Low Urgency → Low Priority",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_priority_matrix/setup_task.sh",
    "post_task": "/workspace/tasks/configure_priority_matrix/export_result.sh",
    "pre_task_timeout": 3600
  },
  "metadata": {
    "expected_mapping": [
      {
        "impact": "High",
        "urgency": "High",
        "priority": "High"
      },
      {
        "impact": "High",
        "urgency": "Medium",
        "priority": "High"
      },
      {
        "impact": "High",
        "urgency": "Low",
        "priority": "Medium"
      },
      {
        "impact": "Medium",
        "urgency": "High",
        "priority": "High"
      },
      {
        "impact": "Medium",
        "urgency": "Medium",
        "priority": "Medium"
      },
      {
        "impact": "Medium",
        "urgency": "Low",
        "priority": "Low"
      },
      {
        "impact": "Low",
        "urgency": "High",
        "priority": "Medium"
      },
      {
        "impact": "Low",
        "urgency": "Medium",
        "priority": "Low"
      },
      {
        "impact": "Low",
        "urgency": "Low",
        "priority": "Low"
      }
    ],
    "credentials": {
      "username": "administrator",
      "password": "administrator"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_priority_matrix"
    }
  }
}
