{
  "id": "provision_asset_to_user@1",
  "version": "1.0",
  "env_id": "manageservice_env@0.1",
  "description": "Update the inventory record for workstation 'WS-LPT-4402' to assign it to user 'Elena Fisher' in the 'Operations' department, set its state to 'In Use', and append 'Handed over with power adapter and docking station.' to the description. Login with username: administrator, password: administrator.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/provision_asset_to_user/setup_task.sh",
    "post_task": "/workspace/tasks/provision_asset_to_user/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "asset_name": "WS-LPT-4402",
    "target_user": "Elena Fisher",
    "target_dept": "Operations",
    "target_state": "In Use",
    "required_description_part": "Handed over with power adapter"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_provision_asset"
    }
  }
}
