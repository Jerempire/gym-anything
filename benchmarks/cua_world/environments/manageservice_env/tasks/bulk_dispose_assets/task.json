{
  "id": "bulk_dispose_assets@1",
  "version": "1.0",
  "env_id": "manageservice_env@0.1",
  "description": "Perform a bulk lifecycle update for a batch of legacy workstations. Identify the workstations named 'OLD-PC-01', 'OLD-PC-02', 'OLD-PC-03', 'OLD-PC-04', and 'OLD-PC-05' in the Assets module and change their status from 'In Store' to 'Disposed'. Login credentials: administrator / administrator",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bulk_dispose_assets/setup_task.sh",
    "post_task": "/workspace/tasks/bulk_dispose_assets/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_assets": [
      "OLD-PC-01",
      "OLD-PC-02",
      "OLD-PC-03",
      "OLD-PC-04",
      "OLD-PC-05"
    ],
    "initial_state": "In Store",
    "target_state": "Disposed",
    "resource_table": "resources",
    "state_table": "resourcestate"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bulk_dispose_assets"
    }
  }
}
