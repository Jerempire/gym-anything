{
  "id": "create_oracle_connection@1",
  "version": "1.0",
  "env_id": "oracle_sql_developer_env@0.1",
  "description": "Create and establish a database connection named 'HR Database' in Oracle SQL Developer using the following credentials: Username 'hr', Password 'hr123', Hostname 'localhost', Port 1521, and Service name 'XEPDB1'.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_oracle_connection/setup_task.sh",
    "post_task": "/workspace/tasks/create_oracle_connection/export_result.sh"
  },
  "metadata": {
    "expected_connection_name": "HR Database",
    "expected_username": "hr",
    "expected_hostname": "localhost",
    "expected_port": 1521,
    "expected_service_name": "XEPDB1",
    "expected_tables": [
      "EMPLOYEES",
      "DEPARTMENTS",
      "JOBS",
      "LOCATIONS",
      "COUNTRIES",
      "REGIONS",
      "JOB_HISTORY"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_oracle_connection"
    }
  }
}
