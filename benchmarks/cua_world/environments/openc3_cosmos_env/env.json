{
  "id": "openc3_cosmos_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "OpenC3 COSMOS satellite ground station environment for spacecraft command and control, telemetry monitoring, limits management, and automated pass sequence operations using real satellite ground station software",
  "resources": {
    "cpu": 4,
    "mem_gb": 16,
    "gpu": 0,
    "net": true
  },
  "diagnostics": true,
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/openc3_cosmos_env/artifacts",
    "video_fps": 10,
    "video_resolution": [1920, 1080],
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": false,
    "host_port": 5970,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/openc3_cosmos_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/openc3_cosmos_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/openc3_cosmos_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/openc3_cosmos_env/utils",
      "target": "/workspace/utils",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_openc3.sh",
    "post_start": "/workspace/scripts/setup_openc3.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "operator",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input", "docker"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "OPENC3_URL": "http://localhost:2900"
        }
      }
    }
  ],
  "tags": [
    "linux",
    "satellite",
    "ground-station",
    "command-control",
    "telemetry",
    "space-operations",
    "web-application",
    "docker",
    "desktop"
  ]
}
