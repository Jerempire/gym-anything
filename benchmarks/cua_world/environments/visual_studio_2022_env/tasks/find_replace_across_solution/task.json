{
  "id": "find_replace_across_solution@1",
  "version": "1.0",
  "env_id": "visual_studio_2022_env@0.1",
  "description": "Visual Studio 2022 is open with the ContosoApiClient C# solution. The company has migrated its API. Replace every occurrence of the legacy URL 'https://api.contoso-legacy.com/v2' with the new URL 'https://api.contoso.io/v3' across the entire solution and save all modified files.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\find_replace_across_solution\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\find_replace_across_solution\\export_result.ps1"
  },
  "metadata": {
    "expected_old_url": "https://api.contoso-legacy.com/v2",
    "expected_new_url": "https://api.contoso.io/v3",
    "target_file_count": 9,
    "target_occurrence_count": 16
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_find_replace_across_solution"
    }
  }
}
