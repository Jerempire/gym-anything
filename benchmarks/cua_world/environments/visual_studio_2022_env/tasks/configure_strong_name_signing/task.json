{
  "id": "configure_strong_name_signing@1",
  "version": "1.0",
  "env_id": "visual_studio_2022_env@0.1",
  "description": "Visual Studio 2022 is open with the EnterpriseSecurity solution loaded. Enable Strong Name assembly signing for the 'CryptoCore' C# class library project using a new strong name key file named 'company_key.snk' without password protection. Rebuild the solution to produce a signed assembly.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_strong_name_signing\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_strong_name_signing\\export_result.ps1"
  },
  "metadata": {
    "expected_key_file": "company_key.snk",
    "project_path": "C:\\Users\\Docker\\source\\repos\\EnterpriseSecurity\\CryptoCore\\CryptoCore.csproj",
    "dll_path": "C:\\Users\\Docker\\source\\repos\\EnterpriseSecurity\\CryptoCore\\bin\\Debug\\net8.0\\CryptoCore.dll"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_strong_name_signing"
    }
  }
}
