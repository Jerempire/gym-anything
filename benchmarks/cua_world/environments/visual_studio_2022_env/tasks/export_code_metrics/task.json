{
  "id": "export_code_metrics@1",
  "version": "1.0",
  "env_id": "visual_studio_2022_env@0.1",
  "description": "Visual Studio 2022 is open with the JitterPhysicsCore C# solution. Generate the code metrics for the solution and export the results to C:\\Users\\Docker\\Documents\\MetricsReport.xlsx. Identify the method with the highest Cyclomatic Complexity from the metrics and save its exact name to C:\\Users\\Docker\\Documents\\HighestComplexity.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_code_metrics\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_code_metrics\\export_result.ps1"
  },
  "metadata": {
    "expected_xlsx_path": "C:\\Users\\Docker\\Documents\\MetricsReport.xlsx",
    "expected_txt_path": "C:\\Users\\Docker\\Documents\\HighestComplexity.txt",
    "expected_method_name": "DetectCollision"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_code_metrics"
    }
  },
  "tags": [
    "visual-studio",
    "csharp",
    "code-metrics",
    "ide-tools",
    "analysis"
  ]
}
