{
  "id": "configure_essay_browser_features@1",
  "version": "1.0",
  "env_id": "safe_exam_browser_env@0.1",
  "name": "Configure Browser Features for Essay Exam",
  "description": "Create a new SEB Exam Configuration named 'ENGL101_Creative_Writing_2026' on the SEB Server (http://localhost:8080) using the credentials super-admin / admin. Configure the settings to enable spell checking, enable text zoom, and disable printing. Save the configuration.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_essay_browser_features/setup_task.sh",
    "post_task": "/workspace/tasks/configure_essay_browser_features/export_result.sh"
  },
  "metadata": {
    "expected_config_name": "ENGL101_Creative_Writing_2026",
    "required_settings": [
      "spell_check",
      "text_zoom",
      "no_printing"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_essay_browser_features"
    }
  },
  "tags": [
    "seb-server",
    "exam-configuration",
    "web-ui",
    "medium"
  ]
}
