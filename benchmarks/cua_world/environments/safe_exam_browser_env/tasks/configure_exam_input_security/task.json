{
  "id": "configure_exam_input_security@1",
  "version": "1.0",
  "env_id": "safe_exam_browser_env@0.1",
  "name": "Configure Exam Input Security and Writing Aids",
  "description": "Create an exam configuration named 'Creative Writing Midterm' in the SEB Server (http://localhost:8080) using the credentials super-admin / admin. The configuration must have spell checking disabled and single app mode enabled.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_exam_input_security/setup_task.sh",
    "post_task": "/workspace/tasks/configure_exam_input_security/export_result.sh"
  },
  "metadata": {
    "expected_config_name": "Creative Writing Midterm",
    "expected_spell_check": false,
    "expected_single_app": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_exam_input_security"
    }
  },
  "tags": [
    "seb-server",
    "exam-configuration",
    "security",
    "web-ui",
    "medium"
  ]
}
