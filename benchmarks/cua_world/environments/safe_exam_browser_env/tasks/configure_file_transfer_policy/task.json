{
  "id": "configure_file_transfer_policy@1",
  "version": "1.0",
  "env_id": "safe_exam_browser_env@0.1",
  "name": "Configure File Transfer Policy for Exam",
  "description": "Log into the SEB Server (http://localhost:8080) using credentials 'super-admin' / 'admin' and modify the 'CS101 Midterm' exam configuration to permit file transfers by enabling both 'Allow Downloads' and 'Allow Uploads'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_file_transfer_policy/setup_task.sh",
    "post_task": "/workspace/tasks/configure_file_transfer_policy/export_result.sh"
  },
  "metadata": {
    "expected_exam_name": "CS101 Midterm",
    "expected_downloads_attr": "allowDownloads",
    "expected_uploads_attr": "allowUploads",
    "expected_value": "true"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_file_transfer_policy"
    }
  },
  "tags": [
    "seb-server",
    "security-policy",
    "web-ui",
    "medium"
  ]
}
