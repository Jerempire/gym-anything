{
  "id": "switch_exam_config_and_time@1",
  "version": "1.0",
  "env_id": "safe_exam_browser_env@0.1",
  "name": "Update Exam Configuration and Schedule",
  "description": "Log in to SEB Server (super-admin/admin) and update the scheduled exam 'Intro to Psychology 101' to reflect a policy update. Change the linked SEB Configuration to 'Calculator Permitted Config' and extend the exam duration by setting the End Time to 14:00 on 2026-06-15.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/switch_exam_config_and_time/setup_task.sh",
    "post_task": "/workspace/tasks/switch_exam_config_and_time/export_result.sh"
  },
  "metadata": {
    "expected_exam": "Intro to Psychology 101",
    "expected_config": "Calculator Permitted Config",
    "expected_end_date": "2026-06-15",
    "expected_end_time": "14:00"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_switch_exam_config_and_time"
    }
  },
  "tags": [
    "seb-server",
    "exam-administration",
    "web-ui",
    "medium"
  ]
}
