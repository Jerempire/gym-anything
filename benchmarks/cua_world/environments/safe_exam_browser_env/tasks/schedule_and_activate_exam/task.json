{
  "id": "schedule_and_activate_exam@1",
  "version": "1.0",
  "env_id": "safe_exam_browser_env@0.1",
  "name": "Schedule and Activate Exam",
  "description": "Configure the 'CS101 - Algorithms Final' exam to be active and scheduled for May 20, 2026, from 08:45 AM to 12:00 PM (Server Time). Login credentials: super-admin / admin.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/schedule_and_activate_exam/setup_task.sh",
    "post_task": "/workspace/tasks/schedule_and_activate_exam/export_result.sh"
  },
  "metadata": {
    "expected_start_date": "2026-05-20",
    "expected_start_time": "08:45",
    "expected_end_date": "2026-05-20",
    "expected_end_time": "12:00",
    "expected_status": "Active"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_schedule_and_activate_exam"
    }
  },
  "tags": [
    "seb-server",
    "exam-scheduling",
    "web-ui",
    "medium"
  ]
}
