{
  "id": "bulk_activate_semester_exams@1",
  "version": "1.0",
  "env_id": "safe_exam_browser_env@0.1",
  "name": "Batch Activate Semester Exams",
  "description": "Activate all exams in the SEB Server Exam Administration with names starting with 'Spring 2026', excluding any that contain the tag '[DEPRECATED]'. Do not modify exams from other semesters (e.g., 'Fall 2025'). The SEB Server is accessible at http://localhost:8080 with login credentials super-admin / admin.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bulk_activate_semester_exams/setup_task.sh",
    "post_task": "/workspace/tasks/bulk_activate_semester_exams/export_result.sh"
  },
  "metadata": {
    "target_pattern": "Spring 2026",
    "exclude_pattern": "[DEPRECATED]",
    "valid_exams": [
      "Spring 2026: Biology 101",
      "Spring 2026: Chemistry 201",
      "Spring 2026: Calculus I"
    ],
    "invalid_exams": [
      "Spring 2026: Physics 301 [DEPRECATED]",
      "Fall 2025: History 101"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bulk_activate"
    }
  },
  "tags": [
    "seb-server",
    "exam-management",
    "batch-processing",
    "web-ui"
  ]
}
