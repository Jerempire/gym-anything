{
  "id": "configure_exam_accessibility_features@1",
  "version": "1.0",
  "env_id": "safe_exam_browser_env@0.1",
  "name": "Configure Exam Accessibility Features",
  "description": "Log into the SEB Server (http://localhost:8080) using credentials super-admin / admin. Update the 'ENGL 204: Modernist Literature Final' exam configuration to enable 'Allow Spell Check', 'Allow Text Search', and 'Enable Zooming'. If the configuration does not exist, create it with that exact name.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_exam_accessibility_features/setup_task.sh",
    "post_task": "/workspace/tasks/configure_exam_accessibility_features/export_result.sh"
  },
  "metadata": {
    "exam_name": "ENGL 204: Modernist Literature Final",
    "features": [
      "allowSpellCheck",
      "allowTextSearch",
      "enableZooming"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_accessibility_features"
    }
  },
  "tags": [
    "seb-server",
    "exam-configuration",
    "accessibility",
    "web-ui",
    "medium"
  ]
}
