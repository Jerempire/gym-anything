{
  "id": "export_exam_config_file@1",
  "version": "1.0",
  "env_id": "safe_exam_browser_env@0.1",
  "name": "Export SEB Exam Configuration File",
  "description": "Export the SEB exam configuration named 'Anatomy Midterm Config' as a .seb file to ~/Downloads/. The SEB Server is accessible at http://localhost:8080 with login credentials super-admin / admin.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_exam_config_file/setup_task.sh",
    "post_task": "/workspace/tasks/export_exam_config_file/export_result.sh"
  },
  "metadata": {
    "expected_download_dir": "/home/ga/Downloads",
    "expected_extension": ".seb",
    "target_config_name": "Anatomy Midterm Config",
    "min_file_size_bytes": 100
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_exam_config_file"
    }
  },
  "tags": [
    "seb-server",
    "exam-configuration",
    "file-download",
    "web-ui",
    "medium"
  ]
}
