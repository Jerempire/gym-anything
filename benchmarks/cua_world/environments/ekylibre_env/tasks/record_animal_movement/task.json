{
  "id": "record_animal_movement@1",
  "version": "1.0",
  "env_id": "ekylibre_env@0.1",
  "description": "Record a pasture rotation for the animal named 'Marguerite' to the zone 'Pature des Saules' with today's date.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_animal_movement/setup_task.sh",
    "post_task": "/workspace/tasks/record_animal_movement/export_result.sh"
  },
  "metadata": {
    "animal_name": "Marguerite",
    "target_zone": "Pature des Saules",
    "start_zone": "Etable Principale"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_animal_movement"
    }
  }
}
