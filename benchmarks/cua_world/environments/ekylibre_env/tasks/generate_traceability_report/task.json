{
  "id": "generate_traceability_report@1",
  "version": "1.0",
  "env_id": "ekylibre_env@0.1",
  "description": "Generate a traceability report (Fiche de traçabilité / Fiche Parcellaire) for the cultivable zone 'Les Groies' for the current campaign. Export the report as a PDF file to ~/Downloads/fiche_tracabilite.pdf.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_traceability_report/setup_task.sh",
    "post_task": "/workspace/tasks/generate_traceability_report/export_result.sh"
  },
  "metadata": {
    "target_zone": "Les Groies",
    "expected_keywords": [
      "Traçabilité",
      "Intervention",
      "Groies"
    ],
    "download_dir": "/home/ga/Downloads"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_traceability_report"
    }
  }
}
