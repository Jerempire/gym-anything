{
  "id": "create_outgoing_sale@1",
  "version": "1.0",
  "env_id": "ekylibre_env@0.1",
  "description": "Create a new outgoing sale in Ekylibre's trade module. The sale must include an existing client and one sale line for a grain or cereal product variant with a quantity of 25 and a unit pretax price of 210.00 EUR.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_outgoing_sale/setup_task.sh",
    "post_task": "/workspace/tasks/create_outgoing_sale/export_result.sh"
  },
  "metadata": {
    "expected_quantity": 25,
    "expected_price": 210.0,
    "quantity_tolerance": 0.5,
    "price_tolerance": 1.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_outgoing_sale"
    }
  },
  "tags": [
    "ekylibre",
    "sales",
    "commerce",
    "invoice",
    "data-entry"
  ]
}
