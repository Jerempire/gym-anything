{
  "id": "register_worker@1",
  "version": "1.0",
  "env_id": "ekylibre_env@0.1",
  "description": "Register a new seasonal worker named Marie Dupont (born June 15, 1992) in the Ekylibre system.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/register_worker/setup_task.sh",
    "post_task": "/workspace/tasks/register_worker/export_result.sh"
  },
  "metadata": {
    "expected_name_part1": "Marie",
    "expected_name_part2": "Dupont",
    "expected_dob": "1992-06-15",
    "target_url_fragment": "/backend/workers"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_register_worker"
    }
  }
}
