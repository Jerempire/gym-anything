{
  "id": "missing_letter_spelling@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Navigate to the 'Missing Letter' activity in GCompris and complete Level 1 by correctly solving at least five spelling puzzles.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/missing_letter_spelling/setup_task.sh",
    "post_task": "/workspace/tasks/missing_letter_spelling/export_result.sh"
  },
  "metadata": {
    "activity_id": "missing_letter",
    "category": "reading",
    "min_puzzles_solved": 5,
    "database_path": "/home/ga/.local/share/GCompris/gcompris-qt.db"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_missing_letter"
    }
  }
}
