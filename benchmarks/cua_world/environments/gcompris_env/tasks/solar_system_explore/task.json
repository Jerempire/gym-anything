{
  "id": "solar_system_explore@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Use the Solar System activity in GCompris to identify the eight planets in order from the Sun. Create a text file at '~/Documents/planets_in_order.txt' listing the 8 planets in order from closest to the Sun to farthest. The file should have exactly 8 lines, with one planet name per line using standard capitalization.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/solar_system_explore/setup_task.sh",
    "post_task": "/workspace/tasks/solar_system_explore/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/planets_in_order.txt",
    "expected_planets": [
      "Mercury",
      "Venus",
      "Earth",
      "Mars",
      "Jupiter",
      "Saturn",
      "Uranus",
      "Neptune"
    ],
    "forbidden_words": [
      "Pluto",
      "Sun",
      "Moon",
      "Ceres"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_solar_system_explore"
    }
  }
}
