{
  "id": "navigate_activity@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "GCompris is open at the activity selection menu. Open the 'Learn additions' activity.",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/navigate_activity/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_navigate_activity"
    }
  }
}
