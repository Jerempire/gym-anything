{
  "id": "left_right_orientation@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Complete the 'Left and Right' activity in GCompris by correctly identifying the displayed hands or objects until the level is finished.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/left_right_orientation/setup_task.sh",
    "post_task": "/workspace/tasks/left_right_orientation/export_result.sh"
  },
  "metadata": {
    "activity_name": "leftright",
    "success_indicator": "congratulations_animation"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_left_right_orientation"
    }
  }
}
