{
  "id": "simple_word_processing@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Create a 'Field Trip Notice' document in the GCompris Word Processor activity with the following text:\n\nFIELD TRIP NOTICE\nDestination: City Zoo\nDate: May 15th\nPlease bring a lunch.\n\nYou may apply bold or header formatting to the title line. Save a screenshot of the completed document to ~/Documents/field_trip_notice.png.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/simple_word_processing/setup_task.sh",
    "post_task": "/workspace/tasks/simple_word_processing/export_result.sh"
  },
  "metadata": {
    "target_text": {
      "title": "FIELD TRIP NOTICE",
      "line1": "Destination: City Zoo",
      "line2": "Date: May 15th",
      "line3": "Please bring a lunch"
    },
    "expected_file": "/home/ga/Documents/field_trip_notice.png",
    "activity_name": "Word Processor",
    "category": "Computer Discovery"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_simple_word_processing"
    }
  }
}
