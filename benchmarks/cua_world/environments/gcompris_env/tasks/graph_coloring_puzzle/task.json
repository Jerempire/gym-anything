  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/graph_coloring_puzzle/setup_task.sh",
    "post_task": "/workspace/tasks/graph_coloring_puzzle/export_result.sh"
  },
  "metadata": {
    "expected_screenshot_path": "/home/ga/graph_solved.png",
    "activity_name": "Graph Coloring",
    "category_name": "Logic/Strategy"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_graph_coloring_puzzle"
    }
  }
}
