{
  "id": "complete_maze@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Complete the Maze activity in GCompris by navigating the penguin character to the exit door.",
  "init": {
    "timeout_sec": 180,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/complete_maze/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_complete_maze"
    }
  }
}
