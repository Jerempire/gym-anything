{
  "id": "assemble_famous_painting@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Complete the first puzzle in the 'Puzzle of famous paintings' activity in GCompris. Save a screenshot of the completed puzzle to /home/ga/Documents/painting_solved.png and record the name of the painting or artist displayed in /home/ga/Documents/painting_info.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/assemble_famous_painting/setup_task.sh",
    "post_task": "/workspace/tasks/assemble_famous_painting/export_result.sh"
  },
  "metadata": {
    "expected_screenshot": "/home/ga/Documents/painting_solved.png",
    "expected_text_file": "/home/ga/Documents/painting_info.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_assemble_famous_painting"
    }
  }
}
