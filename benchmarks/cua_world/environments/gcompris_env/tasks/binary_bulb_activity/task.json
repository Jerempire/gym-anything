{
  "id": "binary_bulb_activity@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Navigate to the 'Binary Bulbs' activity in GCompris and complete at least 3 levels. Save a screenshot of the activity to /tmp/binary_bulb_final.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/binary_bulb_activity/setup_task.sh",
    "post_task": "/workspace/tasks/binary_bulb_activity/export_result.sh"
  },
  "metadata": {
    "activity_name": "Binary Bulbs",
    "expected_screenshot": "/tmp/binary_bulb_final.png",
    "min_levels": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_binary_bulb_activity"
    }
  }
}
