{
  "id": "geography_puzzle@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Navigate to the Geography puzzle activity in GCompris and complete a portion of the South America map by placing at least 4 countries in their correct positions. Save a screenshot of the completed map to /home/ga/geography_result.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/geography_puzzle/setup_task.sh",
    "post_task": "/workspace/tasks/geography_puzzle/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/geography_result.png",
    "target_map": "South America",
    "min_countries_placed": 4
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_geography_puzzle"
    }
  }
}
