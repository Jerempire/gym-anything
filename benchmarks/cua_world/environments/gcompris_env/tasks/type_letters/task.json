{
  "id": "type_letters@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Complete the 'Alphabet sequence' activity in GCompris. Type at least five letters in alphabetical order, starting from 'a' (a through e).",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/type_letters/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_type_letters"
    }
  }
}
