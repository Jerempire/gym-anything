{
  "id": "connect_dots_mystery@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Navigate to the 'Connect the Dots' activity in GCompris. Solve the first available puzzle to reveal the hidden picture. Save a screenshot of the revealed picture to '~/Documents/solved_dots.png' and create a text file at '~/Documents/object_id.txt' containing a sentence identifying the object.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/connect_dots_mystery/setup_task.sh",
    "post_task": "/workspace/tasks/connect_dots_mystery/export_result.sh"
  },
  "metadata": {
    "expected_screenshot": "/home/ga/Documents/solved_dots.png",
    "expected_text_file": "/home/ga/Documents/object_id.txt",
    "category_path": [
      "Mathematics",
      "Numeracy",
      "Connect the dots"
    ],
    "scoring": {
      "file_evidence": 30,
      "navigation": 20,
      "interaction": 30,
      "completion": 20
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_connect_dots_mystery"
    }
  }
}
