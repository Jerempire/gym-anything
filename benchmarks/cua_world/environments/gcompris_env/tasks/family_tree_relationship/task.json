{
  "id": "family_tree_relationship@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Complete the first level of the 'Family' activity in GCompris. Save a screenshot of the completed puzzle to /home/ga/Documents/family_tree_solved.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/family_tree_relationship/setup_task.sh",
    "post_task": "/workspace/tasks/family_tree_relationship/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/family_tree_solved.png",
    "activity_name": "Family",
    "category_hint": "Discovery / Humanities",
    "target_concepts": [
      "Grandfather",
      "Grandmother",
      "Father",
      "Mother",
      "Brother",
      "Sister",
      "Me"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_family_tree_relationship"
    }
  }
}
