{
  "id": "chess_activity@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Play a game of chess against the computer in GCompris for at least 4 complete moves (4 white moves and the computer's responses). Capture a screenshot of the developed board state and save it to /home/ga/chess_progress.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/chess_activity/setup_task.sh",
    "post_task": "/workspace/tasks/chess_activity/export_result.sh"
  },
  "metadata": {
    "expected_screenshot": "/home/ga/chess_progress.png",
    "min_moves": 4
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_chess_activity"
    }
  }
}
