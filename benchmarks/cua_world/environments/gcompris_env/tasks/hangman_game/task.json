{
  "id": "hangman_game@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Play a full round of the Hangman activity within the Reading category of GCompris. Save a screenshot of the completed round result to /home/ga/hangman_result.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/hangman_game/setup_task.sh",
    "post_task": "/workspace/tasks/hangman_game/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/hangman_result.png",
    "min_file_size_bytes": 10000,
    "scoring": {
      "app_running": 10,
      "file_valid": 15,
      "no_crash": 5,
      "vlm_activity_open": 20,
      "vlm_gameplay_progress": 20,
      "vlm_round_complete": 20,
      "vlm_workflow": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_hangman_game"
    }
  }
}
