  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/photo_hunter_differences/setup_task.sh",
    "post_task": "/workspace/tasks/photo_hunter_differences/export_result.sh"
  },
  "metadata": {
    "expected_screenshot": "/home/ga/photo_hunter_success.png",
    "activity_name": "Photo Hunter",
    "category_hint": "Puzzles or Amusement"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_photo_hunter_differences"
    }
  }
}
