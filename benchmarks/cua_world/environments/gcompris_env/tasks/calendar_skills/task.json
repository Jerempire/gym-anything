{
  "id": "calendar_skills@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Complete at least 3 levels of the GCompris 'Calendar' activity by finding the requested dates. For each date successfully identified, append it in YYYY-MM-DD format on a new line to ~/Documents/calendar_log.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/calendar_skills/setup_task.sh",
    "post_task": "/workspace/tasks/calendar_skills/export_result.sh"
  },
  "metadata": {
    "expected_log_file": "/home/ga/Documents/calendar_log.txt",
    "min_dates_required": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_calendar_skills"
    }
  }
}
