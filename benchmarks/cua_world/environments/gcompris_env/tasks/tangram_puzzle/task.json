{
  "id": "tangram_puzzle@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Navigate to the Tangram puzzle activity in GCompris and complete at least one figure by fitting the geometric pieces into the target outline.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/tangram_puzzle/setup_task.sh",
    "post_task": "/workspace/tasks/tangram_puzzle/export_result.sh"
  },
  "metadata": {
    "expected_screenshot": "/tmp/tangram_final.png",
    "activity_name": "tangram",
    "category": "puzzle"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_tangram_puzzle"
    }
  }
}
