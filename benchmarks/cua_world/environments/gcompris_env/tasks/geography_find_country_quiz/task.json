{
  "id": "geography_find_country_quiz@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Complete the 'Locate the region' geography activity for South America in GCompris by successfully identifying at least 5 countries. Save a screenshot of the map showing your progress to /home/ga/Documents/geography_score.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/geography_find_country_quiz/setup_task.sh",
    "post_task": "/workspace/tasks/geography_find_country_quiz/export_result.sh"
  },
  "metadata": {
    "expected_screenshot_path": "/home/ga/Documents/geography_score.png",
    "target_region": "South America",
    "min_countries_identified": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_geography_quiz"
    }
  }
}
