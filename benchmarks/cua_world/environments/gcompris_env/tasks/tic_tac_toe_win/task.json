{
  "id": "tic_tac_toe_win@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Win a game of Tic-Tac-Toe against the computer at Level 1 in GCompris. Save a screenshot of the victory screen to /home/ga/tic_tac_toe_victory.png.",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/tic_tac_toe_win/setup_task.sh",
    "post_task": "/workspace/tasks/tic_tac_toe_win/export_result.sh"
  },
  "metadata": {
    "expected_screenshot_path": "/home/ga/tic_tac_toe_victory.png",
    "category": "Strategy",
    "activity": "Tic-Tac-Toe",
    "min_moves": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_tic_tac_toe_win"
    }
  }
}
