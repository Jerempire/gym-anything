{
  "id": "analog_electricity_circuit@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Build a simple series circuit in the GCompris Analog Electricity activity using a battery, a light bulb, and wires so that the bulb glows. Save a screenshot of the completed working circuit to /home/ga/circuit_complete.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/analog_electricity_circuit/setup_task.sh",
    "post_task": "/workspace/tasks/analog_electricity_circuit/export_result.sh"
  },
  "metadata": {
    "expected_screenshot_path": "/home/ga/circuit_complete.png",
    "min_file_size_kb": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_analog_electricity_circuit"
    }
  }
}
