{
  "id": "construct_gear_mechanism@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Navigate to the 'Gears' activity in GCompris. Connect the driver gear (motor) to the target gear (red) using the provided loose gears to create a functional mechanism. Save a screenshot of the completed, rotating mechanism to /home/ga/gears_success.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/construct_gear_mechanism/setup_task.sh",
    "post_task": "/workspace/tasks/construct_gear_mechanism/export_result.sh"
  },
  "metadata": {
    "expected_screenshot_path": "/home/ga/gears_success.png",
    "activity_name": "Gears",
    "category_name": "Discovery",
    "min_screenshot_size_kb": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_construct_gear_mechanism"
    }
  }
}
