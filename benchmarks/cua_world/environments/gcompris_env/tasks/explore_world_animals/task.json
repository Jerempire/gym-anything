{
  "id": "explore_world_animals@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Explore the 'Explore World Animals' activity in GCompris to learn about wildlife in different regions. Create a report at /home/ga/Documents/world_animals_report.txt with the header 'GCompris World Animals Report'. Document at least 5 animal-region pairs using the format 'Region: [Region Name] - Animal: [Animal Name]' and include a final line 'Total animals explored: [N]'. Save a screenshot of the activity map to /home/ga/Documents/world_animals_screenshot.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/explore_world_animals/setup_task.sh",
    "post_task": "/workspace/tasks/explore_world_animals/export_result.sh"
  },
  "metadata": {
    "report_path": "/home/ga/Documents/world_animals_report.txt",
    "screenshot_path": "/home/ga/Documents/world_animals_screenshot.png",
    "min_entries": 5,
    "known_animals": [
      "polar bear",
      "kangaroo",
      "elephant",
      "panda",
      "bald eagle",
      "llama",
      "toucan",
      "koala",
      "lion",
      "penguin",
      "camel",
      "tiger",
      "whale",
      "dolphin",
      "bear",
      "wolf",
      "moose",
      "jaguar",
      "parrot",
      "monkey",
      "gorilla",
      "giraffe",
      "zebra",
      "rhinoceros",
      "crocodile",
      "flamingo",
      "seal",
      "walrus",
      "owl",
      "deer",
      "fox",
      "rabbit",
      "tortoise",
      "iguana",
      "anaconda",
      "condor",
      "armadillo",
      "sloth",
      "platypus",
      "buffalo",
      "bison",
      "leopard",
      "cheetah",
      "shark"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_explore_world_animals"
    }
  }
}
