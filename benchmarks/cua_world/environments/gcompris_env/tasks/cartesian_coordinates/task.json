{
  "id": "cartesian_coordinates@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Navigate to the 'Cartesian Coordinates' activity in GCompris and complete Level 1 by identifying points on the grid until the level is successfully finished.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/cartesian_coordinates/setup_task.sh",
    "post_task": "/workspace/tasks/cartesian_coordinates/export_result.sh"
  },
  "metadata": {
    "category_path": [
      "Mathematics",
      "Geometry"
    ],
    "activity_name": "Cartesian Coordinates",
    "scoring": {
      "navigation": 20,
      "activity_open": 20,
      "interaction": 30,
      "completion": 30
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_cartesian_coordinates"
    }
  }
}
