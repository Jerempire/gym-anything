{
  "id": "fifteen_puzzle@1",
  "version": "1.0",
  "env_id": "gcompris_env@0.1",
  "description": "Solve the Fifteen Puzzle activity in GCompris. Save a screenshot of the completed puzzle to /home/ga/Documents/fifteen_puzzle_solved.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/fifteen_puzzle/setup_task.sh",
    "post_task": "/workspace/tasks/fifteen_puzzle/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/fifteen_puzzle_solved.png",
    "min_file_size_bytes": 5000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_fifteen_puzzle"
    }
  }
}
