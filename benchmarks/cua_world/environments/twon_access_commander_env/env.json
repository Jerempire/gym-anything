{
  "id": "twon_access_commander_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "2N Access Commander environment for managing physical access control: creating users, assigning credentials (RFID cards, PINs), defining user groups, configuring access rules, time profiles, and reviewing access logs. Runs the official 2N Access Commander OVA as a nested QEMU VM (KVM-accelerated) inside the outer VM, accessible at https://localhost:9443.",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "vnc": {
    "password": "password"
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/twon_access_commander_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/twon_access_commander_env/tasks",   "target": "/workspace/tasks",   "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/twon_access_commander_env/data",    "target": "/workspace/data",    "mode": "ro"}
  ],
  "hooks": {
    "pre_start":  "/workspace/scripts/install_twon_ac.sh",
    "post_start": "/workspace/scripts/setup_twon_ac.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ]
}
