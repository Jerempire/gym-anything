{
  "id": "configure_location_tags@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "Configure the functional capabilities of the 'Isolation Ward' location so that it is selectable for patient admissions and transfers. Add the 'Admission Location' and 'Transfer Location' tags to the 'Isolation Ward' location. Login credentials: admin / Admin123.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_location_tags/setup_task.sh",
    "post_task": "/workspace/tasks/configure_location_tags/export_result.sh"
  },
  "metadata": {
    "target_location_name": "Isolation Ward",
    "required_tags": [
      "Admission Location",
      "Transfer Location"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_location_tags"
    }
  }
}
