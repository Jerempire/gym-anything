{
  "id": "fulfill_appointment_request@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "Fulfill the pending 'Dermatology Consultation' appointment request for patient 'Isabella Martinez' using the date and time specified in '~/appointment_details.txt'. Credentials: admin / Admin123.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/fulfill_appointment_request/setup_task.sh",
    "post_task": "/workspace/tasks/fulfill_appointment_request/export_result.sh"
  },
  "metadata": {
    "patient_name": "Isabella Martinez",
    "service_type": "Dermatology Consultation",
    "appointment_status": "SCHEDULED",
    "request_status": "FULFILLED"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_fulfill_appointment_request"
    }
  }
}
