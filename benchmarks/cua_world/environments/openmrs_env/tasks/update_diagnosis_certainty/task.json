{
  "id": "update_diagnosis_certainty@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "Update the certainty of the 'Anemia' diagnosis for patient 'Ova Rau' from 'Presumed' to 'Confirmed' in their active medical record.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_diagnosis_certainty/setup_task.sh",
    "post_task": "/workspace/tasks/update_diagnosis_certainty/export_result.sh"
  },
  "metadata": {
    "patient_given_name": "Ova",
    "patient_family_name": "Rau",
    "diagnosis_name": "Anemia",
    "initial_certainty": "PRESUMED",
    "target_certainty": "CONFIRMED"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_diagnosis_certainty"
    }
  }
}
