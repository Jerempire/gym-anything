{
  "id": "create_user_role@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "Create a new system user role in OpenMRS 3.x named 'Safety Auditor' with the description 'Read-only access for external safety audits'. Assign exactly two privileges to this role: 'View Patients' and 'View Encounters'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_user_role/setup_task.sh",
    "post_task": "/workspace/tasks/create_user_role/export_result.sh"
  },
  "metadata": {
    "expected_role": "Safety Auditor",
    "expected_description_part": "safety audits",
    "expected_privileges": [
      "View Patients",
      "View Encounters"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_user_role"
    }
  }
}
