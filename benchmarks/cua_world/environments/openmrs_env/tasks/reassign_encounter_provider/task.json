{
  "id": "reassign_encounter_provider@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "A clinical data entry error occurred where a Vitals encounter for patient 'Michael Audit' on Jan 01, 2024, was incorrectly attributed to the 'Super User'. Reassign this specific encounter to the correct provider, 'Dr. Cordelia Clinician'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/reassign_encounter_provider/setup_task.sh",
    "post_task": "/workspace/tasks/reassign_encounter_provider/export_result.sh"
  },
  "metadata": {
    "patient_name": "Michael Audit",
    "target_provider_name": "Cordelia Clinician",
    "encounter_date": "2024-01-01",
    "encounter_type": "Vitals"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reassign_provider"
    }
  }
}
