{
  "id": "mark_patient_deceased@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "Mark patient 'Harold Bergstrom' as deceased with a date of death of January 15, 2025 (2025-01-15).\n\nLogin credentials: admin / Admin123\nURL: http://localhost/openmrs/spa",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/mark_patient_deceased/setup_task.sh",
    "post_task": "/workspace/tasks/mark_patient_deceased/export_result.sh"
  },
  "metadata": {
    "patient_given_name": "Harold",
    "patient_family_name": "Bergstrom",
    "target_death_date": "2025-01-15",
    "target_dead_status": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mark_patient_deceased"
    }
  }
}
