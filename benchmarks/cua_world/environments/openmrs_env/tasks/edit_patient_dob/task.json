{
  "id": "edit_patient_dob@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "Correct the Date of Birth for patient Mario Vega to 15 March 1980 (1980-03-15).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/edit_patient_dob/setup_task.sh",
    "post_task": "/workspace/tasks/edit_patient_dob/export_result.sh"
  },
  "metadata": {
    "patient_given_name": "Mario",
    "patient_family_name": "Vega",
    "target_dob": "1980-03-15",
    "target_dob_display": "15 Mar 1980"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_edit_patient_dob"
    }
  }
}
