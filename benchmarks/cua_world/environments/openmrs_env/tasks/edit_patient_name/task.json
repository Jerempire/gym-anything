{
  "id": "edit_patient_name@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "Correct the misspelled name for patient 'Jonh Smithe' (DOB: 15 Jun 1978) in the OpenMRS Electronic Health Record. Update the Given Name to 'John' and the Family Name to 'Smith'. The application is already logged in as Admin.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/edit_patient_name/setup_task.sh",
    "post_task": "/workspace/tasks/edit_patient_name/export_result.sh"
  },
  "metadata": {
    "initial_given": "Jonh",
    "initial_family": "Smithe",
    "target_given": "John",
    "target_family": "Smith",
    "patient_dob": "1978-06-15",
    "patient_gender": "M"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_edit_patient_name"
    }
  }
}
