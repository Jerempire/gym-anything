{
  "id": "add_phone_number@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "You are an Occupational Health and Safety Technician using OpenMRS 3.x. The patient record currently displayed is missing contact information. Update the patient's record by adding the telephone number '555-867-5309' and ensure the change is saved and visible on the patient dashboard.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_phone_number/setup_task.sh",
    "post_task": "/workspace/tasks/add_phone_number/export_result.sh"
  },
  "metadata": {
    "target_phone": "555-867-5309",
    "target_phone_digits": "5558675309",
    "attribute_type_name": "Telephone Number"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_phone_number"
    }
  },
  "tags": [
    "demographics",
    "data-entry",
    "patient-management",
    "openmrs"
  ],
  "occupation_context": "Occupational Health and Safety Technician",
  "industry_context": "Life, Physical, and Social Science"
}
