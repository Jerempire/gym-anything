{
  "id": "edit_patient_address@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "An occupational health clinic has discovered that patient Angela Rivera's residential address is outdated. She recently relocated from San Francisco to Austin, Texas. Update Angela Rivera's address in the system to 4521 Pine Ridge Drive, Austin, Texas, 78745, United States.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/edit_patient_address/setup_task.sh",
    "post_task": "/workspace/tasks/edit_patient_address/export_result.sh"
  },
  "metadata": {
    "patient_name": "Angela Rivera",
    "initial_city": "San Francisco",
    "expected_address1": "4521 Pine Ridge Drive",
    "expected_city": "Austin",
    "expected_state": "Texas",
    "expected_postal": "78745",
    "expected_country": "United States"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_edit_patient_address"
    }
  },
  "tags": [
    "ehr",
    "patient-management",
    "demographics",
    "data-entry",
    "openmrs"
  ]
}
