{
  "id": "create_provider_schedule@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "Create a provider availability schedule block for 'Super User' in the 'General Medicine' service for tomorrow (relative to the system date) from 09:00 to 17:00 in the Appointments application. URL: http://localhost/openmrs/spa Login credentials: admin / Admin123",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_provider_schedule/setup_task.sh",
    "post_task": "/workspace/tasks/create_provider_schedule/export_result.sh"
  },
  "metadata": {
    "provider_name": "Super User",
    "service_name": "General Medicine",
    "start_time": "09:00",
    "end_time": "17:00",
    "tolerance_minutes": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_provider_schedule"
    }
  }
}
