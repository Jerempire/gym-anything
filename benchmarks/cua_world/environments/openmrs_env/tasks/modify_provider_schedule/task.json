{
  "id": "modify_provider_schedule@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "Shorten the appointment schedule block for 'Dr. Schedule Test' for tomorrow. Update the existing 09:00 AM to 05:00 PM block to end at 12:00 PM (noon) instead, ensuring the start time and provider remain unchanged. Login credentials: admin / Admin123.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/modify_provider_schedule/setup_task.sh",
    "post_task": "/workspace/tasks/modify_provider_schedule/export_result.sh"
  },
  "metadata": {
    "provider_name": "Dr. Schedule Test",
    "original_start_time": "09:00:00",
    "original_end_time": "17:00:00",
    "target_end_time": "12:00:00",
    "appointment_module_url": "http://localhost/openmrs/spa/appointments/calendar"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_modify_provider_schedule"
    }
  }
}
