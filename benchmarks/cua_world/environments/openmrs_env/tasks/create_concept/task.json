    "pre_task": "/workspace/tasks/create_concept/setup_task.sh",
    "post_task": "/workspace/tasks/create_concept/export_result.sh"
  },
  "metadata": {
    "expected_fs_name": "Toluene Exposure",
    "expected_synonym": "Methylbenzene exp",
    "expected_class": "Diagnosis",
    "expected_datatype": "N/A",
    "expected_description": "Occupational exposure to toluene solvent"
