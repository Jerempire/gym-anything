{
  "id": "retire_provider@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "Retire the provider record for 'Dr. Eleanor Arroway' to prevent her from being assigned to new patients while she is on leave. Use the credentials admin/Admin123. The retirement reason must be recorded as 'Sabbatical'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/retire_provider/setup_task.sh",
    "post_task": "/workspace/tasks/retire_provider/export_result.sh"
  },
  "metadata": {
    "provider_name": "Eleanor Arroway",
    "provider_identifier": "PROV-ARROWAY",
    "expected_retire_reason": "Sabbatical"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_retire_provider"
    }
  }
}
