{
  "id": "record_visit_note@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "Record a clinical Visit Note for the patient currently displayed on the screen. Set the Primary Diagnosis to 'Headache' and save the form. Do not add any other observations or notes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_visit_note/setup_task.sh",
    "post_task": "/workspace/tasks/record_visit_note/export_result.sh"
  },
  "metadata": {
    "target_diagnosis": "Headache",
    "target_encounter_type": "Visit Note"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_visit_note"
    }
  }
}
