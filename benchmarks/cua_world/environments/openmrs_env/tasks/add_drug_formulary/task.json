{
  "id": "add_drug_formulary@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "Add a new drug formulation to the OpenMRS formulary. Create a new Drug entry named 'Aspirin 500mg ES' linked to the existing concept 'Aspirin' with a strength of '500'. Use the credentials admin / Admin123 to log in.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_drug_formulary/setup_task.sh",
    "post_task": "/workspace/tasks/add_drug_formulary/export_result.sh"
  },
  "metadata": {
    "expected_name": "Aspirin 500mg ES",
    "expected_concept": "Aspirin",
    "expected_strength": "500"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_drug_formulary"
    }
  }
