{
  "id": "add_relationship@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "You are an Occupational Health and Safety Technician documenting that two workers at a chemical plant are siblings. Identify the names of Patient A and Patient B from /tmp/task_params.txt. On the chart for Patient A, document a 'Sibling' relationship with Patient B.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_relationship/setup_task.sh",
    "post_task": "/workspace/tasks/add_relationship/export_result.sh"
  },
  "metadata": {
    "relationship_type": "Sibling",
    "search_target": "Patient B",
    "scoring": {
      "relationship_exists": 40,
      "correct_type": 30,
      "timestamp_valid": 15,
      "count_increased": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_relationship"
    }
  },
  "tags": [
    "openmrs",
    "ehr",
    "relationships",
    "patient-management"
  ]
}
