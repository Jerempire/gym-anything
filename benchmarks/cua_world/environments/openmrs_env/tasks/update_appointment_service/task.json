{
  "id": "update_appointment_service@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "Update the 'Dermatology Consult' appointment service configuration. Set the duration to 45 minutes and the description to exactly: 'Comprehensive initial skin assessment and biopsy planning'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_appointment_service/setup_task.sh",
    "post_task": "/workspace/tasks/update_appointment_service/export_result.sh"
  },
  "metadata": {
    "service_name": "Dermatology Consult",
    "expected_duration": 45,
    "expected_description": "Comprehensive initial skin assessment and biopsy planning"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_appointment_service"
    }
  },
  "tags": [
    "openmrs",
    "appointments",
    "admin",
    "configuration"
  ]
}
