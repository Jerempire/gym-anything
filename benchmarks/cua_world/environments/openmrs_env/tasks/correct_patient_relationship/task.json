{
  "id": "correct_patient_relationship@1",
  "version": "1.0",
  "env_id": "openmrs_env@0.1",
  "description": "Correct the family relationship record for patient 'Bobby Tables'. Currently, 'Martha Tables' is incorrectly listed as his Sibling. Update the record to reflect that Martha Tables is the Parent and Bobby Tables is the Child. Login credentials: admin / Admin123. URL: http://localhost/openmrs/spa",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/correct_patient_relationship/setup_task.sh",
    "post_task": "/workspace/tasks/correct_patient_relationship/export_result.sh"
  },
  "metadata": {
    "child_name": "Bobby Tables",
    "parent_name": "Martha Tables",
    "relationship_type_parent_uuid": "8d91a210-c2cc-11de-8d13-0010c6dffd0f",
    "relationship_type_sibling_uuid": "8d91a01c-c2cc-11de-8d13-0010c6dffd0f"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_correct_relationship"
    }
  }
}
