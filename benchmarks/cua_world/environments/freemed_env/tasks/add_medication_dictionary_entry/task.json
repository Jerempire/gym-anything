{
  "id": "add_medication_dictionary_entry@1",
  "version": "1.0",
  "env_id": "freemed_env@0.1",
  "description": "Add the following medication to FreeMED's internal drug dictionary/formulary. Log in with username: admin, password: admin.\n\nMedication Details:\n- Brand Name: Wegovy\n- Generic Name: semaglutide\n- Dose/Strength: 2.4 mg\n- NDC (National Drug Code): 00169-4505-14\n- Route: Subcutaneous (or SC)\n- Manufacturer: Novo Nordisk",
