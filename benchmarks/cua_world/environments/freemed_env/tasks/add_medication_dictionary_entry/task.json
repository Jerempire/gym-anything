  "hooks": {
    "pre_task": "/workspace/tasks/add_medication_dictionary_entry/setup_task.sh",
    "post_task": "/workspace/tasks/add_medication_dictionary_entry/export_result.sh"
  },
  "metadata": {
    "expected_brand": "Wegovy",
    "expected_generic": "semaglutide",
    "expected_ndc": "00169-4505-14",
