{
  "id": "order_lab_tests@1",
  "version": "1.0",
  "env_id": "freemed_env@0.1",
  "description": "Log into FreeMED (Username: admin, Password: admin) and record a new laboratory order for patient Marcus Vance. The order must include both a 'Lipid Panel' and a 'Hemoglobin A1c' saved to his clinical record.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/order_lab_tests/setup_task.sh",
    "post_task": "/workspace/tasks/order_lab_tests/export_result.sh"
  },
  "metadata": {
    "patient_fname": "Marcus",
    "patient_lname": "Vance",
    "tests_required": [
      "Lipid Panel",
      "Hemoglobin A1c"
    ],
    "keywords_lipid": [
      "lipid",
      "80061",
      "cholesterol"
    ],
    "keywords_a1c": [
      "a1c",
      "hemoglobin",
      "83036"
    ],
    "data_source": "Realistic synthetic demographics generated for task"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_order_lab_tests"
    }
  }
}
