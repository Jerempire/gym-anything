{
  "id": "record_appointment_noshow@1",
  "version": "1.0",
  "env_id": "freemed_env@0.1",
  "description": "Patient Marcus Vance had an appointment scheduled for today at 09:00 AM but did not arrive. Using the credentials (username: admin, password: admin), update Marcus Vance's appointment status in FreeMED to 'No-Show'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_appointment_noshow/setup_task.sh",
    "post_task": "/workspace/tasks/record_appointment_noshow/export_result.sh"
  },
  "metadata": {
    "patient_fname": "Marcus",
    "patient_lname": "Vance",
    "appointment_time": "09:00",
    "target_status": "No Show"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_appointment_noshow"
    }
  }
}
