{
  "id": "export_patient_roster_pdf@1",
  "version": "1.0",
  "env_id": "freemed_env@0.1",
  "description": "Log in to FreeMED (username: admin, password: admin) and export a patient roster containing multiple patients as a PDF. Save the document to /home/ga/Documents/patient_roster.pdf.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_patient_roster_pdf/setup_task.sh",
    "post_task": "/workspace/tasks/export_patient_roster_pdf/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/patient_roster.pdf",
    "required_patient_matches": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_patient_roster"
    }
  }
}
