{
  "id": "post_billing_writeoff@1",
  "version": "1.0",
  "env_id": "freemed_env@0.1",
  "description": "Post an $8.50 adjustment (write-off) to patient Thomas Wright's financial ledger to clear his outstanding balance. Use the note 'Small balance write-off' for the transaction. Log in with username: admin, password: admin.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/post_billing_writeoff/setup_task.sh",
    "post_task": "/workspace/tasks/post_billing_writeoff/export_result.sh"
  },
  "metadata": {
    "patient_fname": "Thomas",
    "patient_lname": "Wright",
    "adjustment_amount": 8.5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_post_billing_writeoff"
    }
  }
}
