{
  "id": "record_lab_result@1",
  "version": "1.0",
  "env_id": "freemed_env@0.1",
  "description": "Record a manually faxed Hemoglobin A1c (HbA1c) lab result of 6.8% for patient Maria Santos in FreeMED. Use credentials admin/admin. Ensure the clinical record includes the test name (Hemoglobin A1c or HbA1c), value (6.8), units (%), and today's date.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_lab_result/setup_task.sh",
    "post_task": "/workspace/tasks/record_lab_result/export_result.sh"
  },
  "metadata": {
    "patient_fname": "Maria",
    "patient_lname": "Santos",
    "expected_value": "6.8",
    "expected_test_name_keywords": [
      "a1c",
      "hemoglobin"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_lab_result"
    }
  }
}
