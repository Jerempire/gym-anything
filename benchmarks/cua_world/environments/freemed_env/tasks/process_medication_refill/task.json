{
  "id": "process_medication_refill@1",
  "version": "1.0",
  "env_id": "freemed_env@0.1",
  "description": "Process a medication refill request for patient Robert Jenkins in FreeMED (username: admin, password: admin). The pharmacy has requested 3 additional refills for his Atorvastatin 40mg prescription. Ensure his other medications, Metformin and Lisinopril, remain at 0 refills.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/process_medication_refill/setup_task.sh",
    "post_task": "/workspace/tasks/process_medication_refill/export_result.sh"
  },
  "metadata": {
    "patient_fname": "Robert",
    "patient_lname": "Jenkins",
    "target_medication": "Atorvastatin",
    "target_expected_refills": 3,
    "control_medication_1": "Metformin",
    "control_expected_refills_1": 0,
    "control_medication_2": "Lisinopril",
    "control_expected_refills_2": 0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_process_medication_refill"
    }
  }
}
