{
  "id": "record_patient_payment@1",
  "version": "1.0",
  "env_id": "freemed_env@0.1",
  "description": "Record a $35.00 Cash Copay payment for patient Maria Santos in FreeMED. Login credentials: username 'admin', password 'admin'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_patient_payment/setup_task.sh",
    "post_task": "/workspace/tasks/record_patient_payment/export_result.sh"
  },
  "metadata": {
    "patient_fname": "Maria",
    "patient_lname": "Santos",
    "expected_amount": "35.00",
    "expected_type": "Cash",
    "expected_category": "Copay",
    "data_source": "Synthea synthetic patient generator style data, injected at setup"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_payment"
    }
  }
}
