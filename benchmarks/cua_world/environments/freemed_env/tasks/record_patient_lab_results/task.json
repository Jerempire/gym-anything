{
  "id": "record_patient_lab_results@1",
  "version": "1.0",
  "env_id": "freemed_env@0.1",
  "description": "Record a Lipid Panel lab result for patient Robert Johnson in FreeMED (Username: admin, Password: admin). Include the following values: Total Cholesterol: 185, HDL: 55, LDL: 110, and Triglycerides: 100.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_patient_lab_results/setup_task.sh",
    "post_task": "/workspace/tasks/record_patient_lab_results/export_result.sh"
  },
  "metadata": {
    "patient_fname": "Robert",
    "patient_lname": "Johnson",
    "test_name": "Lipid Panel",
    "val_cholesterol": 185,
    "val_hdl": 55,
    "val_ldl": 110,
    "val_triglycerides": 100
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_patient_lab_results"
    }
  }
}
