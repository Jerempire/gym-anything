{
  "id": "kstars_sim_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "KStars planetarium with INDI simulator drivers for telescope operations, CCD imaging, and astrophotography workflows using Ekos",
  "category": "science",
  "tags": ["linux", "science", "astronomy", "desktop", "simulation"],
  "resources": {
    "cpu": 4,
    "mem_gb": 6,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/kstars_sim_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/kstars_sim_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/kstars_sim_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/kstars_sim_env/data", "target": "/workspace/data", "mode": "ro"}
  ],
  "vnc": {"password": "password"},
  "hooks": {
    "pre_start": "/workspace/scripts/install_kstars.sh",
    "post_start": "/workspace/scripts/setup_kstars.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ]
}
