{
  "id": "ccd_focus_calibration@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "Before tonight's science observing run, bring the CCD imaging system to optimal focus on the star Vega using the V-curve method as described in ~/Documents/focus_procedure.txt. Save the calibration report to ~/Documents/calibration_report.txt.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/ccd_focus_calibration/setup_task.sh",
    "post_task": "/workspace/tasks/ccd_focus_calibration/export_result.sh"
  },
  "metadata": {
    "target_name": "Vega",
    "target_ra_hours": 18.6156,
    "target_dec_degrees": 38.7836,
    "coordinate_tolerance_arcmin": 15,
    "optimal_focus_min": 28000,
    "optimal_focus_max": 42000,
    "expected_fits_count": 9,
    "upload_dir": "/home/ga/Images/focus_run",
    "report_path": "/home/ga/Documents/focus_report.txt",
    "procedure_path": "/home/ga/Documents/focus_procedure.txt",
    "occupation": "Observatory Technician",
    "industry": "Observatory Operations / CCD Instrumentation"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ccd_focus_calibration"
    }
  }
}
