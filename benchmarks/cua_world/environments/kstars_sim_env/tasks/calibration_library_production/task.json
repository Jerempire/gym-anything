{
  "id": "calibration_library_production@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "Tonight's science observing run requires a complete CCD calibration library before any science frames can be taken. The observatory director has approved a calibration specification at ~/Documents/cal_requirements.txt. Build the complete library to specification and deliver a summary report confirming all calibration frames are in place.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 90,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/calibration_library_production/setup_task.sh",
    "post_task": "/workspace/tasks/calibration_library_production/export_result.sh"
  },
  "metadata": {
    "cal_root": "/home/ga/Calibration",
    "required_bias": 10,
    "required_dark_300s": 10,
    "required_dark_600s": 10,
    "required_flat_V": 5,
    "required_flat_R": 5,
    "required_flat_B": 5,
    "summary_path": "/home/ga/Calibration/calibration_summary.txt",
    "spec_path": "/home/ga/Documents/cal_requirements.txt",
    "occupation": "Astronomers and Space Scientists",
    "industry": "Observatory Operations / CCD Calibration"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_calibration_library_production"
    }
  }
}
