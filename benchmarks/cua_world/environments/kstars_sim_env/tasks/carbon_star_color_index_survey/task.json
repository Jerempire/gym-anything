{
  "id": "carbon_star_color_index_survey@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "Prepare an educational dataset for an astrophysics lab by observing 4 carbon stars in B and R bands (45-second exposures) as detailed in ~/Documents/lab_prep_request.txt. Capture a vibrant sky view for each star, save all images to the subdirectories under ~/Images/carbon_lab/, and generate a CSV summary report. Ignore any stale data from previous semesters.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/carbon_star_color_index_survey/setup_task.sh",
    "post_task": "/workspace/tasks/carbon_star_color_index_survey/export_result.sh"
  },
  "metadata": {
    "targets": [
      "R_Leporis",
      "T_Lyrae",
      "V_Aquilae",
      "W_Orionis"
    ],
    "required_filters": [
      "B",
      "R"
    ],
    "required_filter_slots": [
      3,
      4
    ],
    "exposure_sec": 45,
    "base_dir": "/home/ga/Images/carbon_lab",
    "summary_csv": "/home/ga/Documents/lab_summary.csv"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_carbon_star_color_index_survey"
    }
  }
}
