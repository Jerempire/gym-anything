{
  "id": "globular_cluster_hdr_profiling@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "A researcher studying the stellar density profile of M15 (a core-collapsed globular cluster) requires a High Dynamic Range (HDR) dataset. Capture the bracketed exposure sequence of M15 in the Luminance filter as specified in the observation plan at ~/Documents/hdr_observation_plan.txt. Organize the resulting FITS files into exposure-specific directories, generate the requested false-color sky view, and provide a summary log.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/globular_cluster_hdr_profiling/setup_task.sh",
    "post_task": "/workspace/tasks/globular_cluster_hdr_profiling/export_result.sh"
  },
  "metadata": {
    "target_name": "M15",
    "target_ra_hours": 21.4994,
    "target_dec_degrees": 12.1669,
    "coordinate_tolerance_arcmin": 30,
    "required_filter_slot": 1,
    "upload_dir_base": "/home/ga/Images/M15_HDR",
    "sky_view_path": "/home/ga/Images/M15_HDR/sky_view_cool.png",
    "summary_path": "/home/ga/Documents/hdr_summary.txt",
    "plan_path": "/home/ga/Documents/hdr_observation_plan.txt",
    "occupation": "Observational Astronomer",
    "industry": "Scientific Research / Stellar Astrophysics"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_globular_cluster_hdr_profiling"
    }
  }
}
