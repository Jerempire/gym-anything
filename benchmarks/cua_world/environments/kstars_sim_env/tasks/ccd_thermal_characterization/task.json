{
  "id": "ccd_thermal_characterization@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "Execute a CCD thermal characterization sequence by capturing 60-second dark frames at 0°C, -10°C, and -20°C. Use the specifications provided in ~/Documents/thermal_characterization_procedure.txt.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/ccd_thermal_characterization/setup_task.sh",
    "post_task": "/workspace/tasks/ccd_thermal_characterization/export_result.sh"
  },
  "metadata": {
    "temperatures": [
      0,
      -10,
      -20
    ],
    "frames_per_temp": 5,
    "exptime": 60,
    "directories": [
      "0C",
      "minus10C",
      "minus20C"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ccd_thermal_characterization"
    }
  }
}
