{
  "id": "messier_marathon_sprint@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "The annual Messier Marathon sprint is tonight! Using the target sheet at ~/Documents/marathon_targets.txt, capture the 6 Messier objects. For each target, use the specified filter and exposure count, saving images to ~/Images/marathon/<TargetName>/. Complete the marathon by generating a sky view of the final target and writing an observation log as specified in the target sheet.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/messier_marathon_sprint/setup_task.sh",
    "post_task": "/workspace/tasks/messier_marathon_sprint/export_result.sh"
  },
  "metadata": {
    "targets": {
      "M1": {
        "required_frames": 2
      },
      "M13": {
        "required_frames": 3
      },
      "M27": {
        "required_frames": 2
      },
      "M51": {
        "required_frames": 2
      },
      "M57": {
        "required_frames": 2
      },
      "M101": {
        "required_frames": 2
      }
    },
    "log_path": "/home/ga/Documents/marathon_log.txt",
    "sky_view_path": "/home/ga/Images/marathon/sky_view_m101.png",
    "marathon_base_dir": "/home/ga/Images/marathon",
    "target_sheet_path": "/home/ga/Documents/marathon_targets.txt",
    "occupation": "Amateur Astronomer",
    "industry": "Observational Astronomy"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_messier_marathon_sprint"
    }
  }
}
