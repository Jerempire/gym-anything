{
  "id": "hubble_sequence_rgb_survey@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "A research group is compiling an RGB imaging atlas of galaxies spanning the Hubble morphological sequence. Using the survey plan at ~/Documents/galaxy_survey_plan.txt, observe 4 galaxies of different Hubble types through R, V, and B filters. Organize all frames into a per-object and per-filter directory tree, create a false-color composite for each galaxy, and produce the morphological survey catalog as requested.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 2400,
    "max_steps": 200,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/hubble_sequence_rgb_survey/setup_task.sh",
    "post_task": "/workspace/tasks/hubble_sequence_rgb_survey/export_result.sh"
  },
  "metadata": {
    "survey_root": "/home/ga/Images/galaxy_survey",
    "targets": {
      "M87": {
        "ra": 12.5136,
        "dec": 12.3911
      },
      "M104": {
        "ra": 12.6664,
        "dec": -11.6231
      },
      "M51": {
        "ra": 13.4981,
        "dec": 47.1953
      },
      "NGC4449": {
        "ra": 12.4697,
        "dec": 44.0944
      }
    },
    "filters": [
      "R",
      "V",
      "B"
    ],
    "required_frames_per_filter": 2,
    "coordinate_tolerance_deg": 2.0,
    "composite_min_size_kb": 50,
    "catalog_path": "/home/ga/Documents/galaxy_survey_catalog.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_hubble_sequence_rgb_survey"
    }
  }
}
