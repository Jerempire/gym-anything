{
  "id": "aavso_variable_star_campaign@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "An urgent outburst alert has been issued by the AAVSO (American Association of Variable Star Observers) for the dwarf nova SS Cygni. Complete the monitoring session according to the requirements in ~/Documents/campaign_brief.txt and save the AAVSO-format observations report.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 90,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/aavso_variable_star_campaign/setup_task.sh",
    "post_task": "/workspace/tasks/aavso_variable_star_campaign/export_result.sh"
  },
  "metadata": {
    "target_name": "SS Cygni",
    "target_ra_hours": 21.7119,
    "target_dec_degrees": 43.5861,
    "coordinate_tolerance_arcmin": 20,
    "required_filter_slot": 2,
    "required_exposure_sec": 45,
    "min_fits_count": 8,
    "upload_dir": "/home/ga/Images/sscyg/session1",
    "report_path": "/home/ga/Documents/aavso_report.txt",
    "campaign_brief_path": "/home/ga/Documents/campaign_brief.txt",
    "occupation": "Astronomers and Space Scientists",
    "industry": "Telescope Control / Variable Star Monitoring"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_aavso_variable_star_campaign"
    }
  }
}
