{
  "id": "blazar_outburst_photometry@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "A major gamma-ray space observatory has detected a TeV flare from the blazar Markarian 421. Using the ATel alert at ~/Documents/atel_alert.txt, capture a multi-band (B, V, R) photometric sequence of the blazar to measure its Spectral Energy Distribution. Generate a false-color 'heat' palette sky view for a press release and draft an optical counterpart report, saving both to ~/Documents/.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 90,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/blazar_outburst_photometry/setup_task.sh",
    "post_task": "/workspace/tasks/blazar_outburst_photometry/export_result.sh"
  },
  "metadata": {
    "target_name": "Markarian 421",
    "target_ra_hours": 11.074,
    "target_dec_degrees": 38.208,
    "coordinate_tolerance_arcmin": 30,
    "required_filters": [
      "B",
      "V",
      "R"
    ],
    "filter_slots": {
      "B": 3,
      "V": 2,
      "R": 4
    },
    "expected_exposures": {
      "B": 120,
      "V": 60,
      "R": 60
    },
    "min_fits_per_filter": 5,
    "upload_dir": "/home/ga/Images/blazar/mrk421",
    "sky_view_path": "/home/ga/Images/blazar/mrk421/mrk421_xray_analog.png",
    "report_path": "/home/ga/Documents/optical_counterpart_report.txt",
    "atel_path": "/home/ga/Documents/atel_alert.txt",
    "occupation": "Astrophysicists",
    "industry": "Scientific Research / Time-Domain Astronomy"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_blazar_outburst_photometry"
    }
  }
}
