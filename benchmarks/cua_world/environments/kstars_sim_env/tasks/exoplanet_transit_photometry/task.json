{
  "id": "exoplanet_transit_photometry@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "A predicted transit of the hot Jupiter HD 189733 b is occurring tonight. Following the observation requirements in ~/Documents/transit_prediction.txt, configure the observatory and conduct a time-series imaging sequence of the transit. Save a sky view to ~/Images/transits/hd189733b/sky_view.png and produce an ETD-compatible transit observation log at ~/Documents/transit_log.txt.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 1800,
    "max_steps": 150,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/exoplanet_transit_photometry/setup_task.sh",
    "post_task": "/workspace/tasks/exoplanet_transit_photometry/export_result.sh"
  },
  "metadata": {
    "target_name": "HD 189733",
    "target_ra_hours": 20.0121,
    "target_dec_degrees": 22.7108,
    "coordinate_tolerance_arcmin": 15.0,
    "required_filter_slot": 2,
    "required_defocus_position": 30500,
    "defocus_tolerance": 200,
    "min_fits_count": 15,
    "upload_dir": "/home/ga/Images/transits/hd189733b",
    "report_path": "/home/ga/Documents/transit_log.txt",
    "prediction_path": "/home/ga/Documents/transit_prediction.txt",
    "occupation": "Astronomer",
    "industry": "Scientific Research / Exoplanet Detection"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_exoplanet_transit_photometry"
    }
  }
}
