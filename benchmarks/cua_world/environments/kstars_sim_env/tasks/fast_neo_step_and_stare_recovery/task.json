{
  "id": "fast_neo_step_and_stare_recovery@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "Execute a 5-waypoint \"step-and-stare\" observing sequence for Asteroid 99942 Apophis using the ephemeris at ~/Documents/apophis_ephemeris.txt. Capture 10-second LIGHT exposures with the Clear/Luminance filter (Slot 1) and save them to /home/ga/Images/neo_tracking/. Produce an infinitely looping animated GIF at /home/ga/Images/neo_tracking/neo_animation.gif with a 500ms frame duration, using a Python script to normalize the FITS arrays (min to 0, 99th percentile to 255).",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/fast_neo_step_and_stare_recovery/setup_task.sh",
    "post_task": "/workspace/tasks/fast_neo_step_and_stare_recovery/export_result.sh"
  },
  "metadata": {
    "target_name": "99942 Apophis",
    "waypoints": [
      {
        "ra": 9.75,
        "dec": 20.25
      },
      {
        "ra": 9.7833,
        "dec": 19.8333
      },
      {
        "ra": 9.8167,
        "dec": 19.4167
      },
      {
        "ra": 9.85,
        "dec": 19.0
      },
      {
        "ra": 9.8833,
        "dec": 18.5833
      }
    ],
    "coordinate_tolerance_deg": 0.15,
    "required_filter_slot": 1,
    "exposure_sec": 10,
    "upload_dir": "/home/ga/Images/neo_tracking",
    "ephemeris_path": "/home/ga/Documents/apophis_ephemeris.txt",
    "gif_path": "/home/ga/Images/neo_tracking/neo_animation.gif",
    "occupation": "Planetary Scientist",
    "industry": "Planetary Defense / Asteroid Tracking"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_fast_neo_step_and_stare"
    }
  }
}
