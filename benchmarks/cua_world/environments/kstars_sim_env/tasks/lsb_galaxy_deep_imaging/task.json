{
  "id": "lsb_galaxy_deep_imaging@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "An observing plan for Malin 1, a massive but extremely faint Low Surface Brightness (LSB) galaxy, is located at ~/Documents/lsb_imaging_plan.txt. Configure the CCD for active cooling and hardware pixel binning, then execute the sequence as specified in the plan to generate the required session artifacts.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/lsb_galaxy_deep_imaging/setup_task.sh",
    "post_task": "/workspace/tasks/lsb_galaxy_deep_imaging/export_result.sh"
  },
  "metadata": {
    "target_name": "Malin 1",
    "target_ra_hours": 12.6165,
    "target_dec_degrees": 13.9983,
    "coordinate_tolerance_arcmin": 30,
    "required_filter": "Luminance",
    "required_exposure_sec": 300,
    "required_binning": 2,
    "required_temp_c": -20.0,
    "min_fits_count": 4,
    "upload_dir": "/home/ga/Images/lsb/malin1",
    "sky_capture_path": "/home/ga/Images/lsb/malin1/malin1_sky.png",
    "report_path": "/home/ga/Documents/malin1_report.txt",
    "plan_path": "/home/ga/Documents/lsb_imaging_plan.txt",
    "occupation": "Astronomers and Space Scientists",
    "industry": "Extragalactic Astronomy / Deep Imaging"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_lsb_galaxy_deep_imaging"
    }
  }
}
