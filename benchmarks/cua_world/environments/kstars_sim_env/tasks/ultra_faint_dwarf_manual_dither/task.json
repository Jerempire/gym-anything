      },
      "north": {
        "ra": 10.1411,
        "dec": 12.3897
      },
      "south": {
        "ra": 10.1411,
        "dec": 12.2231
      },
      "east": {
        "ra": 10.1468,
        "dec": 12.3064
      },
      "west": {
        "ra": 10.1354,
        "dec": 12.3064
      }
    },
    "coord_tolerance_ra": 0.005,
    "coord_tolerance_dec": 0.02
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ultra_faint_dwarf_manual_dither"
    }
  }
