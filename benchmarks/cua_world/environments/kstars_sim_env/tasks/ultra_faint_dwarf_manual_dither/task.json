{
  "id": "ultra_faint_dwarf_manual_dither@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "The automated observing sequencer at the observatory has crashed. Execute a 5-point 'cross' dither pattern for deep imaging of the Leo I dwarf spheroidal galaxy, starting from the current parked position near Regulus. Follow the dither plan, offset coordinates, and storage requirements detailed in ~/Documents/dither_plan.txt to capture frames into the specified directories and provide a final log.",
