{
  "id": "grb_too_response@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "An automated GCN trigger has been received for the optical afterglow of GRB 221009A. Interrupt current operations near Polaris to execute the two-phase Target-of-Opportunity (ToO) imaging protocol for the target using the alert notice at ~/Documents/gcn_alert.txt and the protocol at ~/Documents/too_protocol.txt. Generate the required GCN Circular report.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/grb_too_response/setup_task.sh",
    "post_task": "/workspace/tasks/grb_too_response/export_result.sh"
  },
  "metadata": {
    "target_name": "GRB 221009A",
    "target_ra_hours": 19.2176,
    "target_dec_degrees": 19.7733,
    "coordinate_tolerance_arcmin": 15,
    "required_filter_slot": 1,
    "conf_exposure": 10,
    "sci_exposure": 30,
    "min_conf_frames": 3,
    "min_sci_frames": 10,
    "upload_base": "/home/ga/Images/grb/221009A",
    "report_path": "/home/ga/Documents/gcn_circular.txt",
    "occupation": "Observatory Operator",
    "industry": "Transient Astronomy / Time-Domain Astrophysics"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_grb_too_response"
    }
  }
}
