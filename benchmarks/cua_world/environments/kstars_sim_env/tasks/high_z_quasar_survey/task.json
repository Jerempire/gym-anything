{
  "id": "high_z_quasar_survey@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "Execute the baseline photometric survey of three hyper-luminous quasars (3C 273, TON 618, PG 1634+706) following the observation plan at ~/Documents/quasar_survey_plan.txt. The survey requires capturing Luminance (L) and Red (R) exposures into their respective directories, fetching 'cool' palette DSS2 reference images, and saving a session summary log to ~/Documents/summary_log.txt.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/high_z_quasar_survey/setup_task.sh",
    "post_task": "/workspace/tasks/high_z_quasar_survey/export_result.sh"
  },
  "metadata": {
    "targets": [
      {
        "name": "3C273",
        "ra": 12.485,
        "dec": 2.052,
        "tol": 0.5
      },
      {
        "name": "TON618",
        "ra": 12.474,
        "dec": 35.967,
        "tol": 0.5
      },
      {
        "name": "PG1634",
        "ra": 16.575,
        "dec": 70.526,
        "tol": 0.5
      }
    ],
    "filters": [
      "L",
      "R"
    ],
    "min_exposures_per_filter": 3,
    "log_path": "/home/ga/Documents/quasar_survey_log.txt",
    "occupation": "Astronomers and Space Scientists",
    "industry": "Observational Cosmology"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_high_z_quasar_survey"
    }
  }
}
