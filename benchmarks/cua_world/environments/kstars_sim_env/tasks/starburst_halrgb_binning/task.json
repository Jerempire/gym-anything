{
  "id": "starburst_halrgb_binning@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "Execute a hybrid HaLRGB imaging sequence on the starburst galaxy M82 (Cigar Galaxy) to capture its bipolar outflow. Use the imaging plan at ~/Documents/m82_imaging_plan.txt for target coordinates, filter sequence, binning requirements, and exposure times. Save the captured frames to the appropriate subdirectories, capture a sky view, and produce an observation log.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/starburst_halrgb_binning/setup_task.sh",
    "post_task": "/workspace/tasks/starburst_halrgb_binning/export_result.sh"
  },
  "metadata": {
    "target_name": "M82",
    "target_ra_hours": 9.9311,
    "target_dec_degrees": 69.6797,
    "coordinate_tolerance_arcmin": 15,
    "required_filters": [
      "L",
      "R",
      "G",
      "B",
      "Ha"
    ],
    "l_slot": 1,
    "g_slot": 2,
    "b_slot": 3,
    "r_slot": 4,
    "ha_slot": 5,
    "min_fits_per_filter": 5,
    "upload_dir_base": "/home/ga/Images/m82_superwind",
    "sky_view_path": "/home/ga/Images/m82_superwind/m82_sky_view.png",
    "log_path": "/home/ga/Documents/m82_observation_log.txt",
    "plan_path": "/home/ga/Documents/m82_imaging_plan.txt",
    "occupation": "Astrophysicist / Observatory Technician",
    "industry": "Astronomical Research / Astrophotography"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_starburst_halrgb_binning"
    }
  }
}
