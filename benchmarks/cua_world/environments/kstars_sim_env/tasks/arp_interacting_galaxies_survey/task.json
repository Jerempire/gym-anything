{
  "id": "arp_interacting_galaxies_survey@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "Execute an extragalactic imaging survey of four interacting galaxy pairs from the Arp Atlas using the target list at ~/Documents/arp_merger_targets.txt. Capture FITS exposures and sky view morphology images for each target and compile the survey results into a JSON observation log at ~/Documents/arp_survey_log.json.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/arp_interacting_galaxies_survey/setup_task.sh",
    "post_task": "/workspace/tasks/arp_interacting_galaxies_survey/export_result.sh"
  },
  "metadata": {
    "targets": [
      "arp244",
      "arp273",
      "arp242",
      "arp81"
    ],
    "required_filter": "Luminance",
    "required_filter_slot": 1,
    "required_exposure_sec": 120,
    "min_fits_per_target": 3,
    "fov_degrees": 0.5,
    "palette": "vibrant",
    "base_upload_dir": "/home/ga/Images/arp_survey",
    "log_path": "/home/ga/Documents/arp_survey_log.json",
    "targets_file_path": "/home/ga/Documents/arp_merger_targets.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_arp_interacting_galaxies_survey"
    }
  }
}
