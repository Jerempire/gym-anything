{
  "id": "narrowband_sho_nebula@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "A narrowband emission nebula imaging session has been queued for tonight. Execute the SHO narrowband sequence and produce the composite image following the target selection, filter sequence, and output requirements specified in ~/Documents/imaging_plan.txt.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 90,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/narrowband_sho_nebula/setup_task.sh",
    "post_task": "/workspace/tasks/narrowband_sho_nebula/export_result.sh"
  },
  "metadata": {
    "target_name": "NGC 7000 (North America Nebula)",
    "target_ra_hours": 20.979,
    "target_dec_degrees": 44.334,
    "coordinate_tolerance_arcmin": 30,
    "required_filters": [
      "Ha",
      "OIII",
      "SII"
    ],
    "ha_slot": 5,
    "oiii_slot": 6,
    "sii_slot": 4,
    "min_fits_per_filter": 5,
    "upload_dir_base": "/home/ga/Images/ngc7000/narrowband",
    "composite_path": "/home/ga/Images/ngc7000/composite_sho.png",
    "plan_path": "/home/ga/Documents/imaging_plan.txt",
    "occupation": "Astrophotographers",
    "industry": "Astrophotography / Narrowband Imaging"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_narrowband_sho_nebula"
    }
  }
}
