{
  "id": "agn_reverberation_mapping@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "Execute the nightly reverberation mapping protocol for the Seyfert galaxy NGC 4151 according to the schedule at ~/Documents/reverb_mapping_schedule.txt. Capture V-band continuum frames into the 'V/' directory and H-alpha frames into the 'Ha/' directory. Generate a reference sky view using the provided script and write an observation log, ensuring strict directory isolation between the filter sets.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/agn_reverberation_mapping/setup_task.sh",
    "post_task": "/workspace/tasks/agn_reverberation_mapping/export_result.sh"
  },
  "metadata": {
    "target_name": "NGC 4151",
    "target_ra_hours": 12.1755,
    "target_dec_degrees": 39.4058,
    "coordinate_tolerance_arcmin": 20,
    "v_slot": 2,
    "ha_slot": 5,
    "v_exptime": 60,
    "ha_exptime": 120,
    "v_min_count": 10,
    "ha_min_count": 8,
    "base_dir": "/home/ga/Images/reverb/ngc4151",
    "sky_view_cmd": "bash ~/capture_sky_view.sh ~/Images/reverb/ngc4151/reference_fov.png 0.5 --palette vibrant",
    "log_path": "/home/ga/Documents/ngc4151_obs_log.txt",
    "schedule_path": "/home/ga/Documents/reverb_mapping_schedule.txt",
    "occupation": "Astrophysicist",
    "industry": "Scientific Research / AGN Monitoring"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_agn_reverberation_mapping"
    }
  }
}
