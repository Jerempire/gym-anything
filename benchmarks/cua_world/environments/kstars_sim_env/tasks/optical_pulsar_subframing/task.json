{
  "id": "optical_pulsar_subframing@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "An astrophysicist studying the Crab Pulsar (PSR B0531+21) needs a high-cadence time-domain observation block. Conduct the observation sequence for the Crab Pulsar using the parameters specified in ~/Documents/pulsar_observation_plan.txt (Filter: Luminance, Binning: 2x2, Subframe: 256x256 at X=512, Y=512, Exposure: 0.5s, Sequence: 30 frames). Capture a DSS2 field context image using the provided shell script as requested in the plan.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/optical_pulsar_subframing/setup_task.sh",
    "post_task": "/workspace/tasks/optical_pulsar_subframing/export_result.sh"
  },
  "metadata": {
    "target_name": "Crab Pulsar",
    "target_ra_hours": 5.5755,
    "target_dec_degrees": 22.0144,
    "coordinate_tolerance_deg": 1.0,
    "required_filter_slot": 1,
    "required_binning": 2,
    "max_naxis1": 256,
    "required_exposure_sec": 0.5,
    "min_fits_count": 30,
    "upload_dir": "/home/ga/Images/pulsar_data/crab",
    "context_image_path": "/home/ga/Images/pulsar_data/crab_context.png",
    "plan_path": "/home/ga/Documents/pulsar_observation_plan.txt",
    "occupation": "Astronomers and Space Scientists",
    "industry": "Time-Domain Astrophysics"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_optical_pulsar_subframing"
    }
  }
}
