{
  "id": "xray_optical_counterpart_search@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "An X-ray observatory has published an alert circular containing the coordinates of three active X-ray binaries. Capture deep optical baseline images in the B (blue) and V (visual) bands and reference sky maps using the 'cool' palette for each target listed in ~/Documents/xray_targets.txt. Organize the data into target-specific subdirectories in ~/Documents/ and provide a summary report at ~/Documents/summary_report.txt.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 90,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/xray_optical_counterpart_search/setup_task.sh",
    "post_task": "/workspace/tasks/xray_optical_counterpart_search/export_result.sh"
  },
  "metadata": {
    "targets": {
      "cygx1": {
        "ra": 19.972,
        "dec": 35.201
      },
      "scox1": {
        "ra": 16.332,
        "dec": -15.64
      },
      "v404cyg": {
        "ra": 20.401,
        "dec": 33.867
      }
    },
    "required_filters": [
      "B",
      "V"
    ],
    "required_frames_per_filter": 5,
    "required_exposure_sec": 20,
    "base_upload_dir": "/home/ga/Images/xray_followup",
    "report_path": "/home/ga/Documents/optical_followup_report.txt",
    "occupation": "Astronomers and Space Scientists",
    "industry": "Time-Domain Astronomy / Observational Astrophysics"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_xray_optical_counterpart_search"
    }
  }
}
