{
  "id": "eb_minimum_timing@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "An urgent timing alert has been issued by the AAVSO Eclipsing Binary Section for Algol (Beta Persei). Execute the rapid-cadence observation sequence and produce the required O-C timing report following the target details, ephemeris, cadence, and output requirements specified in ~/Documents/eb_timing_alert.txt.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 90,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/eb_minimum_timing/setup_task.sh",
    "post_task": "/workspace/tasks/eb_minimum_timing/export_result.sh"
  },
  "metadata": {
    "target_name": "Algol (Beta Persei)",
    "target_ra_hours": 3.1361,
    "target_dec_degrees": 40.9556,
    "coordinate_tolerance_arcmin": 30,
    "required_filter_slot": 2,
    "required_exposure_sec": 10,
    "min_fits_count": 20,
    "upload_dir": "/home/ga/Images/eb_timing/algol",
    "report_path": "/home/ga/Documents/algol_oc_report.txt",
    "alert_path": "/home/ga/Documents/eb_timing_alert.txt",
    "occupation": "Astronomers and Space Scientists",
    "industry": "Scientific Research / Time-Domain Astronomy"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_eb_minimum_timing"
    }
  }
}
