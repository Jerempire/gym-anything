{
  "id": "ccd_instrument_commissioning@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "A new CCD camera and filter wheel have been installed at the observatory. Complete the first-light engineering commissioning for the Pleiades (M45) as specified in the checklist at ~/Documents/commissioning_checklist.txt. Verify hardware modes through filter, binning, and ROI tests, organize the resulting FITS files into the designated directories, and save a summary report to ~/Documents/summary_report.txt.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/ccd_instrument_commissioning/setup_task.sh",
    "post_task": "/workspace/tasks/ccd_instrument_commissioning/export_result.sh"
  },
  "metadata": {
    "target_name": "M45 (Pleiades)",
    "target_ra_hours": 3.79,
    "target_dec_degrees": 24.116,
    "coordinate_tolerance_arcmin": 60,
    "expected_binning_levels": [
      1,
      2,
      3,
      4
    ],
    "expected_roi_size": 1024,
    "required_filters_count": 6,
    "base_dir": "/home/ga/Images/commissioning",
    "report_path": "/home/ga/Documents/commissioning_report.txt",
    "checklist_path": "/home/ga/Documents/commissioning_checklist.txt",
    "occupation": "Optical Engineers / Observatory Technicians",
    "industry": "Observatory Operations / Instrument Commissioning"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ccd_instrument_commissioning"
    }
  }
}
