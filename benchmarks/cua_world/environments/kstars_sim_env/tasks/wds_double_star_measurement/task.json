{
  "id": "wds_double_star_measurement@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "The Washington Double Star (WDS) catalog program coordinator at the US Naval Observatory has requested measurements for three neglected double star systems identified in ~/Documents/wds_request.txt. Capture CCD images for each system into the designated per-target upload directories and produce a WDS-format measurement report for submission.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/wds_double_star_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/wds_double_star_measurement/export_result.sh"
  },
  "metadata": {
    "targets": {
      "albireo": {
        "ra": 19.512,
        "dec": 27.96
      },
      "61cyg": {
        "ra": 21.115,
        "dec": 38.749
      },
      "eta_cas": {
        "ra": 0.818,
        "dec": 57.815
      }
    },
    "upload_dirs": {
      "albireo": "/home/ga/Images/doubles/albireo",
      "61cyg": "/home/ga/Images/doubles/61cyg",
      "eta_cas": "/home/ga/Images/doubles/eta_cas"
    },
    "report_path": "/home/ga/Documents/wds_measurements.txt",
    "request_path": "/home/ga/Documents/wds_request.txt",
    "coordinate_tolerance_arcmin": 30.0,
    "min_fits_per_target": 3,
    "occupation": "Astronomers and Space Scientists",
    "industry": "Scientific Research / Astrometry / Washington Double Star Catalog"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_wds_double_star_measurement"
    }
  }
}
