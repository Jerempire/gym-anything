{
  "id": "interstellar_object_rapid_acquisition@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "An urgent Target of Opportunity (ToO) alert has been issued for an interstellar object (C/2026) with details at ~/Documents/iso_too_alert.txt. Because it is a fast mover, image the target using 2x2 hardware binning and short exposures. Generate a thermal proxy map and a confirmation report.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/interstellar_object_rapid_acquisition/setup_task.sh",
    "post_task": "/workspace/tasks/interstellar_object_rapid_acquisition/export_result.sh"
  },
  "metadata": {
    "target_name": "C/2026",
    "target_ra_hours": 18.6155,
    "target_dec_degrees": 38.7836,
    "coordinate_tolerance_arcmin": 20,
    "required_binning": 2,
    "required_exposure_sec": 5.0,
    "min_fits_count": 15,
    "upload_dir": "/home/ga/Images/ISO_C2026",
    "proxy_image_path": "/home/ga/Images/ISO_C2026/thermal_proxy.png",
    "report_path": "/home/ga/Documents/iso_report.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_interstellar_object_rapid_acquisition"
    }
  }
}
