{
  "id": "asteroid_occultation_timing@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "An IOTA (International Occultation Timing Association) prediction alert has been issued for an occultation of the star TYC 6815-00874-1 by the asteroid (52) Europa tonight. Using the prediction and observing instructions in ~/Documents/iota_prediction.txt, capture the rapid-cadence image sequence, generate the required sky view, and submit the IOTA-format observation report.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 90,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/asteroid_occultation_timing/setup_task.sh",
    "post_task": "/workspace/tasks/asteroid_occultation_timing/export_result.sh"
  },
  "metadata": {
    "target_name": "(52) Europa / TYC 6815-00874-1",
    "target_ra_hours": 17.2117,
    "target_dec_degrees": -24.8583,
    "coordinate_tolerance_arcmin": 15,
    "required_filter_slot": 1,
    "required_exposure_sec": 2,
    "min_fits_count": 40,
    "upload_dir": "/home/ga/Images/occultations/52europa/",
    "report_path": "/home/ga/Documents/iota_occultation_report.txt",
    "prediction_path": "/home/ga/Documents/iota_prediction.txt",
    "occupation": "Astronomers and Space Scientists",
    "industry": "Planetary Science / Asteroid Characterization"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_asteroid_occultation_timing"
    }
  }
}
