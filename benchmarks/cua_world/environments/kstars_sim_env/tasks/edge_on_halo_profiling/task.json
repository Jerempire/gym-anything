{
  "id": "edge_on_halo_profiling@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "An extragalactic astronomer studying the vertical structure of NGC 891 needs a multi-resolution imaging sequence. Using the profiling plan and CCD configurations specified in ~/Documents/ngc891_profiling_plan.txt, capture the required unbinned and binned sequences into their respective directories, perform a sky field survey, and generate an observation log.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 90,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/edge_on_halo_profiling/setup_task.sh",
    "post_task": "/workspace/tasks/edge_on_halo_profiling/export_result.sh"
  },
  "metadata": {
    "target_name": "NGC 891",
    "target_ra_hours": 2.3758,
    "target_dec_degrees": 42.349,
    "coordinate_tolerance_arcmin": 30,
    "v_band_slot": 2,
    "l_band_slot": 1,
    "v_band_binning": 1,
    "l_band_binning": 2,
    "ccd_temp_max": -10.0,
    "min_fits_per_sequence": 5,
    "plan_path": "/home/ga/Documents/ngc891_profiling_plan.txt",
    "occupation": "Astronomers and Space Scientists",
    "industry": "Observational Extragalactic Astronomy"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_edge_on_halo_profiling"
    }
  }
}
