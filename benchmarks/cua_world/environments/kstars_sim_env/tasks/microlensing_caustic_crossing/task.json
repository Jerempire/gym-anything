{
  "id": "microlensing_caustic_crossing@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "An urgent alert from the OGLE network indicates a microlensing event (OGLE-2026-BLG-0042) is undergoing a rapid caustic crossing. The telescope is currently parked and tracking is disabled. Using the alert details in ~/Documents/ogle_alert.txt, perform a high-cadence R-band time-series observation of the target. Document the observation with a sky view capture and a summary log.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/microlensing_caustic_crossing/setup_task.sh",
    "post_task": "/workspace/tasks/microlensing_caustic_crossing/export_result.sh"
  },
  "metadata": {
    "target_name": "OGLE-2026-BLG-0042",
    "target_ra_hours": 17.90888,
    "target_dec_degrees": -30.2125,
    "coordinate_tolerance_arcmin": 30,
    "required_filter_slot": 4,
    "required_exposure_sec": 15,
    "min_fits_count": 15,
    "upload_dir": "/home/ga/Images/microlensing/OGLE-2026-BLG-0042",
    "report_path": "/home/ga/Documents/microlensing_response.txt",
    "alert_path": "/home/ga/Documents/ogle_alert.txt",
    "occupation": "Astronomer",
    "industry": "Time-Domain Astronomy"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_microlensing_caustic_crossing"
    }
  }
}
