{
  "id": "wolf_rayet_bubble_survey@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "Execute a narrowband imaging survey of three Galactic Wolf-Rayet stars using the observing plan at ~/Documents/wr_target_list.txt. Capture at least two 60-second exposures per filter per target. Save FITS files and 'cool' palette false-color images to ~/Images/WR_survey/<Target_Name>/<Filter>/ and save the summary report to ~/Documents/wr_survey_report.txt.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/wolf_rayet_bubble_survey/setup_task.sh",
    "post_task": "/workspace/tasks/wolf_rayet_bubble_survey/export_result.sh",
    "pre_task_timeout": 300
  },
  "metadata": {
    "targets": [
      "WR 136",
      "WR 7",
      "WR 134"
    ],
    "required_filters": [
      "Ha",
      "OIII"
    ],
    "required_exposure_sec": 60,
    "base_dir": "/home/ga/Images/WR_survey",
    "report_path": "/home/ga/Documents/wr_survey_report.md",
    "plan_path": "/home/ga/Documents/wr_target_list.txt",
    "occupation": "Stellar Astrophysicists",
    "industry": "Scientific Research / Stellar Astrophysics"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_wolf_rayet_bubble_survey"
    }
  }
}
