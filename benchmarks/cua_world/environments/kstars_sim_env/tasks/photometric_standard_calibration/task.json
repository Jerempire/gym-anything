{
  "id": "photometric_standard_calibration@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "The observatory's CCD photometric calibration is overdue before the next science observing run. Complete the photometric standard star calibration session as specified in ~/Documents/phot_cal_spec.txt and deliver all required output files.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 90,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/photometric_standard_calibration/setup_task.sh",
    "post_task": "/workspace/tasks/photometric_standard_calibration/export_result.sh"
  },
  "metadata": {
    "target_name": "SA 98 (Landolt standard field)",
    "target_ra_hours": 6.86,
    "target_dec_degrees": -0.283,
    "coordinate_tolerance_arcmin": 30,
    "required_filters": [
      "B",
      "V",
      "R"
    ],
    "required_filter_slots": [
      3,
      2,
      4
    ],
    "min_fits_per_filter": 5,
    "upload_dir": "/home/ga/Images/photcal/sa98",
    "catalog_path": "/home/ga/Images/photcal/sa98/calibration_catalog.txt",
    "spec_path": "/home/ga/Documents/phot_cal_spec.txt",
    "occupation": "Astronomers and Space Scientists",
    "industry": "Photometric Calibration / Observatory Operations"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_photometric_standard_calibration"
    }
  }
}
