{
  "id": "ccd_thermal_dark_characterization@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "Perform a thermal characterization of the CCD camera as specified in ~/Documents/thermal_calibration_request.txt. Capture three 60-second dark frames at each stabilized temperature setpoint (0°C, -10°C, and -20°C) into subdirectories under ~/Calibration/thermal/. Create a summary report confirming the successful setpoints at ~/Documents/thermal_report.txt.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/ccd_thermal_dark_characterization/setup_task.sh",
    "post_task": "/workspace/tasks/ccd_thermal_dark_characterization/export_result.sh"
  },
  "metadata": {
    "base_dir": "/home/ga/Calibration/thermal",
    "subdirs": [
      "0C",
      "minus10C",
      "minus20C"
    ],
    "target_temps": [
      0,
      -10,
      -20
    ],
    "exposure_sec": 60,
    "required_frames_per_temp": 3,
    "temp_tolerance_celsius": 1.5,
    "report_path": "/home/ga/Documents/thermal_report.txt",
    "spec_path": "/home/ga/Documents/thermal_calibration_request.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ccd_thermal_dark_characterization"
    }
  }
}
