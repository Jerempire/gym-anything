{
  "id": "telescope_collimation_star_test@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "Perform an optical collimation star test on Capella using the V-band filter at focus positions 50000, 40000, and 60000. Save the FITS files with focus position prefixes, a sky context capture, and a completion report to the upload directory. Refer to ~/Documents/maintenance_ticket_104.txt for coordinates and procedure details.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/telescope_collimation_star_test/setup_task.sh",
    "post_task": "/workspace/tasks/telescope_collimation_star_test/export_result.sh"
  },
  "metadata": {
    "target_name": "Capella",
    "target_ra_hours": 5.278,
    "target_dec_degrees": 45.998,
    "required_filter_slot": 2,
    "focus_nominal": 50000,
    "focus_intra": 40000,
    "focus_extra": 60000,
    "output_dir": "/home/ga/Maintenance/collimation_test",
    "report_path": "/home/ga/Maintenance/collimation_test/report.txt",
    "context_path": "/home/ga/Maintenance/collimation_test/field_context.png"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_collimation_star_test"
    }
  }
}
