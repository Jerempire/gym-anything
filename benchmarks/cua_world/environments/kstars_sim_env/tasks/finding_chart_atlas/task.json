{
  "id": "finding_chart_atlas@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "A visiting astronomer has requested a finding chart atlas for their upcoming remote observing run. Using the target list and requirements in ~/Documents/observing_plan.txt, generate finding charts for each target with the specified FOV and palette. Save the charts and the required atlas index file to the directory specified in the plan.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/finding_chart_atlas/setup_task.sh",
    "post_task": "/workspace/tasks/finding_chart_atlas/export_result.sh"
  },
  "metadata": {
    "plan_path": "/home/ga/Documents/observing_plan.txt",
    "output_dir": "/home/ga/Images/finding_charts",
    "targets": [
      {
        "name": "Abell 2218",
        "ra_h": 16.5983,
        "dec_deg": 66.2,
        "filename": "abell2218_fc.png"
      },
      {
        "name": "M1 (Crab Nebula)",
        "ra_h": 5.5756,
        "dec_deg": 22.0144,
        "filename": "m1_crab_fc.png"
      },
      {
        "name": "Sgr A*",
        "ra_h": 17.7611,
        "dec_deg": -29.0078,
        "filename": "sgra_gc_fc.png"
      },
      {
        "name": "3C 273",
        "ra_h": 12.4853,
        "dec_deg": 2.0525,
        "filename": "3c273_fc.png"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_finding_chart_atlas"
    }
  }
}
