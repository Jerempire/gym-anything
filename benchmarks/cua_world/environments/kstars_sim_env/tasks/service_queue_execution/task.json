{
  "id": "service_queue_execution@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "You are the service observer at a shared observatory tonight. Execute the three PI programs listed in ~/Documents/observing_queue.txt. Configure the telescope and CCD for each target, capture a final sky view to ~/Images/queue/final_sky.png, and create a session log at ~/Documents/session_log.txt.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/service_queue_execution/setup_task.sh",
    "post_task": "/workspace/tasks/service_queue_execution/export_result.sh"
  },
  "metadata": {
    "targets": [
      "M44",
      "NGC 2392",
      "M51"
    ],
    "m44_target_count": 10,
    "ngc2392_target_count": 6,
    "m51_target_count": 8,
    "occupation": "Observatory Operator / Service Observer",
    "industry": "Professional Observatory Operations"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_service_queue_execution"
    }
  }
}
