{
  "id": "supernova_photometric_classification@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "A ZTF transient alert reports a supernova candidate near host galaxy NGC 4526. As the on-duty transient astronomer, perform a complete photometric classification following the standard follow-up protocol detailed in ~/Documents/ztf_alert_AT2026xy.txt. This requires acquiring reference images of the host galaxy, multi-band (B/V/R) science photometry of the candidate, and calibration frames of a Landolt standard star field. Then write a Python data-reduction script using astropy that computes calibrated magnitudes and color indices from the captured FITS data, and draft an ATel (Astronomer's Telegram) reporting your classification results.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 3600,
    "max_steps": 300,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/supernova_photometric_classification/setup_task.sh",
    "post_task": "/workspace/tasks/supernova_photometric_classification/export_result.sh"
  },
  "metadata": {
    "candidate_designation": "AT2026xy",
    "candidate_ra_hours": 12.5644,
    "candidate_dec_degrees": 7.6967,
    "host_galaxy": "NGC 4526",
    "host_ra_hours": 12.5675,
    "host_dec_degrees": 7.6992,
    "standard_field": "SA 104",
    "standard_ra_hours": 12.7,
    "standard_dec_degrees": -0.5333,
    "coordinate_tolerance_arcmin": 20,
    "reference_filter_slot": 1,
    "science_filter_slots": {"B": 3, "V": 2, "R": 4},
    "reference_exposure_sec": 60,
    "science_exposure_sec": 30,
    "standard_exposure_sec": 15,
    "min_reference_frames": 3,
    "min_science_frames_per_filter": 5,
    "min_standard_frames_per_filter": 3,
    "base_dir": "/home/ga/Images/sn_followup",
    "script_path": "/home/ga/reduce_photometry.py",
    "classification_json_path": "/home/ga/classification.json",
    "atel_path": "/home/ga/Documents/atel_draft.txt",
    "alert_path": "/home/ga/Documents/ztf_alert_AT2026xy.txt",
    "standard_mags": {"B": 11.24, "V": 10.51, "R": 10.12},
    "occupation": "Transient Astronomer",
    "industry": "Time-Domain Astrophysics / Supernova Classification"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_supernova_photometric_classification"
    }
  }
}
