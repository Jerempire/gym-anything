{
  "id": "neo_astrometry_verification@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "Perform an independent astrometric verification of a near-Earth asteroid for the Minor Planet Center. Produce an MPC-format astrometry report using the target ephemeris and measurement protocol provided in ~/Documents/neo_obs_request.txt.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 90,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/neo_astrometry_verification/setup_task.sh",
    "post_task": "/workspace/tasks/neo_astrometry_verification/export_result.sh"
  },
  "metadata": {
    "target_name": "2020 QG",
    "target_ra_hours": 16.883,
    "target_dec_degrees": -21.917,
    "coordinate_tolerance_deg": 2.0,
    "min_fits_count": 6,
    "exposure_sec": 30,
    "upload_dir": "/home/ga/Images/asteroids/2020QG",
    "report_path": "/home/ga/Documents/mpc_report.txt",
    "request_path": "/home/ga/Documents/neo_obs_request.txt",
    "occupation": "Astronomers and Space Scientists",
    "industry": "Planetary Defense / Near-Earth Object Observation"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_neo_astrometry_verification"
    }
  }
}
