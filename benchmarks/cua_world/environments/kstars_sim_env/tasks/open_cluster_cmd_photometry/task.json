{
  "id": "open_cluster_cmd_photometry@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "Collect multi-band (B and V) CCD photometry of the open cluster M44 (Praesepe / Beehive Cluster) for a thesis proposal defense. Execute the two-filter imaging sequence and produce a survey-quality sky view and CMD observation report based on the coordinates, parameters, and directory structure specified in ~/Documents/m44_observing_plan.txt.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/open_cluster_cmd_photometry/setup_task.sh",
    "post_task": "/workspace/tasks/open_cluster_cmd_photometry/export_result.sh"
  },
  "metadata": {
    "target_name": "M44 / Praesepe / NGC 2632",
    "target_ra_hours": 8.6733,
    "target_dec_degrees": 19.667,
    "coordinate_tolerance_arcmin": 30.0,
    "required_filters": [
      "B",
      "V"
    ],
    "b_slot": 3,
    "v_slot": 2,
    "b_exptime": 20,
    "v_exptime": 15,
    "min_fits_per_filter": 8,
    "upload_dir_base": "/home/ga/Images/m44_cmd",
    "sky_view_path": "/home/ga/Images/m44_cmd/m44_sky_view.png",
    "report_path": "/home/ga/Documents/m44_cmd_report.txt",
    "plan_path": "/home/ga/Documents/m44_observing_plan.txt",
    "occupation": "Graduate Student in Stellar Astrophysics",
    "industry": "Academic Research / Observational Stellar Astronomy"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_open_cluster_cmd_photometry"
    }
  }
}
