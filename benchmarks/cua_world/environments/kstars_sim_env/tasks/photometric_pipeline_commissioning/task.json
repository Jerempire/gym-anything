{
  "id": "photometric_pipeline_commissioning@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "Commission the observatory's photometric system by following the protocol in ~/Documents/commissioning_spec.txt. The CCD is currently defocused. The commissioning covers focus optimization, calibration frame acquisition, standard-field and science-target photometry in B and V bands, and a Python data-reduction pipeline that derives CCD characteristics and calibrated magnitudes from the captured FITS data. Save all quantitative results to ~/Documents/photometric_pipeline.json.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 3600,
    "max_steps": 350,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/photometric_pipeline_commissioning/setup_task.sh",
    "post_task": "/workspace/tasks/photometric_pipeline_commissioning/export_result.sh"
  },
  "metadata": {
    "focus_target": "Vega",
    "focus_target_ra_hours": 18.6156,
    "focus_target_dec_degrees": 38.7836,
    "focus_test_positions": [25000, 28000, 31000, 34000, 37000],
    "focus_exposure_sec": 10,
    "standard_field": "SA 98",
    "standard_ra_hours": 6.86,
    "standard_dec_degrees": -0.283,
    "science_target": "M67",
    "science_ra_hours": 8.855,
    "science_dec_degrees": 11.8,
    "coordinate_tolerance_arcmin": 30,
    "filter_slots": {"V": 2, "B": 3},
    "bias_count": 10,
    "flat_count": 10,
    "flat_exposure_sec": 5,
    "science_exposure_sec": 30,
    "science_frames_per_filter": 5,
    "standard_catalog_mags": {"V": 10.01, "B": 10.54},
    "focus_test_dir": "/home/ga/Images/focus_test",
    "calibration_bias_dir": "/home/ga/Calibration/bias",
    "calibration_flats_dir": "/home/ga/Calibration/flats_V",
    "science_sa98_v_dir": "/home/ga/Science/sa98_V",
    "science_sa98_b_dir": "/home/ga/Science/sa98_B",
    "science_m67_v_dir": "/home/ga/Science/m67_V",
    "science_m67_b_dir": "/home/ga/Science/m67_B",
    "focus_script_path": "/home/ga/find_best_focus.py",
    "pipeline_script_path": "/home/ga/reduce_and_calibrate.py",
    "output_json_path": "/home/ga/Documents/photometric_pipeline.json",
    "spec_path": "/home/ga/Documents/commissioning_spec.txt",
    "occupation": "Observatory Scientist",
    "industry": "Observational Astronomy / CCD Photometry"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_photometric_pipeline_commissioning"
    }
  }
