{
  "id": "virgo_sn_patrol@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "A coordinated supernova search program has assigned tonight's patrol of four bright Virgo Cluster galaxies. Following the assignment in ~/Documents/patrol_assignment.txt, capture CCD images of each galaxy into target-specific directories and generate a formatted patrol log summarizing the session.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 90,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/virgo_sn_patrol/setup_task.sh",
    "post_task": "/workspace/tasks/virgo_sn_patrol/export_result.sh"
  },
  "metadata": {
    "targets": [
      "M87",
      "M84",
      "M100",
      "M49"
    ],
    "min_frames_per_target": 4,
    "required_filter_slot": 1,
    "required_exposure_sec": 30,
    "patrol_base_dir": "/home/ga/Images/patrol/virgo",
    "log_path": "/home/ga/Images/patrol/virgo/patrol_log.txt",
    "assignment_path": "/home/ga/Documents/patrol_assignment.txt",
    "occupation": "Amateur Astronomer / Survey Participant",
    "industry": "Scientific Research / Transient Astronomy"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_virgo_sn_patrol"
    }
  }
}
