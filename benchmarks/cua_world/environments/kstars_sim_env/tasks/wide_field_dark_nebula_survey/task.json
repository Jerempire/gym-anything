{
  "id": "wide_field_dark_nebula_survey@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "An astrophotographer is building a wide-field catalog of Barnard Dark Nebulae, but the observatory CCD is currently configured for narrow-field imaging (2500mm focal length). Complete a multi-target imaging survey of three dark nebulae as specified in the plan at ~/Documents/dark_nebula_plan.txt, including reconfiguring the CCD simulator optics for wide-field imaging, capturing contextual sky views, and producing the requested survey log.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/wide_field_dark_nebula_survey/setup_task.sh",
    "post_task": "/workspace/tasks/wide_field_dark_nebula_survey/export_result.sh"
  },
  "metadata": {
    "targets": [
      {
        "name": "B33",
        "ra_hours": 5.683,
        "dec_deg": -2.458
      },
      {
        "name": "B143",
        "ra_hours": 19.678,
        "dec_deg": 10.95
      },
      {
        "name": "B86",
        "ra_hours": 18.05,
        "dec_deg": -27.866
      }
    ],
    "required_focal_length": 135,
    "required_aperture": 50,
    "min_fits_per_target": 2,
    "base_upload_dir": "/home/ga/Images/survey",
    "plan_path": "/home/ga/Documents/dark_nebula_plan.txt",
    "log_path": "/home/ga/Documents/survey_log.txt",
    "occupation": "Astrophotographers",
    "industry": "Astrophotography / Dark Nebula Survey"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_wide_field_dark_nebula_survey"
    }
  }
}
