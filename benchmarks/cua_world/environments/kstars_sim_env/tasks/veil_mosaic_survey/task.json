{
  "id": "veil_mosaic_survey@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "A PI running the Cygnus Loop Supernova Remnant Emission Survey has left a mosaic imaging plan at ~/Documents/mosaic_plan.txt. Execute the plan by capturing H-alpha frames for the specified panel coordinates and saving them to the respective subdirectories. Generate the required mosaic log at ~/Documents/mosaic_log.txt.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/veil_mosaic_survey/setup_task.sh",
    "post_task": "/workspace/tasks/veil_mosaic_survey/export_result.sh"
  },
  "metadata": {
    "target_name": "NGC 6992 (Eastern Veil Nebula)",
    "target_ra_hours": 20.94,
    "target_dec_degrees": 31.717,
    "required_filter_slot": 5,
    "frames_per_panel": 3,
    "panel_dirs": [
      "panel_1",
      "panel_2",
      "panel_3",
      "panel_4"
    ],
    "base_dir": "/home/ga/Images/veil_mosaic",
    "log_path": "/home/ga/Documents/mosaic_log.txt",
    "plan_path": "/home/ga/Documents/mosaic_plan.txt",
    "occupation": "Observational Astronomer / Survey Scientist",
    "industry": "Scientific Research / Supernova Remnant Surveys"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_veil_mosaic_survey"
    }
  }
}
