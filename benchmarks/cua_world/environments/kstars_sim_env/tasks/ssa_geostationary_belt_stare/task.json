{
  "id": "ssa_geostationary_belt_stare@1",
  "version": "1.0",
  "env_id": "kstars_sim_env@0.1",
  "description": "A Space Situational Awareness (SSA) tasking order has been issued to monitor a geostationary orbital intersection point. Using the tasking order at ~/Documents/ssa_tasking_order.txt, conduct a 'stare' mode observation with sidereal tracking disabled. Capture the sky view of the final field and save the SSA report to ~/Documents/ssa_report.txt.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/ssa_geostationary_belt_stare/setup_task.sh",
    "post_task": "/workspace/tasks/ssa_geostationary_belt_stare/export_result.sh"
  },
  "metadata": {
    "target_ra_hours": 21.25,
    "target_dec_degrees": -5.25,
    "required_filter_slot": 1,
    "required_exposure_sec": 30,
    "min_fits_count": 15,
    "upload_dir": "/home/ga/Images/SSA/geo_stare",
    "report_path": "/home/ga/Documents/ssa_report.txt",
    "tasking_order_path": "/home/ga/Documents/ssa_tasking_order.txt",
    "sky_view_path": "/home/ga/Images/SSA/geo_stare/sky_view.png",
    "occupation": "Space Situational Awareness Analyst",
    "industry": "Aerospace and Defense / Space Traffic Management"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ssa_geostationary_belt_stare"
    }
  }
}
