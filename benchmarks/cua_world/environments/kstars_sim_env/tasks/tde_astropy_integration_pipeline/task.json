  },
  "metadata": {
    "target_name": "ASASSN-14li",
    "target_ra_hours": 12.8042,
    "target_dec_degrees": 17.774,
    "coordinate_tolerance_arcmin": 30,
    "upload_dir": "/home/ga/Images/tde_monitoring/asassn14li",
    "brief_path": "/home/ga/Documents/tde_followup_brief.txt",
    "summary_json_path": "/home/ga/Documents/integration_summary.json",
    "b_band_slot": 3,
    "v_band_slot": 2,
    "b_band_exptime": 120,
    "v_band_exptime": 60,
    "required_new_frames_per_filter": 5,
    "occupation": "Astronomer",
    "industry": "Time-Domain Astronomy"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_tde_astropy_integration_pipeline"
