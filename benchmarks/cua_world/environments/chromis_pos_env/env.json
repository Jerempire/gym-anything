{
  "id": "chromis_pos_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Chromis POS environment - Java-based Point of Sale system with MariaDB backend, populated with real UK retail product data from UCI Online Retail Dataset",
  "category": "business",
  "tags": ["pos", "java", "retail", "mariadb", "swing"],
  "resources": {
    "cpu": 4,
    "mem_gb": 6,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "mounts": [
    {"source": "benchmarks/cua_world/environments/chromis_pos_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/chromis_pos_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/chromis_pos_env/data", "target": "/workspace/data", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/chromis_pos_env/tasks", "target": "/workspace/tasks", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_chromis.sh",
    "post_start": "/workspace/scripts/setup_chromis.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ],
  "vnc": {
    "enable": true,
    "password": "password"
  },
  "security": {
    "user": "root",
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  }
}
