{
  "id": "style_graduated_population_points@1",
  "version": "1.0",
  "env_id": "geo_server_env@0.1",
  "description": "Create a new SLD style named 'graduated_pop' in the 'ne' workspace and set it as the default style for the 'ne_populated_places' layer. The style must render points as orange circles (fill: #ff9900, stroke: #000000) with a dynamic size based on the 'pop_max' attribute using the formula: 6 + (pop_max / 1,000,000).",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/style_graduated_population_points/setup_task.sh",
    "post_task": "/workspace/tasks/style_graduated_population_points/export_result.sh"
  },
  "metadata": {
    "expected_style_name": "graduated_pop",
    "expected_workspace": "ne",
    "target_layer": "ne_populated_places",
    "formula_base": 6,
    "formula_divisor": 1000000,
    "formula_attribute": "pop_max",
    "fill_color": "#ff9900",
    "stroke_color": "#000000"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_style_graduated_population_points"
    }
  }
}
