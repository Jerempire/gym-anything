{
  "id": "wfs_t_update_feature@1",
  "version": "1.0",
  "env_id": "geo_server_env@0.1",
  "description": "Update the population of Shanghai in the 'ne_populated_places' layer using GeoServer's WFS-T (Transactional) interface. Change the 'pop_max' attribute for the city named 'Shanghai' to 28543210. Save the transaction XML to /home/ga/wfs_update.xml and the server response to /home/ga/wfs_response.xml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/wfs_t_update_feature/setup_task.sh",
    "post_task": "/workspace/tasks/wfs_t_update_feature/export_result.sh"
  },
  "metadata": {
    "target_city": "Shanghai",
    "target_attribute": "pop_max",
    "target_value": 28543210,
    "layer_name": "ne:ne_populated_places",
    "artifact_request": "/home/ga/wfs_update.xml",
    "artifact_response": "/home/ga/wfs_response.xml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_wfs_t_update"
    }
  }
}
