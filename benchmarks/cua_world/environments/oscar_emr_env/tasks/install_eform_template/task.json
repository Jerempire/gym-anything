{
  "id": "install_eform_template@1",
  "version": "1.0",
  "env_id": "oscar_emr_env@0.1",
  "description": "Upload the 'Rapid Pain Assessment' electronic form (eForm) template into the Oscar EMR system using the file at /home/ga/Documents/pain_assessment.html. Log in with username 'oscardoc', password 'oscar', and PIN '1117'. Ensure the form is registered and active under the name 'Rapid Pain Assessment'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/install_eform_template/setup_task.sh",
    "post_task": "/workspace/tasks/install_eform_template/export_result.sh"
  },
  "metadata": {
    "target_form_name": "Rapid Pain Assessment",
    "source_file": "/home/ga/Documents/pain_assessment.html",
    "secure_content_string": "RPA_2024_SECURE_CHECK",
    "credentials": {
      "username": "oscardoc",
      "password": "oscar",
      "pin": "1117"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_install_eform"
    }
  },
  "tags": [
    "admin",
    "configuration",
    "eform",
    "upload",
    "system-management"
  ]
}
