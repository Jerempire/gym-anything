{
  "id": "create_private_invoice@1",
  "version": "1.0",
  "env_id": "oscar_emr_env@0.1",
  "description": "Create a private (uninsured) invoice for patient Maria Santos in Oscar EMR for a 'Sick Note' not covered by insurance. The invoice must be for $20.00 charged directly to the patient. Login credentials: oscardoc / oscar / PIN: 1117.",
  "difficulty": "medium",
