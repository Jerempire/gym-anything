{
  "id": "link_patient_family@1",
  "version": "1.0",
  "env_id": "oscar_emr_env@0.1",
  "description": "Log in to Oscar EMR using username 'oscardoc', password 'oscar', and PIN '1117'. Establish a family relationship link between the child patient 'Leo Das' and his mother 'Priya Das'. Set the relationship type to 'Mother' or 'Parent' and ensure the link is saved so they appear in each other's family records.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/link_patient_family/setup_task.sh",
    "post_task": "/workspace/tasks/link_patient_family/export_result.sh"
  },
  "metadata": {
    "child_fname": "Leo",
    "child_lname": "Das",
    "mother_fname": "Priya",
    "mother_lname": "Das",
    "relationship_type": "Mother",
    "credentials": {
      "username": "oscardoc",
      "password": "oscar",
      "pin": "1117"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_link_patient_family"
    }
  }
}
