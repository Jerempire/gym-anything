{
  "id": "resolve_tickler@1",
  "version": "1.0",
  "env_id": "oscar_emr_env@0.1",
  "description": "Log in to Oscar EMR (oscardoc/oscar/1117) and process the high-priority tickler for patient Marcus Aurelius regarding 'Critical Lab Result: Potassium 6.2'. Update the tickler with the note 'Spoke to patient at 09:00. Advised to go to ER immediately. Patient confirmed they are leaving now.' and mark it as 'Complete'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/resolve_tickler/setup_task.sh",
    "post_task": "/workspace/tasks/resolve_tickler/export_result.sh"
  },
  "metadata": {
    "patient_name": "Marcus Aurelius",
    "target_tickler_content": "Critical Lab Result: Potassium 6.2",
    "required_note_keywords": [
      "spoke",
      "ER",
      "immediately"
    ],
    "credentials": {
      "username": "oscardoc",
      "password": "oscar",
      "pin": "1117"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_resolve_tickler"
    }
  }
}
