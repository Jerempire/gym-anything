{
  "id": "correct_billing_claim@1",
  "version": "1.0",
  "env_id": "oscar_emr_env@0.1",
  "description": "A billing claim for patient Maria Santos from yesterday was rejected due to an invalid diagnosis code. In Oscar EMR (oscardoc/oscar/1117), update the rejected claim (Service Date: Yesterday) by changing the diagnosis code from '999' to '250' (Diabetes) and setting the status to 'Bill'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/correct_billing_claim/setup_task.sh",
    "post_task": "/workspace/tasks/correct_billing_claim/export_result.sh"
  },
  "metadata": {
    "patient_fname": "Maria",
    "patient_lname": "Santos",
    "target_diagnosis": "250",
    "target_status": "B",
    "credentials": {
      "username": "oscardoc",
      "password": "oscar",
      "pin": "1117"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_correct_billing_claim"
    }
  }
}
