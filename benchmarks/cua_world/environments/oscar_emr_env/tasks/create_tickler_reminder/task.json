{
  "id": "create_tickler_reminder@1",
  "version": "1.0",
  "env_id": "oscar_emr_env@0.1",
  "description": "Log into Oscar EMR (Username: oscardoc, Password: oscar, PIN: 1117) and create an active, high-priority clinical reminder (tickler) for patient Maria Santos (DOB: 1978-06-12). The tickler must be assigned to oscardoc (Dr. Sarah Chen) with the message 'Follow up on repeat HbA1c lab results - call patient' and a service date set to exactly 14 days from today.",
