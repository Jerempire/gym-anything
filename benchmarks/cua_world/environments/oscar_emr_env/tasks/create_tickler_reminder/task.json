  "metadata": {
    "patient_fname": "Maria",
    "patient_lname": "Santos",
    "patient_dob": "1978-06-12",
    "target_message_content": "HbA1c",
    "target_priority": "High",
    "target_offset_days": 14,
    "target_assignee": "oscardoc",
    "credentials": {
      "username": "oscardoc",
      "password": "oscar",
      "pin": "1117"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_tickler_reminder"
    }
  },
  "tags": [
    "clinical_workflow",
    "tickler",
    "patient_safety",
    "oscar_emr"
  ]
