{
  "id": "configure_prevention_alert@1",
  "version": "1.0",
  "env_id": "oscar_emr_env@0.1",
  "description": "Configure a new Prevention Rule in OSCAR EMR named 'Senior Weight Monitor'. This rule should trigger for all patients aged 65 and older who have not had a weight recording in the last 12 months. The alert text should mention 'Monitor for unexpected weight loss'. Login credentials: oscardoc / oscar / PIN: 1117.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_prevention_alert/setup_task.sh",
    "post_task": "/workspace/tasks/configure_prevention_alert/export_result.sh"
  },
  "metadata": {
    "expected_name": "Senior Weight Monitor",
    "expected_age_min": 65,
    "expected_duration": 12,
    "expected_unit": "month",
    "expected_text_fragment": "unexpected weight loss",
    "prevention_type_keyword": "Weight"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_prevention_alert"
    }
  }
}
