{
  "id": "initialize_antenatal_record@1",
  "version": "1.0",
  "env_id": "oscar_emr_env@0.1",
  "description": "Create an Antenatal Record 1 (AR1) for patient Diana Prince in OSCAR EMR (username: oscardoc, password: oscar, PIN: 1117). Set the Last Menstrual Period (LMP) date to exactly 8 weeks ago from today and ensure the Estimated Date of Delivery (EDD) is calculated before saving the record.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/initialize_antenatal_record/setup_task.sh",
    "post_task": "/workspace/tasks/initialize_antenatal_record/export_result.sh"
  },
  "metadata": {
    "patient_fname": "Diana",
    "patient_lname": "Prince",
    "patient_dob": "1995-05-15",
    "lmp_weeks_ago": 8,
    "credentials": {
      "username": "oscardoc",
      "password": "oscar",
      "pin": "1117"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_antenatal_record"
    }
  }
}
