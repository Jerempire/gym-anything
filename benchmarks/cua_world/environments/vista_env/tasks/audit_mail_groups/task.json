{
  "id": "audit_mail_groups@1",
  "version": "1.0",
  "env_id": "vista_env@0.1",
  "description": "Using the YDBGui Global Viewer in the VistA VEHU environment, audit the MailMan Mail Group global ^XMB(3.8). Identify at least 10 valid mail group names from the system and record them in a text file at ~/Documents/mail_groups_audit.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/audit_mail_groups/setup_task.sh",
    "post_task": "/workspace/tasks/audit_mail_groups/export_result.sh"
  },
  "metadata": {
    "target_global": "^XMB(3.8)",
    "output_file": "/home/ga/Documents/mail_groups_audit.txt",
    "min_groups_required": 10,
    "scoring_weights": {
      "infrastructure_ready": 10,
      "report_file_valid": 10,
      "vlm_navigation_check": 35,
      "content_accuracy": 45
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_audit_mail_groups"
    }
  }
}
