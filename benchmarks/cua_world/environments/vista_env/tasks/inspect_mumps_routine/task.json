{
  "id": "inspect_mumps_routine@1",
  "version": "1.0",
  "env_id": "vista_env@0.1",
  "description": "Use the YDBGui Routine Viewer to inspect the source code of the 'XLFDT' routine. VistA logic is written in M (MUMPS), and 'XLFDT' is the standard Date/Time Library. Display the routine's source code, ensuring that entry points like 'HTFM' and 'FMTE' and the M code lines are visible on the screen.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/inspect_mumps_routine/setup_task.sh",
    "post_task": "/workspace/tasks/inspect_mumps_routine/export_result.sh"
  },
  "metadata": {
    "target_routine": "XLFDT",
    "required_labels": [
      "HTFM",
      "FMTE",
      "NOW",
      "YM",
      "DOW"
    ],
    "scoring_weights": {
      "vista_running": 5,
      "ydbgui_accessible": 5,
      "browser_open": 5,
      "routine_viewer_active": 20,
      "routine_name_visible": 20,
      "code_content_visible": 45
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_inspect_mumps_routine"
    }
  }
}
