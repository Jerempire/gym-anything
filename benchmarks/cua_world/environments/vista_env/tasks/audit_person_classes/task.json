{
  "id": "audit_person_classes@1",
  "version": "1.0",
  "env_id": "vista_env@0.1",
  "description": "As a Credentialing Specialist, audit the 'Person Class' file in VistA to verify provider taxonomy codes. Locate the entry for 'Emergency Medicine' within the Person Class global ^USC(8932.1) or the PERSON_CLASS table using the YDBGui interface. Ensure the classification name and its associated X12 Taxonomy Code are displayed.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/audit_person_classes/setup_task.sh",
    "post_task": "/workspace/tasks/audit_person_classes/export_result.sh"
  },
  "metadata": {
    "target_global": "^USC(8932.1)",
    "target_term": "Emergency Medicine",
    "expected_code_prefix": "207P",
    "scoring_weights": {
      "vista_running": 10,
      "ydbgui_accessible": 10,
      "global_navigated": 30,
      "term_found": 25,
      "code_visible": 25
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_audit_person_classes"
    }
  }
}
