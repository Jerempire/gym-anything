{
  "id": "gift_message_workflow@1",
  "version": "1.0",
  "env_id": "magento_env@0.1",
  "description": "Enable the 'Gift Messages on Order Level' setting in the Magento configuration. As a guest customer (Email: test.gift@example.com, Address: 123 Gift Way, New York, NY 10001), place an order for the 'Business Laptop Pro' including a gift message with To: 'Alice', From: 'Bob', and Message: 'Happy Birthday! Enjoy the new laptop.'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/gift_message_workflow/setup_task.sh",
    "post_task": "/workspace/tasks/gift_message_workflow/export_result.sh"
  },
  "metadata": {
    "config_path": "sales/gift_options/allow_order",
    "target_sku": "LAPTOP-001",
    "target_email": "test.gift@example.com",
    "expected_sender": "Bob",
    "expected_recipient": "Alice",
    "expected_message_keywords": [
      "Happy Birthday",
      "Enjoy the new laptop"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_gift_message_workflow"
    }
  }
}
