{
  "id": "bulk_attribute_update@1",
  "version": "1.0",
  "env_id": "magento_env@0.1",
  "description": "As the inventory manager, perform a bulk update for all products in the 'Clothing' category. Set the Cost to 12.50 and Meta Keywords to 'Eco-friendly, Sustainable' for these items. If not logged in, use admin/Admin1234!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bulk_attribute_update/setup_task.sh",
    "post_task": "/workspace/tasks/bulk_attribute_update/export_result.sh"
  },
  "metadata": {
    "target_category": "Clothing",
    "target_cost": "12.50",
    "target_meta_keywords": "Eco-friendly, Sustainable"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bulk_attribute_update"
    }
  }
}
