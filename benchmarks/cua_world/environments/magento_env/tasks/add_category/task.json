{
  "id": "add_category@1",
  "version": "1.0",
  "env_id": "magento_env@0.1",
  "description": "Create a new subcategory named 'Eco-Friendly' under the 'Default Category' in the Magento admin panel. Ensure the category is enabled and included in the navigation menu. If not logged in, use admin/Admin1234!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_category/setup_task.sh",
    "post_task": "/workspace/tasks/add_category/export_result.sh"
  },
  "metadata": {
    "expected_name": "Eco-Friendly",
    "expected_parent": "Default Category",
    "expected_parent_id": "2",
    "expected_is_active": true,
    "expected_include_in_menu": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_category"
    }
  }
}
