{
  "id": "search_relevance_config@1",
  "version": "1.0",
  "env_id": "magento_env@0.1",
  "description": "Configure the search relevance weights for the 'sku', 'name', and 'description' product attributes to improve search results. Set the Search Weight for SKU to 10, Product Name to 5, and Description to 1. If not logged in, use admin/Admin1234!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/search_relevance_config/setup_task.sh",
    "post_task": "/workspace/tasks/search_relevance_config/export_result.sh"
  },
  "metadata": {
    "expected_weights": {
      "sku": "10",
      "name": "5",
      "description": "1"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_search_relevance"
    }
  }
}
