{
  "id": "bulk_product_qty_rules@1",
  "version": "1.0",
  "env_id": "magento_env@0.1",
  "description": "Configure the 'Classic Cotton T-Shirt' (SKU: TSHIRT-001) for wholesale bulk purchasing. Set the minimum quantity allowed in the shopping cart to 5 and the maximum quantity to 50. Enable quantity increments and set the increment amount to 5. If not logged in, use admin/Admin1234!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bulk_product_qty_rules/setup_task.sh",
    "post_task": "/workspace/tasks/bulk_product_qty_rules/export_result.sh"
  },
  "metadata": {
    "target_sku": "TSHIRT-001",
    "expected_min_sale_qty": 5.0,
    "expected_max_sale_qty": 50.0,
    "expected_enable_qty_increments": 1,
    "expected_qty_increments": 5.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bulk_product_qty_rules"
    }
  }
}
