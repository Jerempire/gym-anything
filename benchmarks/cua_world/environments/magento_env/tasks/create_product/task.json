{
  "id": "create_product@1",
  "version": "1.0",
  "env_id": "magento_env@0.1",
  "description": "Create a new simple product in the Magento admin panel with the following details: Name 'Organic Cotton T-Shirt', SKU 'OCT-001', Price $29.99, Category 'Clothing', Stock Quantity 100, and Attribute Set 'Default'. If not logged in, use credentials admin/Admin1234!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_product/setup_task.sh",
    "post_task": "/workspace/tasks/create_product/export_result.sh"
  },
  "metadata": {
    "expected_name": "Organic Cotton T-Shirt",
    "expected_sku": "OCT-001",
    "expected_price": "29.99",
    "expected_stock_qty": "100",
    "expected_category": "Clothing"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_product"
    }
  }
}
