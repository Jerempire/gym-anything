{
  "id": "sales_email_copy_config@1",
  "version": "1.0",
  "env_id": "magento_env@0.1",
  "description": "Configure Magento sales email notifications for the operations team. Set 'Order' emails to send a BCC copy to 'manager@nesthome.com' and 'Invoice' emails to send a separate email copy to 'accounting@nesthome.com'. If you are not logged in, use admin / Admin1234!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sales_email_copy_config/setup_task.sh",
    "post_task": "/workspace/tasks/sales_email_copy_config/export_result.sh"
  },
  "metadata": {
    "expected_order_recipient": "manager@nesthome.com",
    "expected_order_method": "bcc",
    "expected_invoice_recipient": "accounting@nesthome.com",
    "expected_invoice_method": "copy"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_sales_email_copy_config"
    }
  }
}
