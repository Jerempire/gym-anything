{
  "id": "inventory_scarcity_config@1",
  "version": "1.0",
  "env_id": "magento_env@0.1",
  "description": "Configure the store's global inventory and catalog settings to create a 'scarcity and retention' strategy. Enable backorders (Allow Qty Below 0 and Notify Customer), set the 'Only X left Threshold' to 5, ensure out-of-stock products remain visible in the catalog, and enable product alerts for when items come back in stock. Use the default global scope. If not logged in, use admin / Admin1234!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/inventory_scarcity_config/setup_task.sh",
    "post_task": "/workspace/tasks/inventory_scarcity_config/export_result.sh"
  },
  "metadata": {
    "config_paths": {
      "backorders": "cataloginventory/item_options/backorders",
      "threshold": "cataloginventory/options/stock_threshold_qty",
      "show_out_of_stock": "cataloginventory/options/show_out_of_stock",
      "allow_alert": "catalog/productalert/allow_stock"
    },
    "expected_values": {
      "backorders": "2",
      "threshold": "5",
      "show_out_of_stock": "1",
      "allow_alert": "1"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_inventory_scarcity_config"
    }
  }
}
