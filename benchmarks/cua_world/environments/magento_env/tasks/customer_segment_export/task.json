{
  "id": "customer_segment_export@1",
  "version": "1.0",
  "env_id": "magento_env@0.1",
  "description": "You are the B2B Sales Director. You need to prepare a lead list for a targeted email campaign. Export a CSV file containing only customers who belong to the 'Wholesale' customer group and save it to /home/ga/Documents/wholesale_leads.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/customer_segment_export/setup_task.sh",
    "post_task": "/workspace/tasks/customer_segment_export/export_result.sh"
  },
  "metadata": {
    "expected_filename": "wholesale_leads.csv",
    "expected_path": "/home/ga/Documents/wholesale_leads.csv",
    "wholesale_emails": [
      "wholesale1@example.com",
      "wholesale2@example.com",
      "wholesale3@example.com"
    ],
    "excluded_emails": [
      "retail1@example.com",
      "retail2@example.com",
      "retail3@example.com"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_customer_segment_export"
    }
  }
}
