{
  "id": "admin_order_grid_customization@1",
  "version": "1.0",
  "env_id": "magento_env@0.1",
  "description": "Customize the Sales Order grid in the Magento Admin panel to create a specialized 'Logistics View'. Configure the grid columns to show 'Payment Method' and 'Shipping Information' and hide 'Grand Total (Base)'. Save this configuration as a new view named 'Logistics View' so it can be accessed later.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/admin_order_grid_customization/setup_task.sh",
    "post_task": "/workspace/tasks/admin_order_grid_customization/export_result.sh"
  },
  "metadata": {
    "target_view_name": "Logistics View",
    "required_visible_columns": [
      "payment_method",
      "shipping_information"
    ],
    "required_hidden_columns": [
      "base_grand_total"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_grid_customization"
    }
  }
}
