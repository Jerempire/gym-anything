{
  "id": "table_rate_shipping@1",
  "version": "1.0",
  "env_id": "magento_env@0.1",
  "description": "Configure Table Rate Shipping for the 'Main Website' scope. The configuration must be enabled, titled 'Heavy Goods Shipping', and use the 'Weight vs. Destination' condition. The shipping rates for the USA (Country: US, Region: *, Zip: *) must be set to $15.00 for 0 lbs and $25.00 for 10 lbs via the import feature.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/table_rate_shipping/setup_task.sh",
    "post_task": "/workspace/tasks/table_rate_shipping/export_result.sh"
  },
  "metadata": {
    "expected_title": "Heavy Goods Shipping",
    "expected_condition": "package_weight",
    "rates": [
      {
        "country": "US",
        "weight": 0.0,
        "price": 15.0
      },
      {
        "country": "US",
        "weight": 10.0,
        "price": 25.0
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_table_rate_shipping"
    }
  }
}
