{
  "id": "stock_visibility_alerts@1",
  "version": "1.0",
  "env_id": "magento_env@0.1",
  "description": "Configure the global inventory and catalog settings to display out-of-stock products, set the 'Only X left' threshold to 5, and enable both stock and price alerts for customers using the 'Customer Support' email identity. If not logged in, use admin/Admin1234!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/stock_visibility_alerts/setup_task.sh",
    "post_task": "/workspace/tasks/stock_visibility_alerts/export_result.sh"
  },
  "metadata": {
    "config_paths": {
      "show_out_of_stock": "cataloginventory/options/show_out_of_stock",
      "stock_threshold": "cataloginventory/options/stock_threshold_qty",
      "allow_stock_alert": "catalog/productalert/allow_stock",
      "allow_price_alert": "catalog/productalert/allow_price",
      "stock_email_identity": "catalog/productalert/email_stock_identity"
    },
    "expected_values": {
      "show_out_of_stock": "1",
      "stock_threshold": "5",
      "allow_stock_alert": "1",
      "allow_price_alert": "1",
      "stock_email_identity": "support"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_stock_visibility_alerts"
    }
  }
}
