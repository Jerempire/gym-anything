{
  "id": "virtual_product_service@1",
  "version": "1.0",
  "env_id": "magento_env@0.1",
  "description": "Create a new Virtual Product in the Magento catalog with the following details: Name 'Professional Home Theater Installation', SKU 'SVC-HT-INSTALL', Price '$199.00', Quantity '100', and Category 'Electronics'. Set Visibility to 'Catalog, Search'. If not logged in, use admin/Admin1234!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/virtual_product_service/setup_task.sh",
    "post_task": "/workspace/tasks/virtual_product_service/export_result.sh"
  },
  "metadata": {
    "expected_sku": "SVC-HT-INSTALL",
    "expected_name": "Professional Home Theater Installation",
    "expected_type": "virtual",
    "expected_price": "199.00",
    "expected_qty": "100",
    "expected_category": "Electronics",
    "expected_visibility": "4"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_virtual_product_service"
    }
  }
}
