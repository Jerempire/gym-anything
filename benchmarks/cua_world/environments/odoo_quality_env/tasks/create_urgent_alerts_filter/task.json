{
  "id": "create_urgent_alerts_filter@1",
  "version": "1.0",
  "env_id": "odoo_quality_env@0.1",
  "description": "As a Quality Manager, you need to focus on critical issues first. Create a saved custom filter in the Quality Alerts view named 'Urgent Actions' that shows only alerts that are 'High Priority' (at least 1 star) and in the 'New' stage.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_urgent_alerts_filter/setup_task.sh",
    "post_task": "/workspace/tasks/create_urgent_alerts_filter/export_result.sh"
  },
  "metadata": {
    "target_filter_name": "Urgent Actions",
    "target_model": "quality.alert",
    "required_stage_name": "New",
    "required_priority_level": "1"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_urgent_alerts_filter"
    }
  }
}
