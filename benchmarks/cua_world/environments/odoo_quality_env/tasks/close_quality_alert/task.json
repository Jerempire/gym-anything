{
  "id": "close_quality_alert@1",
  "version": "1.0",
  "env_id": "odoo_quality_env@0.1",
  "description": "Log in to Odoo at http://localhost:8069 (admin/admin) and update the quality alert titled \"Paint Discoloration on Metal Panels\" to the \"Done\" stage.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 240,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/close_quality_alert/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_close_quality_alert"
    }
  }
}
