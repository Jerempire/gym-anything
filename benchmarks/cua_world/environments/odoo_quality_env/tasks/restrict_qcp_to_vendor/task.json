{
  "id": "restrict_qcp_to_vendor@1",
  "version": "1.0",
  "env_id": "odoo_quality_env@0.1",
  "description": "Log in to Odoo at http://localhost:8069 with username 'admin' and password 'admin'. Update the Quality Control Point titled \"Cabinet Inspection\" (product: Cabinet with Doors, operation: Receipts) to restrict its application exclusively to the vendor \"Gemini Furniture\".",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/restrict_qcp_to_vendor/setup_task.sh",
    "post_task": "/workspace/tasks/restrict_qcp_to_vendor/export_result.sh"
  },
  "metadata": {
    "target_qcp_title": "Cabinet Inspection",
    "target_vendor_name": "Gemini Furniture",
    "target_product_name": "Cabinet with Doors",
    "target_operation_code": "incoming"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_restrict_qcp_to_vendor"
    }
  }
}
