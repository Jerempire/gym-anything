{
  "id": "generate_alert_report_pdf@1",
  "version": "1.0",
  "env_id": "odoo_quality_env@0.1",
  "description": "As a Quality Manager preparing for the weekly Safety Council meeting, you need a hard copy of a critical defect. Locate the quality alert titled 'Structural Crack - Desk Frame' and save its PDF report to ~/Downloads.",
  "difficulty": "medium",
  "tags": [
    "odoo",
    "quality",
    "reporting",
    "pdf",
    "download"
  ],
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_alert_report_pdf/setup_task.sh",
    "post_task": "/workspace/tasks/generate_alert_report_pdf/export_result.sh"
  },
  "metadata": {
    "download_dir": "/home/ga/Downloads",
    "expected_filename_pattern": "Structural Crack",
    "alt_filename_pattern": "Quality Alert"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_alert_report_pdf"
    }
  }
}
