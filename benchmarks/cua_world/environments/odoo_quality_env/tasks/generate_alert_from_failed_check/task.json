{
  "id": "generate_alert_from_failed_check@1",
  "version": "1.0",
  "env_id": "odoo_quality_env@0.1",
  "description": "Log in to Odoo (admin/admin) and create a Quality Alert titled 'Cabinet Structural Defect' with the tag 'Structural' originating from the failed quality check for the product 'Large Cabinet'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_alert_from_failed_check/setup_task.sh",
    "post_task": "/workspace/tasks/generate_alert_from_failed_check/export_result.sh"
  },
  "metadata": {
    "target_product": "Large Cabinet",
    "expected_title": "Cabinet Structural Defect",
    "expected_tag": "Structural",
    "check_state": "fail"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_alert_from_failed_check"
    }
  }
}
