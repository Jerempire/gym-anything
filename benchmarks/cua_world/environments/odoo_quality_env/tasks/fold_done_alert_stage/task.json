{
  "id": "fold_done_alert_stage@1",
  "version": "1.0",
  "env_id": "odoo_quality_env@0.1",
  "description": "Log in to Odoo (admin/admin) and configure the 'Done' Quality Alert Stage to be folded in the Kanban view.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/fold_done_alert_stage/setup_task.sh",
    "post_task": "/workspace/tasks/fold_done_alert_stage/export_result.sh"
  },
  "metadata": {
    "target_stage_name": "Done",
    "expected_fold_state": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_fold_done_alert_stage"
    }
  }
}
