{
  "id": "create_product_filter@1",
  "version": "1.0",
  "env_id": "odoo_quality_env@0.1",
  "description": "Log in to Odoo as admin. Create a custom favorite filter named 'Chairs Only' in the Quality Alerts list that displays only alerts for the product 'Office Chair'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_product_filter/setup_task.sh",
    "post_task": "/workspace/tasks/create_product_filter/export_result.sh"
  },
  "metadata": {
    "target_product_name": "Office Chair",
    "expected_filter_name": "Chairs Only",
    "target_model": "quality.alert"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_product_filter"
    }
  }
}
