{
  "id": "link_vendor_to_alert@1",
  "version": "1.0",
  "env_id": "odoo_quality_env@0.1",
  "description": "Log in to Odoo (admin/admin) and set the Vendor for the quality alert \"Surface Defects on Cabinet Batch\" to \"Wood Corner\".",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/link_vendor_to_alert/setup_task.sh",
    "post_task": "/workspace/tasks/link_vendor_to_alert/export_result.sh"
  },
  "metadata": {
    "target_alert_name": "Surface Defects on Cabinet Batch",
    "target_vendor_name": "Wood Corner",
    "target_product_name": "Cabinet with Doors"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_link_vendor_to_alert"
    }
  }
}
