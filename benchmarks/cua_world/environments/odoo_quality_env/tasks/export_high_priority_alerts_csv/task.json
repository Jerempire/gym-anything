{
  "id": "export_high_priority_alerts_csv@1",
  "version": "1.0",
  "env_id": "odoo_quality_env@0.1",
  "description": "Export all High Priority (3-star) quality alerts for the product 'Office Chair' to a CSV file. Ensure the export includes the 'Display Name' and 'Priority' fields. Save the resulting file to /home/ga/Downloads.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_high_priority_alerts_csv/setup_task.sh",
    "post_task": "/workspace/tasks/export_high_priority_alerts_csv/export_result.sh"
  },
  "metadata": {
    "target_product": "Office Chair",
    "high_priority_alerts": [
      "URGENT: Frame crack on weld B",
      "URGENT: Fabric mismatch batch 99"
    ],
    "low_priority_alerts": [
      "Minor scratch on leg"
    ],
    "expected_columns": [
      "Name",
      "Priority"
    ],
    "download_dir": "/home/ga/Downloads"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_high_priority_alerts_csv"
    }
  }
}
