{
  "id": "add_rss_feed@1",
  "version": "1.0",
  "env_id": "socioboard_env@0.1",
  "description": "Add the RSS feed 'BBC Technology News' (https://feeds.bbci.co.uk/news/technology/rss.xml) to the Socioboard (http://localhost) RSS Content Manager using the credentials admin@socioboard.local and Admin2024!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_rss_feed/setup_task.sh"
  },
  "metadata": {
    "feed_name": "BBC Technology News",
    "feed_url": "https://feeds.bbci.co.uk/news/technology/rss.xml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_rss_feed"
    }
  }
}
