{
  "id": "change_account_password@1",
  "version": "1.0",
  "env_id": "socioboard_env@0.1",
  "description": "Log in to Socioboard (http://localhost) using email admin@socioboard.local and password Admin2024!. Change the account password to SecureBoard#2025! and create a file at /tmp/password_change_done.txt containing the text 'Password changed successfully'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/change_account_password/setup_task.sh",
    "post_task": "/workspace/tasks/change_account_password/export_result.sh"
  },
  "metadata": {
    "user_email": "admin@socioboard.local",
    "old_password": "Admin2024!",
    "new_password": "SecureBoard#2025!",
    "confirmation_file": "/tmp/password_change_done.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_change_account_password"
    }
  }
}
