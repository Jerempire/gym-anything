{
  "id": "create_mating_gasket@1",
  "version": "1.0",
  "env_id": "freecad_envb@0.1",
  "description": "Create a 2mm thick mating gasket for the T8 Lead Screw Housing Bracket currently loaded in FreeCAD. The gasket must match the bottom footprint and mounting holes of the bracket exactly. Save the resulting file containing both the bracket and the new gasket to /home/ga/Documents/FreeCAD/T8_gasket.FCStd.",
