{
  "id": "split_part_for_printing@1",
  "version": "1.0",
  "env_id": "freecad_envb@0.1",
  "description": "The T8 housing bracket model is loaded in FreeCAD. Prepare this part for 3D printing by splitting it into two separate solid bodies at a height of Z = 15 mm. Export the bottom section (below Z=15) to /home/ga/Documents/FreeCAD/bracket_bottom.stl and the top section (above Z=15) to /home/ga/Documents/FreeCAD/bracket_top.stl.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/split_part_for_printing/setup_task.sh",
    "post_task": "/workspace/tasks/split_part_for_printing/export_result.sh"
  },
  "metadata": {
    "split_height_z": 15.0,
    "output_bottom": "/home/ga/Documents/FreeCAD/bracket_bottom.stl",
    "output_top": "/home/ga/Documents/FreeCAD/bracket_top.stl",
    "original_file": "/home/ga/Documents/FreeCAD/T8_housing_bracket.FCStd",
    "tolerance_mm": 1.0,
    "tolerance_vol_percent": 10.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_split_part"
    }
  }
}
