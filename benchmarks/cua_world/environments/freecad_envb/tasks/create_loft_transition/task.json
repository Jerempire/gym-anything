{
  "id": "create_loft_transition@1",
  "version": "1.0",
  "env_id": "freecad_envb@0.1",
  "description": "Create an Additive Loft solid in FreeCAD's Part Design workbench that transitions from a circular profile (40 mm diameter, centered at origin) on the XY plane to a square profile (30 mm x 30 mm, centered at origin) on a plane at Z = 60 mm. Save the result as /home/ga/Documents/FreeCAD/loft_transition.FCStd.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_loft_transition/setup_task.sh",
    "post_task": "/workspace/tasks/create_loft_transition/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/FreeCAD/loft_transition.FCStd",
    "target_height": 60.0,
    "target_circle_dia": 40.0,
    "target_square_side": 30.0,
    "min_volume_mm3": 45000,
    "max_volume_mm3": 85000,
    "bbox_tolerance_mm": 5.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_loft_transition"
    }
  }
}
