{
  "id": "apply_chamfer@1",
  "version": "1.0",
  "env_id": "freecad_envb@0.1",
  "description": "Apply a 2mm chamfer to all 12 edges of the 'TopBox' shape in '~/Documents/FreeCAD/contact_blocks.FCStd' while leaving 'BottomBox' unmodified. Save the updated document to '~/Documents/FreeCAD/chamfered_blocks.FCStd' and export the chamfered 'TopBox' to '~/Documents/FreeCAD/chamfered_topbox.step'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/apply_chamfer/setup_task.sh",
    "post_task": "/workspace/tasks/apply_chamfer/export_result.sh"
  },
  "metadata": {
    "input_file": "/home/ga/Documents/FreeCAD/contact_blocks.FCStd",
    "output_fcstd": "/home/ga/Documents/FreeCAD/chamfered_blocks.FCStd",
    "output_step": "/home/ga/Documents/FreeCAD/chamfered_topbox.step",
    "chamfer_size_mm": 2.0,
    "target_shape": "TopBox"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_apply_chamfer"
    }
  }
}
