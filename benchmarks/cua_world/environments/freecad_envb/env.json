{
  "id": "freecad_envb@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "FreeCAD 3D parametric CAD environment for modeling, export, and geometry tasks",
  "resources": {
    "cpu": 4,
    "mem_gb": 6,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/freecad_envb/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/freecad_envb/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/freecad_envb/data", "target": "/workspace/data", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_freecad.sh",
    "post_start": "/workspace/scripts/setup_freecad.sh"
  },
  "vnc": {"password": "password"},
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ]
}
