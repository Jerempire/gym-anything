{
  "id": "protect_document_for_review@1",
  "version": "1.0",
  "env_id": "microsoft_word_starter_env@0.1",
  "description": "Microsoft Word 2010 is open with a regulatory submission draft ('Regulatory_Submission_Draft.docx'). Protect the document by restricting editing to 'Comments' only, while allowing everyone to edit the 'REVIEWER NOTES' section. Enforce the protection with the password 'Review2024' and save the changes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\protect_document_for_review\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\protect_document_for_review\\export_result.ps1"
  },
  "metadata": {
    "target_file": "C:\\Users\\Docker\\Documents\\Regulatory_Submission_Draft.docx",
    "password": "Review2024",
    "protection_type": "comments",
    "exception_group": "everyone",
    "target_section_text": "REVIEWER NOTES"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_protect_document"
    }
  }
}
