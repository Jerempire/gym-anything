{
  "id": "create_certificate_page_setup@1",
  "version": "1.0",
  "env_id": "microsoft_word_starter_env@0.1",
  "description": "Create a 'Certificate of Completion' for 'James A. Smith' for the course 'Industrial Workplace Safety Level II'. The document must be in Landscape orientation with the text vertically centered on the page. Apply a Dark Blue, Double Line, 3pt Page Border to the document. Save the file to 'C:\\Users\\Docker\\Documents\\Safety_Certificate.docx'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_certificate_page_setup\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_certificate_page_setup\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "Safety_Certificate.docx",
    "expected_path": "C:\\Users\\Docker\\Documents\\Safety_Certificate.docx",
    "required_text": [
      "Certificate of Completion",
      "James A. Smith",
      "Industrial Workplace Safety"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_certificate_page_setup"
    }
  }
}
