{
  "id": "osw_brightness_reduce@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Reduce brightness of the provided photo in GIMP.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 12,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_brightness_reduce/setup_brightness_task.sh",
    "post_task": "/workspace/tasks/osw_brightness_reduce/export_result.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_brightness_reduction"
    }
  }
}
