{
  "id": "osw_palette_convert@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Convert the image to palette-based PNG in GIMP.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 12,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_palette_convert/setup_palette_task.sh",
    "post_task": "/workspace/tasks/osw_palette_convert/export_result.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_palette_conversion"
    }
  }
}
