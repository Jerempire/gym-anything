{
  "id": "osw_saturation_increase@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Increase the color vibrancy of the provided photo in GIMP.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 12,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_saturation_increase/setup_saturation_task.sh",
    "post_task": "/workspace/tasks/osw_saturation_increase/export_result.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_saturation_increase"
    }
  }
}
