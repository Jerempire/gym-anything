{
  "id": "osw_green_background@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Fill the background layer with green while keeping the object layer intact.",
  "init": {
    "timeout_sec": 150,
    "max_steps": 14,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_green_background/setup_green_task.sh",
    "post_task": "/workspace/tasks/osw_green_background/export_result.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_green_background_fill"
    }
  }
}
