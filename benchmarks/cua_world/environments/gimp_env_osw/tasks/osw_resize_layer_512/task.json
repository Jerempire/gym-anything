{
  "id": "osw_resize_layer_512@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Resize the dog layer height to 512 pixels while preserving aspect ratio.",
  "init": {
    "timeout_sec": 150,
    "max_steps": 14,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_resize_layer_512/setup_resize_task.sh",
    "post_task": "/workspace/tasks/osw_resize_layer_512/export_result.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_resize_layer_512"
    }
  }
}
