{
  "id": "osw_horizontal_mirror@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Mirror the provided image horizontally in GIMP.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 12,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_horizontal_mirror/setup_mirror_task.sh",
    "post_task": "/workspace/tasks/osw_horizontal_mirror/export_result.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_horizontal_mirror"
    }
  }
}
