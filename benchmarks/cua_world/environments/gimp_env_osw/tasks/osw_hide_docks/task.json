{
  "id": "osw_hide_docks@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Hide docks in GIMP (session setting).",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_hide_docks/setup_hide_docks_task.sh",
    "post_task": "/workspace/tasks/osw_hide_docks/export_result.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_hide_docks"
    }
  }
}
