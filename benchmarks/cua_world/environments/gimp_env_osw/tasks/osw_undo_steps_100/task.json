{
  "id": "osw_undo_steps_100@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Set GIMP minimum undo steps to 100 via Preferences.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_undo_steps_100/setup_undo_task.sh",
    "post_task": "/workspace/tasks/osw_undo_steps_100/export_result.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_undo_steps_100"
    }
  }
}
