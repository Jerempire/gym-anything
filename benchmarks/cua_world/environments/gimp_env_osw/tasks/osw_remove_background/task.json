{
  "id": "osw_remove_background@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Remove the background from the dog image in GIMP.",
  "init": {
    "timeout_sec": 150,
    "max_steps": 14,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_remove_background/setup_remove_task.sh",
    "post_task": "/workspace/tasks/osw_remove_background/export_result.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_background_removed"
    }
  }
}
