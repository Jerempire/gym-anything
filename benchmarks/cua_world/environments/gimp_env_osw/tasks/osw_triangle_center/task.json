{
  "id": "osw_triangle_center@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Move the yellow triangle to the center of the image in GIMP.",
  "init": {
    "timeout_sec": 150,
    "max_steps": 14,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_triangle_center/setup_triangle_task.sh",
    "post_task": "/workspace/tasks/osw_triangle_center/export_result.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_triangle_center"
    }
  }
}
