{
  "id": "osw_add_layer_square@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Add a new layer and name it 'Square' in GIMP.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 12,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_add_layer_square/setup_layer_task.sh",
    "post_task": "/workspace/tasks/osw_add_layer_square/export_result.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_layer_named_square"
    }
  }
}
