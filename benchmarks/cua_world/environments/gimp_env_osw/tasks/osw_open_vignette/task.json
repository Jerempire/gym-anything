{
  "id": "osw_open_vignette@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Open the Vignette filter window in GIMP.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 12,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_open_vignette/setup_vignette_task.sh",
    "post_task": "/workspace/tasks/osw_open_vignette/export_result.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_vignette_open"
    }
  }
}
