{
  "id": "osw_contrast_increase@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Increase contrast of the berries image in GIMP.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 12,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_contrast_increase/setup_contrast_task.sh",
    "post_task": "/workspace/tasks/osw_contrast_increase/export_result.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_contrast_increase"
    }
  }
}
