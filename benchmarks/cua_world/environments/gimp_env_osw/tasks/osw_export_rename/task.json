{
  "id": "osw_export_rename@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Place the provided photo on the desktop and export as export.jpg.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 12,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_export_rename/setup_export_task.sh",
    "post_task": "/workspace/tasks/osw_export_rename/export_result.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_export_rename"
    }
  }
}
