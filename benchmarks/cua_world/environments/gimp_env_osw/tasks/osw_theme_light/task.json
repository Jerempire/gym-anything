{
  "id": "osw_theme_light@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Change GIMP theme to Light via Preferences.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osw_theme_light/setup_theme_task.sh",
    "post_task": "/workspace/tasks/osw_theme_light/export_result.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_theme_light"
    }
  }
}
