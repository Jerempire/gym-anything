{
  "id": "cleanup_unused_dependencies@1",
  "version": "1.0",
  "env_id": "intellij_idea_env@0.1",
  "description": "The Maven project 'dependency-cleanup' has accumulated several unused dependencies in its pom.xml. Identify and remove only the dependencies that are not used in the source code (src/main/java and src/test/java). Ensure the project still compiles and all tests pass after the removals. Do not modify the Java source code.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/cleanup_unused_dependencies/setup_task.sh",
    "post_task": "/workspace/tasks/cleanup_unused_dependencies/export_result.sh"
  },
  "metadata": {
    "project_dir": "/home/ga/IdeaProjects/dependency-cleanup",
    "unused_dependencies": [
      "guava",
      "commons-io",
      "jackson-databind",
      "commons-collections4",
      "joda-time"
    ],
    "used_dependencies": [
      "commons-lang3",
      "gson",
      "slf4j-api",
      "junit"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_cleanup_unused_dependencies"
    }
  }
}
