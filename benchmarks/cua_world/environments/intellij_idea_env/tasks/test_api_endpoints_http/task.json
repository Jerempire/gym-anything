{
  "id": "test_api_endpoints_http@1",
  "version": "1.0",
  "env_id": "intellij_idea_env@0.1",
  "description": "Create an HTTP Request file named 'library_tests.http' in the 'LibraryClient' project to test the local Library Service at http://localhost:8081. Define and execute a GET request to '/api/books' and a POST request to '/api/books' including a 'Content-Type: application/json' header and a JSON body with 'title', 'author', and 'year' fields.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/test_api_endpoints_http/setup_task.sh",
    "post_task": "/workspace/tasks/test_api_endpoints_http/export_result.sh"
  },
  "metadata": {
    "project_name": "LibraryClient",
    "project_dir": "/home/ga/IdeaProjects/LibraryClient",
    "server_port": 8081,
    "server_log_path": "/tmp/library_server_access.log",
    "expected_filename": "library_tests.http",
    "required_endpoints": [
      "GET /api/books",
      "POST /api/books"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_api_testing"
    }
  }
}
