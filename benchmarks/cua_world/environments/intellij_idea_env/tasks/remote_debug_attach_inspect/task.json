{
  "id": "remote_debug_attach_inspect@1",
  "version": "1.0",
  "env_id": "intellij_idea_env@0.1",
  "description": "A background Java process 'TransactionProcessor' is running on localhost port 5005 with JDWP debugging enabled. Using the 'PaymentGateway' project, attach a remote debugger to the process and identify the value of the 'transactionToken' variable within the 'processTransaction' method. Save the identified token to /home/ga/IdeaProjects/PaymentGateway/token_found.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/remote_debug_attach_inspect/setup_task.sh",
    "post_task": "/workspace/tasks/remote_debug_attach_inspect/export_result.sh"
  },
  "metadata": {
    "project_dir": "/home/ga/IdeaProjects/PaymentGateway",
    "output_file": "/home/ga/IdeaProjects/PaymentGateway/token_found.txt",
    "ground_truth_file": "/tmp/.ground_truth_token",
    "debug_port": 5005,
    "main_class": "com.example.gateway.TransactionProcessor"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_remote_debug"
    }
  },
  "tags": [
    "debug",
    "java",
    "jdwp",
    "intellij",
    "troubleshooting"
  ]
}
