  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/setup_logging_framework/setup_task.sh",
    "post_task": "/workspace/tasks/setup_logging_framework/export_result.sh"
  },
  "metadata": {
    "project_dir": "/home/ga/IdeaProjects/library-app",
    "files_to_modify": [
      "src/main/java/com/library/LibraryApp.java",
      "src/main/java/com/library/service/BookService.java",
      "src/main/java/com/library/repository/BookRepository.java",
      "src/main/java/com/library/util/SearchEngine.java"
    ],
    "file_to_ignore": "src/main/java/com/library/model/Book.java",
    "expected_deps": [
      {
        "groupId": "org.slf4j",
        "artifactId": "slf4j-api"
      },
      {
        "groupId": "ch.qos.logback",
        "artifactId": "logback-classic"
      }
    ]
  },
  "success": {
