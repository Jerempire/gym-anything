{
  "id": "migrate_junit4_to_junit5@1",
  "version": "1.0",
  "env_id": "intellij_idea_env@0.1",
  "description": "Migrate the 'banking-service' Java Maven project from JUnit 4 to JUnit 5 (Jupiter). Refactor all test classes in src/test/java to use JUnit 5 annotations, assertions, and exception testing patterns. Update the project configuration to support the JUnit 5 platform and ensure all 15 tests pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/migrate_junit4_to_junit5/setup_task.sh",
    "post_task": "/workspace/tasks/migrate_junit4_to_junit5/export_result.sh"
  },
  "metadata": {
    "project_dir": "/home/ga/IdeaProjects/banking-service",
    "expected_tests_count": 15,
    "required_dependency": "junit-jupiter",
    "forbidden_dependency": "junit:junit",
    "forbidden_import": "org.junit.Test",
    "required_import": "org.junit.jupiter.api.Test"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_migrate_junit4_to_junit5"
    }
  }
}
