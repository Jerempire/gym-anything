{
  "id": "apply_source_cleanup@1",
  "version": "1.0",
  "env_id": "eclipse_env@0.1",
  "description": "Fix code quality issues in the 'InventoryManager' project. Resolve all instances of missing @Override annotations, unused imports, raw type usage, unnecessary boxing, and String comparisons using '==' instead of '.equals()'. The final project must contain zero errors and zero warnings.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/apply_source_cleanup/setup_task.sh",
    "post_task": "/workspace/tasks/apply_source_cleanup/export_result.sh"
  },
  "metadata": {
    "project_dir": "/home/ga/eclipse-workspace/InventoryManager",
    "source_files": [
      "src/com/warehouse/model/Product.java",
      "src/com/warehouse/model/Category.java",
      "src/com/warehouse/service/InventoryService.java"
    ],
    "forbidden_patterns": {
      "unused_imports": [
        "import java.util.Date;",
        "import java.io.Serializable;",
        "import java.sql.SQLException;"
      ],
      "raw_types": [
        "List tags;",
        "Map inventory;",
        "Set categories;"
      ],
      "string_equality": [
        "sku == otherSku",
        "categoryName == \"Default\"",
        "name == inputName"
      ],
      "unnecessary_boxing": [
        "Integer.valueOf(42)",
        "Boolean.valueOf(true)"
      ]
    },
    "required_patterns": {
      "override_annotation": [
        "@Override\\s+public String toString",
        "@Override\\s+public int compareTo"
      ]
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_apply_source_cleanup"
    }
  }
}
