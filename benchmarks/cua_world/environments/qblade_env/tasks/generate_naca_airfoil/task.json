{
  "id": "generate_naca_airfoil@1",
  "version": "1.0",
  "env_id": "example.qblade_env@0.1",
  "description": "Generate a NACA 4412 airfoil profile with 100 panel discretization points in QBlade. Export the resulting airfoil coordinates to /home/ga/Documents/airfoils/generated_naca4412.dat.",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_naca_airfoil/setup_task.sh",
    "post_task": "/workspace/tasks/generate_naca_airfoil/export_result.sh"
  },
  "metadata": {
    "naca_digits": "4412",
    "panel_count": 100,
    "expected_output": "generated_naca4412.dat",
    "airfoil_name": "NACA 4412"
  },
  "success": {
    "spec": {
      "program": "verifier.py::verify_generate_naca_airfoil"
    }
  }
}
