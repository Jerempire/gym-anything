{
  "id": "load_sample_project@1",
  "version": "1.0",
  "env_id": "example.qblade_env@0.1",
  "description": "Load a QBlade sample project (.wpa) from /home/ga/Documents/sample_projects/ and add a NACA 0015 airfoil to the project. Save the modified project to /home/ga/Documents/projects/my_turbine.wpa.",
  "init": {
    "timeout_sec": 240,
    "max_steps": 35,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/load_sample_project/setup_task.sh",
    "post_task": "/workspace/tasks/load_sample_project/export_result.sh"
  },
  "metadata": {
    "expected_output_name": "my_turbine.wpa"
  },
  "success": {
    "spec": {
      "program": "verifier.py::verify_load_sample_project"
    }
  }
}
