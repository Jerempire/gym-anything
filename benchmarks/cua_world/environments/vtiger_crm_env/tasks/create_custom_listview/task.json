{
  "id": "create_custom_listview@1",
  "version": "1.0",
  "env_id": "vtiger_crm_env@0.1",
  "description": "Create a custom list view named 'New York Contacts' in the Contacts module. The view must display the following columns: First Name, Last Name, Primary Email, Mobile Phone, and Mailing City. Apply a filter condition where 'Mailing City' equals 'New York'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 45,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_custom_listview/setup_task.sh",
    "post_task": "/workspace/tasks/create_custom_listview/export_result.sh"
  },
  "metadata": {
    "expected_view_name": "New York Contacts",
    "expected_filter_column": "mailingcity",
    "expected_filter_value": "New York",
    "expected_filter_comparator": "e",
    "expected_columns": [
      "firstname",
      "lastname",
      "mailingcity"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_custom_listview"
    }
  }
}
