{
  "id": "export_filtered_leads_to_csv@1",
  "version": "1.0",
  "env_id": "vtiger_crm_env@0.1",
  "description": "Export all Leads from Vtiger CRM where the Industry is 'Healthcare' to /home/ga/healthcare_leads.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_filtered_leads_to_csv/setup_task.sh",
    "post_task": "/workspace/tasks/export_filtered_leads_to_csv/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/healthcare_leads.csv",
    "expected_record_count": 18,
    "expected_industry": "Healthcare"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_filtered_leads"
    }
  }
}
