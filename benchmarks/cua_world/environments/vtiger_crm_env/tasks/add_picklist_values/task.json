{
  "id": "add_picklist_values@1",
  "version": "1.0",
  "env_id": "vtiger_crm_env@0.1",
  "description": "Update the 'Leads' module picklist fields in Vtiger CRM. Add 'Social Media' and 'Referral Program' to the 'Lead Source' field, and add 'Landscaping Services' and 'Property Management' to the 'Industry' field. Ensure all values match exactly and are saved.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_picklist_values/setup_task.sh",
    "post_task": "/workspace/tasks/add_picklist_values/export_result.sh"
  },
  "metadata": {
    "expected_leadsource_values": [
      "Social Media",
      "Referral Program"
    ],
    "expected_industry_values": [
      "Landscaping Services",
      "Property Management"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_picklist_values"
    }
  }
}
