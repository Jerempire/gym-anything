{
  "id": "customize_contact_layout@1",
  "version": "1.0",
  "env_id": "vtiger_crm_env@0.1",
  "description": "Customize the Contacts module layout and data rules in Vtiger CRM to improve the sales workflow. Configure the 'Title', 'Mobile Phone', and 'Department' fields to be visible in the Key Field View (Summary View) and set the 'Primary Email' field as a mandatory requirement.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/customize_contact_layout/setup_task.sh",
    "post_task": "/workspace/tasks/customize_contact_layout/export_result.sh"
  },
  "metadata": {
    "target_module": "Contacts",
    "key_fields": [
      "title",
      "mobile",
      "department"
    ],
    "mandatory_field": "email"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_customize_contact_layout"
    }
  }
}
