{
  "id": "add_multicurrency_support@1",
  "version": "1.0",
  "env_id": "vtiger_crm_env@0.1",
  "description": "Add 'Euro' (EUR) and 'Great Britain, Pounds' (GBP) as active currencies in the CRM. Set the conversion rate for Euro to 0.92 and for Great Britain, Pounds to 0.79. Ensure both currencies are set to an active status.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_multicurrency_support/setup_task.sh",
    "post_task": "/workspace/tasks/add_multicurrency_support/export_result.sh"
  },
  "metadata": {
    "expected_currencies": [
      "EUR",
      "GBP"
    ],
    "expected_eur_rate": 0.92,
    "expected_gbp_rate": 0.79,
    "expected_status": "Active",
    "tolerance": 0.005
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_multicurrency_support"
    }
  }
}
