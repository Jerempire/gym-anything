  },
  "metadata": {
    "opportunity_name": "Cloud Migration Phase 2",
    "contact_1": "Marcus Oyelaran",
    "contact_2": "Priya Chakraborty",
    "document": "Cloud Security Addendum",
    "product": "Enterprise Cloud Server"
  },
  "success": {
    "mode": "program",
