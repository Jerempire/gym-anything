{
  "id": "create_pipeline_report@1",
  "version": "1.0",
  "env_id": "vtiger_crm_env@0.1",
  "description": "Create a 'Summary Report' named 'Q4 Pipeline Summary' in the Vtiger CRM 'Potentials' module. The report must include columns for 'Potential Name', 'Amount', 'Sales Stage', 'Expected Close Date', and 'Organization Name'. Group the data by 'Sales Stage' and apply a filter condition where 'Amount' is greater than '5000'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_pipeline_report/setup_task.sh",
    "post_task": "/workspace/tasks/create_pipeline_report/export_result.sh"
  },
  "metadata": {
    "expected_report_name": "Q4 Pipeline Summary",
    "expected_module": "Potentials",
    "expected_type": "summary",
    "expected_grouping": "sales_stage",
    "expected_filter_field": "amount",
    "expected_filter_value": "5000",
    "expected_columns": [
      "potentialname",
      "amount",
      "sales_stage",
      "closingdate"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_pipeline_report"
    }
  }
}
