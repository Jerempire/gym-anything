{
  "id": "revise_sales_quote_discount@1",
  "version": "1.0",
  "env_id": "vtiger_crm_env@0.1",
  "description": "Clone the quote named 'Q3 Hardware Refresh' and update the new record's Subject to 'Q3 Hardware Refresh - Revision 1' and Quote Stage to 'Reviewed'. Apply an overall discount of 10% to the item details and save the record. The original quote must remain unmodified.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/revise_sales_quote_discount/setup_task.sh",
    "post_task": "/workspace/tasks/revise_sales_quote_discount/export_result.sh"
  },
  "metadata": {
    "original_subject": "Q3 Hardware Refresh",
    "expected_subject": "Q3 Hardware Refresh - Revision 1",
    "expected_stage": "Reviewed",
    "expected_discount": 10.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_revise_quote"
    }
  }
}
