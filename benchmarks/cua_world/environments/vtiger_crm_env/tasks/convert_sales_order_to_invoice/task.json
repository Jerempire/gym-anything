{
  "id": "convert_sales_order_to_invoice@1",
  "version": "1.0",
  "env_id": "vtiger_crm_env@0.1",
  "description": "Convert Sales Order 'SO-2026-Alpha' for Alpha Industries into an Invoice. Set the Invoice Subject to 'INV-2026-Alpha', the Status to 'Created', and apply a Shipping & Handling charge of 50.00 before saving the record.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/convert_sales_order_to_invoice/setup_task.sh",
    "post_task": "/workspace/tasks/convert_sales_order_to_invoice/export_result.sh"
  },
  "metadata": {
    "expected_subject": "INV-2026-Alpha",
    "expected_status": "Created",
    "expected_shipping_charge": 50.0,
    "expected_total": 2350.0,
    "original_so": "SO-2026-Alpha",
    "organization": "Alpha Industries"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_convert_sales_order"
    }
  }
