{
  "id": "customize_contacts_travel_layout@1",
  "version": "1.0",
  "env_id": "vtiger_crm_env@0.1",
  "description": "Customize the Contacts module schema for a travel agency workflow by adding a new block named 'Travel Preferences'. Within this block, include a Date field labeled 'Passport Expiry', a Text field labeled 'Frequent Flyer Number', a Picklist field labeled 'Preferred Seating' with the values 'Window', 'Aisle', and 'No Preference', and a Picklist field labeled 'Dietary Restrictions' with the values 'None', 'Vegetarian', 'Vegan', 'Halal', 'Kosher', and 'Gluten-Free'. Save all layout changes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/customize_contacts_travel_layout/setup_task.sh",
    "post_task": "/workspace/tasks/customize_contacts_travel_layout/export_result.sh"
  },
  "metadata": {
    "expected_block": "Travel Preferences",
    "expected_fields": [
      {
        "label": "Passport Expiry",
        "types": [
          5
        ]
      },
      {
        "label": "Frequent Flyer Number",
        "types": [
          1,
          2
        ]
      },
      {
        "label": "Preferred Seating",
        "types": [
          15,
          16,
          33
        ]
      },
      {
        "label": "Dietary Restrictions",
        "types": [
          15,
          16,
          33
        ]
      }
    ],
    "expected_seating": [
      "Window",
      "Aisle",
      "No Preference"
    ],
    "expected_dietary": [
      "None",
      "Vegetarian",
      "Vegan",
      "Halal",
      "Kosher",
      "Gluten-Free"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_customize_layout"
    }
  }
}
