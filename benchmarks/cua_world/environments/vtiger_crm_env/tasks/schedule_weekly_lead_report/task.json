{
  "id": "schedule_weekly_lead_report@1",
  "version": "1.0",
  "env_id": "vtiger_crm_env@0.1",
  "description": "Create a summary report named 'Weekly Lead Source Summary' for the 'Leads' module. Group the records by 'Lead Source' and schedule the report to be automatically emailed to the Admin user every Friday at 17:00.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/schedule_weekly_lead_report/setup_task.sh",
    "post_task": "/workspace/tasks/schedule_weekly_lead_report/export_result.sh"
  },
  "metadata": {
    "expected_name": "Weekly Lead Source Summary",
    "expected_module": "Leads",
    "expected_type": "summary",
    "expected_grouping": "leadsource",
    "expected_schedule_time": "17:00",
    "expected_schedule_day": "5"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_schedule_weekly_lead_report"
    }
  }
}
