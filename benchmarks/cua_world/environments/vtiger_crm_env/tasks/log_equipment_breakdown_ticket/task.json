{
  "id": "log_equipment_breakdown_ticket@1",
  "version": "1.0",
  "env_id": "vtiger_crm_env@0.1",
  "description": "Update the asset with Serial Number 'SN-US-2024-9981' (Sonosite Edge II - Radiology Dept) by changing its Status to 'Out of Service'. Create a related HelpDesk Ticket for this asset with the Title 'Dead Transducer Probe', Priority 'High', Status 'Open', and linked to the Organization 'Memorial Healthcare System'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/log_equipment_breakdown_ticket/setup_task.sh",
    "post_task": "/workspace/tasks/log_equipment_breakdown_ticket/export_result.sh"
  },
  "metadata": {
    "expected_serial": "SN-US-2024-9981",
    "expected_asset_status": "Out of Service",
    "expected_ticket_title": "Dead Transducer Probe",
    "expected_ticket_priority": "High",
    "expected_ticket_status": "Open",
    "expected_org_name": "Memorial Healthcare System"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ticket_from_asset"
    }
  }
}
