# SideFX API credentials for downloading Houdini
# Get credentials from: https://www.sidefx.com/services/
#
# 1. Create a free SideFX account at https://www.sidefx.com
# 2. Go to https://www.sidefx.com/services/
# 3. Create a new Application under "Applications" tab
# 4. Copy the client_id and client_secret below
# 5. Rename this file to sidefx_credentials.env

SIDEFX_CLIENT_ID=your_client_id_here
SIDEFX_CLIENT_SECRET=your_client_secret_here
