{
  "id": "houdini_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "SideFX Houdini environment for procedural 3D modeling, VFX, simulation, and rendering tasks",
  "category": "3d_graphics",
  "tags": [
    "linux",
    "3d",
    "vfx",
    "procedural",
    "simulation",
    "houdini",
    "desktop",
    "creative"
  ],
  "licence": "Proprietary (Apprentice free)",
  "authors": [
    "gym-anything team"
  ],
  "upstream_url": "https://www.sidefx.com",
  "resources": {
    "cpu": 8,
    "mem_gb": 16,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 300,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/houdini_env/artifacts",
    "video_fps": 10,
    "video_resolution": [1920, 1080],
    "video_codec": "libx264",
    "video_crf": 23,
    "audio_rate": 44100,
    "audio_channels": 2,
    "audio_codec": "aac"
  },
  "vnc": {
    "enable": false,
    "host_port": 5970,
    "container_port": 5900,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true,
    "devices": ["/dev/dri"]
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/houdini_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/houdini_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/houdini_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/houdini_env/utils", "target": "/workspace/utils", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/houdini_env/assets", "target": "/workspace/assets", "mode": "rw"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_houdini.sh",
    "post_start": "/workspace/scripts/setup_houdini.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input", "render"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "HOUDINI_NO_START_PAGE_SPLASH": "1",
          "HOUDINI_ANONYMOUS_STATISTICS": "0"
        }
      }
    }
  ]
}
