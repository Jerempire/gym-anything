{
  "id": "import_business_assets@1",
  "version": "1.0",
  "env_id": "eramba_env@0.1",
  "description": "Import the business assets from /home/ga/Documents/inventory_import.csv into the Business Assets section of Eramba. Map the 'Asset Name' CSV column to the 'Title' field and the 'Function' column to the 'Description' field. Verify that the assets are successfully imported.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/import_business_assets/setup_task.sh",
    "post_task": "/workspace/tasks/import_business_assets/export_result.sh"
  },
  "metadata": {
    "csv_path": "/home/ga/Documents/inventory_import.csv",
    "expected_assets": [
      "US-EAST-DB-01",
      "US-WEST-WEB-04",
      "EU-FR-API-02",
      "BAK-SRV-09",
      "DEV-BUILD-01"
    ],
    "expected_description_fragment": "Primary Customer Database",
    "check_asset_id": "US-EAST-DB-01"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_import_business_assets"
    }
  }
}
