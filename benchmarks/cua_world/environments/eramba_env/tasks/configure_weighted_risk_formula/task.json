{
  "id": "configure_weighted_risk_formula@1",
  "version": "1.0",
  "env_id": "eramba_env@0.1",
  "description": "Change the default Risk Calculation formula for the 'Risks' module (sometimes labeled 'Asset Risks') to a weighted addition model using the formula: likelihood + (2 * impact).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_weighted_risk_formula/setup_task.sh",
    "post_task": "/workspace/tasks/configure_weighted_risk_formula/export_result.sh"
  },
  "metadata": {
    "target_model": "Risks",
    "required_elements": [
      "likelihood",
      "impact",
      "2",
      "+"
    ],
    "multiplication_check": [
      "2*",
      "2 *"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_weighted_risk_formula"
    }
  }
}
