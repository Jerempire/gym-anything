{
  "id": "export_risk_register@1",
  "version": "1.0",
  "env_id": "eramba_env@0.1",
  "description": "Export the full Risk Register from Eramba GRC to a CSV or Excel file in /home/ga/Downloads. Ensure the exported file contains the current risk data, specifically 'Phishing Attacks on Employees'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_risk_register/setup_task.sh",
    "post_task": "/workspace/tasks/export_risk_register/export_result.sh"
  },
  "metadata": {
    "download_dir": "/home/ga/Downloads",
    "expected_keywords": [
      "Phishing",
      "Ransomware"
    ],
    "min_file_size_bytes": 100
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_risk_register"
    }
  }
}
