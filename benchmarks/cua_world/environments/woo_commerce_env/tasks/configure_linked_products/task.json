{
  "id": "configure_linked_products@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "You are an online merchant looking to increase your store's average order value by configuring product recommendations. For the product 'USB-C Laptop Charger 65W', configure 'Wireless Bluetooth Headphones' as an Upsell and both 'Organic Cotton T-Shirt' and 'Slim Fit Denim Jeans' as Cross-sells.",
