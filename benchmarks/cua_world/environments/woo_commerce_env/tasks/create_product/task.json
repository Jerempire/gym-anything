{
  "id": "create_product@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "Create and publish a simple product in the WooCommerce admin panel (already open in Firefox) named 'Handcrafted Leather Wallet' with SKU 'HLW-BRN-01' and a regular price of $45.99. Assign the product to the 'Accessories' category.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_product/setup_task.sh",
    "post_task": "/workspace/tasks/create_product/export_result.sh"
  },
  "metadata": {
    "expected_name": "Handcrafted Leather Wallet",
    "expected_sku": "HLW-BRN-01",
    "expected_price": "45.99",
    "expected_category": "Accessories",
    "expected_type": "simple",
    "expected_status": "publish"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_product"
    }
  }
}
