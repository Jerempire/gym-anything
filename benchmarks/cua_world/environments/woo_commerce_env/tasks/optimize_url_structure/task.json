{
  "id": "optimize_url_structure@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "Configure the store's URL structure to improve SEO. Set the product category base to 'collection' and the product tag base to 'labeled'. Update the product permalink structure to use the 'Shop base with category' format.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/optimize_url_structure/setup_task.sh",
    "post_task": "/workspace/tasks/optimize_url_structure/export_result.sh"
  },
  "metadata": {
    "expected_category_base": "collection",
    "expected_tag_base": "labeled",
    "expected_product_structure_part_1": "/shop/",
    "expected_product_structure_part_2": "%product_cat%"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_optimize_url_structure"
    }
  }
}
