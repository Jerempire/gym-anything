{
  "id": "export_filtered_products_csv@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "Export a CSV report of all products in the 'Clothing' category using the WooCommerce exporter. The report must include only the SKU, Name, and Regular price columns. Save the resulting file to /home/ga/Documents/clothing_prices.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_filtered_products_csv/setup_task.sh",
    "post_task": "/workspace/tasks/export_filtered_products_csv/export_result.sh"
  },
  "metadata": {
    "target_category": "Clothing",
    "required_columns": [
      "SKU",
      "Name",
      "Regular price"
    ],
    "forbidden_columns": [
      "Description",
      "Short description",
      "Stock",
      "In stock?",
      "Backorders allowed?",
      "Sold individually?",
      "Weight",
      "Length",
      "Width",
      "Height"
    ],
    "output_path": "/home/ga/Documents/clothing_prices.csv"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_filtered_products_csv"
    }
  }
}
