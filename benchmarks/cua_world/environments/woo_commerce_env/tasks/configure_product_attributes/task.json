{
  "id": "configure_product_attributes@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "Create two global product attributes in the WooCommerce admin panel: \"Color\" (slug: color) with terms Black, White, Blue, Red, Green, and Grey; and \"Material\" (slug: material) with terms Cotton, Polyester, Denim, Wool, and Leather. Assign these attributes to the following products, ensuring they are visible on the product page: \"Organic Cotton T-Shirt\" (Color: Black, Material: Cotton), \"Slim Fit Denim Jeans\" (Color: Blue, Material: Denim), and \"Merino Wool Sweater\" (Color: Grey, Material: Wool).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_product_attributes/setup_task.sh",
    "post_task": "/workspace/tasks/configure_product_attributes/export_result.sh"
  },
  "metadata": {
    "attributes": [
      {
        "name": "Color",
        "slug": "color",
        "terms": [
          "Black",
          "White",
          "Blue",
          "Red",
          "Green",
          "Grey"
        ]
      },
      {
        "name": "Material",
        "slug": "material",
        "terms": [
          "Cotton",
          "Polyester",
          "Denim",
          "Wool",
          "Leather"
        ]
      }
    ],
    "assignments": [
      {
        "product_sku": "OCT-BLK-M",
        "expected_color": "Black",
        "expected_material": "Cotton"
      },
      {
        "product_sku": "SFDJ-BLU-32",
        "expected_color": "Blue",
        "expected_material": "Denim"
      },
      {
        "product_sku": "MWS-GRY-L",
        "expected_color": "Grey",
        "expected_material": "Wool"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_product_attributes"
    }
  }
}
