        "sku": "DECOR-VASE-002",
        "weight": "1.2",
        "length": "15",
        "width": "15",
        "height": "35"
      },
      "Linen Curtains": {
        "sku": "HOME-CURT-003",
        "weight": "0.8",
        "length": "40",
        "width": "30",
        "height": "5"
      }
    }
