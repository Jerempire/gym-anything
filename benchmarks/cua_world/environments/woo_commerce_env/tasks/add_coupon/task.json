{
  "id": "add_coupon@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "In the WooCommerce admin panel (already open in Firefox), create and publish a coupon with the code 'SUMMER25'. The coupon should be a 25% percentage discount with a usage limit of 50 and a minimum spend of $75.00.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_coupon/setup_task.sh",
    "post_task": "/workspace/tasks/add_coupon/export_result.sh"
  },
  "metadata": {
    "expected_code": "SUMMER25",
    "expected_discount_type": "percent",
    "expected_amount": "25",
    "expected_usage_limit": "50",
    "expected_minimum_amount": "75"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_coupon"
    }
  }
}
