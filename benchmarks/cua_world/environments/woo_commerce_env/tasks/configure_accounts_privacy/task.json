{
  "id": "configure_accounts_privacy@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "Configure the WooCommerce Accounts & Privacy settings to meet new GDPR and registration requirements. Disable the option for customers to place orders without an account. Enable options for customers to log into existing accounts during checkout, create accounts during checkout, and create accounts on the 'My Account' page. For account erasure requests, enable the removal of personal data from orders and the removal of access to downloads.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_accounts_privacy/setup_task.sh",
    "post_task": "/workspace/tasks/configure_accounts_privacy/export_result.sh"
  },
  "metadata": {
    "target_options": {
      "woocommerce_enable_guest_checkout": "no",
      "woocommerce_enable_checkout_login_reminder": "yes",
      "woocommerce_enable_signup_and_login_from_checkout": "yes",
      "woocommerce_enable_myaccount_registration": "yes",
      "woocommerce_erasure_request_removes_order_data": "yes",
      "woocommerce_erasure_request_removes_download_data": "yes"
    },
    "scoring": {
      "guest_checkout": 20,
      "login_reminder": 10,
      "checkout_signup": 15,
      "myaccount_signup": 20,
      "erase_orders": 20,
      "erase_downloads": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_accounts_privacy"
    }
  }
}
