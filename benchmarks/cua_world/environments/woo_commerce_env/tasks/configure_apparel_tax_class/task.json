{
  "id": "configure_apparel_tax_class@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "Configure advanced tax rules for clothing. Establish an 'Apparel' tax class with a 4.0% rate for New York (NY) named 'NY Apparel Tax' that includes shipping. Assign the 'Organic Cotton T-Shirt' product to this 'Apparel' tax class. Do not remove existing tax classes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_apparel_tax_class/setup_task.sh",
    "post_task": "/workspace/tasks/configure_apparel_tax_class/export_result.sh"
  },
  "metadata": {
    "target_product_name": "Organic Cotton T-Shirt",
    "expected_tax_class_name": "Apparel",
    "expected_tax_class_slug": "apparel",
    "expected_rate": "4.0000",
    "expected_state": "NY",
    "expected_country": "US",
    "expected_tax_name": "NY Apparel Tax"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_apparel_tax_class"
    }
  }
}
