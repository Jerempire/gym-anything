{
  "id": "create_customer_account@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "In the WooCommerce admin panel (already open in Firefox), create a new user account with the following details: Username: 'sarahjohnson', Email: 'sarah.johnson@example.com', First Name: 'Sarah', Last Name: 'Johnson', and Role: 'Customer'. Use any password.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_customer_account/setup_task.sh",
    "post_task": "/workspace/tasks/create_customer_account/export_result.sh"
  },
  "metadata": {
    "expected_firstname": "Sarah",
    "expected_lastname": "Johnson",
    "expected_email": "sarah.johnson@example.com",
    "expected_username": "sarahjohnson",
    "expected_role": "customer"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_customer_account"
    }
  }
}
