{
  "id": "enable_product_backorders@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "The 'Wireless Bluetooth Headphones' (SKU: WBH-001) are currently out of stock. Configure this product to allow backorders with customer notification and set the low stock threshold to 5. Do not change the stock quantity.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/enable_product_backorders/setup_task.sh",
    "post_task": "/workspace/tasks/enable_product_backorders/export_result.sh"
  },
  "metadata": {
    "target_sku": "WBH-001",
    "expected_backorders_value": "notify",
    "expected_low_stock_amount": "5",
    "expected_manage_stock": "yes",
    "expected_stock_status": "onbackorder"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enable_product_backorders"
    }
  }
}
