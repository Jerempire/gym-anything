{
  "id": "apply_coupon_to_order@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "In the WooCommerce admin panel, create and save a manual order for customer 'John Doe' (john.doe@example.com) containing one 'Yoga Mat Premium' and two 'Insulated Water Bottle 32oz' units with the 'WELCOME10' coupon code applied.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 420,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/apply_coupon_to_order/setup_task.sh",
    "post_task": "/workspace/tasks/apply_coupon_to_order/export_result.sh"
  },
  "metadata": {
    "expected_products": [
      {
        "name": "Yoga Mat Premium",
        "sku": "YMP-001",
        "quantity": 1,
        "unit_price": "39.99"
      },
      {
        "name": "Insulated Water Bottle 32oz",
        "sku": "IWB-032",
        "quantity": 2,
        "unit_price": "27.99"
      }
    ],
    "expected_coupon": "WELCOME10",
    "expected_customer_email": "john.doe@example.com",
    "expected_subtotal": "95.97",
    "expected_discount_percent": "10"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_apply_coupon_to_order"
    }
  }
}
