{
  "id": "configure_tax_rates@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "Configure WooCommerce tax settings to enter prices exclusive of tax, calculate tax based on the customer shipping address, and display prices excluding tax in the shop, cart, and checkout. Add standard tax rates for the following states: California (CA) at 7.25% named 'CA State Tax', New York (NY) at 8.00% named 'NY State Tax', Texas (TX) at 6.25% named 'TX State Tax', Florida (FL) at 6.00% named 'FL State Tax', and Washington (WA) at 6.50% named 'WA State Tax'. All rates should have Priority 1, be non-compound, and apply to shipping.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_tax_rates/setup_task.sh",
    "post_task": "/workspace/tasks/configure_tax_rates/export_result.sh"
  },
  "metadata": {
    "expected_options": {
      "woocommerce_prices_include_tax": "no",
      "woocommerce_tax_based_on": "shipping",
      "woocommerce_tax_display_shop": "excl",
      "woocommerce_tax_display_cart": "excl"
    },
    "expected_rates": [
      {
        "country": "US",
        "state": "CA",
        "rate": "7.2500",
        "name": "CA State Tax",
        "shipping": "1"
      },
      {
        "country": "US",
        "state": "NY",
        "rate": "8.0000",
        "name": "NY State Tax",
        "shipping": "1"
      },
      {
        "country": "US",
        "state": "TX",
        "rate": "6.2500",
        "name": "TX State Tax",
        "shipping": "1"
      },
      {
        "country": "US",
        "state": "FL",
        "rate": "6.0000",
        "name": "FL State Tax",
        "shipping": "1"
      },
      {
        "country": "US",
        "state": "WA",
        "rate": "6.5000",
        "name": "WA State Tax",
        "shipping": "1"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_tax_rates"
    }
  }
}
