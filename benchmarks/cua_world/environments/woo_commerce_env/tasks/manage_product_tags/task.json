{
  "id": "manage_product_tags@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "Create three product tags in WooCommerce: 'Premium' (slug: premium), 'Eco-Friendly' (slug: eco-friendly), and 'Gift Idea' (slug: gift-idea). Assign the 'Premium' and 'Eco-Friendly' tags to the 'Organic Cotton T-Shirt'. Assign the 'Premium' and 'Gift Idea' tags to the 'Wireless Bluetooth Headphones'. Assign the 'Eco-Friendly' and 'Gift Idea' tags to the 'Merino Wool Sweater'. Use the WooCommerce admin panel at http://localhost/wp-admin/ (credentials: admin / Admin1234!).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/manage_product_tags/setup_task.sh",
    "post_task": "/workspace/tasks/manage_product_tags/export_result.sh"
  },
  "metadata": {
    "required_tags": [
      {
        "name": "Premium",
        "slug": "premium"
      },
      {
        "name": "Eco-Friendly",
        "slug": "eco-friendly"
      },
      {
        "name": "Gift Idea",
        "slug": "gift-idea"
      }
    ],
    "assignments": [
      {
        "product": "Organic Cotton T-Shirt",
        "tags": [
          "Premium",
          "Eco-Friendly"
        ]
      },
      {
        "product": "Wireless Bluetooth Headphones",
        "tags": [
          "Premium",
          "Gift Idea"
        ]
      },
      {
        "product": "Merino Wool Sweater",
        "tags": [
          "Eco-Friendly",
          "Gift Idea"
        ]
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_manage_product_tags"
    }
  }
}
