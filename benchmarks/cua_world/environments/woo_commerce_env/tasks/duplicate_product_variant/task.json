{
  "id": "duplicate_product_variant@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "Create a new product variant named 'Wireless Bluetooth Headphones - Gold Edition' (SKU: 'WBH-001-GOLD') by duplicating the existing 'Wireless Bluetooth Headphones' (SKU: WBH-001). Set the regular price to $129.99 and catalog visibility to 'Search results only'. Ensure the new product is published.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/duplicate_product_variant/setup_task.sh",
    "post_task": "/workspace/tasks/duplicate_product_variant/export_result.sh"
  },
  "metadata": {
    "source_sku": "WBH-001",
    "expected_sku": "WBH-001-GOLD",
    "expected_name": "Wireless Bluetooth Headphones - Gold Edition",
    "expected_price": "129.99",
    "expected_visibility_term": "exclude-from-catalog"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_duplicate_product_variant"
    }
  }
}
