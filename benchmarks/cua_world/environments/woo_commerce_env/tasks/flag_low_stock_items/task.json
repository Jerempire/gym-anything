{
  "id": "flag_low_stock_items@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "Perform an inventory audit for the 'Accessories' category. Tag all simple products with a stock quantity strictly less than 10 with the product tag 'Urgent Reorder'. Do not tag variable products or products with a stock quantity of 10 or higher.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/flag_low_stock_items/setup_task.sh",
    "post_task": "/workspace/tasks/flag_low_stock_items/export_result.sh"
  },
  "metadata": {
    "target_category": "Accessories",
    "target_tag": "Urgent Reorder",
    "stock_threshold": 10,
    "low_stock_targets": [
      "Beanie",
      "Cap",
      "Belt"
    ],
    "high_stock_targets": [
      "Sunglasses",
      "Long Sleeve Tee"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_flag_low_stock_items"
    }
  }
}
