{
  "id": "schedule_product_sale@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "Schedule a sale for the 'Wireless Bluetooth Headphones' (SKU: WBH-001) with a Sale Price of $49.99 and a Regular Price of $79.99. The sale must be scheduled to run from 2025-07-01 to 2025-07-07. You start on the All Products screen in the WooCommerce admin panel.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/schedule_product_sale/setup_task.sh",
    "post_task": "/workspace/tasks/schedule_product_sale/export_result.sh"
  },
  "metadata": {
    "target_sku": "WBH-001",
    "expected_sale_price": "49.99",
    "expected_start_date": "2025-07-01",
    "expected_end_date": "2025-07-07",
    "expected_regular_price": "79.99"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_schedule_product_sale"
    }
  }
}
