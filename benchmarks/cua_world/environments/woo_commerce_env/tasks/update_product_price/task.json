{
  "id": "update_product_price@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "Update the 'Wireless Bluetooth Headphones' product in the WooCommerce admin panel (already open in Firefox) by setting the regular price to $59.99 and the sale price to $49.99.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_product_price/setup_task.sh",
    "post_task": "/workspace/tasks/update_product_price/export_result.sh"
  },
  "metadata": {
    "target_product_sku": "WBH-001",
    "target_product_name": "Wireless Bluetooth Headphones",
    "expected_regular_price": "59.99",
    "expected_sale_price": "49.99",
    "original_regular_price": "79.99"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_product_price"
    }
  }
}
