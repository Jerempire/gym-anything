{
  "id": "manage_product_images@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "Enhance the product listing for 'Wireless Bluetooth Headphones' (SKU: WBH-001) by setting 'headphones_main.jpg' from ~/Documents/ProductPhotos/ as the main product image and adding 'headphones_lifestyle.jpg' from the same directory to the product gallery.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/manage_product_images/setup_task.sh",
    "post_task": "/workspace/tasks/manage_product_images/export_result.sh"
  },
  "metadata": {
    "target_sku": "WBH-001",
    "main_image_filename": "headphones_main.jpg",
    "gallery_image_filename": "headphones_lifestyle.jpg",
    "assets_dir": "/home/ga/Documents/ProductPhotos"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_manage_product_images"
    }
  }
}
