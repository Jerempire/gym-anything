{
  "id": "update_order_status@1",
  "version": "1.0",
  "env_id": "woo_commerce_env@0.1",
  "description": "Update the status of Maria Garcia's 'Processing' order to 'Completed' in WooCommerce. Add a private order note with the exact text: 'Shipped via Express. Tracking: TRACK-2024-78542'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_order_status/setup_task.sh",
    "post_task": "/workspace/tasks/update_order_status/export_result.sh"
  },
  "metadata": {
    "target_customer_name": "Maria Garcia",
    "initial_status": "wc-processing",
    "target_status": "wc-completed",
    "note_content": "Shipped via Express. Tracking: TRACK-2024-78542",
    "tracking_number": "TRACK-2024-78542"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_order_status"
    }
  }
}
