{
  "id": "ocean_gyre_thermal_asymmetry@1",
  "version": "1.0",
  "env_id": "panoply_env@0.1",
  "description": "A Physical Oceanography professor needs you to extract baseline climatological reference points from the NOAA Sea Surface Temperature (SST) dataset for an undergraduate lab manual on ocean gyre thermal asymmetry. Using Panoply and the NOAA SST data in ~/PanoplyData/sst.ltm.1991-2020.nc, follow the instructions in ~/Desktop/oceanography_lab_request.txt to export a North Atlantic regional map for February and record the SST at the four specified coordinates. Complete the thermal asymmetry report to prove whether western or eastern boundary currents are warmer at different latitudes.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/ocean_gyre_thermal_asymmetry/setup_task.sh",
    "post_task": "/workspace/tasks/ocean_gyre_thermal_asymmetry/export_result.sh"
  },
  "metadata": {
    "occupation": "Physical Oceanography Professor / Lab Assistant",
    "industry": "Higher Education / Marine Science",
    "data_file": "/home/ga/PanoplyData/sst.ltm.1991-2020.nc",
    "variable": "sst",
    "output_dir": "/home/ga/Documents/GyreStudy",
    "expected_outputs": [
      "/home/ga/Documents/GyreStudy/north_atlantic_feb.png",
      "/home/ga/Documents/GyreStudy/thermal_asymmetry_report.txt"
    ],
    "validation_bounds": {
      "SUB_WEST_30N_78W_C": {
        "min": 19.0,
        "max": 24.0
      },
      "SUB_EAST_30N_12W_C": {
        "min": 15.0,
        "max": 19.0
      },
      "MID_WEST_45N_60W_C": {
        "min": -2.0,
        "max": 6.0
      },
      "MID_EAST_45N_12W_C": {
        "min": 10.0,
        "max": 15.0
      }
    },
    "expected_logic": {
      "SUBTROPICAL_WARMER_SIDE": "WEST",
      "MIDLATITUDE_WARMER_SIDE": "EAST"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ocean_gyre_thermal_asymmetry"
    }
  }
}
