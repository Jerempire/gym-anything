{
  "id": "datacenter_free_cooling_site_selection@1",
  "version": "1.0",
  "env_id": "panoply_env@0.1",
  "description": "Your infrastructure engineering firm needs to select a site for a new hyperscale data center in Europe that remains below 15°C (288.15 K) year-round. Using NASA Panoply, evaluate the candidate locations in ~/Desktop/site_selection_brief.txt against the temperature data in ~/PanoplyData/air.mon.ltm.nc for January and July. Export the maps and a site selection report identifying which candidate site meets the threshold during the July peak.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/datacenter_free_cooling_site_selection/setup_task.sh",
    "post_task": "/workspace/tasks/datacenter_free_cooling_site_selection/export_result.sh"
  },
  "metadata": {
    "occupation": "Data Center Infrastructure Engineer",
    "industry": "Cloud Computing / Infrastructure",
    "data_file": "/home/ga/PanoplyData/air.mon.ltm.nc",
    "variable": "air",
    "output_dir": "/home/ga/Documents/DataCenter",
    "expected_outputs": [
      "/home/ga/Documents/DataCenter/europe_july_temp.png",
      "/home/ga/Documents/DataCenter/europe_jan_temp.png",
      "/home/ga/Documents/DataCenter/site_selection_report.txt"
    ],
    "correct_candidate": "Iceland",
    "threshold_temp_c": 15.0,
    "threshold_temp_k": 288.15
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_datacenter_free_cooling"
    }
  }
}
