{
  "id": "topographic_pressure_fingerprint@1",
  "version": "1.0",
  "env_id": "panoply_env@0.1",
  "description": "You are a physical geography professor preparing for a lecture on how topography shapes the atmosphere. Following the brief at ~/Desktop/pressure_lecture_brief.txt, use Panoply to analyze the surface pressure and sea-level pressure datasets in ~/PanoplyData/. Export comparative visualizations for January and write a structured educational summary analyzing the differences. Deliver all outputs to ~/Documents/PressureLecture/.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/topographic_pressure_fingerprint/setup_task.sh",
    "post_task": "/workspace/tasks/topographic_pressure_fingerprint/export_result.sh"
  },
  "metadata": {
    "occupation": "Physical Geography Lecturer",
    "industry": "Higher Education / Geoscience",
    "data_files": [
      "/home/ga/PanoplyData/pres.mon.ltm.nc",
      "/home/ga/PanoplyData/slp.mon.ltm.nc"
    ],
    "output_dir": "/home/ga/Documents/PressureLecture",
    "expected_outputs": [
      "/home/ga/Documents/PressureLecture/surface_pressure_jan.png",
      "/home/ga/Documents/PressureLecture/sealevel_pressure_jan.png",
      "/home/ga/Documents/PressureLecture/lecture_notes.txt"
    ],
    "surface_pressure_valid_range_hPa": [
      400,
      850
    ],
    "sealevel_pressure_valid_range_hPa": [
      950,
      1050
    ],
    "key_difference_keywords": [
      "elevation",
      "altitude",
      "topograph",
      "height",
      "terrain",
      "mountain"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_topographic_pressure_fingerprint"
    }
  }
}
