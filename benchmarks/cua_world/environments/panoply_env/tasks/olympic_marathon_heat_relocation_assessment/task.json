{
  "id": "olympic_marathon_heat_relocation_assessment@1",
  "version": "1.0",
  "env_id": "panoply_env@0.1",
  "description": "As a Sports Medical Climatologist, audit the International Olympic Committee's decision to relocate the 2020 marathon from Tokyo to Sapporo due to extreme heat. Using the mandate at ~/Desktop/ioc_marathon_audit_request.txt and the surface air temperature dataset in ~/PanoplyData/, extract the precise grid cell temperatures for both cities, export a regional map of Japan, and write a decision audit report evaluating the thermal impact of the relocation. Deliver all outputs to ~/Documents/OlympicPlanning/.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/olympic_marathon_heat_relocation_assessment/setup_task.sh",
    "post_task": "/workspace/tasks/olympic_marathon_heat_relocation_assessment/export_result.sh"
  },
  "metadata": {
    "occupation": "Sports Medical Climatologist",
    "industry": "International Olympic Committee / Medical Logistics",
    "data_file": "/home/ga/PanoplyData/air.mon.ltm.nc",
    "variable": "air",
    "output_dir": "/home/ga/Documents/OlympicPlanning",
    "expected_outputs": [
      "/home/ga/Documents/OlympicPlanning/japan_august_temp.png",
      "/home/ga/Documents/OlympicPlanning/marathon_relocation_audit.txt"
    ],
    "tokyo_coords": "35.0N, 140.0E",
    "sapporo_coords": "42.5N, 140.0E",
    "tokyo_valid_range_c": [
      23.0,
      29.0
    ],
    "sapporo_valid_range_c": [
      18.0,
      24.0
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_olympic_marathon_heat_relocation"
    }
  }
}
