{
  "id": "sh_frost_viticulture_planning@1",
  "version": "1.0",
  "env_id": "panoply_env@0.1",
  "description": "As an agricultural meteorologist for the International Organisation of Vine and Wine (OIV), prepare an updated frost risk assessment for major Southern Hemisphere wine regions ahead of the upcoming pruning season. Use NASA Panoply and the temperature climatology data in ~/PanoplyData/ to produce the plots and advisory report as specified in the request at ~/Desktop/frost_advisory_request.txt.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sh_frost_viticulture_planning/setup_task.sh",
    "pre_task_timeout": 300,
    "post_task": "/workspace/tasks/sh_frost_viticulture_planning/export_result.sh"
  },
  "metadata": {
    "occupation": "Agricultural Meteorologist / Viticultural Climate Advisor",
    "industry": "Precision Agriculture / Viticulture",
    "data_file": "/home/ga/PanoplyData/air.mon.ltm.nc",
    "variable": "air",
    "output_dir": "/home/ga/Documents/FrostRisk",
    "expected_outputs": [
      "/home/ga/Documents/FrostRisk/sh_temperature_july.png",
      "/home/ga/Documents/FrostRisk/sh_temperature_june.png",
      "/home/ga/Documents/FrostRisk/frost_risk_report.txt"
    ],
    "correct_analysis_season": "JJA",
    "correct_coldest_month": "July",
    "correct_highest_risk_region": "Mendoza"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_sh_frost_viticulture_planning"
    }
  }
}
