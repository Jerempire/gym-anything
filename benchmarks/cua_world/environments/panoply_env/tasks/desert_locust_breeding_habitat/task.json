{
  "id": "desert_locust_breeding_habitat@1",
  "version": "1.0",
  "env_id": "panoply_env@0.1",
  "description": "You are a forecasting officer at the FAO Desert Locust Information Service (DLIS). Assess the desert locust breeding suitability in the recession area for October using NASA Panoply and the NCEP climatology data (precipitation and surface air temperature) in ~/PanoplyData/. Identify the optimal breeding zone based on temperature and moisture intersection as specified in the mandate at ~/Desktop/dlis_october_mandate.txt. Export two plot images and a structured assessment report to ~/Documents/LocustAssessment/.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 960,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/desert_locust_breeding_habitat/setup_task.sh",
    "post_task": "/workspace/tasks/desert_locust_breeding_habitat/export_result.sh"
  },
  "metadata": {
    "occupation": "Desert Locust Forecasting Officer",
    "industry": "FAO / International Agriculture / Pest Management",
    "data_files": [
      "/home/ga/PanoplyData/prate.sfc.mon.ltm.nc",
      "/home/ga/PanoplyData/air.mon.ltm.nc"
    ],
    "output_dir": "/home/ga/Documents/LocustAssessment",
    "expected_outputs": [
      "/home/ga/Documents/LocustAssessment/precip_october.png",
      "/home/ga/Documents/LocustAssessment/temperature_october.png",
      "/home/ga/Documents/LocustAssessment/breeding_report.txt"
    ],
    "assessment_month": "October",
    "correct_breeding_zones": [
      "Horn",
      "Arabian",
      "East Africa",
      "Somalia",
      "Yemen",
      "Oman"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_desert_locust_breeding_habitat"
    }
  }
}
