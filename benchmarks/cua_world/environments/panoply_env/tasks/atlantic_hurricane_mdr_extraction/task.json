{
  "id": "atlantic_hurricane_mdr_extraction@1",
  "version": "1.0",
  "env_id": "panoply_env@0.1",
  "description": "Extract the 12-month SST time series for the Atlantic MDR (15.5°N, 40°W) to ~/Documents/mdr_sst.csv, create a September spatial map at ~/Documents/september_map.png, and determine which months exceed the 26.5°C cyclogenesis threshold. Refer to the request at ~/Desktop/mdr_extraction_request.txt.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/atlantic_hurricane_mdr_extraction/setup_task.sh",
    "post_task": "/workspace/tasks/atlantic_hurricane_mdr_extraction/export_result.sh"
  },
  "metadata": {
    "expected_lat": 15.5,
    "expected_lon": 320.5,
    "threshold": 26.5,
    "data_file": "/home/ga/PanoplyData/sst.ltm.1991-2020.nc",
    "output_csv": "/home/ga/Documents/HurricaneResearch/mdr_sst_annual.csv",
    "output_png": "/home/ga/Documents/HurricaneResearch/mdr_map_september.png",
    "output_txt": "/home/ga/Documents/HurricaneResearch/mdr_thermal_report.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_atlantic_hurricane_mdr_extraction"
    }
  }
}
