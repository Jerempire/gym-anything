{
  "id": "nh_winter_circulation_diagnostic@1",
  "version": "1.0",
  "env_id": "panoply_env@0.1",
  "description": "You are a synoptic meteorologist preparing a Northern Hemisphere winter circulation diagnostic for a WMO regional training workshop. Using the briefing at ~/Desktop/wmo_briefing_request.txt and datasets in ~/PanoplyData/, create a combined overlay plot of January air temperature (color fill) with SLP contours in North Polar Stereographic projection, a 1D zonal mean SLP profile, and a structured diagnostic report with extracted pressure values. Save all outputs to ~/Documents/WMO_Briefing/.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 1500,
    "max_steps": 200,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/nh_winter_circulation_diagnostic/setup_task.sh",
    "post_task": "/workspace/tasks/nh_winter_circulation_diagnostic/export_result.sh"
  },
  "metadata": {
    "occupation": "Synoptic Meteorologist / WMO Training Instructor",
    "industry": "Meteorology / Climate Science Education",
    "data_files": [
      "/home/ga/PanoplyData/air.mon.ltm.nc",
      "/home/ga/PanoplyData/slp.mon.ltm.nc"
    ],
    "output_dir": "/home/ga/Documents/WMO_Briefing",
    "expected_outputs": [
      "/home/ga/Documents/WMO_Briefing/nh_circulation_jan.png",
      "/home/ga/Documents/WMO_Briefing/zonal_slp_profile.png",
      "/home/ga/Documents/WMO_Briefing/circulation_diagnostic.txt"
    ],
    "analysis_month": "January",
    "expected_icelandic_low_range_hpa": [995.0, 1010.0],
    "expected_siberian_high_range_hpa": [1025.0, 1045.0],
    "expected_aleutian_low_range_hpa": [995.0, 1012.0],
    "expected_contrast_range_hpa": [20.0, 50.0]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_nh_winter_circulation_diagnostic"
    }
  }
}
