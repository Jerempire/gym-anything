{
  "id": "greenland_ablation_onset_analysis@1",
  "version": "1.0",
  "env_id": "panoply_env@0.1",
  "description": "As a researcher at the National Snow and Ice Data Center (NSIDC), establish a climatological baseline of the Greenland Ice Sheet's ablation season onset. Using Panoply and the surface air temperature dataset in ~/PanoplyData/, produce the diagnostic maps and glaciological report specified in ~/Desktop/nsidc_melt_briefing.txt. Use an appropriate North Polar projection and deliver all outputs to ~/Documents/GrISMelt/.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/greenland_ablation_onset_analysis/setup_task.sh",
    "post_task": "/workspace/tasks/greenland_ablation_onset_analysis/export_result.sh"
  },
  "metadata": {
    "occupation": "Glaciologist / Cryospheric Scientist",
    "industry": "Climate Science / NSIDC",
    "data_file": "/home/ga/PanoplyData/air.mon.ltm.nc",
    "variable": "air",
    "output_dir": "/home/ga/Documents/GrISMelt",
    "expected_outputs": [
      "/home/ga/Documents/GrISMelt/greenland_temp_april.png",
      "/home/ga/Documents/GrISMelt/greenland_temp_july.png",
      "/home/ga/Documents/GrISMelt/ablation_onset_report.txt"
    ],
    "melt_threshold_k": 273.15
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_greenland_ablation_onset_analysis"
    }
  }
}
