{
  "id": "andean_high_hot_aviation_hazard@1",
  "version": "1.0",
  "env_id": "panoply_env@0.1",
  "description": "As an aviation performance engineer, produce a High/Hot hazard flight advisory and corresponding atmospheric maps for Andean cargo routes. Use NASA Panoply to analyze the atmospheric climatology data in ~/PanoplyData/ according to the mandate in ~/Desktop/route_evaluation_mandate.txt. The assessment must use surface pressure and air temperature to determine density altitude. Export the surface pressure map, air temperature map, and the structured advisory text file to ~/Documents/.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 960,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/andean_high_hot_aviation_hazard/setup_task.sh",
    "post_task": "/workspace/tasks/andean_high_hot_aviation_hazard/export_result.sh"
  },
  "metadata": {
    "occupation": "Aviation Performance Engineer",
    "industry": "Cargo Aviation / Flight Operations",
    "data_files": [
      "/home/ga/PanoplyData/pres.mon.ltm.nc",
      "/home/ga/PanoplyData/air.mon.ltm.nc"
    ],
    "distractor_file": "/home/ga/PanoplyData/slp.mon.ltm.nc",
    "output_dir": "/home/ga/Documents/AviationLogistics",
    "expected_outputs": [
      "/home/ga/Documents/AviationLogistics/andes_surface_pressure_jan.png",
      "/home/ga/Documents/AviationLogistics/andes_air_temperature_jan.png",
      "/home/ga/Documents/AviationLogistics/high_hot_advisory.txt"
    ],
    "correct_pressure_range_hpa": [
      500,
      750
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_andean_high_hot_aviation_hazard"
    }
  }
}
