{
  "id": "hokkaido_drift_ice_thermal_forcing@1",
  "version": "1.0",
  "env_id": "panoply_env@0.1",
  "description": "Complete a climatological baseline assessment of the thermal and dynamic forcing for 'Ryuhyo' (drift ice) in the Sea of Okhotsk for the Japan Coast Guard's Ice Information Center. Using Panoply and the atmospheric datasets in ~/PanoplyData/, extract February climatological values to generate the regional plots and quantitative assessment report as specified in the analysis brief at ~/Desktop/ryuhyo_analysis_brief.txt.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/hokkaido_drift_ice_thermal_forcing/setup_task.sh",
    "post_task": "/workspace/tasks/hokkaido_drift_ice_thermal_forcing/export_result.sh"
  },
  "metadata": {
    "occupation": "Marine Forecaster / Climatologist",
    "industry": "Maritime Safety / Coast Guard Ice Information Center",
    "data_files": [
      "/home/ga/PanoplyData/air.mon.ltm.nc",
      "/home/ga/PanoplyData/slp.mon.ltm.nc"
    ],
    "output_dir": "/home/ga/Documents/Ryuhyo",
    "expected_outputs": [
      "/home/ga/Documents/Ryuhyo/okhotsk_airtemp_feb.png",
      "/home/ga/Documents/Ryuhyo/okhotsk_slp_feb.png",
      "/home/ga/Documents/Ryuhyo/thermal_forcing_report.txt"
    ],
    "analysis_month": "February",
    "valid_slp_range_hpa": [
      1025,
      1045
    ],
    "valid_temp_range_c": [
      -40,
      -5
    ],
    "valid_temp_range_k": [
      233,
      268
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_hokkaido_drift_ice_thermal_forcing"
    }
  }
}
