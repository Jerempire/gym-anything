{
  "id": "central_asian_basins_data_extraction@1",
  "version": "1.0",
  "env_id": "panoply_env@0.1",
  "description": "Hydrologists require baseline climatological data to model the Aral Sea and Lake Balkhash endorheic basins. Using the analysis mandate at ~/Desktop/basin_data_request.txt and the NCEP reanalysis NetCDF files in ~/PanoplyData/, extract the long-term mean air temperature and precipitation rate for April at the specified basin coordinates. Create a regional precipitation map and compile the extracted numerical findings into a formatted JSON report.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/central_asian_basins_data_extraction/setup_task.sh",
    "post_task": "/workspace/tasks/central_asian_basins_data_extraction/export_result.sh"
  },
  "metadata": {
    "occupation": "Hydrologist / Climate Data Analyst",
    "industry": "Environmental Science / Water Resources Management",
    "data_files": [
      "/home/ga/PanoplyData/air.mon.ltm.nc",
      "/home/ga/PanoplyData/prate.sfc.mon.ltm.nc"
    ],
    "output_dir": "/home/ga/Documents/CentralAsia",
    "expected_outputs": [
      "/home/ga/Documents/CentralAsia/precip_map_april.png",
      "/home/ga/Documents/CentralAsia/basin_climatology.json"
    ],
    "target_month": "April",
    "target_month_index": 3,
    "aral_coords": {
      "lat": 45.0,
      "lon": 60.0
    },
    "balkhash_coords": {
      "lat": 45.0,
      "lon": 75.0
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_central_asian_basins_data_extraction"
    }
  }
}
