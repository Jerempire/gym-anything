{
  "id": "arabica_coffee_climatology_validation@1",
  "version": "1.0",
  "env_id": "panoply_env@0.1",
  "description": "Perform an agronomic validation of the Brazilian Arabica coffee belt in Minas Gerais using the climatology data in ~/PanoplyData/. Extract 12-month temperature and precipitation time series at Latitude 20.0S (-20.0), Longitude 45.0W (315.0E) and generate 1D line plots for both variables along the time dimension. Export the precipitation data to CSV and complete the baseline report as specified in the mandate at ~/Desktop/coffee_baseline_mandate.txt.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/arabica_coffee_climatology_validation/setup_task.sh",
    "post_task": "/workspace/tasks/arabica_coffee_climatology_validation/export_result.sh"
  },
  "metadata": {
    "occupation": "Agricultural Commodity Analyst",
    "industry": "Coffee Trading / Agricultural Economics",
    "data_files": [
      "/home/ga/PanoplyData/air.mon.ltm.nc",
      "/home/ga/PanoplyData/prate.sfc.mon.ltm.nc"
    ],
    "output_dir": "/home/ga/Documents/CoffeeStudy",
    "expected_outputs": [
      "/home/ga/Documents/CoffeeStudy/minas_temp_cycle.png",
      "/home/ga/Documents/CoffeeStudy/minas_precip_cycle.png",
      "/home/ga/Documents/CoffeeStudy/minas_precip_timeseries.csv",
      "/home/ga/Documents/CoffeeStudy/coffee_baseline_report.txt"
    ],
    "target_lat": -20.0,
    "target_lon": 315.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_arabica_coffee_climatology"
    }
  }
}
