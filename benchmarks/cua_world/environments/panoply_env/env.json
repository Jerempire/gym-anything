{
  "id": "panoply_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "NASA Panoply environment for visualizing netCDF, HDF, and GRIB scientific data files with geo-mapped plots, line plots, and various map projections",
  "category": "science_visualization",
  "tags": [
    "linux",
    "science",
    "visualization",
    "netcdf",
    "climate",
    "nasa",
    "desktop",
    "java"
  ],
  "licence": "Public Domain (NASA)",
  "authors": [
    "gym-anything team"
  ],
  "upstream_url": "https://www.giss.nasa.gov/tools/panoply/",
  "resources": {
    "cpu": 4,
    "mem_gb": 4,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [
        1920,
        1080
      ],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": true,
  "step_cycle_ms": 300,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/panoply_env/artifacts",
    "video_fps": 10,
    "video_resolution": [
      1920,
      1080
    ],
    "video_codec": "libx264",
    "video_crf": 23,
    "audio_rate": 44100,
    "audio_channels": 2,
    "audio_codec": "aac"
  },
  "vnc": {
    "enable": false,
    "host_port": 5970,
    "container_port": 5900,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": [
      "ALL"
    ],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/panoply_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/panoply_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/panoply_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/panoply_env/utils",
      "target": "/workspace/utils",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/panoply_env/assets",
      "target": "/workspace/assets",
      "mode": "rw"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_panoply.sh",
    "post_start": "/workspace/scripts/setup_panoply.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "scientist",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": [
          "sudo",
          "audio",
          "video",
          "input"
        ],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "PANOPLY_HOME": "/opt/PanoplyJ"
        }
      }
    }
  ]
}
