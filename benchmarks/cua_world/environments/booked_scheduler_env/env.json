{
  "id": "booked_scheduler_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Booked Scheduler environment for resource reservation management, room booking, and scheduling tasks",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "diagnostics": true,
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    { "type": "mouse" },
    { "type": "keyboard" }
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/booked_scheduler_env/artifacts",
    "video_fps": 10,
    "video_resolution": [1920, 1080],
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": false,
    "host_port": 5966,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/booked_scheduler_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/booked_scheduler_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/booked_scheduler_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/booked_scheduler_env/utils",
      "target": "/workspace/utils",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/booked_scheduler_env/data",
      "target": "/workspace/data",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_booked_scheduler.sh",
    "post_start": "/workspace/scripts/setup_booked_scheduler.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input", "www-data"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "BOOKED_USER": "ga"
        }
      }
    }
  ],
  "tags": [
    "linux",
    "scheduling",
    "booking",
    "resource-management",
    "web-application",
    "php",
    "mysql",
    "desktop"
  ]
}
