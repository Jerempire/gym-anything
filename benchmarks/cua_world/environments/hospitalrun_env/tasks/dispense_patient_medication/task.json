{
  "id": "dispense_patient_medication@1",
  "version": "1.0",
  "env_id": "hospitalrun_env@0.1",
  "description": "Dispense the active medication order for 'Ibuprofen 400mg' for patient Sven Goran by marking it as 'Completed'. Ensure only the active Ibuprofen order for Sven Goran is dispensed, as the patient has cancelled orders and other patients have similar prescriptions.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/dispense_patient_medication/setup_task.sh",
    "post_task": "/workspace/tasks/dispense_patient_medication/export_result.sh"
  },
  "metadata": {
    "target_patient_name": "Sven Goran",
    "target_medication": "Ibuprofen 400mg",
    "target_doc_id": "medication_target_sven",
    "distractor_cancelled_id": "medication_distractor_sven_cancelled",
    "distractor_other_patient_id": "medication_distractor_janice"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_dispense_medication"
    }
  }
}
