{
  "id": "resolve_incident_report@1",
  "version": "1.0",
  "env_id": "hospitalrun_env@0.1",
  "description": "Resolve the safety incident report for 'Broken Wheelchair in Ward 3' in HospitalRun. Update the incident status to 'Resolved' and include the following note in the record: 'Maintenance replaced the caster wheel. Verified safe.'",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/resolve_incident_report/setup_task.sh",
    "post_task": "/workspace/tasks/resolve_incident_report/export_result.sh"
  },
  "metadata": {
    "target_incident_id": "incident_p1_000001",
    "target_description_snippet": "Broken Wheelchair",
    "expected_status": [
      "Resolved",
      "Closed",
      "Completed"
    ],
    "required_resolution_keywords": [
      "replaced",
      "wheel"
    ],
    "distractor_ids": [
      "incident_p1_000002",
      "incident_p1_000003"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_resolve_incident_report"
    }
  }
}
