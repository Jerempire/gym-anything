{
  "id": "launch_telehealth_service@1",
  "version": "1.0",
  "env_id": "hospitalrun_env@0.1",
  "description": "Configure the system to support 'Telehealth' visits and schedule a Telehealth appointment for patient Lars Jensen on October 15, 2025, at 10:00 AM.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/launch_telehealth_service/setup_task.sh",
    "post_task": "/workspace/tasks/launch_telehealth_service/export_result.sh"
  },
  "metadata": {
    "target_patient_name": "Lars Jensen",
    "target_patient_id": "patient_p1_larsjensen",
    "target_visit_type": "Telehealth",
    "target_date": "2025-10-15",
    "target_time": "10:00 AM"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_launch_telehealth_service"
    }
  }
}
