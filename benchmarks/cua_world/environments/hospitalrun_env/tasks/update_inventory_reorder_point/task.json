{
  "id": "update_inventory_reorder_point@1",
  "version": "1.0",
  "env_id": "hospitalrun_env@0.1",
  "description": "Update the inventory safety stock settings for 'Amoxicillin 500mg' in HospitalRun. The supplier has updated their terms, requiring adjustments to our inventory parameters. Update the Reorder Point to 150 and the Price to 12.50 for this item and save the changes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_inventory_reorder_point/setup_task.sh",
    "post_task": "/workspace/tasks/update_inventory_reorder_point/export_result.sh"
  },
  "metadata": {
    "target_item_name": "Amoxicillin 500mg",
    "initial_reorder_point": 50,
    "initial_price": 10.0,
    "expected_reorder_point": 150,
    "expected_price": 12.5,
    "couch_db_url": "http://couchadmin:test@localhost:5984/main"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_inventory"
    }
  }
}
