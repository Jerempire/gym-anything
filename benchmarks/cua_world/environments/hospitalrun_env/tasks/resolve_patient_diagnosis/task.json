{
  "id": "resolve_patient_diagnosis@1",
  "version": "1.0",
  "env_id": "hospitalrun_env@0.1",
  "description": "Update the clinical record for patient 'Oliver Sacks' by marking the 'Acute Bronchitis' diagnosis from two weeks ago as 'Resolved' or 'Inactive'. Ensure the existing diagnosis record is edited rather than creating a new one.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/resolve_patient_diagnosis/setup_task.sh",
    "post_task": "/workspace/tasks/resolve_patient_diagnosis/export_result.sh"
  },
  "metadata": {
    "patient_first_name": "Oliver",
    "patient_last_name": "Sacks",
    "diagnosis_name": "Acute Bronchitis",
    "target_status_keywords": [
      "resolved",
      "inactive",
      "completed",
      "recovered"
    ],
    "patient_id": "patient_oliver_sacks",
    "diagnosis_id": "diagnosis_oliver_bronchitis"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_resolve_patient_diagnosis"
    }
  }
}
