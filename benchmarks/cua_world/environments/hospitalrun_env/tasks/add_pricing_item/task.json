{
  "id": "add_pricing_item@1",
  "version": "1.0",
  "env_id": "hospitalrun_env@0.1",
  "description": "Add a new pricing item to HospitalRun with the following details:\n- Name: 'Portable Ultrasound - Limited Bedside'\n- Price: '275'\n- Category: 'Imaging'\n- Pricing Type: 'Per Case'\n- Expense Account: 'Radiology Services'",
