  "hooks": {
    "pre_task": "/workspace/tasks/add_pricing_item/setup_task.sh",
    "post_task": "/workspace/tasks/add_pricing_item/export_result.sh"
  },
  "metadata": {
    "expected_name": "Portable Ultrasound - Limited Bedside",
    "expected_price": 275,
    "expected_category": "Imaging",
    "expected_expense_account": "Radiology Services",
    "expected_pricing_type": "Per Case"
