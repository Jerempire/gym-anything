{
  "id": "reset_user_password@1",
  "version": "1.0",
  "env_id": "hospitalrun_env@0.1",
  "description": "Reset the password for Dr. Amani Al-Fayed (username: 'dr_amani') to 'WelcomeBack2026!' using the administrator account (username: 'hradmin', password: 'test'). Ensure her other profile details, such as roles and name, remain unchanged.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/reset_user_password/setup_task.sh",
    "post_task": "/workspace/tasks/reset_user_password/export_result.sh"
  },
  "metadata": {
    "target_username": "dr_amani",
    "target_fullname": "Amani Al-Fayed",
    "target_roles": [
      "Doctor",
      "Healer",
      "user"
    ],
    "new_password": "WelcomeBack2026!",
    "admin_user": "hradmin",
    "admin_pass": "test"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reset_user_password"
    }
  }
}
