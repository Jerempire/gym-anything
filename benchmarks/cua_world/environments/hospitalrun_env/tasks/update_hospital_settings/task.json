{
  "id": "update_hospital_settings@1",
  "version": "1.0",
  "env_id": "hospitalrun_env@0.1",
  "description": "The hospital has rebranded and needs its system configuration updated in HospitalRun. Update the global hospital settings by changing the Hospital Name to 'Grand Oak Community Hospital' and the Hospital Email to 'admin@grandoak.org'. Ensure the changes are saved.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_hospital_settings/setup_task.sh",
    "post_task": "/workspace/tasks/update_hospital_settings/export_result.sh"
  },
  "metadata": {
    "expected_name": "Grand Oak Community Hospital",
    "expected_email": "admin@grandoak.org",
    "initial_name": "City General Hospital",
    "initial_email": "admin@citygeneral.org"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_settings"
    }
  }
}
