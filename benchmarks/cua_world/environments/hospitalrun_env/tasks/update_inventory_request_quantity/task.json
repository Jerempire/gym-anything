{
  "id": "update_inventory_request_quantity@1",
  "version": "1.0",
  "env_id": "hospitalrun_env@0.1",
  "description": "The hospital is preparing for flu season and needs to increase the stock of protective equipment. Update the existing pending inventory request for 'Surgical Masks' by changing the quantity to 500. Ensure you modify the existing request rather than creating a new one.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_inventory_request_quantity/setup_task.sh",
    "post_task": "/workspace/tasks/update_inventory_request_quantity/export_result.sh"
  },
  "metadata": {
    "target_doc_id": "inv_req_masks_001",
    "target_item_name": "Surgical Masks",
    "initial_quantity": 100,
    "target_quantity": 500,
    "expected_status": "Requested"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_inventory_request"
    }
  }
}
