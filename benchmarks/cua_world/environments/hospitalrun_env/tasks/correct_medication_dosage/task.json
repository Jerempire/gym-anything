{
  "id": "correct_medication_dosage@1",
  "version": "1.0",
  "env_id": "hospitalrun_env@0.1",
  "description": "Correct a clinical data error in HospitalRun for patient 'Arthur Dent', who has a medication order for 'Amoxicillin' with a dangerously high dosage of '2000mg' due to a data entry error. Update the existing medication order to the correct dosage of '500mg' without deleting and re-creating the record.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/correct_medication_dosage/setup_task.sh",
    "post_task": "/workspace/tasks/correct_medication_dosage/export_result.sh"
  },
  "metadata": {
    "patient_first_name": "Arthur",
    "patient_last_name": "Dent",
    "medication_name": "Amoxicillin",
    "incorrect_dosage": "2000mg",
    "correct_dosage": "500mg",
    "target_doc_id_suffix": "med_amox_001"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_correct_medication_dosage"
    }
  }
}
