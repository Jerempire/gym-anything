{
  "id": "generate_diagnostic_report@1",
  "version": "1.0",
  "env_id": "hospitalrun_env@0.1",
  "description": "Log into HospitalRun and generate a 'Diagnostic' report to analyze disease prevalence for the period of January 1, 2025, to January 31, 2025. Ensure the report displays the diagnosis data from the pre-loaded patient records.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_diagnostic_report/setup_task.sh",
    "post_task": "/workspace/tasks/generate_diagnostic_report/export_result.sh"
  },
  "metadata": {
    "report_type": "Diagnostic",
    "start_date": "01/01/2025",
    "end_date": "01/31/2025",
    "expected_diagnoses": [
      "J18.9",
      "E11.9",
      "I10",
      "M54.5"
    ],
    "expected_text_visible": [
      "Diagnostic Report",
      "Pneumonia",
      "Diabetes",
      "Hypertension"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_diagnostic_report"
    }
  }
}
