    "pre_task": "/workspace/tasks/add_patient_photo/setup_task.sh",
    "post_task": "/workspace/tasks/add_patient_photo/export_result.sh"
  },
  "metadata": {
    "patient_first_name": "Dolores",
    "patient_last_name": "Welch",
    "patient_couch_id": "patient_p1_dolores",
    "photo_path": "/home/ga/Documents/patient_photo.jpg",
    "expected_description": "Patient Identification Photo - Front View",
    "description_keywords": [
      "identification",
      "photo",
      "front",
      "view"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_patient_photo"
    }
  }
}
