{
  "id": "add_patient_photo@1",
  "version": "1.0",
  "env_id": "hospitalrun_env@0.1",
  "description": "Upload the patient identification photo for Dolores Welch (P00010) in HospitalRun using the image file located at /home/ga/Documents/patient_photo.jpg. Use the description 'Patient Identification Photo - Front View' for the record.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
