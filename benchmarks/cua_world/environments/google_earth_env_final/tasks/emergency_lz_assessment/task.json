{
  "id": "emergency_lz_assessment@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Identify at least 3 helicopter landing zones within 5 km of Rifugio Lagazuoi in the Dolomites, Italy (46.5289°N, 12.0078°E). For each LZ, create a placemark with a systematic name (e.g., LZ-Alpha), coordinates, elevation, estimated dimensions, and terrain notes. Organize in a folder named 'Emergency LZ Assessment' and export to ~/Documents/emergency_lz_assessment.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/emergency_lz_assessment/setup_task.sh",
    "post_task": "/workspace/tasks/emergency_lz_assessment/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "accident_coordinates": {
      "lat": 46.5289,
      "lon": 12.0078
    },
    "search_radius_km": 5.0,
    "min_lz_count": 3,
    "min_lz_dimension_m": 30,
    "region": "Dolomites, Italy",
    "expected_output_path": "/home/ga/Documents/emergency_lz_assessment.kml",
    "expected_folder_name": "Emergency LZ Assessment",
    "score_file_exists": 15,
    "score_folder_structure": 10,
    "score_min_placemarks": 20,
    "score_coords_in_range": 15,
    "score_elevation_documented": 10,
    "score_dimensions_documented": 10,
    "score_systematic_naming": 5,
    "score_terrain_notes": 10,
    "score_trajectory_verification": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_emergency_lz_assessment"
    }
  }
}