{
  "id": "stadium_field_measurement@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure the playing field length and width at Camp Nou stadium in Barcelona (~41.38°N, 2.12°E). Create corner placemarks 'NW Corner', 'NE Corner', 'SW Corner', 'SE Corner' in a folder 'Camp Nou Field Survey'. Export KML to /home/ga/Documents/camp_nou_survey.kml. Save field dimensions and FIFA compliance to /home/ga/Documents/field_measurements.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/stadium_field_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/stadium_field_measurement/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "kml_output_path": "/home/ga/Documents/camp_nou_survey.kml",
    "text_output_path": "/home/ga/Documents/field_measurements.txt",
    "expected_length_m": 105,
    "expected_width_m": 68,
    "tolerance_m": 5,
    "stadium_name": "Camp Nou",
    "stadium_location": "Barcelona, Spain",
    "stadium_center_lat": 41.3809,
    "stadium_center_lon": 2.1228,
    "bounds_lat_min": 41.378,
    "bounds_lat_max": 41.384,
    "bounds_lon_min": 2.119,
    "bounds_lon_max": 2.127,
    "expected_corners": ["NW Corner", "NE Corner", "SW Corner", "SE Corner"],
    "fifa_length_min": 100,
    "fifa_length_max": 110,
    "fifa_width_min": 64,
    "fifa_width_max": 75
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_stadium_field_measurement"
    }
  }
}