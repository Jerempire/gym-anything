{
  "id": "geofence_parameter_export@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a rectangular polygon named 'Angkor Wat No-Fly Zone' around Angkor Wat temple complex (13.4125°N, 103.8670°E) extending 500 meters beyond the outer moat on all sides. Create a placemark named 'Geofence Center' at the central tower with coordinates in the description. Save both to ~/Documents/angkor_geofence.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/geofence_parameter_export/setup_task.sh",
    "post_task": "/workspace/tasks/geofence_parameter_export/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/angkor_geofence.kml",
    "center_coordinates": {
      "latitude": 13.4125,
      "longitude": 103.867,
      "tolerance_meters": 200
    },
    "polygon_bounds": {
      "min_latitude": 13.4,
      "max_latitude": 13.425,
      "min_longitude": 103.85,
      "max_longitude": 103.885
    },
    "expected_area_km2": {
      "min": 3.0,
      "max": 5.0
    },
    "polygon_name": "Angkor Wat No-Fly Zone",
    "placemark_name": "Geofence Center",
    "location_name": "Angkor Wat, Cambodia"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_geofence_parameter_export"
    }
  }
}
