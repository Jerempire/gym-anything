{
  "id": "solar_roof_assessment@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure the roof area of the IKEA store in East Palo Alto, California (37.4683°N, 122.1325°W). Create a placemark named 'IKEA East Palo Alto - Solar Assessment' with the roof area, compass orientation, and solar suitability note in the description.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/solar_roof_assessment/setup_task.sh",
    "post_task": "/workspace/tasks/solar_roof_assessment/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "target_location": {
      "name": "IKEA East Palo Alto",
      "address": "1700 East Bayshore Road, East Palo Alto, CA 94303",
      "latitude": 37.4683,
      "longitude": -122.1325
    },
    "expected_area": {
      "min_sq_ft": 280000,
      "max_sq_ft": 420000,
      "min_sq_m": 26000,
      "max_sq_m": 39000,
      "min_acres": 6.4,
      "max_acres": 9.6
    },
    "required_placemark_keywords": [
      "IKEA",
      "Solar"
    ],
    "coordinate_tolerance_degrees": 0.01,
    "myplaces_path": "/home/ga/.googleearth/myplaces.kml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_solar_roof_assessment"
    }
  }
}
