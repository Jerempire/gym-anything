{
  "id": "dam_crest_measurement_itaipu@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure the main concrete dam crest length of Itaipu Dam (approximately 25.4085°S, 54.5890°W) on the Brazil-Paraguay border. Measure only the concrete section, not earthfill embankments. Save the measurement to /home/ga/dam_measurement.txt in the format: 'Itaipu Dam Crest Length Measurement / Feature: Main concrete dam crest / Measured Length: [VALUE] meters'. Save a screenshot with measurement overlay to /home/ga/dam_screenshot.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/dam_crest_measurement_itaipu/setup_task.sh",
    "post_task": "/workspace/tasks/dam_crest_measurement_itaipu/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "dam_name": "Itaipu Dam",
    "location": "Brazil-Paraguay border, Paraná River",
    "coordinates_lat": -25.4085,
    "coordinates_lon": -54.5890,
    "main_concrete_crest_length_meters": 1064,
    "tolerance_meters": 100,
    "extended_tolerance_meters": 200,
    "total_dam_axis_meters": 7919,
    "expected_measurement_file": "/home/ga/dam_measurement.txt",
    "expected_screenshot_file": "/home/ga/dam_screenshot.png",
    "data_source": "Itaipu Binacional official specifications",
    "score_file_exists": 10,
    "score_format_correct": 10,
    "score_accuracy_high": 30,
    "score_accuracy_medium": 15,
    "score_screenshot_exists": 10,
    "score_vlm_trajectory": 25,
    "score_vlm_content": 15
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_dam_crest_measurement"
    }
  }
}