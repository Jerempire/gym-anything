{
  "id": "lat_landfall_marking@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Identify the location where the 45th parallel north (45°N) first crosses land on the Atlantic coast of North America. Create a placemark named '45N Atlantic Landfall' at this intersection and record the longitude coordinate in the description.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 150,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/lat_landfall_marking/setup_task.sh",
    "post_task": "/workspace/tasks/lat_landfall_marking/export_result.sh"
  },
  "metadata": {
    "expected_placemark_name": "45N Atlantic Landfall",
    "target_latitude": 45.0,
    "latitude_tolerance": 0.005,
    "longitude_min": -64.5,
    "longitude_max": -63.0,
    "optimal_longitude_min": -64.0,
    "optimal_longitude_max": -63.3,
    "region": "Nova Scotia, Canada",
    "kml_paths": [
      "/home/ga/.googleearth/myplaces.kml",
      "/home/ga/.config/Google/googleearth/myplaces.kml"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_lat_landfall_marking"
    }
  }
}
