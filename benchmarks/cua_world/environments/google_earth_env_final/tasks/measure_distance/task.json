{
  "id": "measure_distance@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure the distance from the Statue of Liberty (40.6892° N, 74.0445° W) to the Empire State Building (40.7484° N, 73.9857° W) in New York City.",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/measure_distance/setup_task.sh",
    "post_task": "/workspace/tasks/measure_distance/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_measurement"
    }
  }
}
