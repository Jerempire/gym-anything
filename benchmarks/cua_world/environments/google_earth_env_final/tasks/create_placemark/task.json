{
  "id": "create_placemark@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to the Golden Gate Bridge (37.8199° N, 122.4783° W) and create a placemark named 'Golden Gate Bridge' at that location.",
  "init": {
    "timeout_sec": 150,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_placemark/setup_task.sh",
    "post_task": "/workspace/tasks/create_placemark/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_placemark"
    }
  }
}
