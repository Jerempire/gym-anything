{
  "id": "take_screenshot@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Mount Everest (27.9881°N, 86.9250°E) and save a high-quality screenshot of the view to /home/ga/Desktop/mount_everest.png.",
  "init": {
    "timeout_sec": 150,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/take_screenshot/setup_task.sh",
    "post_task": "/workspace/tasks/take_screenshot/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_screenshot"
    }
  }
}
