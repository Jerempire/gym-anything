{
  "id": "thames_river_path@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a path tracing the River Thames from Tower Bridge (51.5055°N, 0.0754°W) to Westminster Bridge (51.5007°N, 0.1218°W), following the river's natural curves with at least 8 waypoints. Save as KML to ~/Documents/thames_path.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/thames_river_path/setup_task.sh",
    "post_task": "/workspace/tasks/thames_river_path/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/thames_path.kml",
    "tower_bridge_lat": 51.5055,
    "tower_bridge_lon": -0.0754,
    "westminster_bridge_lat": 51.5007,
    "westminster_bridge_lon": -0.1218,
    "coordinate_tolerance": 0.005,
    "thames_corridor_north": 51.515,
    "thames_corridor_south": 51.495,
    "thames_corridor_west": -0.135,
    "thames_corridor_east": -0.065,
    "min_waypoints": 8,
    "expected_distance_km_min": 2.8,
    "expected_distance_km_max": 4.0,
    "data_source": "Real geographic coordinates from OpenStreetMap and UK Ordnance Survey"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_thames_river_path"
    }
  }
}