{
  "id": "supply_route_network@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a folder named 'Chicago Distribution Network' containing three paths: 'Primary Route - Hub to Regional DC' (O'Hare 41.97°N, 87.91°W to Joliet 41.45°N, 88.08°W, red 3px), 'Primary Route - Regional DC to South Hub' (Joliet to University Park 41.44°N, 87.72°W, red 3px), and 'Secondary Route - East Connection' (University Park to Gary 41.59°N, 87.35°W, blue 2px). Export the folder as a KML to /home/ga/Documents/chicago",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/supply_route_network/setup_task.sh",
    "post_task": "/workspace/tasks/supply_route_network/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/chicago_distribution_network.kml",
    "expected_folder_name": "Chicago Distribution Network",
    "expected_path_count": 3,
    "locations": {
      "ohare": {
        "lat": 41.9742,
        "lon": -87.9073
      },
      "joliet": {
        "lat": 41.4545,
        "lon": -88.0817
      },
      "university_park": {
        "lat": 41.4428,
        "lon": -87.7214
      },
      "gary": {
        "lat": 41.5934,
        "lon": -87.3464
      }
    },
    "coordinate_tolerance_degrees": 0.15,
    "chicago_bounds": {
      "lat_min": 41.0,
      "lat_max": 42.5,
      "lon_min": -88.5,
      "lon_max": -87.0
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_supply_route_network"
    }
  }
}
