{
  "id": "date_line_measurement@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to the Bering Strait (65.75°N, 169°W). Create placemarks on Big Diomede Island named 'Big Diomede (Russia)' and Little Diomede Island named 'Little Diomede (USA)'. Measure the coast-to-coast distance and create a third placemark named 'Diomede Distance' with the distance in km in its description. Export all placemarks to /home/ga/Documents/diomede_measurement.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/date_line_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/date_line_measurement/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/diomede_measurement.kml",
    "big_diomede_lat_range": [
      65.7,
      65.85
    ],
    "big_diomede_lon_range": [
      -169.2,
      -168.9
    ],
    "little_diomede_lat_range": [
      65.7,
      65.82
    ],
    "little_diomede_lon_range": [
      -169.0,
      -168.8
    ],
    "expected_distance_km_min": 3.0,
    "expected_distance_km_max": 5.0,
    "expected_distance_km_typical": 3.8,
    "min_placemark_separation_deg": 0.03,
    "score_kml_exists": 15,
    "score_big_diomede_placemark": 20,
    "score_little_diomede_placemark": 20,
    "score_distance_placemark": 10,
    "score_distance_documented": 15,
    "score_distance_accurate": 20
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_date_line_measurement"
    }
  }
}
