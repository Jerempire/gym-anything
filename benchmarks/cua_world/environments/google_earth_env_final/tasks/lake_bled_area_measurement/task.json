{
  "id": "lake_bled_area_measurement@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure the surface area of Lake Bled, Slovenia (46.3625°N, 14.0938°E). Save a screenshot showing the measurement to /home/ga/lake_bled_measurement.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/lake_bled_area_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/lake_bled_area_measurement/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/lake_bled_measurement.png",
    "min_file_size_kb": 100,
    "location": {
      "name": "Lake Bled",
      "country": "Slovenia",
      "lat": 46.3625,
      "lon": 14.0938
    },
    "expected_area_km2": {
      "min": 1.0,
      "max": 2.0,
      "reference": 1.45
    },
    "data_source": "Slovenian Environment Agency - Lakes Database",
    "verification_features": [
      "distinctive island in lake center",
      "oval shape",
      "Alpine surroundings"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_lake_bled_area_measurement"
    }
  }
}
