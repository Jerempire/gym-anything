        "latitude": 14.009,
        "longitude": 120.993
      }
    },
    "expected_areas_km2": {
      "outer_polygon_min": 200,
      "outer_polygon_max": 400,
      "inner_hole_min": 15,
      "inner_hole_max": 45,
      "water_area_min": 180,
      "water_area_max": 350
    }
  },
  "success": {
    "mode": "program",
    "spec": {
