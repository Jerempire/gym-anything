{
  "id": "lake_annulus_polygon@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a polygon named 'Taal Lake Water Area' at Taal Lake, Batangas, Philippines (~13.98°N, 121.04°E) with an outer boundary tracing the lake shore and an inner boundary around Volcano Island. Use a semi-transparent blue fill and export to /home/ga/Documents/taal_lake_polygon.kml.",
