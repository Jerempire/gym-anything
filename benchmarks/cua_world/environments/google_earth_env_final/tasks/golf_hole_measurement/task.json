{
  "id": "golf_hole_measurement@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure the distance from the championship tee to the center of the green at Augusta National Golf Club's 12th hole (33.503°N, 81.998°W). Save the measurement as a path named 'Augusta 12th' to My Places.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 150,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/golf_hole_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/golf_hole_measurement/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "target_location": {
      "name": "Augusta National Golf Club - 12th Hole",
      "tee_lat": 33.5031,
      "tee_lon": -81.9978,
      "green_lat": 33.5025,
      "green_lon": -81.9968,
      "course_center_lat": 33.503,
      "course_center_lon": -81.998
    },
    "expected_distance_m": 142,
    "distance_tolerance_m": 18,
    "tee_tolerance_m": 30,
    "green_tolerance_m": 25,
    "expected_kml_path": "/home/ga/.googleearth/myplaces.kml",
    "name_keywords": [
      "augusta",
      "12",
      "twelfth",
      "golden",
      "bell",
      "golf",
      "hole"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_golf_hole_measurement"
    }
  }
}
