{
  "id": "screen_overlay_compass@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a Screen Overlay named 'Compass Legend' using the image at https://upload.wikimedia.org/wikipedia/commons/thumb/1/1a/Brosen_windrose.svg/240px-Brosen_windrose.svg.png. Set the position to Screen X: 0.95 and Screen Y: 0.05 (Fraction units). Export the KML to /home/ga/Documents/compass_overlay.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/screen_overlay_compass/setup_task.sh",
    "post_task": "/workspace/tasks/screen_overlay_compass/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/compass_overlay.kml",
    "overlay_name": "Compass Legend",
    "compass_image_url": "https://upload.wikimedia.org/wikipedia/commons/thumb/1/1a/Brosen_windrose.svg/240px-Brosen_windrose.svg.png",
    "expected_screen_x_min": 0.7,
    "expected_screen_y_max": 0.3,
    "score_file_exists": 10,
    "score_is_screen_overlay": 20,
    "score_correct_image": 15,
    "score_positioned_right": 15,
    "score_positioned_bottom": 10,
    "score_proper_name": 10,
    "score_visual_trajectory": 20
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_screen_overlay_compass"
    }
  }
}
