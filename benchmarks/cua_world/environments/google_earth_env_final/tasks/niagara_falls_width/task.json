{
  "id": "niagara_falls_width@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create placemarks at the crest endpoints of Horseshoe Falls ('Horseshoe Falls West End', 'Horseshoe Falls East End') and American Falls ('American Falls South End', 'American Falls North End') near 43.0799°N, 79.0747°W. Place them in a folder named 'Niagara Falls Measurements' with each falls' measured width and the combined total in the folder description. Save to /home/ga/Documents/niagara_falls_measurements.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/niagara_falls_width/setup_task.sh",
    "post_task": "/workspace/tasks/niagara_falls_width/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/niagara_falls_measurements.kml",
    "center_lat": 43.0799,
    "center_lon": -79.0747,
    "horseshoe_width_m": 670,
    "american_width_m": 260,
    "horseshoe_tolerance_m": 75,
    "american_tolerance_m": 60,
    "bounding_box": {
      "min_lat": 43.07,
      "max_lat": 43.09,
      "min_lon": -79.08,
      "max_lon": -79.06
    },
    "expected_placemarks": [
      "Horseshoe Falls West End",
      "Horseshoe Falls East End",
      "American Falls South End",
      "American Falls North End"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_niagara_falls_width"
    }
  }
}