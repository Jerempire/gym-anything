{
  "id": "layer_visibility_infrastructure@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to San Francisco, California. Create a visualization of downtown infrastructure showing 3D building heights and roads, with borders, labels, and places hidden. Save a screenshot of this view to ~/Documents/sf_infrastructure.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/layer_visibility_infrastructure/setup_task.sh",
    "post_task": "/workspace/tasks/layer_visibility_infrastructure/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/sf_infrastructure.png",
    "min_file_size_kb": 100,
    "target_location": "San Francisco, California",
    "required_layers_enabled": [
      "3D Buildings",
      "Roads"
    ],
    "required_layers_disabled": [
      "Borders and Labels",
      "Places"
    ],
    "score_file_exists": 15,
    "score_timestamp_valid": 10,
    "score_file_size_ok": 5,
    "score_shows_san_francisco": 20,
    "score_3d_buildings_visible": 20,
    "score_roads_visible": 10,
    "score_labels_minimized": 15,
    "score_3d_perspective": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_layer_visibility_infrastructure"
    }
  }
}
