{
  "id": "landlocked_sea_distance@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure the shortest straight-line distance from Sükhbaatar Square, Ulaanbaatar, Mongolia (47.9184°N, 106.9177°E) to the nearest ocean coastline. Create a path named 'Ulaanbaatar_to_Coast' and save a screenshot showing the measurement to /home/ga/Documents/distance_measurement.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/landlocked_sea_distance/setup_task.sh",
    "post_task": "/workspace/tasks/landlocked_sea_distance/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_screenshot_path": "/home/ga/Documents/distance_measurement.png",
    "expected_measurement_name": "Ulaanbaatar_to_Coast",
    "start_location": {
      "name": "Sükhbaatar Square, Ulaanbaatar",
      "lat": 47.9184,
      "lon": 106.9177,
      "tolerance_km": 10
    },
    "end_location": {
      "region": "Bohai Sea / Yellow Sea coastline",
      "lat_range": [
        38.0,
        42.0
      ],
      "lon_range": [
        117.0,
        125.0
      ]
    },
    "expected_distance_km": {
      "min": 650,
      "max": 750
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_landlocked_sea_distance"
    }
  }
}
