{
  "id": "river_sinuosity_analysis@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Analyze the sinuosity of the Mississippi River between 33.4000°N, 91.0500°W and 33.2500°N, 91.2000°W. Create placemarks 'Sinuosity_Start' and 'Sinuosity_End' at these coordinates. At the midpoint, create a 'Sinuosity_Analysis' placemark with a description recording the straight-line distance (km), channel length (km), sinuosity index (channel/straight to 2 decimals), and classification ('Straight' <1.3, 'Sinuous' 1.3-1.5, 'Meandering' >1.5). Export the 'Mississippi_Sinuosity' folder",
  "difficulty": "medium-hard",
  "init": {
    "timeout_sec": 300,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/river_sinuosity_analysis/setup_task.sh",
    "post_task": "/workspace/tasks/river_sinuosity_analysis/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/mississippi_sinuosity.kml",
    "start_coords": {
      "lat": 33.4,
      "lon": -91.05
    },
    "end_coords": {
      "lat": 33.25,
      "lon": -91.2
    },
    "coord_tolerance": 0.05,
    "straight_distance_km": {
      "min": 20,
      "max": 28
    },
    "channel_length_km": {
      "min": 32,
      "max": 48
    },
    "sinuosity_range": {
      "min": 1.3,
      "max": 2.0
    },
    "expected_classification": "Meandering",
    "placemark_names": [
      "Sinuosity_Start",
      "Sinuosity_End",
      "Sinuosity_Analysis"
    ],
    "folder_name": "Mississippi_Sinuosity"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_river_sinuosity_analysis"
    }
  }
}
