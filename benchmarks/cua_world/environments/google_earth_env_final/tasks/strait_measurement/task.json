{
  "id": "strait_measurement@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure the distance across the narrowest crossing point of the Strait of Gibraltar, from Punta de Tarifa (36.000°N, 5.611°W) to the Moroccan coast near Point Cires (35.911°N, 5.479°W). Save the measurement as a path named 'Gibraltar_Crossing_Measurement'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/strait_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/strait_measurement/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "target_location": "Strait of Gibraltar",
    "expected_distance_km_min": 13.0,
    "expected_distance_km_max": 16.5,
    "european_endpoint_lat": 36.0014,
    "european_endpoint_lon": -5.6087,
    "african_endpoint_lat": 35.9053,
    "african_endpoint_lon": -5.51,
    "coordinate_tolerance_deg": 0.1,
    "save_name": "Gibraltar_Crossing_Measurement",
    "myplaces_path": "/home/ga/.googleearth/myplaces.kml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_strait_measurement"
    }
  }
}
