{
  "id": "tokyo_3d_buildings@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Capture a tilted perspective screenshot of the 3D urban skyline in Tokyo's Shinjuku district (35.6938°N, 139.7034°E). Save the screenshot to ~/Documents/tokyo_skyline_3d.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/tokyo_3d_buildings/setup_task.sh",
    "post_task": "/workspace/tasks/tokyo_3d_buildings/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/tokyo_skyline_3d.png",
    "min_file_size_kb": 50,
    "target_location": {
      "name": "Shinjuku, Tokyo, Japan",
      "latitude": 35.6938,
      "longitude": 139.7034,
      "tolerance_km": 5
    },
    "view_requirements": {
      "3d_buildings_required": true,
      "tilt_angle_min_degrees": 45,
      "tilt_angle_max_degrees": 70
    },
    "scoring": {
      "file_exists": 15,
      "file_created_during_task": 15,
      "valid_image_size": 10,
      "tokyo_location_visible": 20,
      "3d_buildings_visible": 25,
      "tilted_perspective": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_tokyo_3d_buildings"
    }
  }
}
