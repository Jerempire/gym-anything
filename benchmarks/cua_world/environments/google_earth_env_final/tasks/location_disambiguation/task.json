{
  "id": "location_disambiguation@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Harvard Yard in Cambridge, Massachusetts (42.374°N, 71.117°W). Create a placemark named 'Cambridge MA Research Point' with the coordinates in the format 'Coordinates: [latitude], [longitude]' in the description. Export the placemark as KML to ~/Documents/cambridge_research.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/location_disambiguation/setup_task.sh",
    "post_task": "/workspace/tasks/location_disambiguation/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/cambridge_research.kml",
    "expected_placemark_name": "Cambridge MA Research Point",
    "latitude_min": 42.35,
    "latitude_max": 42.4,
    "longitude_min": -71.15,
    "longitude_max": -71.08,
    "harvard_yard_lat": 42.374,
    "harvard_yard_lon": -71.117,
    "harvard_lat_min": 42.37,
    "harvard_lat_max": 42.38,
    "harvard_lon_min": -71.125,
    "harvard_lon_max": -71.11,
    "search_term": "Cambridge",
    "target_city": "Cambridge, Massachusetts, USA"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_location_disambiguation"
    }
  }
}
