{
  "id": "coastal_flythrough_export@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Produce a 1280x720 resolution flythrough video of a coastal path (minimum 3 km) between Positano and Amalfi (40.6333° N, 14.6000° E). Save the output to /home/ga/Videos/amalfi_flythrough.mp4.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/coastal_flythrough_export/setup_task.sh",
    "post_task": "/workspace/tasks/coastal_flythrough_export/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Videos/amalfi_flythrough.mp4",
    "min_resolution_width": 1280,
    "min_resolution_height": 720,
    "duration_min_seconds": 10,
    "duration_max_seconds": 30,
    "min_file_size_bytes": 500000,
    "location": {
      "name": "Amalfi Coast, Italy",
      "latitude": 40.6333,
      "longitude": 14.6,
      "search_terms": [
        "Amalfi Coast",
        "Positano",
        "Amalfi, Italy"
      ]
    },
    "score_file_exists": 15,
    "score_valid_format": 15,
    "score_resolution": 15,
    "score_duration": 15,
    "score_vlm_aerial": 15,
    "score_vlm_coastal": 15,
    "score_vlm_location": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_coastal_flythrough_export"
    }
  }
}
