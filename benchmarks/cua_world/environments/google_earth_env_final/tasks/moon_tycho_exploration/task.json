{
  "id": "moon_tycho_exploration@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Tycho Crater (43.31°S, 11.36°W) on the Moon. Measure the crater diameter and create a placemark named 'Tycho Crater - Research Site' at the crater center with the diameter in the description. Save the placemark to My Places.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/moon_tycho_exploration/setup_task.sh",
    "post_task": "/workspace/tasks/moon_tycho_exploration/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "target_body": "moon",
    "target_feature": "Tycho Crater",
    "target_latitude": -43.31,
    "target_longitude": -11.36,
    "coordinate_tolerance": 5.0,
    "expected_placemark_name": "Tycho Crater - Research Site",
    "expected_diameter_km": 85,
    "myplaces_file": "/home/ga/.googleearth/myplaces.kml",
    "score_moon_mode": 25,
    "score_crater_located": 25,
    "score_placemark_created": 20,
    "score_coordinates_correct": 15,
    "score_description_included": 10,
    "score_workflow_evidence": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_moon_tycho_exploration"
    }
  }
}
