{
  "id": "flight_simulator_grand_canyon@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Capture a screenshot of the flight simulator over the Grand Canyon (36.054°N, 112.140°W) showing the cockpit view with instruments and canyon terrain visible. Save the file to /home/ga/grand_canyon_flight.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/flight_simulator_grand_canyon/setup_task.sh",
    "post_task": "/workspace/tasks/flight_simulator_grand_canyon/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/grand_canyon_flight.png",
    "min_file_size_kb": 50,
    "target_location": "Grand Canyon, Arizona",
    "target_coordinates": {
      "latitude": 36.0544,
      "longitude": -112.1401
    },
    "flight_simulator_shortcut": "Ctrl+Alt+A",
    "aircraft_options": [
      "F-16 Viper",
      "SR22"
    ],
    "verification_elements": [
      "cockpit_instruments",
      "canyon_terrain",
      "first_person_view"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_flight_simulator_grand_canyon"
    }
  }
}
