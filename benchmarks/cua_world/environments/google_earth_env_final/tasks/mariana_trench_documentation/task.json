{
  "id": "mariana_trench_documentation@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Challenger Deep in the Mariana Trench (11.3493°N, 142.1996°E) and create a placemark named 'Challenger Deep' using ocean floor visualization. Include the depth reading and the text 'Mariana Trench' in the description. Export the placemark as KML to /home/ga/Documents/challenger_deep.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/mariana_trench_documentation/setup_task.sh",
    "post_task": "/workspace/tasks/mariana_trench_documentation/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/challenger_deep.kml",
    "expected_placemark_name": "Challenger Deep",
    "target_latitude": 11.3493,
    "target_longitude": 142.1996,
    "latitude_tolerance": 1.0,
    "longitude_tolerance": 1.5,
    "expected_depth_min": -12000,
    "expected_depth_max": -10000,
    "required_description_text": "mariana"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mariana_trench_documentation"
    }
  }
}
