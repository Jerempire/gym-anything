{
  "id": "atmosphere_toggle_comparison@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Mount Everest (27.9881, 86.9250) at approximately 50km altitude. Capture two screenshots from this viewpoint: one with the atmosphere enabled saved to /home/ga/Documents/everest_with_atmosphere.png, and one with the atmosphere disabled saved to /home/ga/Documents/everest_without_atmosphere.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/atmosphere_toggle_comparison/setup_task.sh",
    "post_task": "/workspace/tasks/atmosphere_toggle_comparison/export_result.sh"
  },
  "metadata": {
    "expected_output_1": "/home/ga/Documents/everest_with_atmosphere.png",
    "expected_output_2": "/home/ga/Documents/everest_without_atmosphere.png",
    "target_location": "Mount Everest",
    "target_latitude": 27.9881,
    "target_longitude": 86.925,
    "min_file_size_kb": 100,
    "score_file1_exists": 15,
    "score_file2_exists": 15,
    "score_timestamps_valid": 10,
    "score_location_correct": 20,
    "score_viewpoints_match": 20,
    "score_atmosphere_difference": 20
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_atmosphere_toggle_comparison"
    }
  }
}
