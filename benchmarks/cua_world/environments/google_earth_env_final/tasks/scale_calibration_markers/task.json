{
  "id": "scale_calibration_markers@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to the Bonneville Salt Flats, Utah (40.77°N, 113.86°W). Create a placemark named 'Cal Point A' on the salt flat surface and a second placemark named 'Cal Point B' exactly 1 kilometer due east of Cal Point A.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/scale_calibration_markers/setup_task.sh",
    "post_task": "/workspace/tasks/scale_calibration_markers/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "target_location": "Bonneville Salt Flats, Utah",
    "target_lat": 40.77,
    "target_lon": -113.86,
    "salt_flat_bounds": {
      "lat_min": 40.7,
      "lat_max": 40.85,
      "lon_min": -114.1,
      "lon_max": -113.7
    },
    "expected_distance_km": 1.0,
    "distance_tolerance_percent": 10,
    "placemark_a_name": "Cal Point A",
    "placemark_b_name": "Cal Point B",
    "max_latitude_diff_deg": 0.002
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_scale_calibration_markers"
    }
  }
}
