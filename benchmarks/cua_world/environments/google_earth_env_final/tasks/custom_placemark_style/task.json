{
  "id": "custom_placemark_style@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a placemark named 'NYC Regional Office' at the Chrysler Building (40.7516°N, 73.9755°W). Use a blue building-related icon and set the description to 'Regional headquarters - Eastern Division. Established 2019.' with a view altitude between 500-2000 meters.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/custom_placemark_style/setup_task.sh",
    "post_task": "/workspace/tasks/custom_placemark_style/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "placemark_name": "NYC Regional Office",
    "target_latitude": 40.7516,
    "target_longitude": -73.9755,
    "coordinate_tolerance": 0.005,
    "required_description_terms": [
      "Regional headquarters",
      "Eastern Division"
    ],
    "min_altitude": 500,
    "max_altitude": 2000,
    "expected_color": "blue",
    "landmark_name": "Chrysler Building"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_custom_placemark_style"
    }
  }
}
