{
  "id": "view_history_navigation@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Niagara Falls, Ontario, Grand Canyon National Park, Arizona, and the Golden Gate Bridge, San Francisco in that order. Use the navigation history to return to the Niagara Falls view and save a screenshot to /home/ga/niagara_history_return.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/view_history_navigation/setup_task.sh",
    "post_task": "/workspace/tasks/view_history_navigation/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/niagara_history_return.png",
    "min_file_size_kb": 50,
    "locations": {
      "first": "Niagara Falls, Ontario",
      "second": "Grand Canyon National Park, Arizona",
      "third": "Golden Gate Bridge, San Francisco"
    },
    "target_location": "Niagara Falls",
    "feature_tested": "view_history_navigation",
    "score_weights": {
      "file_exists": 15,
      "valid_timestamp": 15,
      "valid_image": 10,
      "vlm_content": 35,
      "vlm_trajectory": 25
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_view_history_navigation"
    }
  }
}
