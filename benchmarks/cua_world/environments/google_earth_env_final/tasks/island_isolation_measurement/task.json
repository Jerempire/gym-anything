{
  "id": "island_isolation_measurement@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure the distance from Pitcairn Island (25.067°S, 130.100°W) to Totegegie Airport on Mangareva Island, French Polynesia (23.080°S, 134.889°W) and create a path named 'Pitcairn to Totegegie Airfield'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/island_isolation_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/island_isolation_measurement/export_result.sh"
  },
  "metadata": {
    "expected_output_file": "/home/ga/.googleearth/myplaces.kml",
    "path_name": "Pitcairn to Totegegie Airfield",
    "pitcairn_lat": -25.067,
    "pitcairn_lon": -130.1,
    "totegegie_lat": -23.08,
    "totegegie_lon": -134.889,
    "coordinate_tolerance_km": 50,
    "expected_distance_min_km": 400,
    "expected_distance_max_km": 600,
    "data_source": "Official UK Hydrographic Office coordinates and ICAO aeronautical database"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_island_isolation_measurement"
    }
  }
}
