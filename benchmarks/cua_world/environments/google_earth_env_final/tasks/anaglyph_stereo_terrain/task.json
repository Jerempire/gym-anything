{
  "id": "anaglyph_stereo_terrain@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Mount Everest (27.9881, 86.9250) and display the Himalayan terrain using anaglyph 3D stereo viewing mode with red-cyan color separation.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/anaglyph_stereo_terrain/setup_task.sh",
    "post_task": "/workspace/tasks/anaglyph_stereo_terrain/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "target_location": "Mount Everest",
    "target_latitude": 27.9881,
    "target_longitude": 86.925,
    "coordinate_tolerance_degrees": 2.0,
    "anaglyph_color_threshold": 2.0,
    "expected_setting": "Anaglyph 3D enabled",
    "score_anaglyph_enabled": 40,
    "score_mountainous_terrain": 20,
    "score_view_tilted": 20,
    "score_settings_accessed": 20
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_anaglyph_stereo_terrain"
    }
  }
}
