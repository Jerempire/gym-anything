{
  "id": "alcatraz_boundary_export@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a polygon tracing the coastline perimeter of Alcatraz Island (37.827°N, 122.423°W) following its irregular shoreline shape. Name the polygon 'Alcatraz_Boundary'. Export as KML to /home/ga/Documents/alcatraz_boundary.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/alcatraz_boundary_export/setup_task.sh",
    "post_task": "/workspace/tasks/alcatraz_boundary_export/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/alcatraz_boundary.kml",
    "target_location": {
      "name": "Alcatraz Island",
      "latitude": 37.8267,
      "longitude": -122.4230,
      "bounding_box": {
        "north": 37.8295,
        "south": 37.8240,
        "east": -122.4180,
        "west": -122.4280
      }
    },
    "expected_area_hectares": {
      "min": 6,
      "max": 15
    },
    "minimum_vertices": 8,
    "expected_placemark_name": "Alcatraz_Boundary"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_alcatraz_boundary_export"
    }
  }
}