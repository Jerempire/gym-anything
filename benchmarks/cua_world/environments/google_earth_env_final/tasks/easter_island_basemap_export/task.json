{
  "id": "easter_island_basemap_export@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Export a clean satellite image of Easter Island (Rapa Nui, Chile, -27.1127, -109.3497) to /home/ga/exports/easter_island_basemap.png. The image must frame the complete island with all three volcanic peaks visible in a top-down view, with all labels, borders, roads, and 3D buildings disabled. Minimum resolution: 1920x1080.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/easter_island_basemap_export/setup_task.sh",
    "post_task": "/workspace/tasks/easter_island_basemap_export/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/exports/easter_island_basemap.png",
    "min_file_size_kb": 500,
    "min_width": 1920,
    "min_height": 1080,
    "target_location": {
      "name": "Easter Island (Rapa Nui)",
      "country": "Chile",
      "latitude": -27.1127,
      "longitude": -109.3497
    },
    "required_layers_off": [
      "Labels",
      "Borders and Labels",
      "Roads",
      "3D Buildings"
    ],
    "score_weights": {
      "file_exists": 15,
      "valid_png": 10,
      "meets_resolution": 15,
      "file_created_during_task": 10,
      "file_size_reasonable": 5,
      "vlm_shows_easter_island": 20,
      "vlm_complete_island": 10,
      "vlm_no_labels": 10,
      "vlm_trajectory_workflow": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_easter_island_basemap_export"
    }
  }
}
