{
  "id": "airport_flight_path@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a direct path named 'KSFO-KLAX Direct Route' from San Francisco International Airport (KSFO, 37.62°N, 122.38°W) to Los Angeles International Airport (KLAX, 33.94°N, 118.41°W). Use 'Cross-country VFR route, approximately 300 nm' as the description and export the path as KML to /home/ga/Documents/flight_path.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/airport_flight_path/setup_task.sh",
    "post_task": "/workspace/tasks/airport_flight_path/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/flight_path.kml",
    "expected_path_name": "KSFO-KLAX Direct Route",
    "sfo_lat": 37.6213,
    "sfo_lon": -122.379,
    "lax_lat": 33.9425,
    "lax_lon": -118.4081,
    "coord_tolerance_degrees": 0.5,
    "expected_distance_km": 543,
    "distance_tolerance_km": 50,
    "min_file_size_bytes": 200
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_airport_flight_path"
    }
  }
}
