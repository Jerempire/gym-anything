{
  "id": "river_confluence_marking@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a placemark named 'Ohio-Mississippi Confluence' at the confluence of the Ohio and Mississippi Rivers near Cairo, Illinois (36.98°N, 89.13°W). Include the coordinates in the placemark description.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/river_confluence_marking/setup_task.sh",
    "post_task": "/workspace/tasks/river_confluence_marking/export_result.sh"
  },
  "metadata": {
    "expected_placemark_name": "Ohio-Mississippi Confluence",
    "confluence_lat": 36.9871,
    "confluence_lon": -89.1328,
    "tolerance_km_pass": 5.0,
    "tolerance_km_bonus": 1.0,
    "myplaces_path": "/home/ga/.googleearth/myplaces.kml",
    "search_terms": [
      "Cairo Illinois",
      "Ohio Mississippi confluence",
      "Fort Defiance State Park"
    ],
    "geographic_context": "Southern tip of Illinois where Ohio River joins Mississippi River"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_river_confluence_marking"
    }
  }
}
