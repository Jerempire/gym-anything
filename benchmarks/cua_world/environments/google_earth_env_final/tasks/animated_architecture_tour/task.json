{
  "id": "animated_architecture_tour@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a folder named 'Modern Architecture Tour' containing placemarks for 'Sydney Opera House' (33.8568°S, 151.2153°E), 'Burj Khalifa' (25.1972°N, 55.2744°E), and 'Guggenheim Bilbao' (43.2685°N, 2.9340°W). Record a fly-through tour of these locations and save the folder with the tour data as KMZ to /home/ga/Documents/architecture_tour.kmz.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/animated_architecture_tour/setup_task.sh",
    "post_task": "/workspace/tasks/animated_architecture_tour/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/architecture_tour.kmz",
    "alternate_output_path": "/home/ga/Documents/architecture_tour.kml",
    "expected_locations": {
      "sydney": {
        "name_patterns": [
          "sydney",
          "opera"
        ],
        "lat": -33.857,
        "lon": 151.215,
        "tolerance": 0.1
      },
      "dubai": {
        "name_patterns": [
          "burj",
          "khalifa",
          "dubai"
        ],
        "lat": 25.197,
        "lon": 55.274,
        "tolerance": 0.1
      },
      "bilbao": {
        "name_patterns": [
          "guggenheim",
          "bilbao"
        ],
        "lat": 43.269,
        "lon": -2.934,
        "tolerance": 0.1
      }
    },
    "expected_folder_name": "Modern Architecture Tour"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_animated_architecture_tour"
    }
  }
}
