{
  "id": "antipodal_point_marking@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to the antipodal point of Quito, Ecuador (0.1807°S, 78.4678°W) and create a placemark named 'Quito Antipode' at that location.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/antipodal_point_marking/setup_task.sh",
    "post_task": "/workspace/tasks/antipodal_point_marking/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "source_location": "Quito, Ecuador",
    "source_latitude": -0.1807,
    "source_longitude": -78.4678,
    "expected_latitude": 0.1807,
    "expected_longitude": 101.5322,
    "coordinate_tolerance_degrees": 0.5,
    "expected_placemark_name": "Quito Antipode",
    "destination_region": "Sumatra, Indonesia",
    "max_distance_km": 100,
    "myplaces_path": "/home/ga/.googleearth/myplaces.kml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_antipodal_point_marking"
    }
  }
}
