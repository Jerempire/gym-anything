{
  "id": "image_date_extraction@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to the Colosseum in Rome, Italy (41.8902°N, 12.4922°E). Document the location, coordinates, satellite imagery capture date (YYYY-MM-DD), and eye altitude in a text file at /home/ga/imagery_date_report.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/image_date_extraction/setup_task.sh",
    "post_task": "/workspace/tasks/image_date_extraction/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/imagery_date_report.txt",
    "target_location": "Colosseum, Rome, Italy",
    "target_latitude": 41.8902,
    "target_longitude": 12.4922,
    "coordinate_tolerance": 0.05,
    "min_year": 2000,
    "max_year": 2030
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_image_date_extraction"
    }
  }
}
