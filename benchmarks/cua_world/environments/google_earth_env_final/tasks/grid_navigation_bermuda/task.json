{
  "id": "grid_navigation_bermuda@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to 25°N, 71°W in the Atlantic Ocean and capture a screenshot showing the latitude/longitude grid overlay. Save the screenshot to ~/Pictures/bermuda_grid.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/grid_navigation_bermuda/setup_task.sh",
    "post_task": "/workspace/tasks/grid_navigation_bermuda/export_result.sh"
  },
  "metadata": {
    "target_latitude": 25.0,
    "target_longitude": -71.0,
    "coordinate_tolerance_degrees": 8.0,
    "expected_screenshot_path": "/home/ga/Pictures/bermuda_grid.png",
    "min_file_size_kb": 50,
    "region_name": "Bermuda Triangle",
    "bounding_points": {
      "miami": {
        "lat": 25.7617,
        "lon": -80.1918
      },
      "bermuda": {
        "lat": 32.3078,
        "lon": -64.7505
      },
      "puerto_rico": {
        "lat": 18.2208,
        "lon": -66.5901
      }
    },
    "score_screenshot_exists": 20,
    "score_file_created_during_task": 15,
    "score_grid_visible": 25,
    "score_ocean_location": 25,
    "score_vlm_verification": 15
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_grid_navigation_bermuda"
    }
  }
}
