{
  "id": "street_view_heritage_alamo@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Capture a Street View screenshot of the main facade of The Alamo (29.4260° N, 98.4861° W) from Alamo Plaza. Save the screenshot to /home/ga/Documents/alamo_streetview.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/street_view_heritage_alamo/setup_task.sh",
    "post_task": "/workspace/tasks/street_view_heritage_alamo/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/alamo_streetview.png",
    "alternate_output_path": "/home/ga/Documents/alamo_streetview.jpg",
    "location_name": "The Alamo, San Antonio, Texas",
    "latitude": 29.426,
    "longitude": -98.4861,
    "min_image_width": 640,
    "min_image_height": 480,
    "landmark_features": [
      "limestone facade",
      "curved parapet",
      "mission architecture",
      "main entrance doors"
    ],
    "score_file_exists": 15,
    "score_valid_image": 10,
    "score_street_view_mode": 20,
    "score_correct_location": 25,
    "score_facade_orientation": 20,
    "score_complete_facade": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_street_view_heritage_alamo"
    }
  }
}
