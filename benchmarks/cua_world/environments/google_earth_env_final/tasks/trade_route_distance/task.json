{
  "id": "trade_route_distance@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure a multi-point path in kilometers connecting Alexandria, Egypt (31.2°N, 29.9°E), Heraklion, Crete (35.3°N, 25.1°E), Piraeus, Greece (37.9°N, 23.6°E), Ostia Antica, Italy (41.7°N, 12.3°E), and Carthage, Tunisia (36.85°N, 10.33°E) in that order. Save a screenshot showing the path and distance measurement to /home/ga/trade_route_measurement.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/trade_route_distance/setup_task.sh",
    "post_task": "/workspace/tasks/trade_route_distance/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/trade_route_measurement.png",
    "min_file_size_kb": 50,
    "expected_distance_min_km": 2400,
    "expected_distance_max_km": 3400,
    "num_path_points": 5,
    "port_cities": [
      {
        "name": "Alexandria",
        "lat": 31.2,
        "lon": 29.92
      },
      {
        "name": "Heraklion",
        "lat": 35.34,
        "lon": 25.13
      },
      {
        "name": "Piraeus",
        "lat": 37.94,
        "lon": 23.65
      },
      {
        "name": "Ostia",
        "lat": 41.76,
        "lon": 12.29
      },
      {
        "name": "Carthage",
        "lat": 36.85,
        "lon": 10.33
      }
    ],
    "regions_expected": [
      "Egypt",
      "Greece",
      "Italy",
      "Tunisia"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_trade_route_distance"
    }
  }
}
