{
  "id": "glacier_terminus_width@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure the width of the Perito Moreno Glacier terminus (-50.497, -73.137) by tracing the ice/water boundary as a path named 'Perito_Moreno_Terminus'. Create a placemark named 'Terminus_Center' at the midpoint with the measured width in the description. Export both to ~/Documents/glacier_terminus.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/glacier_terminus_width/setup_task.sh",
    "post_task": "/workspace/tasks/glacier_terminus_width/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/glacier_terminus.kml",
    "expected_path_name": "Perito_Moreno_Terminus",
    "expected_placemark_name": "Terminus_Center",
    "glacier_lat_min": -50.55,
    "glacier_lat_max": -50.45,
    "glacier_lon_min": -73.25,
    "glacier_lon_max": -73.05,
    "expected_length_min_km": 4.0,
    "expected_length_max_km": 6.0,
    "min_path_points": 10,
    "location_name": "Perito Moreno Glacier, Argentina",
    "scientific_width_km": 5.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_glacier_terminus_width"
    }
  }
}