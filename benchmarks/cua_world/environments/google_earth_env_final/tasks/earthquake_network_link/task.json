{
  "id": "earthquake_network_link@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a Network Link named 'USGS Earthquakes M2.5+ Past Day' using the URL https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/2.5_day.kml. Ensure the link is active and earthquake markers are visible on the globe.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 35,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/earthquake_network_link/setup_task.sh",
    "post_task": "/workspace/tasks/earthquake_network_link/export_result.sh"
  },
  "metadata": {
    "expected_url": "https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/2.5_day.kml",
    "expected_name_keywords": [
      "usgs",
      "earthquake",
      "quake",
      "seismic",
      "2.5"
    ],
    "myplaces_paths": [
      "/home/ga/.googleearth/myplaces.kml",
      "/home/ga/.config/Google/GoogleEarthPro/myplaces.kml"
    ],
    "data_source": "USGS Earthquake Hazards Program",
    "data_source_url": "https://earthquake.usgs.gov/earthquakes/feed/"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_earthquake_network_link"
    }
  }
}
