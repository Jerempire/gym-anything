{
  "id": "building_extrusion_polygon@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a 3D extruded polygon named 'Proposed Office Tower' at 41.8839°N, 87.6416°W in Chicago (~60m x 40m). Set the altitude to 75 meters relative to ground, extend sides to ground, and use a semi-transparent blue fill. Export KML to /home/ga/Documents/proposed_building.kml and save an angled screenshot of the extrusion to /home/ga/Documents/building_visualization.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/building_extrusion_polygon/setup_task.sh",
    "post_task": "/workspace/tasks/building_extrusion_polygon/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "target_latitude": 41.8839,
    "target_longitude": -87.6416,
    "target_height_meters": 75,
    "height_tolerance_meters": 5,
    "coordinate_tolerance_degrees": 0.01,
    "expected_kml_path": "/home/ga/Documents/proposed_building.kml",
    "expected_screenshot_path": "/home/ga/Documents/building_visualization.png",
    "expected_polygon_name": "Proposed Office Tower",
    "min_kml_size_bytes": 500,
    "min_screenshot_size_bytes": 10000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_building_extrusion"
    }
  }
}
