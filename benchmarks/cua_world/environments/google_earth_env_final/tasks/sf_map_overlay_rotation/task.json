{
  "id": "sf_map_overlay_rotation@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create an Image Overlay named 'SF 1906 Historical Map' using the file at /home/ga/Documents/sf_1906_map.png. Position and rotate the overlay to align with San Francisco's downtown area and Market Street (approximately 37.77-37.79°N, 122.39-122.42°W). Set transparency to 50% and export as KMZ to /home/ga/Documents/sf_overlay.kmz.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sf_map_overlay_rotation/setup_task.sh",
    "post_task": "/workspace/tasks/sf_map_overlay_rotation/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/sf_overlay.kmz",
    "map_image_path": "/home/ga/Documents/sf_1906_map.png",
    "overlay_name": "SF 1906 Historical Map",
    "expected_rotation_min": 8,
    "expected_rotation_max": 12,
    "expected_opacity_min": 0.35,
    "expected_opacity_max": 0.65,
    "target_location": "San Francisco, CA",
    "target_lat_min": 37.76,
    "target_lat_max": 37.81,
    "target_lon_min": -122.43,
    "target_lon_max": -122.38,
    "data_source": "Library of Congress Sanborn Fire Insurance Maps"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_sf_map_overlay_rotation"
    }
  }
}
