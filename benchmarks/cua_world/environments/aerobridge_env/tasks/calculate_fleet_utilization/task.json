{
  "id": "calculate_fleet_utilization@1",
  "version": "1.0",
  "env_id": "aerobridge_env@0.1",
  "description": "Calculate the total flight duration in minutes for all flight plans belonging to the operator 'SkyHigh Surveyors' that occurred in October 2023. Save the total number of minutes to /home/ga/Documents/utilization_report.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/calculate_fleet_utilization/setup_task.sh",
    "post_task": "/workspace/tasks/calculate_fleet_utilization/export_result.sh"
  },
  "metadata": {
    "expected_value": 135,
    "tolerance": 2,
    "operator_name": "SkyHigh Surveyors",
    "target_month": "October 2023",
    "report_path": "/home/ga/Documents/utilization_report.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_calculate_fleet_utilization"
    }
  }
}
