{
  "id": "reconcile_bank_account@1",
  "version": "1.0",
  "env_id": "manager_env@0.1",
  "description": "Perform a bank reconciliation for the 'Petty Cash' account in Northwind Traders for the month ending January 31, 2025. Use a statement balance of 170.00 and ensure all transactions are cleared to achieve a zero discrepancy before saving the reconciliation.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/reconcile_bank_account/setup_task.sh",
    "post_task": "/workspace/tasks/reconcile_bank_account/export_result.sh"
  },
  "metadata": {
    "account_name": "Petty Cash",
    "target_date": "2025-01-31",
    "target_balance": 170.0,
    "manager_module": "bank_reconciliations"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reconcile_bank_account"
    }
  }
}
