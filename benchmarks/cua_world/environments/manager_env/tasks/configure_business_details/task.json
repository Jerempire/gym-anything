{
  "id": "configure_business_details@1",
  "version": "1.0",
  "env_id": "manager_env@0.1",
  "description": "You are a General Operations Manager at Northwind Traders. Configure the company's official business details in Manager.io before issuing invoices. Update the business information to:\n\n- Business Name: Northwind Traders Ltd.\n- Address: 456 Commerce Boulevard, Suite 200, Chicago, IL 60601, United States\n- Email: accounts@northwindtraders.com",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_business_details/setup_task.sh",
    "post_task": "/workspace/tasks/configure_business_details/export_result.sh"
  },
  "metadata": {
    "expected_name": "Northwind Traders Ltd.",
    "expected_address_parts": [
      "456 Commerce Boulevard",
      "Suite 200",
      "Chicago, IL 60601",
      "United States"
    ],
    "expected_email": "accounts@northwindtraders.com",
    "initial_name": "Northwind Traders"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_business_details"
    }
  },
  "tags": [
    "settings",
    "configuration",
    "manager.io",
    "admin"
  ]
}
