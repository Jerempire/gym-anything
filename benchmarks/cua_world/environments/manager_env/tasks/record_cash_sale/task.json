{
  "id": "record_cash_sale@1",
  "version": "1.0",
  "env_id": "manager_env@0.1",
  "description": "Record a direct cash sale for Northwind Traders in Manager.io. A walk-in customer has purchased 12 boxes of 'Chai'. Create a receipt for 'Walk-in Customer' using the 'Cash on Hand' account for the 12 units of 'Chai'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_cash_sale/setup_task.sh",
    "post_task": "/workspace/tasks/record_cash_sale/export_result.sh"
  },
  "metadata": {
    "expected_payer": "Walk-in Customer",
    "expected_item": "Chai",
    "expected_qty": 12,
    "expected_account": "Cash on Hand",
    "manager_business": "Northwind Traders"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_cash_sale"
    }
  }
}
