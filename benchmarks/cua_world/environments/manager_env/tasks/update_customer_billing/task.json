{
  "id": "update_customer_billing@1",
  "version": "1.0",
  "env_id": "manager_env@0.1",
  "description": "Update the billing information for the existing customer 'Ernst Handel'. Change the billing address to Musterstraße 42, Wien 1010, Austria and the email to e.handel@ernsthandel.at. Ensure the customer name remains 'Ernst Handel' and no new customer record is created. Save the changes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_customer_billing/setup_task.sh",
    "post_task": "/workspace/tasks/update_customer_billing/export_result.sh"
  },
  "metadata": {
    "target_customer": "Ernst Handel",
    "expected_address_parts": [
      "Musterstraße 42",
      "Wien 1010",
      "Austria"
    ],
    "expected_email": "e.handel@ernsthandel.at",
    "forbidden_address_parts": [
      "Kirchgasse 6",
      "Graz 8010"
    ],
    "forbidden_email": "ernst.handel@example.at",
    "manager_module": "customers"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_customer_billing"
    }
  }
}
