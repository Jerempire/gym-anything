{
  "id": "record_prepaid_expense@1",
  "version": "1.0",
  "env_id": "manager_env@0.1",
  "description": "Create an Asset account named 'Prepaid Insurance' in the Chart of Accounts and record a payment of $2,400.00 to a new payee 'Fairfax Insurance' allocated to this account. This represents an annual premium payment that should be treated as an asset rather than an immediate expense.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_prepaid_expense/setup_task.sh",
    "post_task": "/workspace/tasks/record_prepaid_expense/export_result.sh"
  },
  "metadata": {
    "expected_account_name": "Prepaid Insurance",
    "expected_payee": "Fairfax Insurance",
    "expected_amount": 2400.0,
    "manager_url": "http://localhost:8080"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_prepaid_expense"
    }
  }
