{
  "id": "setup_tax_codes@1",
  "version": "1.0",
  "env_id": "manager_env@0.1",
  "description": "Configure VAT tax codes for the Northwind Traders business in Manager.io. Create two tax codes: 'UK Standard Rate' with a 20% rate and 'UK Reduced Rate' with a 5% rate.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/setup_tax_codes/setup_task.sh",
    "post_task": "/workspace/tasks/setup_tax_codes/export_result.sh"
  },
  "metadata": {
    "tax_codes": [
      {
        "name": "UK Standard Rate",
        "rate": 20.0
      },
      {
        "name": "UK Reduced Rate",
        "rate": 5.0
      }
    ],
    "manager_business": "Northwind Traders",
    "manager_module": "settings"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_setup_tax_codes"
    }
  }
}
