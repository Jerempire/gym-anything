{
  "id": "reclassify_misallocated_expense@1",
  "version": "1.0",
  "env_id": "manager_env@0.1",
  "description": "A payment of $245.00 to 'City Grill' on 2025-05-15 was incorrectly recorded under 'Office Supplies'. Starting from the Northwind Traders Summary page, reclassify this payment to a new Expense Account named 'Meals & Entertainment'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/reclassify_misallocated_expense/setup_task.sh",
    "post_task": "/workspace/tasks/reclassify_misallocated_expense/export_result.sh"
  },
  "metadata": {
    "target_payee": "City Grill",
    "target_amount": 245.0,
    "target_date": "2025-05-15",
    "old_account": "Office Supplies",
    "new_account": "Meals & Entertainment",
    "manager_module": "payments"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reclassify_misallocated_expense"
    }
  }
}
