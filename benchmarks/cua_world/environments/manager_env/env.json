{
  "id": "manager_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Manager.io Server Edition accounting software environment. Manager.io is free, open-source accounting software for small businesses with invoicing, inventory, payroll, and financial reporting. Uses the official Northwind Traders sample business for realistic accounting tasks.",
  "resources": {
    "cpu": 4,
    "mem_gb": 6,
    "gpu": 0,
    "net": true
  },
  "vnc": {
    "password": "password"
  },
  "diagnostics": true,
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "mounts": [
    {"source": "benchmarks/cua_world/environments/manager_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/manager_env/config",  "target": "/workspace/config",  "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/manager_env/tasks",   "target": "/workspace/tasks",   "mode": "ro"}
  ],
  "hooks": {
    "pre_start":  "/workspace/scripts/install_manager.sh",
    "post_start": "/workspace/scripts/setup_manager.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input", "docker"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1"
        }
      }
    }
  ],
  "tags": ["linux", "accounting", "finance", "manager.io", "web-application", "docker", "northwind"]
}
