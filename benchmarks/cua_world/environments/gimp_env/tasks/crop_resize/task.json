{
  "id": "crop_resize@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Crop an image to focus on the main subject and resize to 400x300 pixels",
  "init": {
    "timeout_sec": 120,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/crop_resize/setup_crop_task.sh",
    "post_task": "/workspace/tasks/crop_resize/export_crop.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_crop_resize"
    }
  }
}
