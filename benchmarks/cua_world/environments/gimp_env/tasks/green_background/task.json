{
  "id": "green_background@1",
  "env_id": "example.gimp_env@0.1",
  "difficulty": "medium",
  "natural_language": {
    "prompt": "Could you fill the background layer with green color, leaving the object layer as is? The file 'white_background_with_object.xcf' is available on the Desktop."
  },
  "init": {
    "timeout_sec": 120,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/green_background/setup_green_task.sh",
    "post_task": "/workspace/tasks/green_background/export_green.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_green_background"
    }
  }
}
