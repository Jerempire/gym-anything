{
  "id": "undo_config@1",
  "env_id": "example.gimp_env@0.1",
  "difficulty": "easy",
  "natural_language": {
    "prompt": "Set the minimum number of undo steps to 100 in GIMP preferences."
  },
  "init": {
    "timeout_sec": 90,
    "max_steps": 12,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/undo_config/setup_undo_task.sh",
    "post_task": "/workspace/tasks/undo_config/close_gimp.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_config_status"
    }
  }
}
