{
  "id": "color_replacement@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Replace red color in an image with blue color using GIMP's color selection tools",
  "init": {
    "timeout_sec": 120,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/color_replacement/setup_color_task.sh",
    "post_task": "/workspace/tasks/color_replacement/export_color.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_color_replacement"
    }
  }
}
