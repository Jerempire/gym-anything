{
  "id": "horizontal_mirror@1",
  "env_id": "example.gimp_env@0.1",
  "difficulty": "easy",
  "natural_language": {
    "prompt": "Please rotate my figure to mirror it horizontally. The image is located at /home/ga/Desktop/berry.png. Use GIMP to flip the image horizontally and save it as berry_mirror.png."
  },
  "init": {
    "timeout_sec": 120,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/horizontal_mirror/setup_mirror_task.sh",
    "post_task": "/workspace/tasks/horizontal_mirror/export_mirror.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_image_mirror"
    }
  }
}
