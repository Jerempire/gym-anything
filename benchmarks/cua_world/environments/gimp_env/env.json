{
  "id": "example.gimp_env@0.1", 
  "version": "0.1",
  "base": "ubuntu-gnome-systemd",
  "description": "GIMP image editing environment with custom setup and configuration",
  "observation": [
    {"type": "rgb_screen", "fps": 10, "resolution": [1600, 900], "inline": false}
  ],
  "action": [
    {"type": "mouse"}, 
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": true,
    "output_dir": "benchmarks/cua_world/environments/gimp_env/artifacts"
  },
  "vnc": {
    "enable": true,
    "host_port": 5950,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/gimp_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/gimp_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/gimp_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_gimp.sh",
    "post_start": "/workspace/scripts/setup_gimp.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {
          "GIMP_USER": "ga",
          "DISPLAY": ":1"
        }
      }
    },
    {
      "name": "artist",
      "password": "artist123",
      "uid": 1001,
      "role": "user",
      "permissions": {
        "sudo": false,
        "groups": ["audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {
          "GIMP_USER": "artist"
        }
      }
    }
  ],
  "tags": ["linux", "graphics", "image-editing", "gimp", "desktop"]
}
