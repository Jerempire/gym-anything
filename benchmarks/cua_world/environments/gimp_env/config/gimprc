# GIMP configuration for gym-anything environment
# Optimized for container usage and agent interaction

# Performance settings - memory in MB 
(tile-cache-size 1024000000)
(num-processors 2)

# User interface optimizations  
(show-tooltips yes)
(use-help yes)

# Undo settings
(undo-levels 64)

# File handling  
(check-updates no)

# Display settings
(transparency-type 1)
(cursor-updating yes)

# Disable problematic features for VNC
(save-session-info no)
(restore-session no)
