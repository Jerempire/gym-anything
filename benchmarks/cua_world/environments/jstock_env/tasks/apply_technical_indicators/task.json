{
  "id": "apply_technical_indicators@1",
  "version": "1.0",
  "env_id": "jstock_env@0.1",
  "description": "Configure a technical analysis chart for Apple Inc. (AAPL) in JStock. The chart must display the stock price history with both a 50-day Simple Moving Average (SMA) and a 200-day Simple Moving Average (SMA) overlaid. Save the chart as an image to /home/ga/Documents/aapl_trend_analysis.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/apply_technical_indicators/setup_task.sh",
    "post_task": "/workspace/tasks/apply_technical_indicators/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/aapl_trend_analysis.png",
    "stock_symbol": "AAPL",
    "indicators": [
      {
        "type": "SMA",
        "period": 50
      },
      {
        "type": "SMA",
        "period": 200
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_apply_technical_indicators"
    }
  }
}
