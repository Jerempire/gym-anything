{
  "id": "customize_watchlist_columns@1",
  "version": "1.0",
  "env_id": "jstock_env@0.1",
  "description": "Customize the JStock watchlist view for a long-term investor who doesn't need real-time bid/ask data. Hide the 'Buy', 'B.Qty', 'Sell', and 'S.Qty' columns while ensuring the 'High' and 'Low' columns remain visible to create a cleaner interface.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/customize_watchlist_columns/setup_task.sh",
    "post_task": "/workspace/tasks/customize_watchlist_columns/export_result.sh"
  },
  "metadata": {
    "hidden_columns": [
      "Buy",
      "B.Qty",
      "Sell",
      "S.Qty"
    ],
    "visible_columns": [
      "High",
      "Low"
    ],
    "config_path_pattern": "/home/ga/.jstock/1.0.7/*.xml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_customize_watchlist_columns"
    }
  }
}
