{
  "id": "configure_proxy_settings@1",
  "version": "1.0",
  "env_id": "jstock_env@0.1",
  "description": "A corporate analyst needs to configure JStock to use their company's HTTP proxy server. Configure the application to use the proxy server proxy.acmecorp.net on port 3128 and ensure the settings are saved.",
  "category": "configuration",
  "tags": [
    "settings",
    "proxy",
    "options",
    "network",
    "preferences"
  ],
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_proxy_settings/setup_task.sh",
    "post_task": "/workspace/tasks/configure_proxy_settings/export_result.sh"
  },
  "metadata": {
    "expected_proxy_host": "proxy.acmecorp.net",
    "expected_proxy_port": "3128",
    "config_dir": "/home/ga/.jstock",
    "java_prefs_dir": "/home/ga/.java/.userPrefs"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_proxy_settings"
    }
  }
}
