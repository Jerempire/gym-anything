{
  "id": "exit_and_remove_stock@1",
  "version": "1.0",
  "env_id": "jstock_env@0.1",
  "description": "Completely exit your position in NVIDIA (NVDA) and stop tracking it. Record a sell transaction for all 25 shares of NVDA at a price of $850.00 with a broker fee of 0. Remove NVDA from your watchlist.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/exit_and_remove_stock/setup_task.sh",
    "post_task": "/workspace/tasks/exit_and_remove_stock/export_result.sh"
  },
  "metadata": {
    "target_symbol": "NVDA",
    "target_qty": 25.0,
    "target_sell_price": 850.0,
    "watchlist_path": "/home/ga/.jstock/1.0.7/UnitedState/watchlist/My Watchlist/realtimestock.csv",
    "sell_portfolio_path": "/home/ga/.jstock/1.0.7/UnitedState/portfolios/My Portfolio/sellportfolio.csv"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_exit_and_remove_stock"
    }
  }
}
