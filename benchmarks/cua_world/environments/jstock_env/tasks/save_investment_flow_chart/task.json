{
  "id": "save_investment_flow_chart@1",
  "version": "1.0",
  "env_id": "jstock_env@0.1",
  "description": "Navigate to the 'Investment Flow Summary' chart in JStock to view the portfolio performance history and export the chart as a PNG image to /home/ga/Documents/investment_flow.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/save_investment_flow_chart/setup_task.sh",
    "post_task": "/workspace/tasks/save_investment_flow_chart/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/investment_flow.png",
    "min_file_size_bytes": 5000,
    "expected_width_min": 400,
    "expected_height_min": 300
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_save_investment_flow_chart"
    }
  }
}
