{
  "id": "segment_watchlist@1",
  "version": "1.0",
  "env_id": "jstock_env@0.1",
  "description": "Reorganize your stock watchlists by creating a new watchlist named 'Core Holdings' containing Apple (AAPL) and Microsoft (MSFT). Ensure 'My Watchlist' is updated to contain only GOOGL, AMZN, and NVDA.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/segment_watchlist/setup_task.sh",
    "post_task": "/workspace/tasks/segment_watchlist/export_result.sh"
  },
  "metadata": {
    "target_watchlist_name": "Core Holdings",
    "source_watchlist_name": "My Watchlist",
    "moved_stocks": [
      "AAPL",
      "MSFT"
    ],
    "remaining_stocks": [
      "GOOGL",
      "AMZN",
      "NVDA"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_segment_watchlist"
    }
  }
}
