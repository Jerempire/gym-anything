{
  "id": "rename_portfolio@1",
  "version": "1.0",
  "env_id": "jstock_env@0.1",
  "description": "Rename the existing default portfolio from 'My Portfolio' to 'Tech Growth Fund' while preserving all transaction data, including the original buy transactions for AAPL, MSFT, and NVDA.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rename_portfolio/setup_task.sh",
    "post_task": "/workspace/tasks/rename_portfolio/export_result.sh"
  },
  "metadata": {
    "old_portfolio_name": "My Portfolio",
    "new_portfolio_name": "Tech Growth Fund",
    "expected_transactions": [
      {
        "code": "AAPL",
        "units": 100.0,
        "price": 185.2
      },
      {
        "code": "MSFT",
        "units": 50.0,
        "price": 374.5
      },
      {
        "code": "NVDA",
        "units": 25.0,
        "price": 615.3
      }
    ],
    "jstock_data_dir": "/home/ga/.jstock/1.0.7/UnitedState/portfolios"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rename_portfolio"
    }
  }
}
