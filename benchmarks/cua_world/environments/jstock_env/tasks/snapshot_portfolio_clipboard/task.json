{
  "id": "snapshot_portfolio_clipboard@1",
  "version": "1.0",
  "env_id": "jstock_env@0.1",
  "description": "Create a text snapshot of your current JStock portfolio. JStock is open on the 'My Portfolio' tab containing AAPL (123 units) and MSFT (45 units). Save the plain text representation of the portfolio table to /home/ga/Documents/portfolio_snapshot.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/snapshot_portfolio_clipboard/setup_task.sh",
    "post_task": "/workspace/tasks/snapshot_portfolio_clipboard/export_result.sh"
  },
  "metadata": {
    "expected_file": "/home/ga/Documents/portfolio_snapshot.txt",
    "required_content": [
      {
        "symbol": "AAPL",
        "units": "123"
      },
      {
        "symbol": "MSFT",
        "units": "45"
      }
    ],
    "anti_gaming_strings": [
      "123",
      "45"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_snapshot_portfolio"
    }
  }
}
