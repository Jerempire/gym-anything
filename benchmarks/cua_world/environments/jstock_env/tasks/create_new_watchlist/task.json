{
  "id": "create_new_watchlist@1",
  "version": "1.0",
  "env_id": "jstock_env@0.1",
  "description": "JStock is open showing the Stock Watchlist with only 'My Watchlist' available. Create a new watchlist named 'Dividend Stocks'.",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_new_watchlist/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_new_watchlist"
    }
  }
}
