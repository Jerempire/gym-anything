{
  "id": "save_stock_history_chart@1",
  "version": "1.0",
  "env_id": "jstock_env@0.1",
  "description": "Open the historical stock price chart for NVIDIA (NVDA) in JStock and save the chart image as NVDA_chart.png to the /home/ga/Documents/ folder.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/save_stock_history_chart/setup_task.sh",
    "post_task": "/workspace/tasks/save_stock_history_chart/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/NVDA_chart.png",
    "min_file_size_bytes": 5000,
    "expected_format": "PNG",
    "desktop_width": 1920,
    "desktop_height": 1080
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_save_stock_history_chart"
    }
  }
}
