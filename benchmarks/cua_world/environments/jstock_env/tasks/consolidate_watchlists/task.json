{
  "id": "consolidate_watchlists@1",
  "version": "1.0",
  "env_id": "jstock_env@0.1",
  "description": "Consolidate the 'Auto' watchlist (F, GM, TSLA) into the 'Tech' watchlist (AAPL, MSFT, TSLA) so that 'Tech' contains all unique stocks from both lists. Once the 'Tech' watchlist is updated to include all five stocks, delete the 'Auto' watchlist.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/consolidate_watchlists/setup_task.sh",
    "post_task": "/workspace/tasks/consolidate_watchlists/export_result.sh"
  },
  "metadata": {
    "target_watchlist": "Tech",
    "source_watchlist": "Auto",
    "expected_stocks": [
      "AAPL",
      "MSFT",
      "TSLA",
      "F",
      "GM"
    ],
    "jstock_data_dir": "/home/ga/.jstock/1.0.7/UnitedState/watchlist"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_consolidate_watchlists"
    }
  }
}
