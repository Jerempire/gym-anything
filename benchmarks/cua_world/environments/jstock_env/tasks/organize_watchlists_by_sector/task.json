{
  "id": "organize_watchlists_by_sector@1",
  "version": "1.0",
  "env_id": "jstock_env@0.1",
  "description": "Reorganize the stocks in 'My Watchlist' (AAPL, MSFT, GOOGL, AMZN, and NVDA) into sector-specific watchlists. Create a new watchlist named 'Semiconductors' containing NVDA and another named 'Software & Cloud' containing MSFT and GOOGL. Update the original 'My Watchlist' so it only contains AAPL and AMZN.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/organize_watchlists_by_sector/setup_task.sh",
    "post_task": "/workspace/tasks/organize_watchlists_by_sector/export_result.sh"
  },
  "metadata": {
    "watchlists": {
      "My Watchlist": [
        "AAPL",
        "AMZN"
      ],
      "Semiconductors": [
        "NVDA"
      ],
      "Software & Cloud": [
        "MSFT",
        "GOOGL"
      ]
    },
    "forbidden_in_my_watchlist": [
      "NVDA",
      "MSFT",
      "GOOGL"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_organize_watchlists"
    }
  }
}
