{
  "id": "rebalance_portfolio_equal_weight@1",
  "version": "1.0",
  "env_id": "jstock_env@0.1",
  "description": "Rebalance the existing portfolio consisting of Apple (AAPL), Microsoft (MSFT), and NVIDIA (NVDA) to an equal-weight allocation. Analyze the current positions in JStock and record the necessary buy and sell transactions using the current date to achieve this balance. Create a text report at /home/ga/Documents/rebalancing_report.txt documenting the trades, including the stock symbols and the actions taken (Buy/Sell).",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rebalance_portfolio_equal_weight/setup_task.sh",
    "post_task": "/workspace/tasks/rebalance_portfolio_equal_weight/export_result.sh"
  },
  "metadata": {
    "report_path": "/home/ga/Documents/rebalancing_report.txt",
    "sell_csv_path": "/home/ga/.jstock/1.0.7/UnitedState/portfolios/My Portfolio/sellportfolio.csv",
    "buy_csv_path": "/home/ga/.jstock/1.0.7/UnitedState/portfolios/My Portfolio/buyportfolio.csv",
    "targets": {
      "AAPL": {
        "action": "sell",
        "qty": 5,
        "tolerance": 1
      },
      "MSFT": {
        "action": "sell",
        "qty": 3,
        "tolerance": 1
      },
      "NVDA": {
        "action": "buy",
        "qty": 3,
        "tolerance": 1
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rebalance_portfolio"
    }
  }
}
