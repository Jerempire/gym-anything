    "industry": "Public Accounting / Tax Services",
    "portfolio_name": "Tax Lots 2024",
    "watchlist_name": "Tax Watch 2024",
    "data_source": "Yahoo Finance historical closing prices (Dec 2023 - Feb 2024)",
    "buy_lots": [
      {
        "code": "COST",
        "lot": 1,
        "units": 10,
        "price": 638.22,
        "date": "Dec 1, 2023",
        "broker": 4.95,
        "clearing": 0.2
      },
      {
        "code": "COST",
        "lot": 2,
        "units": 8,
        "price": 715.4,
        "date": "Jan 19, 2024",
        "broker": 4.95,
        "clearing": 0.2
      },
      {
        "code": "META",
        "lot": 1,
        "units": 20,
        "price": 367.15,
        "date": "Dec 15, 2023",
        "broker": 4.95,
        "clearing": 0.2
      },
      {
        "code": "META",
        "lot": 2,
        "units": 12,
        "price": 484.1,
        "date": "Jan 26, 2024",
        "broker": 4.95,
        "clearing": 0.2
      },
      {
        "code": "AMZN",
        "lot": 1,
        "units": 30,
        "price": 172.35,
