{
  "id": "tax_lot_portfolio_tracking@1",
  "version": "1.0",
  "env_id": "jstock_env@0.1",
  "description": "You are a Senior Accountant (CPA) at Harrington & Associates, preparing year-end tax documentation for a client's brokerage account. Document FIFO cost basis tracking for multiple tax lots by creating a portfolio named 'Tax Lots 2024' in JStock. Record the following buy transactions separately, ensuring broker commissions ($4.95) and clearing fees ($0.20) are recorded distinctly: 10 shares of COST (Costco Wholesale) at $638.22 on December 1, 2023 (Comment: 'COST lot 1 Dec 2023') and 8 shares of COST at $715.40 on January 19, 2024.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
