{
  "id": "restore_archived_meeting@1",
  "version": "1.0",
  "env_id": "odoo_scheduling_env@0.1",
  "description": "Locate the archived meeting titled 'Q3 Board Prep' scheduled for next Wednesday at 2:00 PM and restore it to active status. Do not create a new meeting; the existing archived record must be unarchived to appear on the calendar again.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/restore_archived_meeting/setup_task.sh",
    "post_task": "/workspace/tasks/restore_archived_meeting/export_result.sh"
  },
  "metadata": {
    "target_event_name": "Q3 Board Prep",
    "expected_description_snippet": "CRITICAL: Review board deck slides",
    "required_attendees": [
      "Grace Patel",
      "Henry Kim"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_restore_archived_meeting"
    }
  }
}
