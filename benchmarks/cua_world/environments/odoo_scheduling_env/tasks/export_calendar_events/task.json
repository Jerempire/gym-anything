{
  "id": "export_calendar_events@1",
  "version": "1.0",
  "env_id": "odoo_scheduling_env@0.1",
  "description": "Export all calendar events from the Odoo Calendar module (http://localhost:8069) to a CSV file. The export must include the 'Subject' (or Name), 'Start Date', and 'End Date' (or Stop) columns. Save the resulting file to /home/ga/Documents/calendar_export.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_calendar_events/setup_task.sh",
    "post_task": "/workspace/tasks/export_calendar_events/export_result.sh"
  },
  "metadata": {
    "expected_path": "/home/ga/Documents/calendar_export.csv",
    "required_columns": [
      "subject",
      "name",
      "start",
      "stop",
      "end"
    ],
    "min_rows": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_calendar_events"
    }
  }
}
