{
  "id": "batch_reschedule_afternoon_syncs@1",
  "version": "1.0",
  "env_id": "odoo_scheduling_env@0.1",
  "description": "Reschedule all calendar events with 'Sync' in the title that start after 12:00 PM to start at 09:00 AM on their respective days. Maintain the original duration and date for each event, and do not modify any other meetings.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/batch_reschedule_afternoon_syncs/setup_task.sh",
    "post_task": "/workspace/tasks/batch_reschedule_afternoon_syncs/export_result.sh"
  },
  "metadata": {
    "target_hour": 9,
    "target_minute": 0,
    "targets": [
      "Operations Daily Sync",
      "Sales Pipeline Sync"
    ],
    "controls": [
      "Weekly Team Kickoff"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_batch_reschedule"
    }
  }
}
