{
  "id": "calculate_weekly_meeting_load@1",
  "version": "1.0",
  "env_id": "odoo_scheduling_env@0.1",
  "description": "Calculate the total duration (in hours) of all meetings Alice Johnson is attending during the week that contains the event 'Q2 Financial Review'. Save the final number to /home/ga/alice_load.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/calculate_weekly_meeting_load/setup_task.sh",
    "post_task": "/workspace/tasks/calculate_weekly_meeting_load/export_result.sh"
  },
  "metadata": {
    "target_attendee": "Alice Johnson",
    "anchor_event": "Q2 Financial Review",
    "output_file": "/home/ga/alice_load.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_calculate_weekly_meeting_load"
    }
  }
}
