{
  "id": "convert_meeting_to_recurring_schedule@1",
  "version": "1.0",
  "env_id": "odoo_scheduling_env@0.1",
  "description": "Convert the 'Team Standup' meeting scheduled for next Monday into a recurring series repeating weekly on Mondays and Thursdays for exactly 10 occurrences. Log in with username 'admin' and password 'admin'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/convert_meeting_to_recurring_schedule/setup_task.sh",
    "post_task": "/workspace/tasks/convert_meeting_to_recurring_schedule/export_result.sh"
  },
  "metadata": {
    "target_event_name": "Team Standup",
    "expected_rrule_type": "weekly",
    "expected_days": [
      "mon",
      "thu"
    ],
    "expected_end_type": "count",
    "expected_count": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_convert_meeting_to_recurring_schedule"
    }
  }
}
