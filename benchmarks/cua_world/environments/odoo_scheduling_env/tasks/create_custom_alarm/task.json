{
  "id": "create_custom_alarm@1",
  "version": "1.0",
  "env_id": "odoo_scheduling_env@0.1",
  "description": "The CFO, Grace Patel, requires specific preparation time for the upcoming 'Q2 Financial Review'. The standard system reminders are not suitable. Configure a custom email reminder for the 'Q2 Financial Review' meeting in the Odoo Calendar to be sent exactly 3 hours before the event.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_custom_alarm/setup_task.sh",
    "post_task": "/workspace/tasks/create_custom_alarm/export_result.sh"
  },
  "metadata": {
    "target_event": "Q2 Financial Review",
    "expected_type": "email",
    "expected_duration": 3,
    "expected_interval": "hours",
    "alternative_duration_minutes": 180
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_custom_alarm"
    }
  }
}
