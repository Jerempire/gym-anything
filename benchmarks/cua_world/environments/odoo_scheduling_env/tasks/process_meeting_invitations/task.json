{
  "id": "process_meeting_invitations@1",
  "version": "1.0",
  "env_id": "odoo_scheduling_env@0.1",
  "description": "You have received two new meeting invitations for next Wednesday. Accept the meeting 'Project Alpha Sync' scheduled for 10:00 AM and decline the meeting 'Vendor Cold Call' scheduled for 11:00 AM.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/process_meeting_invitations/setup_task.sh",
    "post_task": "/workspace/tasks/process_meeting_invitations/export_result.sh"
  },
  "metadata": {
    "event_1_name": "Project Alpha Sync",
    "event_1_action": "accept",
    "event_2_name": "Vendor Cold Call",
    "event_2_action": "decline"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_process_meeting_invitations"
    }
  }
}
