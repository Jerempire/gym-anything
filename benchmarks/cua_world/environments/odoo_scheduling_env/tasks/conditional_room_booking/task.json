{
  "id": "conditional_room_booking@1",
  "version": "1.0",
  "env_id": "odoo_scheduling_env@0.1",
  "description": "Schedule a 1-hour meeting named 'Project Sync' for the Friday of the upcoming week at 2:00 PM (14:00). Use the 'Board Room' if it is available; otherwise, use the 'Engineering Lab'. Log in with username 'admin' and password 'admin'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/conditional_room_booking/setup_task.sh",
    "post_task": "/workspace/tasks/conditional_room_booking/export_result.sh"
  },
  "metadata": {
    "meeting_name": "Project Sync",
    "meeting_hour": 14,
    "meeting_duration": 1.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_conditional_room_booking"
    }
  }
}
