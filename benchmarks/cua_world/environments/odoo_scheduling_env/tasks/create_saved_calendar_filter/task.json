{
  "id": "create_saved_calendar_filter@1",
  "version": "1.0",
  "env_id": "odoo_scheduling_env@0.1",
  "description": "As the Executive Assistant, you need quick access to the CFO's schedule. Create and save a custom filter named 'CFO Schedule' that filters for events attended by 'Grace Patel'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_saved_calendar_filter/setup_task.sh",
    "post_task": "/workspace/tasks/create_saved_calendar_filter/export_result.sh"
  },
  "metadata": {
    "target_filter_name": "CFO Schedule",
    "target_attendee_name": "Grace Patel"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_saved_calendar_filter"
    }
  }
}
