{
  "id": "substitute_meeting_attendee@1",
  "version": "1.0",
  "env_id": "odoo_scheduling_env@0.1",
  "description": "Update the 'Marketing Campaign Review' calendar event scheduled for next Tuesday. Replace attendee 'Carol Martinez' with 'David Chen' and ensure 'Alice Johnson' remains on the attendee list.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/substitute_meeting_attendee/setup_task.sh",
    "post_task": "/workspace/tasks/substitute_meeting_attendee/export_result.sh"
  },
  "metadata": {
    "target_event": "Marketing Campaign Review",
    "attendee_to_remove": "Carol Martinez",
    "attendee_to_add": "David Chen",
    "attendee_to_keep": "Alice Johnson"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_substitute_meeting_attendee"
    }
  }
}
