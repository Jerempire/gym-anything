{
  "id": "update_recurring_event_series@1",
  "version": "1.0",
  "env_id": "odoo_scheduling_env@0.1",
  "description": "The location for the 'Weekly Operations Sync' meeting has changed permanently. Update the location for the entire meeting series (next occurrence Monday at 09:00 AM) to 'Strategy Room'. Log in with username 'admin' and password 'admin' at http://localhost:8069.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_recurring_event_series/setup_task.sh",
    "post_task": "/workspace/tasks/update_recurring_event_series/export_result.sh"
  },
  "metadata": {
    "target_event_name": "Weekly Operations Sync",
    "expected_location": "Strategy Room",
    "original_location": "Room 3A"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_recurring_event_series"
    }
  }
}
