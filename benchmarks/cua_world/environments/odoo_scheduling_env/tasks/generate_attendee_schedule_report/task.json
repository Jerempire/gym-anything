{
  "id": "generate_attendee_schedule_report@1",
  "version": "1.0",
  "env_id": "odoo_scheduling_env@0.1",
  "description": "Generate a report of all Odoo Calendar events where 'Grace Patel' is an attendee. Save the report to /home/ga/Documents/grace_patel_schedule.txt with each event formatted as 'Event Name | YYYY-MM-DD | HH:MM' as displayed in the calendar view.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_attendee_schedule_report/setup_task.sh",
    "post_task": "/workspace/tasks/generate_attendee_schedule_report/export_result.sh"
  },
  "metadata": {
    "target_attendee": "Grace Patel",
    "output_path": "/home/ga/Documents/grace_patel_schedule.txt",
    "expected_format": "Name | Date | Time"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_attendee_schedule_report"
    }
  }
}
