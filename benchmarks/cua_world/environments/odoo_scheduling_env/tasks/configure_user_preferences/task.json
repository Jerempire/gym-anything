{
  "id": "configure_user_preferences@1",
  "version": "1.0",
  "env_id": "odoo_scheduling_env@0.1",
  "description": "As the admin user (credentials: admin/admin), update your personal preferences by setting the Timezone to 'America/Chicago' and the Notification preference to 'Handle by Emails'.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_user_preferences/setup_task.sh",
    "post_task": "/workspace/tasks/configure_user_preferences/export_result.sh"
  },
  "metadata": {
    "target_timezone": "America/Chicago",
    "target_notification_type": "email",
    "admin_login": "admin"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_user_preferences"
    }
  }
}
