{
  "id": "communicate_meeting_update@1",
  "version": "1.0",
  "env_id": "odoo_scheduling_env@0.1",
  "description": "Update the 'Q2 Financial Review' calendar meeting description to include the agenda items: Revenue Analysis, Expense Report, and Forecasting. Notify the attendees with a message stating: \"I've added the agenda items. Please prepare your data.\"",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/communicate_meeting_update/setup_task.sh",
    "post_task": "/workspace/tasks/communicate_meeting_update/export_result.sh"
  },
  "metadata": {
    "target_event": "Q2 Financial Review",
    "required_agenda_items": [
      "Revenue Analysis",
      "Expense Report",
      "Forecasting"
    ],
    "required_message_content": "prepare your data",
    "required_message_type": "comment"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_communicate_meeting_update"
    }
  }
}
