{
  "id": "raster_to_tabular_csv_export@1",
  "version": "1.0",
  "env_id": "snap_env@0.1",
  "description": "Open the Landsat multispectral image located at /home/ga/snap_data/landsat_multispectral.tif in ESA SNAP. Extract a 100x100 pixel spatial subset containing all 4 spectral bands. Save this subset in BEAM-DIMAP format to /home/ga/snap_exports/ml_subset.dim and export the data as a CSV file to /home/ga/snap_exports/ml_dataset.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/raster_to_tabular_csv_export/setup_task.sh",
    "post_task": "/workspace/tasks/raster_to_tabular_csv_export/export_result.sh"
  },
  "metadata": {
    "source_file": "/home/ga/snap_data/landsat_multispectral.tif",
    "expected_dim_file": "/home/ga/snap_exports/ml_subset.dim",
    "expected_csv_file": "/home/ga/snap_exports/ml_dataset.csv",
    "expected_rows": 10000,
    "expected_width": 100,
    "expected_height": 100
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_raster_to_tabular_csv"
    }
  }
}
