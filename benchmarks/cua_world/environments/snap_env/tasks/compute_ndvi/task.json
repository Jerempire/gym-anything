{
  "id": "compute_ndvi@1",
  "version": "1.0",
  "env_id": "snap_env@0.1",
  "description": "Compute the Normalized Difference Vegetation Index (NDVI) for the loaded Landsat multi-spectral GeoTIFF in ESA SNAP Desktop. Use the formula (band_2 - band_3) / (band_2 + band_3), where band_2 is NIR and band_3 is Red. Create a virtual band named 'ndvi' and display the resulting layer.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/compute_ndvi/setup_task.sh"
  },
  "metadata": {
    "data_file": "/home/ga/snap_data/landsat_multispectral.tif",
    "data_source": "Landsat satellite imagery, from github.com/opengeos/data",
    "nir_band": "band_2",
    "red_band": "band_3",
    "ndvi_expression": "(band_2 - band_3) / (band_2 + band_3)",
    "target_band_name": "ndvi"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_compute_ndvi"
    }
  }
}
