{
  "id": "create_rgb_composite@1",
  "version": "1.0",
  "env_id": "snap_env@0.1",
  "description": "In ESA SNAP Desktop, create and display a false-color RGB composite using the loaded Landsat multi-spectral GeoTIFF. Assign the NIR band (band_2) to the Red channel, the Red band (band_3) to the Green channel, and the Green band (band_4) to the Blue channel.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_rgb_composite/setup_task.sh"
  },
  "metadata": {
    "data_file": "/home/ga/snap_data/landsat_multispectral.tif",
    "data_source": "Landsat satellite imagery, from github.com/opengeos/data",
    "expected_bands": 4,
    "band_names": [
      "SWIR1",
      "NIR",
      "Red",
      "Green"
    ],
    "rgb_assignment": {
      "red": "band_2",
      "green": "band_3",
      "blue": "band_4"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_rgb_composite"
    }
  }
}
