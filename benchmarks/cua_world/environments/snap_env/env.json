{
  "id": "snap_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "ESA SNAP (Sentinel Application Platform) environment for satellite remote sensing tasks including opening satellite imagery, creating RGB composites, computing spectral indices, and geospatial data analysis",
  "category": "remote-sensing",
  "tags": [
    "linux",
    "remote-sensing",
    "satellite",
    "geospatial",
    "snap",
    "sentinel",
    "desktop"
  ],
  "licence": "GPL-3.0",
  "authors": [
    "gym-anything team"
  ],
  "upstream_url": "https://step.esa.int/main/toolboxes/snap/",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [
        1920,
        1080
      ],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/snap_env/artifacts",
    "video_fps": 10,
    "video_resolution": [
      1920,
      1080
    ],
    "video_codec": "libx264",
    "video_crf": 23,
    "audio_rate": 44100,
    "audio_channels": 2,
    "audio_codec": "aac"
  },
  "vnc": {
    "enable": false,
    "host_port": 5960,
    "container_port": 5900,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": [
      "ALL"
    ],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true,
    "runtime": "sysbox-runc"
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/snap_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/snap_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/snap_env/data",
      "target": "/workspace/data",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/snap_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/snap_env/utils",
      "target": "/workspace/utils",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_snap.sh",
    "post_start": "/workspace/scripts/setup_snap.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": [
          "sudo",
          "audio",
          "video",
          "input"
        ],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "SNAP_USER": "ga"
        }
      }
    }
  ]
}
