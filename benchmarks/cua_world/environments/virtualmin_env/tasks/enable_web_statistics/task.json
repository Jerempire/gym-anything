{
  "id": "enable_web_statistics@1",
  "version": "1.0",
  "env_id": "virtualmin_env@0.1",
  "description": "Enable web traffic statistics for the 'acmecorp.test' virtual server using Webalizer. Enable the Webalizer reporting feature and manually generate the initial report immediately to process existing log data without waiting for the scheduled cron job.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/enable_web_statistics/setup_task.sh",
    "post_task": "/workspace/tasks/enable_web_statistics/export_result.sh"
  },
  "metadata": {
    "target_domain": "acmecorp.test",
    "feature_name": "webalizer",
    "report_path": "/home/acmecorp/public_html/stats/index.html",
    "expected_string": "Usage Statistics for"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enable_web_statistics"
    }
  }
}
