{
  "id": "terminate_runaway_process@1",
  "version": "1.0",
  "env_id": "virtualmin_env@0.1",
  "description": "A background process named 'stuck_import.py' is consuming excessive CPU resources. Using the Webmin interface, terminate this specific process. Do not terminate the legitimate 'daily_report.py' process that is also running.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/terminate_runaway_process/setup_task.sh",
    "post_task": "/workspace/tasks/terminate_runaway_process/export_result.sh"
  },
  "metadata": {
    "target_process_name": "stuck_import.py",
    "safe_process_name": "daily_report.py"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_terminate_runaway_process"
    }
  }
}
