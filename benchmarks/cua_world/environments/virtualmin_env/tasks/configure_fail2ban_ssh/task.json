{
  "id": "configure_fail2ban_ssh@1",
  "version": "1.0",
  "env_id": "virtualmin_env@0.1",
  "description": "Configure the Fail2Ban intrusion detection system to protect the SSH service. Ensure the Fail2Ban service is running and enabled. Configure the 'sshd' jail with a maximum of 3 retries and a ban time of 7200 seconds.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_fail2ban_ssh/setup_task.sh",
    "post_task": "/workspace/tasks/configure_fail2ban_ssh/export_result.sh"
  },
  "metadata": {
    "expected_max_retry": 3,
    "expected_ban_time": 7200,
    "jail_name": "sshd"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_fail2ban_ssh"
    }
  }
}
