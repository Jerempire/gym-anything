{
  "id": "inspect_with_lens_tool@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Inspect micro-structures in the loaded DICOM image using the Lens (magnifying glass) tool. Capture a screenshot showing the active lens overlay on the image and save it to ~/DICOM/exports/lens_inspection.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/inspect_with_lens_tool/setup_task.sh",
    "post_task": "/workspace/tasks/inspect_with_lens_tool/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/DICOM/exports/lens_inspection.png",
    "min_file_size_kb": 50
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_inspect_with_lens"
    }
  }
}
