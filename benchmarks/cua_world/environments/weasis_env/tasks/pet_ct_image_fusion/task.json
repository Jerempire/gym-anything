{
  "id": "pet_ct_image_fusion@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Fuse the PET series over the corresponding CT series from the dataset at ~/DICOM/pet_ct/. Apply a standard color scale to the PET overlay so metabolic activity is colored while the underlying CT anatomy remains in grayscale. Export a screenshot of the fused view to ~/DICOM/exports/fusion_view.jpg.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/pet_ct_image_fusion/setup_task.sh",
    "post_task": "/workspace/tasks/pet_ct_image_fusion/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_export_path": "/home/ga/DICOM/exports/fusion_view.jpg",
    "data_source_dir": "/home/ga/DICOM/pet_ct",
    "data_type": "Real Clinical PET/CT Dataset",
    "min_export_size_bytes": 20000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_pet_ct_fusion"
    }
  }
}
