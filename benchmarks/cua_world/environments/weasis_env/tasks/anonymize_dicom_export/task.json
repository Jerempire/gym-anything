{
  "id": "anonymize_dicom_export@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Export the loaded synthetic CT study (original files in ~/DICOM/samples/) to ~/DICOM/anonymized/ in DICOM format. Ensure that patient-identifying information, specifically the PatientName and PatientID tags, is anonymized or de-identified while preserving the image data intact.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/anonymize_dicom_export/setup_task.sh",
    "post_task": "/workspace/tasks/anonymize_dicom_export/export_result.sh"
  },
  "metadata": {
    "output_dir": "/home/ga/DICOM/anonymized",
    "original_patient_name": "Test^Patient",
    "original_patient_id": "TEST001",
    "expected_rows": 256,
    "expected_columns": 256
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_anonymize_dicom_export"
    }
  }
}
