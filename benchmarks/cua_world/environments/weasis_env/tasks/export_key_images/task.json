{
  "id": "export_key_images@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Bookmark slice 3 and slice 8 from the loaded CT series. Export only these bookmarked key images as JPEG files to ~/DICOM/exports/key_images/.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 45,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_key_images/setup_task.sh",
    "post_task": "/workspace/tasks/export_key_images/export_result.sh"
  },
  "metadata": {
    "export_directory": "/home/ga/DICOM/exports/key_images",
    "expected_file_count": 2,
    "expected_format": "JPEG",
    "min_file_size_bytes": 10000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_key_images"
    }
  }
}
