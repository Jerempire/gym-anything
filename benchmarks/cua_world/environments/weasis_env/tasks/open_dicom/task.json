{
  "id": "open_dicom@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Open a DICOM file from the samples directory at ~/DICOM/samples in the Weasis DICOM Viewer.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 120,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/open_dicom/setup_task.sh",
    "post_task": "/workspace/tasks/open_dicom/export_result.sh"
  },
  "metadata": {
    "dicom_directory": "/home/ga/DICOM/samples",
    "expected_modality": "CT"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_open_dicom"
    }
  }
}
