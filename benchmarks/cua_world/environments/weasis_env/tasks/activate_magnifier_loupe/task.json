{
  "id": "activate_magnifier_loupe@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "With a medical image loaded in Weasis, activate the Lens (Magnifier) tool. Capture a screenshot of the application showing the active magnifier widget positioned over the image and save it to /home/ga/DICOM/exports/lens_active.png",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 35,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/activate_magnifier_loupe/setup_task.sh",
    "post_task": "/workspace/tasks/activate_magnifier_loupe/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/DICOM/exports/lens_active.png",
    "min_file_size_bytes": 15000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_activate_magnifier"
    }
  }
}
