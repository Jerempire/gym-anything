{
  "id": "inspect_raw_voxels_interpolation@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Inspect the raw voxel data of the CT scan loaded in Weasis by visualizing the raw pixel grid. Set the display interpolation to 'Nearest' (Nearest Neighbor) and zoom in to at least 400% on a structure. Export the resulting view to ~/DICOM/exports/nearest_neighbor.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/inspect_raw_voxels_interpolation/setup_task.sh",
    "post_task": "/workspace/tasks/inspect_raw_voxels_interpolation/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/DICOM/exports/nearest_neighbor.png",
    "min_identical_ratio": 0.25
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_inspect_raw_voxels"
    }
  }
}
