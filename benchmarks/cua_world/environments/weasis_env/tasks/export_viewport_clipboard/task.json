{
  "id": "export_viewport_clipboard@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Load a CT image in Weasis and zoom in on a specific structure to at least 2x magnification. Copy the viewport image to the system clipboard and export the clipboard contents to /home/ga/DICOM/exports/clipboard_dump.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_viewport_clipboard/setup_task.sh",
    "post_task": "/workspace/tasks/export_viewport_clipboard/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/DICOM/exports/clipboard_dump.png",
    "min_size_bytes": 20480,
    "target_dir": "/home/ga/DICOM/exports"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_viewport_clipboard"
    }
  }
}
