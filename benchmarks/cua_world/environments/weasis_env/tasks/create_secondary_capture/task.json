{
  "id": "create_secondary_capture@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Draw an arrow annotation pointing to a distinct anatomical structure on the loaded MR image. Export the current view as a DICOM Secondary Capture file to '~/DICOM/exports/finding_sc.dcm', ensuring the annotation is burned into the exported image pixels.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_secondary_capture/setup_task.sh",
    "post_task": "/workspace/tasks/create_secondary_capture/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/DICOM/exports/finding_sc.dcm",
    "expected_sop_class_prefix": "1.2.840.10008.5.1.4.1.1.7",
    "secondary_capture_name": "Secondary Capture Image Storage"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_secondary_capture"
    }
  }
}
