{
  "id": "configure_split_view@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Change the Weasis viewer layout to a two-panel side-by-side (1 row x 2 columns) layout with DICOM image content displayed in both panels. Save a full screenshot of the configured comparison layout to ~/DICOM/exports/split_view.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_split_view/setup_task.sh",
    "post_task": "/workspace/tasks/configure_split_view/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/DICOM/exports/split_view.png",
    "min_file_size_bytes": 50000,
    "min_width": 800,
    "min_height": 600
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_split_view"
    }
  }
}
