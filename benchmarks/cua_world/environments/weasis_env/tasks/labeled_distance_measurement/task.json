{
  "id": "labeled_distance_measurement@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Measure the central prominent structure on the loaded DICOM image. Label the measurement line exactly 'Aortic Root' and export the annotated view as a PNG to '~/DICOM/exports/labeled_vessel.png'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/labeled_distance_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/labeled_distance_measurement/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/DICOM/exports/labeled_vessel.png",
    "expected_label": "Aortic Root",
    "min_file_size_bytes": 5000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_labeled_distance_measurement"
    }
  }
}
