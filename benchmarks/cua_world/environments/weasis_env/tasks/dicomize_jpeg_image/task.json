{
  "id": "dicomize_jpeg_image@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Convert the clinical photograph at `~/Desktop/endoscopy_capture.jpg` into a DICOM file using the Weasis Dicomizer tool. Assign the patient name `Doe^John`, patient ID `ENDO-5512`, and modality `ES`. Save the resulting DICOM file to `~/DICOM/exports/`.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/dicomize_jpeg_image/setup_task.sh",
    "post_task": "/workspace/tasks/dicomize_jpeg_image/export_result.sh"
  },
  "metadata": {
    "source_image": "/home/ga/Desktop/endoscopy_capture.jpg",
    "export_dir": "/home/ga/DICOM/exports",
    "expected_patient_name": "Doe^John",
    "expected_patient_id": "ENDO-5512",
    "expected_modality": "ES"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_dicomize_jpeg"
    }
  }
}
