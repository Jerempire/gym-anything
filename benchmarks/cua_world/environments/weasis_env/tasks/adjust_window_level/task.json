{
  "id": "adjust_window_level@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Adjust the window center (brightness) and window width (contrast) of the loaded CT scan in Weasis to optimize the visibility of the anatomical structures. Ensure the final window/level values differ from the initial default settings.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 120,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/adjust_window_level/setup_task.sh",
    "post_task": "/workspace/tasks/adjust_window_level/export_result.sh"
  },
  "metadata": {
    "initial_window_center": 40,
    "initial_window_width": 400
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_adjust_window_level"
    }
  }
}
