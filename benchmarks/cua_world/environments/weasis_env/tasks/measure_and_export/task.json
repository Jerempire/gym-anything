{
  "id": "measure_and_export@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Use the distance measurement tool in Weasis to draw a measurement across a visible structure on the loaded DICOM image. Export the annotated view as a JPEG file to /home/ga/DICOM/exports/annotated_measurement.jpg.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/measure_and_export/setup_task.sh",
    "post_task": "/workspace/tasks/measure_and_export/export_result.sh"
  },
  "metadata": {
    "export_path": "/home/ga/DICOM/exports/annotated_measurement.jpg",
    "min_file_size_bytes": 10240,
    "expected_format": "jpeg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_measure_and_export"
    }
  }
}
