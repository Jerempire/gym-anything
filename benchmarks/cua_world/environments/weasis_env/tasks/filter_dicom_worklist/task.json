{
  "id": "filter_dicom_worklist@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Import the DICOM directory at ~/DICOM/trauma_transfer/ into Weasis. Locate the study for Patient ID 'TRAUMA-007' and save a full viewer screenshot to ~/DICOM/exports/target_patient.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/filter_dicom_worklist/setup_task.sh",
    "post_task": "/workspace/tasks/filter_dicom_worklist/export_result.sh"
  },
  "metadata": {
    "target_patient_id": "TRAUMA-007",
    "input_directory": "/home/ga/DICOM/trauma_transfer",
    "expected_output_path": "/home/ga/DICOM/exports/target_patient.png",
    "expected_visual_pattern": "geometric cross"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_filter_dicom_worklist"
    }
  }
}
