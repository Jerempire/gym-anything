{
  "id": "export_series_to_video_presentation@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Export the currently loaded multi-slice CT series as a video file for a presentation. Save the export to ~/DICOM/exports/anatomy_scroll.avi with a frame rate of 10-15 fps.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_series_to_video_presentation/setup_task.sh",
    "post_task": "/workspace/tasks/export_series_to_video_presentation/export_result.sh"
  },
  "metadata": {
    "expected_filenames": [
      "anatomy_scroll.avi",
      "anatomy_scroll.mp4"
    ],
    "export_directory": "/home/ga/DICOM/exports",
    "min_size_bytes": 10240
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_video_export"
    }
  }
}
