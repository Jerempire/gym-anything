{
  "id": "inspect_calculus_magnifier@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Activate the Magnifier (Lens) tool in Weasis and position it over the brightest central structure in the loaded CT image to locally magnify it. Capture a screenshot showing the active magnifying glass overlay and save it to ~/DICOM/exports/lens_view.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/inspect_calculus_magnifier/setup_task.sh",
    "post_task": "/workspace/tasks/inspect_calculus_magnifier/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/DICOM/exports/lens_view.png",
    "min_file_size_bytes": 10000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_inspect_calculus_magnifier"
    }
  }
}
