{
  "id": "cine_navigate_keyslice@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Navigate to slice 3 of the loaded synthetic CT series in Weasis. Create a text file at ~/DICOM/exports/slice_info.txt containing the following content:\nSlice: 3\nTotal: 5\nFile: CT_slice_003.dcm\nExport slice 3 as a PNG image to ~/DICOM/exports/key_slice.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/cine_navigate_keyslice/setup_task.sh",
    "post_task": "/workspace/tasks/cine_navigate_keyslice/export_result.sh"
  },
  "metadata": {
    "expected_png": "/home/ga/DICOM/exports/key_slice.png",
    "expected_txt": "/home/ga/DICOM/exports/slice_info.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_cine_navigate"
    }
  }
}
