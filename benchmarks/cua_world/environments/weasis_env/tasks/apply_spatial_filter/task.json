{
  "id": "apply_spatial_filter@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Apply a sharpening spatial filter to the loaded DICOM CT image in Weasis. Export the filtered view as a TIFF file to ~/DICOM/exports/sharpened_ct.tiff and create a text file at ~/DICOM/exports/filter_applied.txt containing the word 'sharpen'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/apply_spatial_filter/setup_task.sh",
    "post_task": "/workspace/tasks/apply_spatial_filter/export_result.sh"
  },
  "metadata": {
    "expected_export_path": "/home/ga/DICOM/exports/sharpened_ct.tiff",
    "expected_note_path": "/home/ga/DICOM/exports/filter_applied.txt",
    "filter_keyword": "sharpen"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_apply_spatial_filter"
    }
  }
}
