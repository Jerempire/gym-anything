{
  "id": "apply_digital_collimation@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Apply a Rectangular Shutter to the loaded DICOM image to mask out the outer edges, leaving only the central anatomy visible. Export the masked view as a JPEG file to '~/DICOM/exports/collimated_view.jpg'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/apply_digital_collimation/setup_task.sh",
    "post_task": "/workspace/tasks/apply_digital_collimation/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/DICOM/exports/collimated_view.jpg",
    "max_edge_variance": 50,
    "min_center_variance": 500
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_digital_collimation"
    }
  }
}
