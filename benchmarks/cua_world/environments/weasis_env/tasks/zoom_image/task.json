{
  "id": "zoom_image@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Zoom in on the loaded DICOM image in Weasis to examine details more closely. Magnify the image by at least 2x from its initial size.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 90,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/zoom_image/setup_task.sh",
    "post_task": "/workspace/tasks/zoom_image/export_result.sh"
  },
  "metadata": {
    "initial_zoom": 1.0,
    "target_zoom": 2.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_zoom_image"
    }
  }
}
