{
  "id": "export_clean_and_annotated_views@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Draw a line measurement on the loaded CT image. Export two JPEG versions of this view to ~/DICOM/exports/: one named 'annotated.jpg' showing the measurement, and one named 'clean.jpg' with the measurement hidden.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_clean_and_annotated_views/setup_task.sh",
    "post_task": "/workspace/tasks/export_clean_and_annotated_views/export_result.sh"
  },
  "metadata": {
    "export_dir": "/home/ga/DICOM/exports",
    "annotated_filename": "annotated.jpg",
    "clean_filename": "clean.jpg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_clean_and_annotated_views"
    }
  }
}
