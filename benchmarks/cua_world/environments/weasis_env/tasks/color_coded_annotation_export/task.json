{
  "id": "color_coded_annotation_export@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Annotate the bright, distinct lesion in the lower right center of the DICOM image. Encircle the lesion and add a label reading 'URGENT'. Both the annotation and the label must be RED. Export the viewer display with these annotations as a JPEG to ~/DICOM/exports/urgent_finding.jpg.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/color_coded_annotation_export/setup_task.sh",
    "post_task": "/workspace/tasks/color_coded_annotation_export/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/DICOM/exports/urgent_finding.jpg",
    "expected_text": "URGENT",
    "expected_color": "RED",
    "min_file_size": 5000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_color_coded_annotation"
    }
  }
}
