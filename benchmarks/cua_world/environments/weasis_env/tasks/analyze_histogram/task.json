{
  "id": "analyze_histogram@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Read the pixel intensity statistics for the currently loaded DICOM image. Create a report file at ~/DICOM/exports/histogram_report.txt containing the min, max, and mean values in the following format:\nmin: <value>\nmax: <value>\nmean: <value>",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/analyze_histogram/setup_task.sh",
    "post_task": "/workspace/tasks/analyze_histogram/export_result.sh"
  },
  "metadata": {
    "expected_output_file": "/home/ga/DICOM/exports/histogram_report.txt",
    "min_tolerance_hu": 50,
    "max_tolerance_hu": 50,
    "mean_tolerance_hu": 100,
    "ground_truth_location": "/tmp/ground_truth/pixel_stats.json"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_analyze_histogram"
    }
  }
}
