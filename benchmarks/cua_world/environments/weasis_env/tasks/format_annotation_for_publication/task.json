{
  "id": "format_annotation_for_publication@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Create a red arrow annotation with a line thickness of at least 3 on the loaded medical image. Export the resulting view as a PNG to ~/DICOM/exports/publication_figure.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/format_annotation_for_publication/setup_task.sh",
    "post_task": "/workspace/tasks/format_annotation_for_publication/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/DICOM/exports/publication_figure.png",
    "expected_color": "Red",
    "min_thickness": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_format_annotation"
    }
  }
}
