{
  "id": "dicomize_clinical_photo@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Import the clinical photograph from `~/Desktop/clinical_photo.jpg` into Weasis and convert it to a compliant DICOM file. Assign the metadata Patient Name 'Smith^John', Patient ID 'DERM001', and Modality 'XC'. Export the resulting DICOM file to `~/DICOM/exports/`.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/dicomize_clinical_photo/setup_task.sh",
    "post_task": "/workspace/tasks/dicomize_clinical_photo/export_result.sh"
  },
  "metadata": {
    "expected_patient_name": "Smith^John",
    "expected_patient_id": "DERM001",
    "expected_modality": "XC",
    "source_image": "/home/ga/Desktop/clinical_photo.jpg",
    "export_dir": "/home/ga/DICOM/exports"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_dicomize_clinical_photo"
    }
  }
}
