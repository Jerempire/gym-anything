{
  "id": "apply_color_lut@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Apply the 'Hot Iron' pseudo-color Look-Up Table (LUT) to the loaded DICOM image in Weasis. Export the resulting colorized view as a PNG image to ~/DICOM/exports/colorized_ct.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/apply_color_lut/setup_task.sh",
    "post_task": "/workspace/tasks/apply_color_lut/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/DICOM/exports/colorized_ct.png",
    "expected_lut": "Hot Iron",
    "min_file_size_bytes": 1024
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_apply_color_lut"
    }
  }
}
