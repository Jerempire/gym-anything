{
  "id": "activate_mpr_export@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Activate Multiplanar Reconstruction (MPR) mode for the loaded volumetric CT series in Weasis. Export the coronal reconstruction view to '~/DICOM/exports/mpr_coronal.png' and the sagittal reconstruction view to '~/DICOM/exports/mpr_sagittal.png'.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/activate_mpr_export/setup_task.sh",
    "post_task": "/workspace/tasks/activate_mpr_export/export_result.sh",
    "pre_task_timeout": 300
  },
  "metadata": {
    "expected_coronal_path": "/home/ga/DICOM/exports/mpr_coronal.png",
    "expected_sagittal_path": "/home/ga/DICOM/exports/mpr_sagittal.png",
    "min_file_size_bytes": 5000,
    "min_dimensions": 100
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_activate_mpr_export"
    }
  }
}
