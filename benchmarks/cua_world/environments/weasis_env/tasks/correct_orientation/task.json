{
  "id": "correct_orientation@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "The loaded DICOM image has an incorrect orientation. Correct the orientation by applying a 90-degree clockwise rotation and a horizontal flip. Export the resulting view as a PNG to ~/DICOM/exports/corrected_orientation.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 45,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/correct_orientation/setup_task.sh",
    "post_task": "/workspace/tasks/correct_orientation/export_result.sh"
  },
  "metadata": {
    "expected_export_path": "/home/ga/DICOM/exports/corrected_orientation.png",
    "expected_format": "PNG",
    "min_file_size_kb": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_correct_orientation"
    }
  }
}
