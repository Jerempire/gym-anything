{
  "id": "tile_series_layout@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Configure the Weasis display layout to a tiled grid (at least 2x2) to view multiple slices of the loaded DICOM series simultaneously. Save a screenshot of the viewer showing at least 4 slices to ~/DICOM/exports/grid_layout.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/tile_series_layout/setup_task.sh",
    "post_task": "/workspace/tasks/tile_series_layout/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/DICOM/exports/grid_layout.png",
    "min_file_size_bytes": 10240,
    "min_width": 800,
    "min_height": 600
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_tile_series_layout"
    }
  }
}
