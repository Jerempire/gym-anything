{
  "id": "export_cropped_roi_figure@1",
  "version": "1.0",
  "env_id": "weasis_env@0.1",
  "description": "Zoom into an off-center quadrant of the loaded DICOM image to at least 300% magnification and center the feature in the view. Export the visible cropped sub-region as a JPEG to ~/DICOM/exports/figure_roi.jpg.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_cropped_roi_figure/setup_task.sh",
    "post_task": "/workspace/tasks/export_cropped_roi_figure/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/DICOM/exports/figure_roi.jpg",
    "expected_format": "JPEG",
    "synthetic_image_size": 1024
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_cropped_roi"
    }
  }
}
