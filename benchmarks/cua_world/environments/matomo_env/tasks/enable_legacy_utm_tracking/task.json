{
  "id": "enable_legacy_utm_tracking@1",
  "version": "1.0",
  "env_id": "matomo_env@0.1",
  "description": "You are migrating a site from GA4 to Matomo. Configure Matomo to recognize standard Google Analytics UTM parameters alongside the default Matomo parameters in config/config.ini.php. Ensure the system tracks both sets of parameters for the following categories:\n- Campaign Name: pk_campaign and utm_campaign\n- Campaign Keyword: pk_kwd and utm_term\n- Campaign Source: pk_source and utm_source\n- Campaign Medium: pk_medium and utm_medium\n- Campaign Content: pk_content and utm_content\n- Campaign ID: pk_id and utm_id",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/enable_legacy_utm_tracking/setup_task.sh",
    "post_task": "/workspace/tasks/enable_legacy_utm_tracking/export_result.sh"
  },
  "metadata": {
    "config_path": "/var/www/html/config/config.ini.php",
    "required_params": {
      "campaign_var_name": [
        "pk_campaign",
        "utm_campaign"
      ],
      "campaign_keyword_var_name": [
        "pk_kwd",
        "utm_term"
      ],
      "campaign_source_var_name": [
        "pk_source",
        "utm_source"
      ],
      "campaign_medium_var_name": [
        "pk_medium",
        "utm_medium"
      ],
      "campaign_content_var_name": [
        "pk_content",
        "utm_content"
      ],
      "campaign_id_var_name": [
        "pk_id",
        "utm_id"
      ]
    },
    "scoring_weights": {
      "campaign_name": 15,
      "campaign_source": 15,
      "campaign_medium": 15,
      "campaign_keyword": 15,
      "campaign_content": 15,
      "campaign_id": 10,
      "defaults_preserved": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enable_legacy_utm_tracking"
    }
  }
}
