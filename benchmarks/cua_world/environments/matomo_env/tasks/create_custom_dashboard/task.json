{
  "id": "create_custom_dashboard@1",
  "version": "1.0",
  "env_id": "matomo_env@0.1",
  "description": "You are logged in as the 'admin' user. The default dashboard contains too much information, and the marketing team needs a focused view for their weekly meetings. Create a new dashboard named 'Weekly Marketing Review' and add the following widgets: Visits Overview (from Visits Summary), Referrer Type (from Referrers/Acquisition), and Device Type (from Devices). Ensure the new dashboard is the one currently displayed.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_custom_dashboard/setup_task.sh",
    "post_task": "/workspace/tasks/create_custom_dashboard/export_result.sh"
  },
  "metadata": {
    "expected_dashboard_name": "Weekly Marketing Review",
    "required_widgets": [
      {
        "name": "Visits Overview",
        "module_patterns": [
          "VisitsSummary",
          "VisitOverview"
        ]
      },
      {
        "name": "Referrer Type",
        "module_patterns": [
          "Referrers",
          "ReferrerType",
          "ChannelType"
        ]
      },
      {
        "name": "Device Type",
        "module_patterns": [
          "DevicesDetection",
          "DeviceType",
          "Devices"
        ]
      }
    ],
    "scoring_weights": {
      "dashboard_created": 20,
      "name_correct": 20,
      "widgets_correct": 45,
      "visible_at_end": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_custom_dashboard"
    }
  },
  "tags": [
    "matomo",
    "dashboard",
    "analytics",
    "ui-configuration"
  ]
}
