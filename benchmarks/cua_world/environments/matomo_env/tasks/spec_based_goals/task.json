{
  "id": "spec_based_goals@1",
  "version": "1.0",
  "env_id": "matomo_env@0.1",
  "description": "The SportsFit Shop e-commerce team has prepared a conversion tracking specification document at /workspace/tasks/spec_based_goals/funnel_spec.txt. Implement all conversion goals for the 'SportsFit Shop' website in Matomo as defined in the specification. Login credentials: admin / Admin12345",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/spec_based_goals/setup_task.sh",
    "post_task": "/workspace/tasks/spec_based_goals/export_result.sh"
  },
  "metadata": {
    "target_site": "SportsFit Shop",
    "goals": {
      "product_page_view": {
        "name": "Product Page View",
        "pattern_type": "contains",
        "pattern": "/products/",
        "match_attribute": "url"
      },
      "add_to_cart": {
        "name": "Add to Cart",
        "pattern_type": "contains",
        "pattern": "/cart/add",
        "match_attribute": "url"
      },
      "checkout_started": {
        "name": "Checkout Started",
        "pattern_type": "contains",
        "pattern": "/checkout",
        "match_attribute": "url"
      },
      "purchase_confirmation": {
        "name": "Purchase Confirmation",
        "pattern_type": "exact",
        "pattern": "/order/thank-you",
        "match_attribute": "url"
      }
    },
    "scoring_weights": {
      "product_page_view": 22,
      "add_to_cart": 22,
      "checkout_started": 22,
      "purchase_confirmation": 22,
      "all_created_during_task": 12
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_spec_based_goals"
    }
  }
}
