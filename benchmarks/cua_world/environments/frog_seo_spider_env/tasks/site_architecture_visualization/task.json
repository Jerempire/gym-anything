{
  "id": "site_architecture_visualization@1",
  "version": "1.0",
  "env_id": "frog_seo_spider_env@0.1",
  "description": "Create a Force-Directed Crawl Diagram for the e-commerce sandbox site 'https://books.toscrape.com/'. Limit the crawl to 200 URLs and export the resulting visualization as an HTML file named 'site_graph.html' to '/home/ga/Documents/SEO/exports/'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/site_architecture_visualization/setup_task.sh",
    "post_task": "/workspace/tasks/site_architecture_visualization/export_result.sh"
  },
  "metadata": {
    "target_url": "https://books.toscrape.com/",
    "expected_output_path": "/home/ga/Documents/SEO/exports/site_graph.html",
    "min_file_size_bytes": 1024,
    "crawl_limit": 200
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_site_architecture_visualization"
    }
  }
}
