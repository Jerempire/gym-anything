{
  "id": "x_robots_tag_audit@1",
  "version": "1.0",
  "env_id": "frog_seo_spider_env@0.1",
  "description": "Crawl https://crawler-test.com/ using Screaming Frog SEO Spider to identify pages that use the 'X-Robots-Tag' HTTP header (such as noindex or nofollow directives). Export the directives data for these pages to a CSV file named 'x_robots_header_report.csv' in the '~/Documents/SEO/exports/' directory.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/x_robots_tag_audit/setup_task.sh",
    "post_task": "/workspace/tasks/x_robots_tag_audit/export_result.sh"
  },
  "metadata": {
    "target_url": "https://crawler-test.com/",
    "expected_filename": "x_robots_header_report.csv",
    "export_dir": "/home/ga/Documents/SEO/exports",
    "required_column_fragment": "X-Robots-Tag",
    "expected_url_part": "/headers/x_robots_tag_"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_x_robots_tag_audit"
    }
  }
}
