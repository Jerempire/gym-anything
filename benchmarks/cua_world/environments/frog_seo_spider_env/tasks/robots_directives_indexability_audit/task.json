{
  "id": "robots_directives_indexability_audit@1",
  "version": "1.0",
  "env_id": "frog_seo_spider_env@0.1",
  "description": "Perform an indexability audit on https://crawler-test.com/ using Screaming Frog SEO Spider. Export the Directives data to a CSV file in ~/Documents/SEO/exports/. Create a text report at ~/Documents/SEO/reports/indexability_report.txt that includes the total URL count, a breakdown of non-indexable URLs by reason (such as noindex or canonicalised), and at least 5 specific examples of non-indexable URLs found.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/robots_directives_indexability_audit/setup_task.sh",
    "post_task": "/workspace/tasks/robots_directives_indexability_audit/export_result.sh"
  },
  "metadata": {
    "target_url": "https://crawler-test.com/",
    "target_domain": "crawler-test.com",
    "report_path": "~/Documents/SEO/reports/indexability_report.txt",
    "export_dir": "~/Documents/SEO/exports/",
    "required_columns": [
      "Meta Robots",
      "X-Robots-Tag",
      "Canonical Link Element",
      "Indexability"
    ],
    "required_report_terms": [
      "noindex",
      "canonical",
      "indexable",
      "blocked"
    ],
    "min_urls_crawled": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_robots_directives_indexability_audit"
    }
  }
}
