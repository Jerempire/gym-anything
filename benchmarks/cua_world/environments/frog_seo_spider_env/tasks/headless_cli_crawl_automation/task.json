{
  "id": "headless_cli_crawl_automation@1",
  "version": "1.0",
  "env_id": "frog_seo_spider_env@0.1",
  "description": "Perform a headless crawl of https://quotes.toscrape.com/ using the Screaming Frog SEO Spider CLI (screamingfrogseospider). Export the 'Internal:All' report to ~/Documents/SEO/cli_results/.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/headless_cli_crawl_automation/setup_task.sh",
    "post_task": "/workspace/tasks/headless_cli_crawl_automation/export_result.sh"
  },
  "metadata": {
    "target_url": "https://quotes.toscrape.com/",
    "target_domain": "quotes.toscrape.com",
    "output_dir": "/home/ga/Documents/SEO/cli_results",
    "expected_min_rows": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_headless_cli_crawl"
    }
  }
}
