{
  "id": "cookie_inventory_audit@1",
  "version": "1.0",
  "env_id": "frog_seo_spider_env@0.1",
  "description": "Configure Screaming Frog SEO Spider to store cookies and crawl https://crawler-test.com/. Export the cookie inventory to ~/Documents/SEO/exports/cookie_inventory.csv. Additionally, create a summary text file at ~/Documents/SEO/reports/cookie_summary.txt listing the total number of cookies found and the name of at least one specific cookie.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/cookie_inventory_audit/setup_task.sh",
    "post_task": "/workspace/tasks/cookie_inventory_audit/export_result.sh"
  },
  "metadata": {
    "target_url": "https://crawler-test.com/",
    "export_path": "/home/ga/Documents/SEO/exports/cookie_inventory.csv",
    "report_path": "/home/ga/Documents/SEO/reports/cookie_summary.txt",
    "expected_csv_headers": [
      "Address",
      "Cookie Name",
      "Cookie Value",
      "Domain"
    ],
    "min_expected_cookies": 1
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_cookie_inventory_audit"
    }
  }
}
