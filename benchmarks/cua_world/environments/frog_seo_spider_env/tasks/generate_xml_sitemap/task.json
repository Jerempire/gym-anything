{
  "id": "generate_xml_sitemap@1",
  "version": "1.0",
  "env_id": "frog_seo_spider_env@0.1",
  "description": "Crawl https://books.toscrape.com/ using Screaming Frog SEO Spider to generate an XML sitemap. The sitemap must include only HTML pages and be saved to ~/Documents/SEO/sitemaps/sitemap.xml. Additionally, create a text summary at ~/Documents/SEO/reports/sitemap_summary.txt containing the domain name, total URL count, and today's date.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_xml_sitemap/setup_task.sh",
    "post_task": "/workspace/tasks/generate_xml_sitemap/export_result.sh"
  },
  "metadata": {
    "target_url": "https://books.toscrape.com/",
    "target_domain": "books.toscrape.com",
    "sitemap_path": "/home/ga/Documents/SEO/sitemaps/sitemap.xml",
    "report_path": "/home/ga/Documents/SEO/reports/sitemap_summary.txt",
    "expected_min_urls": 20,
    "sitemap_namespace": "http://www.sitemaps.org/schemas/sitemap/0.9"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_xml_sitemap"
    }
  }
}
