{
  "id": "non_html_document_audit@1",
  "version": "1.0",
  "env_id": "frog_seo_spider_env@0.1",
  "description": "Conduct a non-HTML content audit to identify PDF assets on https://crawler-test.com/. Export a list of all identified PDF URLs to /home/ga/Documents/SEO/exports/pdf_inventory.csv. Create a summary report at /home/ga/Documents/SEO/reports/pdf_audit_summary.txt that includes the total count of PDF files found and a list of their filenames.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/non_html_document_audit/setup_task.sh",
    "post_task": "/workspace/tasks/non_html_document_audit/export_result.sh"
  },
  "metadata": {
    "target_url": "https://crawler-test.com/",
    "target_domain": "crawler-test.com",
    "expected_extension": ".pdf",
    "expected_content_type": "application/pdf",
    "csv_path": "/home/ga/Documents/SEO/exports/pdf_inventory.csv",
    "report_path": "/home/ga/Documents/SEO/reports/pdf_audit_summary.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_non_html_document_audit"
    }
  }
}
