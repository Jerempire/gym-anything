{
  "id": "list_mode_health_check@1",
  "version": "1.0",
  "env_id": "frog_seo_spider_env@0.1",
  "description": "Perform a targeted health check on the 20 landing pages listed in ~/Documents/SEO/landing_pages.txt using Screaming Frog in List Mode. Export the internal results as a CSV to ~/Documents/SEO/exports/ and create a summary report of any issues found (such as missing titles or status codes) at ~/Documents/SEO/reports/landing_page_health.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/list_mode_health_check/setup_task.sh",
    "post_task": "/workspace/tasks/list_mode_health_check/export_result.sh"
  },
  "metadata": {
    "url_list_path": "/home/ga/Documents/SEO/landing_pages.txt",
    "export_dir": "/home/ga/Documents/SEO/exports",
    "report_path": "/home/ga/Documents/SEO/reports/landing_page_health.txt",
    "target_domain": "books.toscrape.com",
    "expected_url_count": 20,
    "min_row_count": 15,
    "max_row_count": 50
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_list_mode_health_check"
    }
  }
}
