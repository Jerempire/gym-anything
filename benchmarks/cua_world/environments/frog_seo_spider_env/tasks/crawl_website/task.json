{
  "id": "crawl_website@1",
  "version": "1.0",
  "env_id": "frog_seo_spider_env@0.1",
  "description": "Use Screaming Frog SEO Spider to crawl https://crawler-test.com/ until at least 10 URLs are discovered.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/crawl_website/setup_task.sh",
    "post_task": "/workspace/tasks/crawl_website/export_result.sh"
  },
  "metadata": {
    "target_url": "https://crawler-test.com/",
    "expected_min_urls": 10,
    "expected_pages": [
      "links",
      "content",
      "mobile",
      "javascript"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_crawl_website"
    }
  }
}
