{
  "id": "technical_head_tags_audit@1",
  "version": "1.0",
  "env_id": "frog_seo_spider_env@0.1",
  "description": "Perform a technical audit of critical <head> tags for https://books.toscrape.com/ by extracting the Viewport content, Favicon href, and Charset/Content-Type. After crawling at least 20 URLs, export the custom extraction results to ~/Documents/SEO/exports/head_tags_audit.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/technical_head_tags_audit/setup_task.sh",
    "post_task": "/workspace/tasks/technical_head_tags_audit/export_result.sh"
  },
  "metadata": {
    "target_url": "https://books.toscrape.com/",
    "expected_filename": "head_tags_audit.csv",
    "min_rows": 20,
    "expected_viewport_snippet": "width=device-width",
    "expected_favicon_snippet": "icon",
    "expected_charset_snippet": "utf"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_technical_head_tags_audit"
    }
  }
}
