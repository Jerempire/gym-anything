{
  "id": "directory_tree_visualization_export@1",
  "version": "1.0",
  "env_id": "frog_seo_spider_env@0.1",
  "description": "Crawl https://books.toscrape.com/ and generate a visual site architecture map using a Directory Tree Graph. Export the resulting visualization as a PNG image to /home/ga/Documents/SEO/reports/site_tree.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/directory_tree_visualization_export/setup_task.sh",
    "post_task": "/workspace/tasks/directory_tree_visualization_export/export_result.sh"
  },
  "metadata": {
    "target_url": "https://books.toscrape.com/",
    "expected_output_path": "/home/ga/Documents/SEO/reports/site_tree.png",
    "min_file_size_kb": 5,
    "expected_text_in_image": [
      "catalogue",
      "books",
      "toscrape"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_directory_tree_export"
    }
  }
}
