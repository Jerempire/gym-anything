{
  "id": "edge_kiosk_policy_config@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "Configure Microsoft Edge enterprise policies for a public government kiosk according to the specifications in /home/ga/Desktop/kiosk_requirements.txt. Ensure the policies are active in the managed policies directory (/etc/microsoft-edge/policies/managed/) and document the applied settings in a deployment confirmation report at /home/ga/Desktop/kiosk_deploy_report.txt.",
  "difficulty": "hard",
  "tags": [
    "edge",
    "policy",
    "sysadmin",
    "kiosk",
    "configuration",
    "linux"
  ],
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/edge_kiosk_policy_config/setup_task.sh",
    "post_task": "/workspace/tasks/edge_kiosk_policy_config/export_result.sh"
  },
  "metadata": {
    "requirements_path": "/home/ga/Desktop/kiosk_requirements.txt",
    "report_path": "/home/ga/Desktop/kiosk_deploy_report.txt",
    "policy_dir": "/etc/microsoft-edge/policies/managed",
    "expected_policies": {
      "HomepageLocation": "https://www.usa.gov/benefits",
      "NewTabPageLocation": "https://www.ssa.gov",
      "DownloadRestrictions": 3,
      "DeveloperToolsAvailability": 2,
      "InPrivateModeAvailability": 1,
      "PasswordManagerEnabled": false,
      "BookmarkBarEnabled": true,
      "BrowserSignin": 0
    },
    "required_blocked_domains": [
      "facebook.com",
      "twitter.com",
      "youtube.com",
      "tiktok.com",
      "instagram.com",
      "reddit.com"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_edge_kiosk_policy"
    }
  }
}
