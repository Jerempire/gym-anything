{
  "id": "configure_site_permissions@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "Configure site-specific content permissions in Microsoft Edge for a shared computer lab. Based on the requirements at /home/ga/Desktop/lab_permission_requirements.txt, block notifications for youtube.com and facebook.com, allow notifications for teams.microsoft.com, allow camera access for zoom.us, and allow location access for maps.google.com. Create a summary report listing the changes made at /home/ga/Desktop/permission_config_report.txt.",
  "difficulty": "medium",
  "tags": [
    "edge",
    "settings",
    "privacy",
    "permissions",
    "configuration",
    "admin"
  ],
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_site_permissions/setup_task.sh",
    "post_task": "/workspace/tasks/configure_site_permissions/export_result.sh"
  },
  "metadata": {
    "requirements_file": "/home/ga/Desktop/lab_permission_requirements.txt",
    "report_file": "/home/ga/Desktop/permission_config_report.txt",
    "expected_configs": [
      {
        "domain": "youtube.com",
        "type": "notifications",
        "setting": 2,
        "setting_name": "Block"
      },
      {
        "domain": "facebook.com",
        "type": "notifications",
        "setting": 2,
        "setting_name": "Block"
      },
      {
        "domain": "teams.microsoft.com",
        "type": "notifications",
        "setting": 1,
        "setting_name": "Allow"
      },
      {
        "domain": "zoom.us",
        "type": "media_stream_camera",
        "setting": 1,
        "setting_name": "Allow"
      },
      {
        "domain": "maps.google.com",
        "type": "geolocation",
        "setting": 1,
        "setting_name": "Allow"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_site_permissions"
    }
  }
}
