{
  "id": "corporate_browser_deployment@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "You are an IT systems administrator at Meridian Financial Services. A deployment specification document is located at /home/ga/Desktop/deployment_spec.txt. Deploy the corporate Edge browser standard on this new analyst workstation by reading the specification and applying every configuration directive using the Edge browser GUI. When finished, export the favorites bar to /home/ga/Documents/browser_config_export.html and create a deployment verification log at /home/ga/Desktop/deployment_log.txt documenting each change made and its final value.",
  "difficulty": "very_hard",
  "tags": [
    "edge",
    "browser",
    "configuration",
    "bookmarks",
    "settings",
    "privacy",
    "search-engine",
    "it-admin",
    "long-horizon",
    "compliance"
  ],
  "init": {
    "timeout_sec": 1500,
    "max_steps": 350,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/corporate_browser_deployment/setup_task.sh",
    "post_task": "/workspace/tasks/corporate_browser_deployment/export_result.sh"
  },
  "metadata": {
    "deployment_spec_path": "/home/ga/Desktop/deployment_spec.txt",
    "export_path": "/home/ga/Documents/browser_config_export.html",
    "deployment_log_path": "/home/ga/Desktop/deployment_log.txt",
    "required_folders": [
      {
        "name": "Market Data",
        "bookmarks": [
          {"title": "Markets", "url": "https://finance.yahoo.com"},
          {"title": "Terminal", "url": "https://www.bloomberg.com"},
          {"title": "Wire", "url": "https://www.reuters.com"}
        ]
      },
      {
        "name": "Regulatory",
        "bookmarks": [
          {"title": "SEC EDGAR", "url": "https://www.sec.gov"},
          {"title": "FINRA", "url": "https://www.finra.org"}
        ]
      },
      {
        "name": "Internal Tools",
        "bookmarks": [
          {"title": "Code Repos", "url": "https://github.com"},
          {"title": "Wiki", "url": "https://confluence.atlassian.net"}
        ]
      }
    ],
    "required_settings": {
      "startup_pages": ["https://finance.yahoo.com", "https://github.com"],
      "home_button_url": "https://intranet.meridianfs.com",
      "tracking_prevention": "Strict",
      "password_saving_disabled": true,
      "address_autofill_disabled": true,
      "do_not_track_enabled": true,
      "default_search_engine": "DuckDuckGo",
      "download_directory": "/home/ga/Documents/Downloads"
    },
    "occupation_context": "IT Systems Administrator - corporate browser provisioning for new employee workstation"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_corporate_browser_deployment"
    }
  }
}
