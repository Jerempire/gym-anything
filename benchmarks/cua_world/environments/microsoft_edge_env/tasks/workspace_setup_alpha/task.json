{
  "id": "workspace_setup_alpha@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "Configure Microsoft Edge for a new developer workstation. Create a folder named 'Dev Tools' on the Favorites Bar containing three bookmarks: 'Repo' (https://github.com), 'Help' (https://stackoverflow.com), and 'Build' (https://www.jenkins.io). Set the browser to open https://github.com on startup and export the favorites to /home/ga/Documents/initial_setup.html.",
  "difficulty": "medium",
  "tags": [
    "edge",
    "browser",
    "configuration",
    "bookmarks",
    "productivity"
  ],
  "init": {
    "timeout_sec": 480,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/workspace_setup_alpha/setup_task.sh",
    "post_task": "/workspace/tasks/workspace_setup_alpha/export_result.sh"
  },
  "metadata": {
    "target_folder_name": "Dev Tools",
    "required_bookmarks": [
      {
        "url": "github.com",
        "title": "Repo"
      },
      {
        "url": "stackoverflow.com",
        "title": "Help"
      },
      {
        "url": "jenkins.io",
        "title": "Build"
      }
    ],
    "startup_url": "https://github.com",
    "export_path": "/home/ga/Documents/initial_setup.html"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_workspace_setup"
    }
  }
}
