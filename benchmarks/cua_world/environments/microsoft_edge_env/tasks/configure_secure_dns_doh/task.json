{
  "id": "configure_secure_dns_doh@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "Configure Microsoft Edge to use DNS-over-HTTPS (DoH) with Cloudflare (1.1.1.1) for enhanced privacy. Verify the configuration by visiting https://1.1.1.1/help. Save a screenshot of the help page showing the active DoH status to /home/ga/Desktop/doh_verification.png and create a text file at /home/ga/Desktop/doh_status.txt containing the text 'DoH Active: Yes'.",
  "difficulty": "medium",
  "tags": [
    "edge",
    "privacy",
    "security",
    "dns",
    "settings",
    "network"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_secure_dns_doh/setup_task.sh",
    "post_task": "/workspace/tasks/configure_secure_dns_doh/export_result.sh"
  },
  "metadata": {
    "expected_screenshot": "/home/ga/Desktop/doh_verification.png",
    "expected_text_file": "/home/ga/Desktop/doh_status.txt",
    "target_doh_provider": "cloudflare",
    "target_doh_template": "https://chrome.cloudflare-dns.com/dns-query",
    "verification_url": "https://1.1.1.1/help"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_secure_dns_doh"
    }
  }
}
