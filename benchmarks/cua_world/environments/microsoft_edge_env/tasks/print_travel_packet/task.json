{
  "id": "print_travel_packet@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "Navigate to the Wikipedia pages for 'Schengen Area', 'Jet lag', and 'Travel document'. Save each page as a PDF to /home/ga/Documents/TravelPacket/ using the filenames 'schengen_area.pdf', 'jet_lag.pdf', and 'travel_documents.pdf' respectively.",
  "difficulty": "medium",
  "tags": [
    "edge",
    "print",
    "pdf",
    "navigation",
    "wikipedia",
    "file-management"
  ],
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/print_travel_packet/setup_task.sh",
    "post_task": "/workspace/tasks/print_travel_packet/export_result.sh"
  },
  "metadata": {
    "output_dir": "/home/ga/Documents/TravelPacket",
    "targets": [
      {
        "url": "https://en.wikipedia.org/wiki/Schengen_Area",
        "filename": "schengen_area.pdf",
        "keywords": [
          "Schengen",
          "border",
          "visa"
        ]
      },
      {
        "url": "https://en.wikipedia.org/wiki/Jet_lag",
        "filename": "jet_lag.pdf",
        "keywords": [
          "jet lag",
          "circadian",
          "sleep"
        ]
      },
      {
        "url": "https://en.wikipedia.org/wiki/Travel_document",
        "filename": "travel_documents.pdf",
        "keywords": [
          "passport",
          "visa",
          "identity"
        ]
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_print_travel_packet"
    }
  }
}
