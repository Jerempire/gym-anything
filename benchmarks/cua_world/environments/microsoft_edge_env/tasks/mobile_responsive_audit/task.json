{
  "id": "mobile_responsive_audit@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "Perform a mobile responsive design audit for the Department of Energy website (https://www.energy.gov/). Capture a full-size screenshot of the entire page using iPhone 12 Pro emulation. Save the resulting image to /home/ga/Desktop/energy_mobile_audit.png.",
  "difficulty": "medium",
  "tags": [
    "edge",
    "devtools",
    "mobile",
    "responsive",
    "screenshot",
    "audit"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/mobile_responsive_audit/setup_task.sh",
    "post_task": "/workspace/tasks/mobile_responsive_audit/export_result.sh"
  },
  "metadata": {
    "target_url": "https://www.energy.gov/",
    "output_path": "/home/ga/Desktop/energy_mobile_audit.png",
    "expected_device": "iPhone 12 Pro",
    "expected_widths": [
      390,
      780,
      1170
    ],
    "min_height": 1500,
    "width_tolerance": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mobile_responsive_audit"
    }
  }
}
