{
  "id": "print_stylesheet_compliance_audit@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "Navigate to the Wikipedia article for 'Turing machine' (https://en.wikipedia.org/wiki/Turing_machine). Generate a PDF of the page to verify that the print stylesheet correctly hides sidebar navigation while preserving the main article text. The PDF must be produced without headers, footers, or background graphics. Save the output to /home/ga/Desktop/turing_print_audit.pdf.",
  "difficulty": "medium",
  "tags": [
    "edge",
    "print",
    "pdf",
    "css-audit",
    "qa"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/print_stylesheet_compliance_audit/setup_task.sh",
    "post_task": "/workspace/tasks/print_stylesheet_compliance_audit/export_result.sh"
  },
  "metadata": {
    "target_url": "https://en.wikipedia.org/wiki/Turing_machine",
    "output_path": "/home/ga/Desktop/turing_print_audit.pdf",
    "required_content": [
      "Turing machine",
      "mathematical model of computation"
    ],
    "forbidden_content": [
      "Donate to Wikipedia",
      "Current events",
      "Random article",
      "Upload file"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_print_stylesheet_compliance_audit"
    }
  }
}
