{
  "id": "w9_form_completion@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "Download and complete the official IRS Form W-9 for Acme Industrial Supply LLC (Business Name: Acme Supply). Use the following details: Tax Classification: C Corporation; Address: 4500 Auto Mall Dr, Kersey, PA 15846; EIN: 12-3456789. Save the completed PDF to /home/ga/Documents/Acme_W9_Filled.pdf.",
  "difficulty": "medium",
  "tags": [
    "edge",
    "pdf",
    "form-filling",
    "administrative",
    "irs",
    "download"
  ],
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/w9_form_completion/setup_task.sh",
    "post_task": "/workspace/tasks/w9_form_completion/export_result.sh"
  },
  "metadata": {
    "target_file": "/home/ga/Documents/Acme_W9_Filled.pdf",
    "expected_values": {
      "name": "Acme Industrial Supply LLC",
      "business_name": "Acme Supply",
      "address": "4500 Auto Mall Dr",
      "city_state_zip": "Kersey, PA 15846",
      "ein": "12-3456789",
      "tax_classification": "C Corporation"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_w9_form_completion"
    }
  }
}
