{
  "id": "configure_auto_translation@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "Configure Microsoft Edge to automatically translate Spanish pages to English without prompting. Navigate to the Spanish Wikipedia article 'Transporte en España' (https://es.wikipedia.org/wiki/Transporte_en_España) and print the translated English version of the page to /home/ga/Desktop/spain_transport_report.pdf.",
  "difficulty": "medium",
  "tags": [
    "edge",
    "settings",
    "translation",
    "automation",
    "pdf",
    "productivity"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_auto_translation/setup_task.sh",
    "post_task": "/workspace/tasks/configure_auto_translation/export_result.sh"
  },
  "metadata": {
    "target_url": "https://es.wikipedia.org/wiki/Transporte_en_España",
    "output_path": "/home/ga/Desktop/spain_transport_report.pdf",
    "required_language_code": "es",
    "expected_preference_key": "translate_whitelists",
    "min_pdf_size_kb": 50
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_auto_translation"
    }
  }
}
