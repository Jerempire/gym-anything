{
  "id": "pwa_workspace_provisioning@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "Configure a productivity workspace by installing Photopea (https://www.photopea.com), Excalidraw (https://excalidraw.com), and DevDocs (https://devdocs.io) as Progressive Web Apps (PWAs) using Microsoft Edge. Name the apps 'Photopea', 'Excalidraw', and 'DevDocs' respectively and ensure they are accessible as standalone apps in the system menu.",
  "difficulty": "medium",
  "tags": [
    "edge",
    "pwa",
    "install",
    "configuration",
    "workspace"
  ],
  "init": {
    "timeout_sec": 420,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/pwa_workspace_provisioning/setup_task.sh",
    "post_task": "/workspace/tasks/pwa_workspace_provisioning/export_result.sh"
  },
  "metadata": {
    "targets": [
      {
        "name": "Photopea",
        "url_fragment": "photopea.com",
        "clean_name": "Photopea"
      },
      {
        "name": "Excalidraw",
        "url_fragment": "excalidraw.com",
        "clean_name": "Excalidraw"
      },
      {
        "name": "DevDocs",
        "url_fragment": "devdocs.io",
        "clean_name": "DevDocs"
      }
    ],
    "desktop_entry_path": "/home/ga/.local/share/applications"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_pwa_provisioning"
    }
  }
}
