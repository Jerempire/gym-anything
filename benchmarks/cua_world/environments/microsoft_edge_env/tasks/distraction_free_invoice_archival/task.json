{
  "id": "distraction_free_invoice_archival@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "A vendor invoice is available at file:///workspace/assets/vendor_invoice.html. The page is cluttered with a promotional banner ('FLASH SALE'), a floating chat widget, and a cookie consent footer. Save a clean PDF of this invoice to ~/Documents/Invoices/invoice_8492_clean.pdf. The final document must contain the invoice details (Invoice #8492) but must not show the promotional banner, chat button, or cookie text.",
  "difficulty": "medium",
  "tags": [
    "edge",
    "devtools",
    "dom-manipulation",
    "printing",
    "pdf",
    "admin"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/distraction_free_invoice_archival/setup_task.sh",
    "post_task": "/workspace/tasks/distraction_free_invoice_archival/export_result.sh"
  },
  "metadata": {
    "invoice_url": "file:///workspace/assets/vendor_invoice.html",
    "expected_pdf_path": "/home/ga/Documents/Invoices/invoice_8492_clean.pdf",
    "required_text": [
      "Invoice #8492",
      "Total:",
      "1,240.50"
    ],
    "forbidden_text": [
      "FLASH SALE",
      "Chat with Agent",
      "We use cookies"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_distraction_free_invoice_archival"
    }
  }
}
