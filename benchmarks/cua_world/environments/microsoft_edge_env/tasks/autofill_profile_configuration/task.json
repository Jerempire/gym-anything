{
  "id": "autofill_profile_configuration@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "Configure Microsoft Edge to automatically fill forms using the business identity details provided in /home/ga/Desktop/identity_details.txt. Ensure the profile is accurate and complete.",
  "difficulty": "medium",
  "tags": [
    "edge",
    "settings",
    "autofill",
    "productivity",
    "configuration"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/autofill_profile_configuration/setup_task.sh",
    "post_task": "/workspace/tasks/autofill_profile_configuration/export_result.sh"
  },
  "metadata": {
    "identity_file": "/home/ga/Desktop/identity_details.txt",
    "expected_profile": {
      "first_name": "Jordan",
      "last_name": "Rivera",
      "company": "Apex Logistics Solutions",
      "address": "4500 Harbour Pointe Blvd",
      "city": "Mukilteo",
      "state": "WA",
      "zip": "98275",
      "phone": "425-555-0199",
      "email": "j.rivera@apexlogistics.test"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_autofill_profile"
    }
  }
}
