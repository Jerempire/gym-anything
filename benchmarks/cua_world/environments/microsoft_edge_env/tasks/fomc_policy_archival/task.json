{
  "id": "fomc_policy_archival@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "Retrieve documentation from the most recent past FOMC meeting via the Federal Reserve Board's website (federalreserve.gov). Save the 'Statement' PDF as 'statement.pdf' and the 'Implementation Note' PDF as 'implementation_note.pdf' to the directory '/home/ga/Documents/FOMC_Policy/'. Within that directory, record the first full paragraph of the Statement text in 'summary_text.txt' and the meeting date in 'metadata.txt'.",
  "difficulty": "medium",
  "tags": [
    "edge",
    "finance",
    "research",
    "download",
    "pdf",
    "file-management"
  ],
  "init": {
    "timeout_sec": 480,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/fomc_policy_archival/setup_task.sh",
    "post_task": "/workspace/tasks/fomc_policy_archival/export_result.sh"
  },
  "metadata": {
    "target_dir": "/home/ga/Documents/FOMC_Policy",
    "required_files": [
      "statement.pdf",
      "implementation_note.pdf",
      "metadata.txt",
      "summary_text.txt"
    ],
    "domain_keywords": [
      "federalreserve.gov",
      "monetarypolicy"
    ],
    "content_keywords": [
      "inflation",
      "Committee",
      "target range",
      "employment",
      "federal funds rate"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_fomc_archival"
    }
  }
}
