{
  "id": "granular_cookie_clearing@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "A user is reporting login loops on GitHub and Stack Overflow, but they have an active session on Google that must NOT be lost. Troubleshoot this by clearing the cookies and site data specifically for 'github.com' and 'stackoverflow.com' while strictly preserving all data for 'google.com'.",
  "difficulty": "medium",
  "tags": [
    "edge",
    "troubleshooting",
    "cookies",
    "privacy",
    "settings"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/granular_cookie_clearing/setup_task.sh",
    "post_task": "/workspace/tasks/granular_cookie_clearing/export_result.sh"
  },
  "metadata": {
    "target_removal": [
      "github.com",
      "stackoverflow.com"
    ],
    "target_preserve": [
      "google.com"
    ],
    "cookie_db_path": "Network/Cookies"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_granular_cookie_clearing"
    }
  }
}
