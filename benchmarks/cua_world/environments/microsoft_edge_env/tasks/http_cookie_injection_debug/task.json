{
  "id": "http_cookie_injection_debug@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "You are a QA engineer debugging a feature flag issue. In Microsoft Edge, set two cookies for the domain 'httpbin.org': 'debug_session_id' with value '8849-alpha-test' and 'ui_variant' with value 'dark_v2' (Secure and HttpOnly). Save the raw JSON response from 'https://httpbin.org/cookies' to '/home/ga/Desktop/cookie_verification.json' to verify the server received the cookies.",
  "difficulty": "medium",
  "tags": [
    "edge",
    "devtools",
    "cookies",
    "qa",
    "web-development"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/http_cookie_injection_debug/setup_task.sh",
    "post_task": "/workspace/tasks/http_cookie_injection_debug/export_result.sh"
  },
  "metadata": {
    "target_domain": "httpbin.org",
    "output_file": "/home/ga/Desktop/cookie_verification.json",
    "cookies": [
      {
        "name": "debug_session_id",
        "value": "8849-alpha-test"
      },
      {
        "name": "ui_variant",
        "value": "dark_v2",
        "secure": true,
        "httponly": true
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_http_cookie_injection_debug"
    }
  }
}
