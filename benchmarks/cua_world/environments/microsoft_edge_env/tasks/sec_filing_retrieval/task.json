{
  "id": "sec_filing_retrieval@1",
  "version": "1.0",
  "env_id": "microsoft_edge_env@0.1",
  "description": "Retrieve the 2024 Annual Report (Form 10-K) for Ford Motor Company (Ticker: F) from the SEC EDGAR database (sec.gov) and save the official filing (PDF or HTML) to /home/ga/Documents/. Extract 'Total Revenues' and 'Net Income attributable to Ford Motor Company' for the year 2024 from the Consolidated Statement of Operations and record these values in /home/ga/Documents/key_financials.txt.",
  "difficulty": "hard",
  "tags": [
    "edge",
    "research",
    "finance",
    "data-extraction",
    "government",
    "pdf"
  ],
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sec_filing_retrieval/setup_task.sh",
    "post_task": "/workspace/tasks/sec_filing_retrieval/export_result.sh"
  },
  "metadata": {
    "target_ticker": "F",
    "target_company": "Ford Motor Company",
    "filing_type": "10-K",
    "filing_year": "2024",
    "expected_revenue_pattern": "184,?992",
    "expected_net_income_pattern": "5,?879",
    "download_dir": "/home/ga/Documents",
    "output_file": "/home/ga/Documents/key_financials.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_sec_filing_retrieval"
    }
  }
}
