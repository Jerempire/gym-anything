{
  "id": "openice_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "OpenICE (Open-source Integrated Clinical Environment) - Medical device interoperability platform for connecting and monitoring medical devices with clinical applications",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/openice_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/openice_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/openice_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/openice_env/assets", "target": "/workspace/assets", "mode": "rw"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_openice.sh",
    "post_start": "/workspace/scripts/setup_openice.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ],
  "observation": [
    {
      "type": "rgb_screen",
      "resolution": [1920, 1080],
      "fps": 10,
      "inline": true
    }
  ],
  "action": [
    {"type": "mouse", "events": ["move", "click", "drag", "scroll"]},
    {"type": "keyboard", "events": ["press", "release", "type"]}
  ],
  "recording": {
    "enable": true,
    "output_dir": "./artifacts",
    "video_fps": 10,
    "video_resolution": [1920, 1080]
  },
  "vnc": {
    "enable": true,
    "password": "password"
  },
  "diagnostics": true
}
