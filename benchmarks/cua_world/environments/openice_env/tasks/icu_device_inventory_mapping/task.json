{
  "id": "icu_device_inventory_mapping@1",
  "version": "1.0",
  "env_id": "openice_env@0.1",
  "description": "Commission three simulated medical devices for a new ICU ward and generate a technical inventory manifest. Assign a Multiparameter Monitor to Bed 101, a Pulse Oximeter to Bed 102, and an Infusion Pump to Bed 103. Create a CSV inventory file at /home/ga/Desktop/icu_inventory.csv with the header 'Bed_ID,Device_Type,Device_UDI' mapping each bed to its assigned device type and its 36-character Unique Device Identifier (UDI).",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/icu_device_inventory_mapping/setup_task.sh",
    "post_task": "/workspace/tasks/icu_device_inventory_mapping/export_result.sh"
  },
  "metadata": {
    "output_file": "/home/ga/Desktop/icu_inventory.csv",
    "required_devices": [
      {
        "bed": "101",
        "type": "Multiparameter Monitor",
        "type_keywords": [
          "Multiparameter",
          "MultiParam"
        ]
      },
      {
        "bed": "102",
        "type": "Pulse Oximeter",
        "type_keywords": [
          "Pulse",
          "Oximeter",
          "SpO2"
        ]
      },
      {
        "bed": "103",
        "type": "Infusion Pump",
        "type_keywords": [
          "Infusion",
          "Pump"
        ]
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_icu_inventory"
    }
  }
}
