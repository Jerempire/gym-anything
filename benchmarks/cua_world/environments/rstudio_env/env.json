{
  "id": "rstudio_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "RStudio Desktop environment for statistical computing and data analysis with R",
  "category": ["data_science", "statistics", "ide"],
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse",
      "events": ["move", "click", "drag", "scroll"]
    },
    {
      "type": "keyboard",
      "events": ["press", "release", "type"]
    }
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "mounts": [
    {"source": "benchmarks/cua_world/environments/rstudio_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/rstudio_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/rstudio_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/rstudio_env/utils", "target": "/workspace/utils", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/rstudio_env/assets", "target": "/workspace/assets", "mode": "rw"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_rstudio.sh",
    "post_start": "/workspace/scripts/setup_rstudio.sh"
  },
  "security": {
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "runtime": "sysbox-runc"
  },
  "recording": {
    "enable": true,
    "output_dir": "./artifacts",
    "video_fps": 10,
    "video_resolution": [1920, 1080]
  },
  "vnc": {
    "enable": true,
    "host_port": 5901,
    "password": "password"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {
          "DISPLAY": ":1",
          "R_LIBS_USER": "/home/ga/R/library"
        }
      }
    }
  ]
}
