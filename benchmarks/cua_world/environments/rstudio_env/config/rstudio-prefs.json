{
    "auto_save_on_idle": "commit",
    "initial_working_directory": "~/RProjects",
    "save_workspace": "never",
    "load_workspace": false,
    "always_save_history": true,
    "remove_history_duplicates": true,
    "show_line_numbers": true,
    "highlight_selected_line": true,
    "show_margin": true,
    "margin_column": 80,
    "soft_wrap_r_files": false,
    "syntax_color_console": true,
    "show_invisibles": false,
    "editor_keybindings": "default",
    "font_size_points": 12,
    "tab_size": 2,
    "insert_spaces": true,
    "auto_append_newline": true,
    "strip_trailing_whitespace": true,
    "check_for_updates": false,
    "submit_crash_reports": false,
    "send_usage_stats": false,
    "default_encoding": "UTF-8",
    "default_project_location": "~/RProjects",
    "restore_source_documents": true,
    "restore_source_document_cursor_position": true,
    "help_font_size_points": 12,
    "show_diagnostics_r": true,
    "show_diagnostics_other": true,
    "style_diagnostics": true,
    "background_diagnostics_delay_ms": 2000,
    "diagnostics_on_save": true,
    "warn_if_no_such_variable_in_scope": true,
    "warn_variable_defined_but_not_used": true,
    "auto_discover_package_dependencies": true,
    "num_spaces_for_tab": 2,
    "insert_matching": true,
    "insert_native_pipe_operator": true,
    "reindent_on_paste": true,
    "scroll_past_end_of_document": true,
    "highlight_r_function_calls": true,
    "show_help_tooltip_on_idle": true,
    "enable_snippets": true,
    "tab_completion_delay": 200,
    "console_double_click_select": true,
    "ansi_console_mode": "on"
}
