{
  "id": "cable_ampacity_check@1",
  "version": "1.0",
  "env_id": "electrical_calculations_env@0.1",
  "description": "Determine the maximum current carrying capacity (Ampacity) of a 25 mm² Copper cable with PVC insulation (3 loaded cores/Three Phase) installed in Free Air or a Perforated Tray (Method E/F) at 30°C. Save the numeric ampacity value to /sdcard/ampacity_result.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/cable_ampacity_check/setup_task.sh",
    "post_task": "sh /sdcard/tasks/cable_ampacity_check/export_result.sh"
  },
  "metadata": {
    "expected_min": 70.0,
    "expected_max": 100.0,
    "target_value": 89.0,
    "output_file": "/sdcard/ampacity_result.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_cable_ampacity"
    }
  }
}
