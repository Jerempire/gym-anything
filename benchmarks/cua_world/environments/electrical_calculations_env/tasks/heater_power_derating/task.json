{
  "id": "heater_power_derating@1",
  "version": "1.0",
  "env_id": "example.electrical_calculations_env@0.1",
  "description": "Calculate the reduced power output of a heating element rated for 5000 W at 240 V when it is operated at 208 V using the Electrical Engineering Calculations app. Save the final power value in Watts to /sdcard/Download/derated_power.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/heater_power_derating/setup_task.sh",
    "post_task": "/sdcard/tasks/heater_power_derating/export_result.sh"
  },
  "metadata": {
    "rated_voltage": 240,
    "rated_power": 5000,
    "operating_voltage": 208,
    "expected_resistance": 11.52,
    "expected_power": 3755.56,
    "tolerance_watts": 5,
    "output_file": "/sdcard/Download/derated_power.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_heater_power_derating"
    }
  }
}
