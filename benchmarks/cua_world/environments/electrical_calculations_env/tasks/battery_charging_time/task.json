{
  "id": "battery_charging_time@1",
  "version": "1.0",
  "env_id": "example.electrical_calculations_env@0.1",
  "description": "Calculate the estimated charging time for a 200 Ah battery using a 25 A charger (Lead Acid / 85% efficiency) using the Electrical Engineering Calculations app. Save the numerical result in hours to /sdcard/tasks/charge_time_result.txt and a screenshot of the result screen to /sdcard/tasks/charge_time_screenshot.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/battery_charging_time/setup_task.sh",
    "post_task": "/sdcard/tasks/battery_charging_time/export_result.sh"
  },
  "metadata": {
    "capacity_ah": 200,
    "current_a": 25,
    "min_expected_hours": 7.5,
    "max_expected_hours": 11.5,
    "expected_result_file": "/sdcard/tasks/charge_time_result.txt",
    "expected_screenshot_file": "/sdcard/tasks/charge_time_screenshot.png"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_battery_charging_time"
    }
  }
}
