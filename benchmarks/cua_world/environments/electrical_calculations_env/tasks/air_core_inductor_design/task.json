{
  "id": "air_core_inductor_design@1",
  "version": "1.0",
  "env_id": "example.electrical_calculations_env@0.1",
  "description": "Design an air-core inductor using the Electrical Engineering Calculations app with a diameter of 40 mm, a length of 50 mm, and 35 turns. Save the calculated inductance value in µH to /sdcard/inductor_result.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/air_core_inductor_design/setup_task.sh",
    "post_task": "/sdcard/tasks/air_core_inductor_design/export_result.sh"
  },
  "metadata": {
    "diameter_mm": 40,
    "length_mm": 50,
    "turns": 35,
    "expected_inductance_uh": 28.3,
    "tolerance_uh": 4.5,
    "output_file": "/sdcard/inductor_result.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_air_core_inductor"
    }
  }
}
