{
  "id": "wire_dc_resistance@1",
  "version": "1.0",
  "env_id": "example.electrical_calculations_env@0.1",
  "description": "Use the Electrical Engineering Calculations app to calculate the DC resistance of a copper wire with a length of 200 meters and a cross-sectional area of 1.5 mm². Save a screenshot of the calculation result to /sdcard/task_result.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/wire_dc_resistance/setup_task.sh",
    "post_task": "sh /sdcard/tasks/wire_dc_resistance/export_result.sh"
  },
  "metadata": {
    "expected_result_ohms": 2.293,
    "tolerance_ohms": 0.15,
    "inputs": {
      "material": "Copper",
      "length": "200",
      "area": "1.5"
    },
    "expected_screenshot_path": "/sdcard/task_result.png"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_wire_dc_resistance"
    }
  }
}
