{
  "id": "rms_to_peak_voltage@1",
  "version": "1.0",
  "env_id": "example.electrical_calculations_env@0.1",
  "description": "Convert an RMS voltage of 120 Volts to its Peak Voltage using the Electrical Engineering Calculations app. Save a screenshot of the result screen to /sdcard/tasks/rms_to_peak_result.png and write the resulting Peak Voltage value (number only) to /sdcard/tasks/peak_voltage.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/rms_to_peak_voltage/setup_task.sh",
    "post_task": "/sdcard/tasks/rms_to_peak_voltage/export_result.sh"
  },
  "metadata": {
    "input_rms": 120,
    "expected_peak": 169.7,
    "tolerance": 1.5,
    "output_text_file": "/sdcard/tasks/peak_voltage.txt",
    "output_screenshot": "/sdcard/tasks/rms_to_peak_result.png"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rms_to_peak_voltage"
    }
  }
}
