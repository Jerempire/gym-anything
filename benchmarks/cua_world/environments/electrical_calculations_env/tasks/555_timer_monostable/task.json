    "pre_task": "sh /sdcard/tasks/555_timer_monostable/setup_task.sh",
    "post_task": "sh /sdcard/tasks/555_timer_monostable/export_result.sh"
  },
  "metadata": {
    "expected_value": 51.7,
    "tolerance_tight": 1.0,
    "tolerance_loose": 2.0,
    "result_file_path": "/sdcard/tasks/555_timer_monostable/result.txt",
    "inputs": {
      "R": "470 kOhm",
      "C": "100 uF",
