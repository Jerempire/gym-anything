{
  "id": "restore_trashed_cases@1",
  "version": "1.0",
  "env_id": "juris_m_env@0.1",
  "description": "Three important U.S. Supreme Court cases ('Brown v. Board of Education', 'Miranda v. Arizona', and 'Gideon v. Wainwright') were accidentally moved to the Trash. Restore these items to your library without deleting them permanently.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/restore_trashed_cases/setup_task.sh",
    "post_task": "/workspace/tasks/restore_trashed_cases/export_result.sh"
  },
  "metadata": {
    "target_cases": [
      "Brown v. Board of Education",
      "Miranda v. Arizona",
      "Gideon v. Wainwright"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_restore_trashed_cases"
    }
  }
}
