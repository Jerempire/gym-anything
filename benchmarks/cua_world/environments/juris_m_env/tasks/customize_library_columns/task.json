{
  "id": "customize_library_columns@1",
  "version": "1.0",
  "env_id": "juris_m_env@0.1",
  "description": "Customize the Juris-M library list view to display the 'Date Added' and 'Item Type' columns alongside the existing Title, Creator, and Date columns.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/customize_library_columns/setup_task.sh",
    "post_task": "/workspace/tasks/customize_library_columns/export_result.sh"
  },
  "metadata": {
    "target_columns": [
      "zotero-items-column-dateAdded",
      "zotero-items-column-itemType"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_customize_library_columns"
    }
  }
}
