{
  "id": "add_book_creators@1",
  "version": "1.0",
  "env_id": "juris_m_env@0.1",
  "description": "In the Jurism library, add William Blackstone as an Author and St. George Tucker as an Editor to the book reference titled 'Commentaries on the Laws of England' (1803).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_book_creators/setup_task.sh",
    "post_task": "/workspace/tasks/add_book_creators/export_result.sh"
  },
  "metadata": {
    "target_title": "Commentaries on the Laws of England",
    "target_year": "1803",
    "creators": [
      {
        "firstName": "William",
        "lastName": "Blackstone",
        "role": "author"
      },
      {
        "firstName": "St. George",
        "lastName": "Tucker",
        "role": "editor"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_book_creators"
    }
  }
}
