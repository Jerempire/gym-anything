{
  "id": "add_map_reference@1",
  "version": "1.0",
  "env_id": "juris_m_env@0.1",
  "description": "Create a new bibliographic reference for a USGS topographic map in your Juris-M library using the following details:\n\nItem Type: Map\nTitle: Washington West, DC-MD-VA\nCreator: U.S. Geological Survey (Role: Cartographer)\nDate: 2016\nScale: 1:24000\nSeries Title: 7.5 Minute Series\nPublisher: U.S. Geological Survey\nPlace: Reston, VA",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_map_reference/setup_task.sh",
    "post_task": "/workspace/tasks/add_map_reference/export_result.sh"
  },
  "metadata": {
    "target_item_type": "map",
    "expected_fields": {
      "title": "Washington West, DC-MD-VA",
      "date": "2016",
      "scale": "1:24000",
      "seriesTitle": "7.5 Minute Series",
      "publisher": "U.S. Geological Survey",
      "place": "Reston, VA"
    },
    "expected_creator": {
      "name": "U.S. Geological Survey",
      "role": "cartographer"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_map_reference"
    }
  }
}
