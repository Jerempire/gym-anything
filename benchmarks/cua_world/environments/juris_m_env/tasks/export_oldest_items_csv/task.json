{
  "id": "export_oldest_items_csv@1",
  "version": "1.0",
  "env_id": "juris_m_env@0.1",
  "description": "Export the three oldest historical precedents from the Jurism library to /home/ga/Documents/oldest_precedents.csv in CSV format.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_oldest_items_csv/setup_task.sh",
    "post_task": "/workspace/tasks/export_oldest_items_csv/export_result.sh"
  },
  "metadata": {
    "expected_filename": "oldest_precedents.csv",
    "expected_path": "/home/ga/Documents/oldest_precedents.csv",
    "required_items": [
      "Marbury",
      "Path of the Law",
      "Brown"
    ],
    "forbidden_items": [
      "Obergefell",
      "Tinker",
      "Miranda"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_oldest_items_csv"
    }
  }
}
