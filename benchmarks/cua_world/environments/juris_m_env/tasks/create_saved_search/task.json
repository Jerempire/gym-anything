{
  "id": "create_saved_search@1",
  "version": "1.0",
  "env_id": "juris_m_env@0.1",
  "description": "Create a Saved Search in Juris-M named \"Post-1960 SCOTUS Decisions\" for cases from the \"United States Supreme Court\" decided after 1960. Your library has been pre-populated with various legal authorities.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_saved_search/setup_task.sh",
    "post_task": "/workspace/tasks/create_saved_search/export_result.sh"
  },
  "metadata": {
    "expected_name_keywords": [
      "Post-1960",
      "SCOTUS",
      "Supreme Court",
      "1960"
    ],
    "expected_min_year": 1960,
    "expected_court_keywords": [
      "Supreme",
      "SCOTUS",
      "U.S.",
      "US"
    ],
    "required_conditions": [
      "date",
      "court"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_saved_search"
    }
  }
}
