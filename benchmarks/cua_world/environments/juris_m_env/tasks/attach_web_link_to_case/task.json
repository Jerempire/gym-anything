{
  "id": "attach_web_link_to_case@1",
  "version": "1.0",
  "env_id": "juris_m_env@0.1",
  "description": "Attach a web link to the 'Gideon v. Wainwright' case in your library. The link should point to the Oyez transcript (https://www.oyez.org/cases/1962/155) and be titled 'Oyez Transcript'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/attach_web_link_to_case/setup_task.sh",
    "post_task": "/workspace/tasks/attach_web_link_to_case/export_result.sh"
  },
  "metadata": {
    "target_case": "Gideon v. Wainwright",
    "expected_url": "https://www.oyez.org/cases/1962/155",
    "expected_title": "Oyez Transcript",
    "link_mode": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_attach_web_link"
    }
  }
}
