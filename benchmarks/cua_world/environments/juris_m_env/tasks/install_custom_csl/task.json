{
  "id": "install_custom_csl@1",
  "version": "1.0",
  "env_id": "juris_m_env@0.1",
  "description": "Install the custom citation style 'firm-standard-2025.csl' from /home/ga/Documents/ into Juris-M. Ensure the style 'Firm Standard 2025' is correctly installed and available in the application.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/install_custom_csl/setup_task.sh",
    "post_task": "/workspace/tasks/install_custom_csl/export_result.sh"
  },
  "metadata": {
    "style_id": "http://www.zotero.org/styles/firm-standard-2025",
    "style_filename": "firm-standard-2025.csl",
    "style_title": "Firm Standard 2025",
    "source_path": "/home/ga/Documents/firm-standard-2025.csl"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_install_custom_csl"
    }
  }
}
