{
  "id": "curate_warren_court_collection@1",
  "version": "1.0",
  "env_id": "juris_m_env@0.1",
  "description": "Create a collection named 'Warren Court' in your Juris-M library containing all U.S. Supreme Court cases from your library decided between 1953 and 1969 (inclusive). Do not include cases from other eras or journal articles.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/curate_warren_court_collection/setup_task.sh",
    "post_task": "/workspace/tasks/curate_warren_court_collection/export_result.sh"
  },
  "metadata": {
    "target_collection_name": "Warren Court",
    "start_year": 1953,
    "end_year": 1969,
    "expected_cases": [
      "Brown v. Board of Education",
      "Gideon v. Wainwright",
      "New York Times Co. v. Sullivan",
      "Miranda v. Arizona",
      "Tinker v. Des Moines Independent Community School District"
    ],
    "excluded_cases": [
      "Marbury v. Madison",
      "Obergefell v. Hodges"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_curate_warren_court_collection"
    }
  }
}
