{
  "id": "change_citation_style@1",
  "version": "1.0",
  "env_id": "juris_m_env@0.1",
  "description": "Set the active Quick Copy citation style in Juris-M to OSCOLA (Oxford Standard for Citation of Legal Authorities). OSCOLA is already installed.",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/change_citation_style/setup_task.sh",
    "post_task": "/workspace/tasks/change_citation_style/export_result.sh"
  },
  "metadata": {
    "target_style": "oscola",
    "style_title": "OSCOLA"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_change_citation_style"
    }
  }
}
