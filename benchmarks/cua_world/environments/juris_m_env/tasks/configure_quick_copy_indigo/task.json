{
  "id": "configure_quick_copy_indigo@1",
  "version": "1.0",
  "env_id": "juris_m_env@0.1",
  "description": "Configure Jurism's Quick Copy settings to use the 'JM Indigo (Law Review)' citation style (or 'Bluebook Law Review' if Indigo is unavailable). Generate a citation for the case 'Brown v. Board of Education' using the Quick Copy feature and save it to /home/ga/Documents/brown_citation.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_quick_copy_indigo/setup_task.sh",
    "post_task": "/workspace/tasks/configure_quick_copy_indigo/export_result.sh"
  },
  "metadata": {
    "output_file": "/home/ga/Documents/brown_citation.txt",
    "case_name": "Brown v. Board of Education",
    "expected_reporter": "347 U.S. 483",
    "expected_year": "(1954)",
    "apa_pattern": "\\(1954\\).+Brown",
    "bluebook_pattern": "Brown.+347\\s+U\\.?\\s*S\\.?\\s*483.+\\(1954\\)"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_quick_copy_indigo"
    }
  }
}
