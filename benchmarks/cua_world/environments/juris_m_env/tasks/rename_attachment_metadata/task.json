{
  "id": "rename_attachment_metadata@1",
  "version": "1.0",
  "env_id": "juris_m_env@0.1",
  "description": "A scanned PDF for the case 'Marbury v. Madison' was imported with the generic name 'scan_generic.pdf'. Rename this attachment based on the case's citation info (Case Name and Year) so that the final filename includes 'Marbury' and '1803'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rename_attachment_metadata/setup_task.sh",
    "post_task": "/workspace/tasks/rename_attachment_metadata/export_result.sh"
  },
  "metadata": {
    "parent_case_name": "Marbury v. Madison",
    "initial_filename": "scan_generic.pdf",
    "expected_name_part_1": "Marbury",
    "expected_name_part_2": "1803"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rename_attachment"
    }
  }
}
