{
  "id": "send_portal_message@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Send a portal message to Jayson Fadel (DOB: 1992-06-30) using the credentials admin/pass. The message must have the subject 'Lab Results - Please Schedule Follow-up' and a body that references available lab results, requests a follow-up appointment, includes the phone number 555-0100, and ends with a professional closing. Ensure the message is sent rather than saved as a draft.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/send_portal_message/setup_task.sh",
    "post_task": "/workspace/tasks/send_portal_message/export_result.sh"
  },
  "metadata": {
    "patient_pid": 3,
    "patient_fname": "Jayson",
    "patient_lname": "Fadel",
    "patient_dob": "1992-06-30",
    "expected_subject_keywords": [
      "lab",
      "results",
      "follow"
    ],
    "expected_body_keywords": [
      "lab",
      "results",
      "schedule",
      "follow",
      "appointment",
      "555-0100"
    ],
    "phone_number": "555-0100",
    "scoring_weights": {
      "message_exists": 25,
      "correct_patient": 20,
      "subject_correct": 15,
      "body_has_lab_reference": 10,
      "body_has_followup_request": 10,
      "body_has_phone": 10,
      "message_sent_not_draft": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_send_portal_message"
    }
  }
}
