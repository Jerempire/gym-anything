{
  "id": "assign_primary_care_provider@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Assign Philip Katz as the primary care provider for Jayson Fadel (DOB: 1992-06-30) in his patient demographics. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 35,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/assign_primary_care_provider/setup_task.sh",
    "post_task": "/workspace/tasks/assign_primary_care_provider/export_result.sh"
  },
  "metadata": {
    "patient_pid": 3,
    "patient_fname": "Jayson",
    "patient_lname": "Fadel",
    "patient_dob": "1992-06-30",
    "provider_username": "physician",
    "provider_fname": "Philip",
    "provider_lname": "Katz",
    "scoring_weights": {
      "patient_accessed": 20,
      "demographics_accessed": 20,
      "provider_assigned": 40,
      "correct_provider": 20
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_assign_pcp"
    }
  }
}