{
  "id": "create_patient_letter@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Create a patient letter for Jayson Fadel (DOB: 1992-06-30) notifying him that his lab results are available and requesting he contact the office at (555) 123-4567 to schedule an appointment to review results. Save the letter to the patient's chart. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_patient_letter/setup_task.sh",
    "post_task": "/workspace/tasks/create_patient_letter/export_result.sh"
  },
  "metadata": {
    "patient_pid": 3,
    "patient_fname": "Jayson",
    "patient_lname": "Fadel",
    "patient_dob": "1992-06-30",
    "required_phone": "555",
    "content_keywords": [
      "lab",
      "result",
      "contact",
      "appointment",
      "call"
    ],
    "scoring_weights": {
      "patient_selected": 15,
      "letter_feature_accessed": 15,
      "letter_created": 25,
      "content_correct": 25,
      "proper_save": 10,
      "timestamp_valid": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_patient_letter"
    }
  }
}
