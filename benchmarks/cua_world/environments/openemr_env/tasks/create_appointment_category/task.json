{
  "id": "create_appointment_category@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Create a new appointment category named Telehealth Visit with a duration of 20 minutes. Assign a distinct color and add a brief description. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_appointment_category/setup_task.sh",
    "post_task": "/workspace/tasks/create_appointment_category/export_result.sh"
  },
  "metadata": {
    "expected_category_name": "Telehealth Visit",
    "expected_duration_minutes": 20,
    "duration_tolerance_minutes": 5,
    "scoring": {
      "category_created": 30,
      "correct_name": 25,
      "correct_duration": 20,
      "color_assigned": 10,
      "description_present": 10,
      "category_active": 5
