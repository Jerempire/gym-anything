{
  "id": "review_lab_results@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Acknowledge the pending Lipid Panel results for Abraham Gutmann (DOB: 1996-12-14) by marking them as reviewed and adding the follow-up note: 'Results reviewed. Lipid panel within acceptable limits for current therapy. Continue current statin dose. Recheck in 6 months.' Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/review_lab_results/setup_task.sh",
    "post_task": "/workspace/tasks/review_lab_results/export_result.sh"
  },
  "metadata": {
    "patient_pid": 4,
    "patient_fname": "Abraham",
    "patient_lname": "Gutmann",
    "patient_dob": "1996-12-14",
    "lab_test_type": "Lipid Panel",
    "expected_note_keywords": [
      "results",
      "reviewed",
      "lipid",
      "acceptable",
      "continue",
      "statin",
      "recheck"
    ],
    "lab_values": {
      "total_cholesterol": {
        "value": 185,
        "unit": "mg/dL",
        "range": "<200"
      },
      "hdl": {
        "value": 45,
        "unit": "mg/dL",
        "range": ">40"
      },
      "ldl": {
        "value": 110,
        "unit": "mg/dL",
        "range": "<130"
      },
      "triglycerides": {
        "value": 150,
        "unit": "mg/dL",
        "range": "<150"
      }
    },
    "scoring_weights": {
      "correct_patient_found": 15,
      "lab_results_accessed": 20,
      "results_marked_reviewed": 30,
      "followup_note_added": 25,
      "timestamp_valid": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_review_lab_results"
    }
  }
}
