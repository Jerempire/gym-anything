{
  "id": "create_recurring_appointment_series@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Create a recurring weekly appointment series for Nereida Windler (DOB: 1959-06-07). Schedule 4 consecutive Tuesday appointments at 10:00 AM, 45 minutes each. Reason: Physical Therapy - Post-op Knee Rehab. Login: admin/pass.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_recurring_appointment_series/setup_task.sh",
    "post_task": "/workspace/tasks/create_recurring_appointment_series/export_result.sh"
  },
  "metadata": {
    "patient_pid": 1,
    "patient_fname": "Nereida",
    "patient_lname": "Windler",
    "patient_dob": "1959-06-07",
    "expected_appointment_count": 4,
    "expected_day_of_week": 2,
    "expected_day_name": "Tuesday",
    "expected_start_time": "10:00",
    "expected_duration_minutes": 45,
    "expected_interval_days": 7,
    "time_tolerance_minutes": 30,
    "appointment_reason": "Physical Therapy"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_recurring_appointments"
    }
  }
}