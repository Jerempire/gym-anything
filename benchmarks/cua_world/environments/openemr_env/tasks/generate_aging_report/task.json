{
  "id": "generate_aging_report@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Generate an Accounts Receivable (A/R) Aging Report showing outstanding patient balances organized by aging periods (0-30, 31-60, 61-90, 91-120, 120+ days). The report must be displayed on screen with patient names, aging columns, and totals. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_aging_report/setup_task.sh",
    "post_task": "/workspace/tasks/generate_aging_report/export_result.sh"
  },
  "metadata": {
    "report_type": "aging_report",
    "expected_keywords": ["aging", "collection", "receivable", "balance", "past due", "overdue"],
    "aging_columns": ["0-30", "31-60", "61-90", "91-120", "120+"],
    "scoring_weights": {
      "logged_in": 15,
      "navigated_to_reports": 20,
      "correct_report_type": 20,
      "report_generated": 25,
      "aging_columns_visible": 15,
      "patient_data_displayed": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_aging_report"
    }
  }
}