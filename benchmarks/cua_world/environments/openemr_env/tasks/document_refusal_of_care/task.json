{
  "id": "document_refusal_of_care@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Document an informed refusal of care for Rosario Conn (DOB: 2005-09-19) by creating a patient note. The note title must contain \"Refusal\", \"Refused\", \"AMA\", or \"Declined\", and the body must state that an MRI or imaging study was refused by the parent or guardian and that risks were explained. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/document_refusal_of_care/setup_task.sh",
    "post_task": "/workspace/tasks/document_refusal_of_care/export_result.sh"
  },
  "metadata": {
    "patient_fname": "Rosario",
    "patient_lname": "Conn",
    "patient_dob": "2005-09-19",
    "refused_procedure": "MRI",
    "refusal_keywords": [
      "refus",
      "ama",
      "against medical advice",
      "decline"
    ],
    "procedure_keywords": [
      "mri",
      "imaging",
      "scan",
      "magnetic resonance"
    ],
    "risk_keywords": [
      "risk",
      "explain",
      "discuss",
      "counsel",
      "inform",
      "understand"
    ],
    "parent_keywords": [
      "parent",
      "guardian",
      "mother",
      "father",
      "family"
    ],
    "scoring_weights": {
      "login_successful": 10,
      "correct_patient": 15,
      "note_created": 25,
      "title_contains_refusal": 15,
      "body_references_procedure": 15,
      "risks_documented": 10,
      "timestamp_valid": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_document_refusal"
    }
  }
}
