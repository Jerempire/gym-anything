  "hooks": {
    "pre_task": "/workspace/tasks/schedule_appointment/setup_task.sh",
    "post_task": "/workspace/tasks/schedule_appointment/export_result.sh"
  },
  "metadata": {
    "patient_pid": 2,
    "patient_fname": "Maria",
    "patient_lname": "Espinal",
    "patient_dob": "1964-08-17",
    "required_days_ahead": 7,
    "required_time_start": "09:00",
    "required_time_end": "16:00",
    "min_duration_minutes": 15,
    "expected_comment_keywords": ["routine", "follow", "visit", "check"]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_schedule_appointment"
    }
  }
