    "expected_output_path": "/home/ga/Documents/encounter_report.pdf",
    "alternative_paths": [
      "/home/ga/Downloads/encounter_report.pdf",
      "/home/ga/Downloads/*.pdf",
      "/home/ga/Documents/*.pdf"
    ],
    "scoring": {
      "pdf_exists": 25,
      "valid_pdf_format": 15,
      "created_during_task": 15,
      "reasonable_size": 10,
      "contains_patient_info": 15,
      "contains_encounter_data": 10,
      "vlm_workflow_verified": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_encounter_report"
    }
  }
