{
  "id": "generate_encounter_report@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Generate a PDF report of the encounter from 2019-10-15 for Jayson Fadel (DOB: 1992-06-30). Save the report to /home/ga/Documents/encounter_report.pdf. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
