{
  "id": "generate_day_sheet@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Generate a Day Sheet financial report for today's date. The report must be displayed on screen showing charges, payments, adjustments, and totals. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_day_sheet/setup_task.sh",
    "post_task": "/workspace/tasks/generate_day_sheet/export_result.sh"
  },
  "metadata": {
    "report_type": "day_sheet",
    "report_section": "financial",
    "expected_menu_path": ["Reports", "Financial", "Day Sheet"],
    "alternative_paths": [
      ["Reports", "Clients", "Day Sheet"],
      ["Fees", "Reports", "Day Sheet"],
      ["Reports", "Billing", "Daily Summary"]
    ],
    "required_columns": ["charges", "payments", "adjustments"],
    "scoring_weights": {
      "login_success": 15,
      "navigated_reports": 20,
      "accessed_financial": 20,
      "report_generated": 25,
      "vlm_verification": 20
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_day_sheet"
    }
  }
}