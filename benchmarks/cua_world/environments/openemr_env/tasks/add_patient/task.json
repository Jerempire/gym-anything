{
  "id": "add_patient@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Add a new patient to OpenEMR with the following details: First Name: John, Last Name: TestPatient, Date of Birth: March 15, 1985, Sex: Male. Login credentials: Username: admin, Password: pass",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_patient/setup_task.sh",
    "post_task": "/workspace/tasks/add_patient/export_result.sh"
  },
  "metadata": {
    "expected_fname": "John",
    "expected_lname": "TestPatient",
    "expected_dob": "1985-03-15",
    "expected_sex": "Male"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_patient"
    }
  }
}
