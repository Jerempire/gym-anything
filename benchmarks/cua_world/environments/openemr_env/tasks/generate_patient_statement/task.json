{
  "id": "generate_patient_statement@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Generate and display a patient account statement for Jayson Fadel (DOB: 1992-06-30) showing charges, payments, and balance. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 35,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_patient_statement/setup_task.sh",
    "post_task": "/workspace/tasks/generate_patient_statement/export_result.sh"
  },
  "metadata": {
    "patient_pid": 3,
    "patient_fname": "Jayson",
    "patient_lname": "Fadel",
    "patient_dob": "1992-06-30",
    "expected_result_file": "/tmp/patient_statement_result.json",
    "scoring_weights": {
      "login_completed": 10,
      "correct_patient_selected": 25,
      "billing_section_accessed": 25,
      "statement_viewed": 30,
      "billing_data_visible": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_patient_statement"
    }
  }
}