{
  "id": "record_patient_copay@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Record a $30.00 cash copay payment for Jude Sauer (DOB: 1975-04-11) with the note 'copay'. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_patient_copay/setup_task.sh",
    "post_task": "/workspace/tasks/record_patient_copay/export_result.sh"
  },
  "metadata": {
    "patient_pid": 4,
    "patient_fname": "Jude",
    "patient_lname": "Sauer",
    "patient_dob": "1975-04-11",
    "expected_amount": 30.0,
    "expected_method": "cash",
    "amount_tolerance": 0.01,
    "scoring_weights": {
      "payment_exists": 25,
      "correct_patient": 25,
      "correct_amount": 20,
      "correct_method": 15,
      "newly_created": 10,
      "copay_noted": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_copay"
    }
  }
}
