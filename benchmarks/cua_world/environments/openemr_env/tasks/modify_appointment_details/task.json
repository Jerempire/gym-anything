{
  "id": "modify_appointment_details@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Modify Marilynn Corkery's (DOB: 1945-04-01) appointment scheduled for tomorrow at 10:00 AM. Change the duration to 30 minutes, the category to Office Visit, and add the comment: 'Extended - patient has additional concerns'. Do not change the date or time. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/modify_appointment_details/setup_task.sh",
    "post_task": "/workspace/tasks/modify_appointment_details/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "patient_pid": 2,
    "patient_fname": "Marilynn",
    "patient_lname": "Corkery",
    "patient_dob": "1945-04-01",
    "initial_duration_seconds": 900,
    "expected_duration_seconds": 1800,
    "initial_duration_minutes": 15,
    "expected_duration_minutes": 30,
    "appointment_start_time": "10:00:00",
    "expected_category_name": "Office Visit",
    "expected_comment_keywords": [
      "additional",
      "concerns",
      "extended"
    ],
    "scoring_weights": {
      "appointment_exists": 15,
      "correct_patient": 10,
      "duration_changed": 25,
      "category_changed": 25,
      "comment_updated": 15,
      "datetime_preserved": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_modify_appointment"
    }
  }
}
