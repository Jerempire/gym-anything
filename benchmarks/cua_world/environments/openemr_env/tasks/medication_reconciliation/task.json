{
  "id": "medication_reconciliation@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Perform medication reconciliation for Edmund Walker (DOB: 1954-05-02). Add at least 3 of these patient-reported medications: Lisinopril 20 mg once daily, Metformin 500 mg twice daily, Atorvastatin 40 mg once daily at bedtime, Aspirin 81 mg once daily, Omeprazole 20 mg once daily. Login: admin/pass.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/medication_reconciliation/setup_task.sh",
    "post_task": "/workspace/tasks/medication_reconciliation/export_result.sh"
  },
  "metadata": {
    "patient_pid": 25,
    "patient_fname": "Edmund",
    "patient_lname": "Walker",
    "patient_dob": "1954-05-02",
    "target_medications": [
      {"drug": "Lisinopril", "dose": "20", "unit": "mg", "frequency": "daily", "class": "ace_inhibitor"},
      {"drug": "Metformin", "dose": "500", "unit": "mg", "frequency": "BID", "class": "biguanide"},
      {"drug": "Atorvastatin", "dose": "40", "unit": "mg", "frequency": "daily", "class": "statin"},
      {"drug": "Aspirin", "dose": "81", "unit": "mg", "frequency": "daily", "class": "antiplatelet"},
      {"drug": "Omeprazole", "dose": "20", "unit": "mg", "frequency": "daily", "class": "ppi"}
    ],
    "minimum_medications_required": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_medication_reconciliation"
    }
  }
}
