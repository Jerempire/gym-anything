{
  "id": "generate_patient_ccd@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Generate and export a Continuity of Care Document (CCD/CCDA) for Rickie Batz (DOB: 1990-08-14). The CCD file should be saved to /home/ga/Downloads/ or displayed in the browser. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_patient_ccd/setup_task.sh",
    "post_task": "/workspace/tasks/generate_patient_ccd/export_result.sh"
  },
  "metadata": {
    "patient_pid": 5,
    "patient_fname": "Rickie",
    "patient_lname": "Batz",
    "patient_dob": "1990-08-14",
    "expected_conditions": ["Hypertension", "Essential hypertension"],
    "expected_medications": ["Lisinopril"],
    "ccd_markers": ["ClinicalDocument", "recordTarget", "component"],
    "download_locations": ["/home/ga/Downloads", "/tmp", "/home/ga"],
    "scoring_weights": {
      "patient_selected": 15,
      "ccd_interface_accessed": 20,
      "file_generated": 30,
      "valid_ccd_format": 15,
      "correct_patient_data": 15,
      "clinical_content_present": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_ccd"
    }
  }
}