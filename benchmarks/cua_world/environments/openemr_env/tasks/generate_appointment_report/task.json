{
  "id": "generate_appointment_report@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Generate an appointment report for all providers for the current month (from the 1st to today). The report must be displayed on screen. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_appointment_report/setup_task.sh",
    "post_task": "/workspace/tasks/generate_appointment_report/export_result.sh"
  },
  "metadata": {
    "report_section": "Appointments",
    "valid_report_names": [
      "Appointments Report",
      "Appointment Report",
      "Patient Appointments",
      "Appointments"
    ],
    "expected_workflow_steps": [
      "login",
      "reports_menu",
      "report_selection",
      "parameter_config",
      "generate_report"
    ],
    "date_format": "YYYY-MM-DD",
    "scoring_weights": {
      "reports_accessed": 20,
      "report_selected": 20,
      "dates_configured": 25,
      "report_generated": 25,
      "results_visible": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_appointment_report"
    }
  }
}
