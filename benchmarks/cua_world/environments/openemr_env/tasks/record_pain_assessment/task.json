{
  "id": "record_pain_assessment@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Record a pain assessment for Isabella Margarita Gonzalez (DOB: 1961-05-08) in the encounter vitals form. Use the following details: pain score 7/10, location in the lower back (lumbar region) radiating to the left leg, and quality described as aching with occasional sharp shooting pain. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_pain_assessment/setup_task.sh",
    "post_task": "/workspace/tasks/record_pain_assessment/export_result.sh"
  },
  "metadata": {
    "patient_fname": "Isabella",
    "patient_mname": "Margarita",
    "patient_lname": "Gonzalez",
    "patient_dob": "1961-05-08",
    "expected_pain_score": "7",
    "expected_location": "lower back",
    "score_weights": {
      "correct_patient": 20,
      "encounter_created": 15,
      "pain_score_recorded": 25,
      "pain_score_correct": 15,
      "location_documented": 15,
      "recent_timestamp": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_pain_assessment"
    }
  }
}
