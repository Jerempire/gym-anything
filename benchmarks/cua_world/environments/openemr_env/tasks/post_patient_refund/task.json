{
  "id": "post_patient_refund@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Post a $45.00 refund for Marcus Cartwright (DOB: 1972-02-14). Payment method: Check, reference number: REF-2024-001, note: 'Insurance overpayment - credit balance refund'. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 35,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/post_patient_refund/setup_task.sh",
    "post_task": "/workspace/tasks/post_patient_refund/export_result.sh"
  },
  "metadata": {
    "patient_fname": "Marcus",
    "patient_lname": "Cartwright",
    "patient_dob": "1972-02-14",
    "refund_amount": 45.00,
    "refund_amount_tolerance": 1.00,
    "reference_number": "REF-2024-001",
    "expected_keywords": ["overpay", "refund", "credit", "balance", "insurance"],
    "scoring_weights": {
      "patient_correct": 15,
      "navigation_billing": 15,
      "refund_amount_correct": 25,
      "documentation_present": 20,
      "transaction_saved": 15,
      "timestamp_valid": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_post_refund"
    }
  }
}