{
  "id": "add_encounter_diagnosis@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Add an ICD-10 diagnosis code for COPD to the most recent encounter of Rozella Corkery (DOB: 1947-02-23). The code must be linked to the encounter, not just the problem list. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_encounter_diagnosis/setup_task.sh",
    "post_task": "/workspace/tasks/add_encounter_diagnosis/export_result.sh"
  },
  "metadata": {
    "patient_pid": 2,
    "patient_fname": "Rozella",
    "patient_lname": "Corkery",
    "patient_dob": "1947-02-23",
    "condition_name": "Chronic obstructive bronchitis",
    "condition_snomed": "185086009",
    "valid_icd10_codes": [
      "J44.1",
      "J44.9",
      "J44.0",
      "J44"
    ],
    "code_type": "ICD10",
    "scoring_weights": {
      "patient_located": 15,
      "encounter_accessed": 20,
      "diagnosis_section_used": 15,
      "icd10_code_added": 30,
      "code_linked_encounter": 15,
      "code_saved_active": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_encounter_diagnosis"
    }
  }
}
