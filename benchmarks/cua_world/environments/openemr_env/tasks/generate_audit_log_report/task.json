{
  "id": "generate_audit_log_report@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Generate an audit log report of access events for patient Rosa Bayer (DOB: 2015-10-10, Patient ID: 2) covering the past 30 days and display it on screen. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_audit_log_report/setup_task.sh",
    "post_task": "/workspace/tasks/generate_audit_log_report/export_result.sh"
  },
  "metadata": {
    "patient_pid": 2,
    "patient_fname": "Rosa",
    "patient_lname": "Bayer",
    "patient_dob": "2015-10-10",
    "date_range_days": 30,
    "scoring_weights": {
      "logged_in": 10,
      "navigated_reports": 15,
      "found_audit_log": 20,
      "patient_filter_applied": 25,
      "date_range_set": 15,
      "report_displayed": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_audit_log_report"
    }
  }
}
