{
  "id": "add_pharmacy@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Add a new pharmacy to the pharmacy directory. Details: CVS Pharmacy #8472, 2150 Commonwealth Avenue, Boston, MA 02135, Phone: (617) 555-0142, Fax: (617) 555-0143, Email: rx8472@cvs.com, NPI/NCPDP: 1234567890. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
