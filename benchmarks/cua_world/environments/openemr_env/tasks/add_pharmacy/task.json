  "metadata": {
    "pharmacy_name": "CVS Pharmacy #8472",
    "expected_name_contains": ["CVS", "8472"],
    "address": "2150 Commonwealth Avenue",
    "city": "Boston",
    "state": "MA",
    "zip": "02135",
    "phone": "(617) 555-0142",
    "fax": "(617) 555-0143",
    "email": "rx8472@cvs.com",
    "npi": "1234567890",
    "scoring_weights": {
      "pharmacy_exists": 25,
      "name_correct": 15,
      "address_correct": 15,
      "location_correct": 15,
      "phone_present": 10,
      "fax_present": 10,
      "newly_created": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_pharmacy"
    }
  }
