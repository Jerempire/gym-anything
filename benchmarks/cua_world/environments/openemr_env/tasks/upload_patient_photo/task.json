{
  "id": "upload_patient_photo@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Upload the patient photo at /home/ga/Documents/patient_photo.jpg to Jayson Fadel's record (DOB: 1992-06-30). The photo must be saved and visible on the patient's chart. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/upload_patient_photo/setup_task.sh",
    "post_task": "/workspace/tasks/upload_patient_photo/export_result.sh"
  },
  "metadata": {
    "patient_pid": 3,
    "patient_fname": "Jayson",
    "patient_lname": "Fadel",
    "patient_dob": "1992-06-30",
    "photo_source_path": "/home/ga/Documents/patient_photo.jpg",
    "documents_storage_path": "/var/www/html/openemr/sites/default/documents",
    "scoring_weights": {
      "correct_patient_accessed": 15,
      "photo_upload_initiated": 15,
      "photo_file_selected": 15,
      "photo_saved_to_patient": 25,
      "photo_visible_in_chart": 20,
      "upload_timestamp_valid": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_upload_patient_photo"
    }
  }
}