{
  "id": "record_smoking_status_change@1",
  "version": "1.0",
  "env_id": "openemr_env@0.1",
  "description": "Update the smoking status for Marcus Weber (DOB: 1973-04-07) to 'Former Smoker' and set the cessation date to 2024-09-15. Login: admin/pass.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_smoking_status_change/setup_task.sh",
    "post_task": "/workspace/tasks/record_smoking_status_change/export_result.sh"
  },
  "metadata": {
    "patient_pid": 6,
    "patient_fname": "Marcus",
    "patient_lname": "Weber",
    "patient_dob": "1973-04-07",
    "initial_smoking_status": "Current Every Day Smoker",
    "expected_smoking_status": "Former Smoker",
    "cessation_date": "2024-09-15",
    "acceptable_former_values": [
      "former",
      "ex-",
      "quit",
      "past",
      "8517006",
      "former smoker",
      "ex smoker",
      "ex-smoker"
    ],
    "scoring_weights": {
      "patient_correct": 15,
      "status_changed": 30,
      "status_correct_value": 25,
      "record_saved": 15,
      "vlm_verification": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_smoking_status_change"
    }
  }
}
