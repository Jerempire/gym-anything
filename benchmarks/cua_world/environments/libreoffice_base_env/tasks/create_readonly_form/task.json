{
  "id": "create_readonly_form@1",
  "version": "1.0",
  "env_id": "libreoffice_base_env@0.1",
  "description": "Create a secure 'Look-Up' form named 'Customer_ReadOnly' for the Customer table in /home/ga/chinook.odb. The form must include all fields from the table and be configured to strictly prevent any data additions, modifications, or deletions.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_readonly_form/setup_task.sh",
    "post_task": "/workspace/tasks/create_readonly_form/export_result.sh"
  },
  "metadata": {
    "database_path": "/home/ga/chinook.odb",
    "expected_form_name": "Customer_ReadOnly",
    "target_table": "Customer",
    "required_properties": {
      "allow-inserts": "false",
      "allow-updates": "false",
      "allow-deletes": "false"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_readonly_form"
    }
  }
}
