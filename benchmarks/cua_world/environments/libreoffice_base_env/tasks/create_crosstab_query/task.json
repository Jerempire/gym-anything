{
  "id": "create_crosstab_query@1",
  "version": "1.0",
  "env_id": "libreoffice_base_env@0.1",
  "description": "Create and save a SQL query named 'CountrySalesPivot' in LibreOffice Base using the 'Customer' and 'Invoice' tables. The query must produce a pivot table showing total sales by Country (rows) and Year (columns for 2009, 2010, 2011, 2012, and 2013), plus a 'Grand_Total' column summing all sales for each country. Order the results by 'Grand_Total' in descending order.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_crosstab_query/setup_task.sh",
    "post_task": "/workspace/tasks/create_crosstab_query/export_result.sh"
  },
  "metadata": {
    "expected_query_name": "CountrySalesPivot",
    "required_keywords": [
      "CASE",
      "SUM",
      "GROUP BY",
      "ORDER BY",
      "Customer",
      "Invoice",
      "2009",
      "2013"
    ],
    "required_columns": [
      "Country",
      "Sales_2009",
      "Sales_2010",
      "Sales_2011",
      "Sales_2012",
      "Sales_2013",
      "Grand_Total"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_crosstab_query"
    }
  }
}
