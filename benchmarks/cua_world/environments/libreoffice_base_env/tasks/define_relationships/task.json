{
  "id": "define_relationships@1",
  "version": "1.0",
  "env_id": "libreoffice_base_env@0.1",
  "description": "Define three foreign key relationships in the Chinook music store database located at /home/ga/chinook.odb. Establish the following connections: Artist.ArtistId to Album.ArtistId, Album.AlbumId to Track.AlbumId, and Customer.CustomerId to Invoice.CustomerId. Save the database to persist these foreign key constraints.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/define_relationships/setup_task.sh",
    "post_task": "/workspace/tasks/define_relationships/export_result.sh"
  },
  "metadata": {
    "database_path": "/home/ga/chinook.odb",
    "relationships": [
      {
        "parent_table": "Artist",
        "parent_col": "ArtistId",
        "child_table": "Album",
        "child_col": "ArtistId"
      },
      {
        "parent_table": "Album",
        "parent_col": "AlbumId",
        "child_table": "Track",
        "child_col": "AlbumId"
      },
      {
        "parent_table": "Customer",
        "parent_col": "CustomerId",
        "child_table": "Invoice",
        "child_col": "CustomerId"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_relationships"
    }
  }
}
