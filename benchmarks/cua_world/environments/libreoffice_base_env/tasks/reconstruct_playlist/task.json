{
  "id": "reconstruct_playlist@1",
  "version": "1.0",
  "env_id": "libreoffice_base_env@0.1",
  "description": "Create a new playlist in the Chinook database named 'Heavy Classics' containing the following tracks: 'Ace Of Spades', 'Master Of Puppets', 'For Whom The Bell Tolls', 'The Number Of The Beast', and 'Run To The Hills'. Ensure all changes are saved to the database.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/reconstruct_playlist/setup_task.sh",
    "post_task": "/workspace/tasks/reconstruct_playlist/export_result.sh"
  },
  "metadata": {
    "target_playlist_name": "Heavy Classics",
    "target_tracks": [
      "Ace Of Spades",
      "Master Of Puppets",
      "For Whom The Bell Tolls",
      "The Number Of The Beast",
      "Run To The Hills"
    ],
    "database_path": "/home/ga/chinook.odb"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reconstruct_playlist"
    }
  }
}
