{
  "id": "customize_form_controls@1",
  "version": "1.0",
  "env_id": "libreoffice_base_env@0.1",
  "description": "Create a form named 'TrackEditor' for the 'Track' table in the Chinook database to improve data integrity. The form must include all fields from the table. Configure the 'TrackId' field as read-only, format the 'UnitPrice' field as currency (USD with 2 decimal places), and set the 'Composer' field's maximum text length to 100 characters.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/customize_form_controls/setup_task.sh",
    "post_task": "/workspace/tasks/customize_form_controls/export_result.sh"
  },
  "metadata": {
    "db_path": "/home/ga/chinook.odb",
    "form_name": "TrackEditor",
    "target_table": "Track",
    "constraints": {
      "TrackId": {
        "property": "Read-Only",
        "value": true
      },
      "UnitPrice": {
        "property": "Currency",
        "symbol": "$"
      },
      "Composer": {
        "property": "Max Length",
        "value": 100
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_customize_form_controls"
    }
  }
}
