{
  "id": "analyze_customer_tenure@1",
  "version": "1.0",
  "env_id": "libreoffice_base_env@0.1",
  "description": "Create and save a query named 'LongTermLoyalty' in the Chinook database that calculates customer tenure in days as the difference between their first and last invoice dates. Filter for customers with tenure exceeding 1095 days and sort the results by tenure in descending order.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/analyze_customer_tenure/setup_task.sh",
    "post_task": "/workspace/tasks/analyze_customer_tenure/export_result.sh"
  },
  "metadata": {
    "database_path": "/home/ga/chinook.odb",
    "query_name": "LongTermLoyalty",
    "required_tables": [
      "Customer",
      "Invoice"
    ],
    "required_functions": [
      "DATEDIFF",
      "MIN",
      "MAX"
    ],
    "required_filter_value": "1095"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_analyze_customer_tenure"
    }
  }
}
