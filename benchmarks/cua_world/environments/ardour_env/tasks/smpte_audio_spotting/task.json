{
  "id": "smpte_audio_spotting@1",
  "version": "1.0",
  "env_id": "ardour_env@0.1",
  "description": "Set the Ardour session frame rate to 24 fps and import /home/ga/Audio/samples/narration.wav into a new track named 'Voiceover'. The audio region must be positioned at SMPTE Timecode 00:01:30:12 and locked to the timeline. Save the session.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/smpte_audio_spotting/setup_task.sh",
    "post_task": "/workspace/tasks/smpte_audio_spotting/export_result.sh"
  },
  "metadata": {
    "target_timecode": "00:01:30:12",
    "target_fps": 24,
    "target_samples": 3991050,
    "tolerance_exact_samples": 500,
    "tolerance_partial_samples": 44100,
    "audio_source": "/home/ga/Audio/samples/narration.wav",
    "session_file": "/home/ga/Audio/sessions/MyProject/MyProject.ardour"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_smpte_audio_spotting"
    }
  }
}
