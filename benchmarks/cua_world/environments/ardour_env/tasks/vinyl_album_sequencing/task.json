{
  "id": "vinyl_album_sequencing@1",
  "version": "1.0",
  "env_id": "ardour_env@0.1",
  "description": "You are a mastering engineer preparing a continuous pre-master sequence for Side A of a split 7-inch vinyl record. Sequence the source audio files 'moonlight_sonata.wav' and 'narration.wav' from /home/ga/Audio/vinyl_source/ on a single track in Ardour according to the specifications in /home/ga/Audio/vinyl_source/pressing_plant_spec.txt. Export the final continuous WAV file to /home/ga/Audio/vinyl_delivery/.",
  "difficulty": "hard",
  "category": "audio_production",
  "tags": [
    "daw",
    "sequencing",
    "mastering",
    "vinyl",
    "precise_editing"
  ],
  "estimated_time_minutes": 15,
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/vinyl_album_sequencing/setup_task.sh",
    "post_task": "/workspace/tasks/vinyl_album_sequencing/export_result.sh"
  },
  "metadata": {
    "target_track_name": "Vinyl Pre-Master",
    "required_gap_seconds": 3.0,
    "required_fade_seconds": 2.0,
    "sample_rate": 44100,
    "gap_tolerance_samples": 8820,
    "fade_tolerance_samples": 22050,
    "marker_tolerance_samples": 4410,
    "export_directory": "/home/ga/Audio/vinyl_delivery",
    "pass_threshold": 70
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_vinyl_album_sequencing"
    }
  }
}
