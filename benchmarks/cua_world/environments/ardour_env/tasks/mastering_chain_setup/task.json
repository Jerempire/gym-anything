{
  "id": "mastering_chain_setup@1",
  "version": "1.0",
  "env_id": "ardour_env@0.1",
  "description": "You are a freelance mastering engineer preparing a client's stereo mix for digital distribution in the Ardour session 'MyProject'. Rename the existing audio track to 'Stereo Mix'. On the Master bus, insert the 'ACE EQ' and 'ACE Compressor' plugins, ensuring the signal chain order is EQ followed by Compressor. Save the session.",
  "difficulty": "hard",
  "category": "audio_engineering",
  "tags": [
    "daw",
    "mastering",
    "signal_chain",
    "plugins",
    "mixer"
  ],
  "estimated_time_minutes": 12,
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/mastering_chain_setup/setup_task.sh",
    "post_task": "/workspace/tasks/mastering_chain_setup/export_result.sh"
  },
  "metadata": {
    "expected_track_name": "Stereo Mix",
    "eq_keywords": [
      "eq",
      "equalizer",
      "a-eq",
      "ace eq",
      "ace-eq"
    ],
    "eq_uris": [
      "urn:ardour:a-eq",
      "http://ardour.org/uri/a-eq"
    ],
    "comp_keywords": [
      "comp",
      "compressor",
      "a-comp",
      "ace comp",
      "ace-comp",
      "ace compressor"
    ],
    "comp_uris": [
      "urn:ardour:a-comp",
      "http://ardour.org/uri/a-comp"
    ],
    "pass_threshold": 60
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mastering_chain_setup"
    }
  }
}
