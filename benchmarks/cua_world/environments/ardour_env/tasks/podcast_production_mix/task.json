{
  "id": "podcast_production_mix@1",
  "version": "1.0",
  "env_id": "ardour_env@0.1",
  "description": "You are a broadcast technician at WKRP community radio station. Raw audio files for this week's 'Community Voices' podcast episode are in /home/ga/Audio/podcast_raw/. A production brief with track naming, level, and ordering requirements is in the same directory. Assemble the complete episode in the currently open Ardour session and deliver the final stereo mix as a WAV file to /home/ga/Audio/podcast_final/.",
  "difficulty": "very_hard",
  "category": "audio_production",
  "tags": ["daw", "podcast", "mixing", "broadcasting", "media_production"],
  "estimated_time_minutes": 15,
  "init": {
    "timeout_sec": 680,
    "max_steps": 85,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/podcast_production_mix/setup_task.sh",
    "post_task": "/workspace/tasks/podcast_production_mix/export_result.sh"
  },
  "metadata": {
    "required_tracks": ["Intro Theme", "Interview", "Outro Theme"],
    "music_gain_db_range": [-18, -6],
    "speech_gain_db_range": [-3, 3],
    "export_directory": "/home/ga/Audio/podcast_final",
    "source_directory": "/home/ga/Audio/podcast_raw",
    "required_markers": ["Episode Start", "Interview Begin", "Outro Begin", "Episode End"],
    "pass_threshold": 65
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_podcast_production_mix"
    }
  }
}
