{
  "id": "export_session@1",
  "version": "1.0",
  "env_id": "ardour_env@0.1",
  "description": "Export the currently open Ardour session as a stereo WAV file (16-bit or 24-bit) to /home/ga/Audio/export/. The exported file must be valid and non-silent.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 150,
    "max_steps": 35,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_session/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_session"
    }
  }
}
