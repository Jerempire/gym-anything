{
  "id": "route_group_submix@1",
  "version": "1.0",
  "env_id": "ardour_env@0.1",
  "description": "You are preparing a mix template for a recording session. Create five mono audio tracks with the following names and fader gains: 'Kick' (-6 dB), 'Snare' (-6 dB), 'Overhead' (-9 dB), 'Lead Vocal' (0 dB), and 'Harmony Vocal' (-3 dB). Organize these into two route groups: a 'Drums' group containing the Kick, Snare, and Overhead tracks with sharing properties set to Gain and Mute, and a 'Vocals' group containing the Lead Vocal and Harmony Vocal tracks with sharing properties set to Gain, Mute, and Solo. Mute the drum tracks and save the session.",
  "difficulty": "hard",
  "category": "audio_production",
  "tags": [
    "daw",
    "mixing",
    "session_organization",
    "route_groups",
    "gain_staging"
  ],
  "estimated_time_minutes": 12,
  "init": {
    "timeout_sec": 720,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/route_group_submix/setup_task.sh",
    "post_task": "/workspace/tasks/route_group_submix/export_result.sh"
  },
  "metadata": {
    "track_targets": {
      "kick": {
        "gain_db": -6,
        "muted": true,
        "group_alias": "drums"
      },
      "snare": {
        "gain_db": -6,
        "muted": true,
        "group_alias": "drums"
      },
      "overhead": {
        "gain_db": -9,
        "muted": true,
        "group_alias": "drums"
      },
      "lead_vocal": {
        "gain_db": 0,
        "muted": false,
        "group_alias": "vocals"
      },
      "harmony_vocal": {
        "gain_db": -3,
        "muted": false,
        "group_alias": "vocals"
      }
    },
    "group_targets": {
      "drums": {
        "flags": [
          "GainControl",
          "MuteControl"
        ]
      },
      "vocals": {
        "flags": [
          "GainControl",
          "MuteControl",
          "SoloControl"
        ]
      }
    },
    "tolerance_db": 2.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_route_group_submix"
    }
  }
}
