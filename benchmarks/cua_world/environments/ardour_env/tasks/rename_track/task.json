{
  "id": "rename_track@1",
  "version": "1.0",
  "env_id": "ardour_env@0.1",
  "description": "Rename the audio track called 'Audio 1' in the currently open Ardour session to 'Lead Vocals'.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 90,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rename_track/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rename_track"
    }
  }
}
