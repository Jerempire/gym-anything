{
  "id": "configure_campaign_hotkeys@1",
  "version": "1.0",
  "env_id": "vicidial_env@0.1",
  "description": "Create a new Vicidial Campaign with the ID 'RAPID' and name 'Rapid Response Team'. Configure the campaign to be Active and enable Allow Closers. Enable HotKeys for this campaign and map the following statuses: Key '1' to 'SALE', Key '3' to 'DNC', Key '8' to 'CALLBK', and Key '9' to 'NI'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_campaign_hotkeys/setup_task.sh",
    "post_task": "/workspace/tasks/configure_campaign_hotkeys/export_result.sh"
  },
  "metadata": {
    "target_campaign_id": "RAPID",
    "target_campaign_name": "Rapid Response Team",
    "required_hotkeys": {
      "1": "SALE",
      "3": "DNC",
      "8": "CALLBK",
      "9": "NI"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_campaign_hotkeys"
    }
  }
}
