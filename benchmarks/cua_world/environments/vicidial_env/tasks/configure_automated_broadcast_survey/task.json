{
  "id": "configure_automated_broadcast_survey@1",
  "version": "1.0",
  "env_id": "vicidial_env@0.1",
  "description": "Configure the 'EMRGNCY' (City Emergency Alert) campaign to function as an automated broadcast survey using the following parameters:\n- Survey First Audio File: vm-greeting\n- Survey DTMF Digits: 1\n- Survey Not Interested Digit: 1\n- Survey Not Interested Status: SAFE\n- Survey Wait Seconds: 5\n- Survey Method: EXTENSION\n- Survey Extension: 8300\n- Survey No-Response Action: OPTIN",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_automated_broadcast_survey/setup_task.sh",
    "post_task": "/workspace/tasks/configure_automated_broadcast_survey/export_result.sh"
  },
  "metadata": {
    "campaign_id": "EMRGNCY",
    "expected_config": {
      "survey_first_audio_file": "vm-greeting",
      "survey_dtmf_digits": "1",
      "survey_ni_digit": "1",
      "survey_ni_status": "SAFE",
      "survey_wait_seconds": "5",
      "survey_method": "EXTENSION",
      "survey_extension": "8300",
      "survey_no_response_action": "OPTIN"
    },
    "scoring": {
      "survey_first_audio_file": 15,
      "survey_dtmf_digits": 15,
      "survey_ni_digit": 15,
      "survey_ni_status": 15,
      "survey_wait_seconds": 10,
      "survey_method": 15,
      "survey_no_response_action": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_broadcast_survey"
    }
  }
}
