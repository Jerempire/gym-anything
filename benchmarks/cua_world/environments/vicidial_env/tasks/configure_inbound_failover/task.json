{
  "id": "configure_inbound_failover@1",
  "version": "1.0",
  "env_id": "vicidial_env@0.1",
  "description": "Configure the Inbound Group 'SUPPORT' to handle after-hours and overflow traffic. Set the Call Time to 'BIZ_HRS' and ensure the After Hours Action, the 'No Agent No Queue' Action, and the Wait Time Option (for hold times exceeding 90 seconds) are all configured to route to Voicemail Box '8500'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_inbound_failover/setup_task.sh",
    "post_task": "/workspace/tasks/configure_inbound_failover/export_result.sh"
  },
  "metadata": {
    "target_group_id": "SUPPORT",
    "expected_values": {
      "call_time_id": "BIZ_HRS",
      "after_hours_action": "VOICEMAIL",
      "after_hours_voicemail": "8500",
      "no_agent_no_queue_action": "VOICEMAIL",
      "no_agent_no_queue_action_value": "8500",
      "wait_hold_option": "VOICEMAIL",
      "wait_time_option_seconds": 90,
      "wait_time_option_value": "8500"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_inbound_failover"
    }
  }
}
