      "active": 10,
      "queue_priority": 15,
      "next_agent_call": 10,
      "fronter_display": 5,
      "ingroup_recording_override": 15,
      "drop_call_seconds": 10,
      "after_hours_action": 10
    }
  },
  "success": {
