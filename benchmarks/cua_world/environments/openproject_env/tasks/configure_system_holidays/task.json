{
  "id": "configure_system_holidays@1",
  "version": "1.0",
  "env_id": "openproject_env@0.1",
  "description": "Configure the global system holidays for the year 2026. Log in as admin (password: Admin1234!) and add the following non-working days to the system: Memorial Day (2026-05-25), Labor Day (2026-09-07), and Thanksgiving Day (2026-11-26). Ensure these entries are saved and visible in the system's working days configuration.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_system_holidays/setup_task.sh",
    "post_task": "/workspace/tasks/configure_system_holidays/export_result.sh"
  },
  "metadata": {
    "holidays": [
      {
        "date": "2026-05-25",
        "name_keywords": [
          "Memorial"
        ]
      },
      {
        "date": "2026-09-07",
        "name_keywords": [
          "Labor"
        ]
      },
      {
        "date": "2026-11-26",
        "name_keywords": [
          "Thanksgiving"
        ]
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_system_holidays"
    }
  }
}
