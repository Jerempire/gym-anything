{
  "id": "create_kanban_board@1",
  "version": "1.0",
  "env_id": "openproject_env@0.1",
  "description": "You are managing a cross-functional product design workflow for the E-Commerce Platform project. Create a status-based Kanban board named 'Design Workflow Board' within the project. The board must include columns for the 'New' and 'In progress' statuses.",
  "difficulty": "medium",
  "tags": [
    "openproject",
    "agile",
    "kanban",
    "boards",
    "visualization"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_kanban_board/setup_task.sh",
    "post_task": "/workspace/tasks/create_kanban_board/export_result.sh"
  },
  "metadata": {
    "project_identifier": "ecommerce-platform",
    "expected_board_name": "Design Workflow Board",
    "expected_board_type": "action",
    "expected_board_attribute": "status",
    "min_columns": 2,
    "required_statuses": [
      "New",
      "In progress"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_kanban_board"
    }
  }
}
