{
  "id": "configure_system_default_columns@1",
  "version": "1.0",
  "env_id": "openproject_env@0.1",
  "description": "Log in to OpenProject as admin (username: 'admin', password: 'Admin1234!'). Configure the system-wide default columns for work package lists to prioritize schedule tracking. The default columns must be exactly: ID, Subject, Status, Assignee, Due date, and % Complete, in that specific order.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_system_default_columns/setup_task.sh",
    "post_task": "/workspace/tasks/configure_system_default_columns/export_result.sh"
  },
  "metadata": {
    "expected_columns": [
      "id",
      "subject",
      "status",
      "assigned_to",
      "duedate",
      "done_ratio"
    ],
    "forbidden_columns": [
      "type",
      "priority"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_system_default_columns"
    }
  }
}
