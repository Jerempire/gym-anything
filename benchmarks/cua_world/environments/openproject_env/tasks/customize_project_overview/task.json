{
  "id": "customize_project_overview@1",
  "version": "1.0",
  "env_id": "openproject_env@0.1",
  "description": "Customize the 'Mobile Banking App' project overview page to serve as a team dashboard. The dashboard must include both the 'Members' and 'News' widgets. Login: admin (password: Admin1234!).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/customize_project_overview/setup_task.sh",
    "post_task": "/workspace/tasks/customize_project_overview/export_result.sh"
  },
  "metadata": {
    "project_identifier": "mobile-banking-app",
    "required_widgets": [
      "members",
      "news"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_customize_project_overview"
    }
  }
}
