{
  "id": "escalate_project_health_status@1",
  "version": "1.0",
  "env_id": "openproject_env@0.1",
  "description": "Update the 'Mobile Banking App' project status to 'At risk' to signal a critical issue. Use the following text for the status update: 'Critical security vulnerability found in biometric auth module (CVE-2024-9999). Release candidate 1.0 blocked pending patch.'",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/escalate_project_health_status/setup_task.sh",
    "post_task": "/workspace/tasks/escalate_project_health_status/export_result.sh"
  },
  "metadata": {
    "project_identifier": "mobile-banking-app",
    "target_status_name": "At risk",
    "required_keywords": [
      "security",
      "vulnerability",
      "biometric",
      "CVE-2024-9999"
    ],
    "expected_explanation_length_min": 50
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_escalate_project_health_status"
    }
  }
}
