{
  "id": "configure_personal_dashboard@1",
  "version": "1.0",
  "env_id": "openproject_env@0.1",
  "description": "Log in to OpenProject as user 'bob.smith' (password: 'User1234!@'). Configure your personal 'My Page' dashboard to focus on your work. The dashboard must contain only two widgets: 'Work packages assigned to me' and 'Spent time', arranged with 'Work packages assigned to me' at the top.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_personal_dashboard/setup_task.sh",
    "post_task": "/workspace/tasks/configure_personal_dashboard/export_result.sh"
  },
  "metadata": {
    "target_user_login": "bob.smith",
    "expected_widgets": [
      "work_packages_assigned",
      "time_entries_current_user"
    ],
    "widget_names_ui": [
      "Work packages assigned to me",
      "Spent time"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_personal_dashboard"
    }
  }
}
