{
  "id": "correct_misfiled_time_entry@1",
  "version": "1.0",
  "env_id": "openproject_env@0.1",
  "description": "A time entry was logged against the wrong work package. In the 'Mobile Banking App' project, reassign the 4.00-hour time entry with the comment 'External security analysis' from the 'Asset Design' task to the 'Security Audit' task. Do not change the hours or the comment.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/correct_misfiled_time_entry/setup_task.sh",
    "post_task": "/workspace/tasks/correct_misfiled_time_entry/export_result.sh"
  },
  "metadata": {
    "project_identifier": "mobile-banking-app",
    "wrong_wp_subject": "Asset Design",
    "correct_wp_subject": "Security Audit",
    "time_entry_hours": 4.0,
    "time_entry_comment": "External security analysis"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_correct_misfiled_time_entry"
    }
  }
}
