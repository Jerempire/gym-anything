{
  "id": "bulk_tag_work_packages@1",
  "version": "1.0",
  "env_id": "openproject_env@0.1",
  "description": "In the 'E-Commerce Platform' project, add the tag 'search-initiative' to all work packages that have 'Search' (case-insensitive) in their subject. Do not modify any other work packages or attributes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bulk_tag_work_packages/setup_task.sh",
    "post_task": "/workspace/tasks/bulk_tag_work_packages/export_result.sh"
  },
  "metadata": {
    "project_identifier": "ecommerce-platform",
    "search_term": "Search",
    "target_tag": "search-initiative"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bulk_tag_work_packages"
    }
  }
}
