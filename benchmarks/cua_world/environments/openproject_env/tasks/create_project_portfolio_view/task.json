{
  "id": "create_project_portfolio_view@1",
  "version": "1.0",
  "env_id": "openproject_env@0.1",
  "description": "Create a public saved view named 'PMO Portfolio' in the global Projects list. The view must display exactly these columns: Name, Project status, Description, and Created on, sorted by 'Created on' in descending order.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_project_portfolio_view/setup_task.sh",
    "post_task": "/workspace/tasks/create_project_portfolio_view/export_result.sh"
  },
  "metadata": {
    "expected_name": "PMO Portfolio",
    "expected_columns": [
      "name",
      "status",
      "description",
      "created_on"
    ],
    "expected_sort": [
      [
        "created_on",
        "desc"
      ]
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_project_portfolio_view"
    }
  }
}
