{
  "id": "integrate_git_repository@1",
  "version": "1.0",
  "env_id": "openproject_env@0.1",
  "description": "Enable the 'Repositories' module for the 'DevOps Automation' project and configure it to track the Git repository located at '/var/lib/openproject/git/devops.git'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/integrate_git_repository/setup_task.sh",
    "post_task": "/workspace/tasks/integrate_git_repository/export_result.sh"
  },
  "metadata": {
    "project_identifier": "devops-automation",
    "expected_path": "/var/lib/openproject/git/devops.git",
    "expected_type": "Git"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_integrate_git_repository"
    }
  }
}
