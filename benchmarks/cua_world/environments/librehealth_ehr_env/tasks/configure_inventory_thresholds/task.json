{
  "id": "configure_inventory_thresholds@1",
  "version": "1.0",
  "env_id": "librehealth_ehr_env@0.1",
  "description": "Configure inventory safety stock levels for the clinic dispensary in LibreHealth EHR (admin/password). Set the Reorder Level for 'Ibuprofen 200mg' to 150 and for 'Metformin 500mg' to 60.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_inventory_thresholds/setup_task.sh",
    "post_task": "/workspace/tasks/configure_inventory_thresholds/export_result.sh"
  },
  "metadata": {
    "target_drugs": [
      {
        "name": "Ibuprofen 200mg",
        "expected_reorder_point": 150
      },
      {
        "name": "Metformin 500mg",
        "expected_reorder_point": 60
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_inventory_thresholds"
    }
  }
}
