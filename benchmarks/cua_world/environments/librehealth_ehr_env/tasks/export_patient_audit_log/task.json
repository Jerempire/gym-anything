{
  "id": "export_patient_audit_log@1",
  "version": "1.0",
  "env_id": "librehealth_ehr_env@0.1",
  "description": "Log in to LibreHealth EHR (admin / password) and generate a CSV audit log report showing all access activity for patient 'Brandie Sammet' for 'Today'. Export the results to /home/ga/Documents/brandie_sammet_audit.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_patient_audit_log/setup_task.sh",
    "post_task": "/workspace/tasks/export_patient_audit_log/export_result.sh"
  },
  "metadata": {
    "target_patient_fname": "Brandie",
    "target_patient_lname": "Sammet",
    "expected_filename": "brandie_sammet_audit.csv",
    "expected_path": "/home/ga/Documents/brandie_sammet_audit.csv",
    "target_user": "admin"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_patient_audit_log"
    }
  }
}
