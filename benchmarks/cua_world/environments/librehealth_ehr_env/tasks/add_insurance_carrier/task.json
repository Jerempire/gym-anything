{
  "id": "add_insurance_carrier@1",
  "version": "1.0",
  "env_id": "librehealth_ehr_env@0.1",
  "description": "Log in to LibreHealth EHR (admin/password) and add 'Cigna Health Spring' as a new insurance carrier using the Name, Address, Phone, and Payer ID (CMS ID) provided in ~/Desktop/new_carrier_info.txt. Do not modify any existing carriers.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_insurance_carrier/setup_task.sh",
    "post_task": "/workspace/tasks/add_insurance_carrier/export_result.sh"
  },
  "metadata": {
    "expected_name": "Cigna Health Spring",
    "expected_street": "500 Great Circle Road",
    "expected_city": "Nashville",
    "expected_state": "TN",
    "expected_zip": "37228",
    "expected_phone": "(800) 668-3813",
    "expected_cms_id": "62308",
    "info_file_path": "/home/ga/Desktop/new_carrier_info.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_insurance_carrier"
    }
  }
}
