{
  "id": "add_document_category@1",
  "version": "1.0",
  "env_id": "librehealth_ehr_env@0.1",
  "description": "Log into LibreHealth EHR (username: 'admin', password: 'password') and create a new document category named 'Telehealth Consent' as a child of the root 'Categories' folder.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_document_category/setup_task.sh",
    "post_task": "/workspace/tasks/add_document_category/export_result.sh"
  },
  "metadata": {
    "category_name": "Telehealth Consent",
    "parent_name_requirement": "Categories"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_document_category"
    }
  }
}
