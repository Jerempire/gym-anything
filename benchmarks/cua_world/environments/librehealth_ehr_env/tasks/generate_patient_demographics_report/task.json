{
  "id": "generate_patient_demographics_report@1",
  "version": "1.0",
  "env_id": "librehealth_ehr_env@0.1",
  "description": "Generate a patient demographics report in LibreHealth EHR using the credentials 'admin' and 'password'. Filter the report for male patients born before January 1, 1960. Identify the total count of matching patients and write only this integer to the first line of /home/ga/patient_report_count.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_patient_demographics_report/setup_task.sh",
    "post_task": "/workspace/tasks/generate_patient_demographics_report/export_result.sh"
  },
  "metadata": {
    "output_path": "/home/ga/patient_report_count.txt",
    "filter_sex": "Male",
    "filter_dob_cutoff": "1960-01-01",
    "sql_logic": "sex = 'Male' AND DOB < '1960-01-01'"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_patient_demographics_report"
    }
  }
}
