{
  "id": "record_social_history@1",
  "version": "1.0",
  "env_id": "librehealth_ehr_env@0.1",
  "description": "Log in to LibreHealth EHR (admin/password) and update the Social History for the patient specified in /tmp/task_patient_info.txt. Record the following details: Tobacco Use: 'Current every day smoker', Alcohol: 'Beer and wine, 4-5 drinks per week', Recreational Drugs: 'None', Counseling: 'N/A', and Exercise Patterns: 'Sedentary lifestyle, no regular exercise'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_social_history/setup_task.sh",
    "post_task": "/workspace/tasks/record_social_history/export_result.sh"
  },
  "metadata": {
    "patient_info_file": "/tmp/task_patient_info.txt",
    "expected_tobacco": "Current every day smoker",
    "expected_alcohol_keywords": [
      "beer",
      "wine",
      "4-5",
      "drinks"
    ],
    "expected_drugs_keywords": [
      "none",
      "n/a"
    ],
    "expected_exercise_keywords": [
      "sedentary",
      "no regular"
    ],
    "expected_counseling_keywords": [
      "n/a",
      "none"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_social_history"
    }
  }
}
