{
  "id": "configure_provider_insurance_numbers@1",
  "version": "1.0",
  "env_id": "librehealth_ehr_env@0.1",
  "description": "Log in to LibreHealth EHR (admin/password) and configure the billing numbers for the provider 'Admin'. Link the provider to insurance company 'Blue Cross Blue Shield' using Provider Number 'BCBS-8842-X' and Group Number 'GRP-99104'.",
  "difficulty": "medium",
  "tags": [
    "librehealth",
    "billing",
    "admin",
    "configuration",
    "insurance"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_provider_insurance_numbers/setup_task.sh",
    "post_task": "/workspace/tasks/configure_provider_insurance_numbers/export_result.sh"
  },
  "metadata": {
    "expected_provider_number": "BCBS-8842-X",
    "expected_group_number": "GRP-99104",
    "target_provider": "Admin",
    "target_insurance": "Blue Cross Blue Shield"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_provider_insurance_numbers"
    }
  }
}
