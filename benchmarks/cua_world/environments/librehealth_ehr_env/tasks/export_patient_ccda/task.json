{
  "id": "export_patient_ccda@1",
  "version": "1.0",
  "env_id": "librehealth_ehr_env@0.1",
  "description": "Export the full clinical record for the patient specified in '~/Desktop/transfer_request.txt' from LibreHealth EHR (admin/password) as a C-CDA or CCR XML file. Save the export to '~/Documents/Transfer/export.xml'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_patient_ccda/setup_task.sh",
    "post_task": "/workspace/tasks/export_patient_ccda/export_result.sh"
  },
  "metadata": {
    "output_path": "/home/ga/Documents/Transfer/export.xml",
    "request_file": "/home/ga/Desktop/transfer_request.txt",
    "credentials": {
      "username": "admin",
      "password": "password"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_patient_ccda"
    }
  }
}
