{
  "id": "document_patient_phone_call@1",
  "version": "1.0",
  "env_id": "librehealth_ehr_env@0.1",
  "description": "Document a patient phone call regarding lost medication in the LibreHealth EHR (admin/password). Using the information provided in /home/ga/Desktop/call_details.txt, create a new Patient Note in the 'Notes' section of the correct patient's chart.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/document_patient_phone_call/setup_task.sh",
    "post_task": "/workspace/tasks/document_patient_phone_call/export_result.sh"
  },
  "metadata": {
    "call_details_path": "/home/ga/Desktop/call_details.txt",
    "ground_truth_path": "/tmp/task_ground_truth.json",
    "required_keywords": [
      "lost",
      "losing",
      "bottle"
    ],
    "target_table": "pnotes"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_document_patient_phone_call"
    }
  }
}
