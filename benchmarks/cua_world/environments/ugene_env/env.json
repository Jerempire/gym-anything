{
  "id": "ugene_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "UGENE bioinformatics environment for DNA/protein sequence analysis, multiple sequence alignment, and phylogenetic tree building",
  "resources": {
    "cpu": 4,
    "mem_gb": 6,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/ugene_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/ugene_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/ugene_env/assets", "target": "/workspace/assets", "mode": "ro"}
  ],
  "vnc": {
    "enable": true,
    "password": "password"
  },
  "hooks": {
    "pre_start": "/workspace/scripts/install_ugene.sh",
    "post_start": "/workspace/scripts/setup_ugene.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ]
}
