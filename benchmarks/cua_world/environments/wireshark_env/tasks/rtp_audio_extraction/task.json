{
  "id": "rtp_audio_extraction@1",
  "version": "1.0",
  "env_id": "wireshark_env@0.1",
  "description": "Perform forensic audio recovery on the VoIP packet capture located at ~/Documents/captures/sip-rtp-g711.pcap. Reconstruct the audio from the RTP stream and save it as a playable .au (Sun Audio) file to ~/Documents/captures/recovered_call.au.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rtp_audio_extraction/setup_task.sh",
    "post_task": "/workspace/tasks/rtp_audio_extraction/export_result.sh"
  },
  "metadata": {
    "pcap_file": "sip-rtp-g711.pcap",
    "expected_output_path": "/home/ga/Documents/captures/recovered_call.au",
    "min_expected_size_bytes": 50000,
    "expected_file_type": "Sun/NeXT audio"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rtp_audio_extraction"
    }
  }
}
