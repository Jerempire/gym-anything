{
  "id": "identify_top_talkers@1",
  "version": "1.0",
  "env_id": "example.wireshark_env@0.1",
  "description": "Identify the IPv4 endpoint that sent the most bytes in the capture file /home/ga/Documents/captures/200722_tcp_anon.pcapng. Save only the IP address of this top sender to /home/ga/Documents/captures/top_talker.txt.",
  "init": {
    "timeout_sec": 150,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/identify_top_talkers/setup_task.sh",
    "post_task": "/workspace/tasks/identify_top_talkers/export_result.sh"
  },
  "metadata": {
    "pcap_file": "200722_tcp_anon.pcapng",
    "output_file": "top_talker.txt"
  },
  "success": {
    "spec": {
      "program": "verifier.py::verify_identify_top_talkers"
    }
  }
}
