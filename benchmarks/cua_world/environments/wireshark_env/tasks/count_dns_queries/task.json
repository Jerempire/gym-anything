{
  "id": "count_dns_queries@1",
  "version": "1.0",
  "env_id": "example.wireshark_env@0.1",
  "description": "Determine the total number of DNS query packets (excluding responses) in the capture file located at /home/ga/Documents/captures/dns.cap. Save the count as a plain integer to /home/ga/Documents/captures/dns_query_count.txt.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/count_dns_queries/setup_task.sh",
    "post_task": "/workspace/tasks/count_dns_queries/export_result.sh"
  },
  "metadata": {
    "pcap_file": "dns.cap",
    "display_filter": "dns.flags.response == 0",
    "output_file": "dns_query_count.txt"
  },
  "success": {
    "spec": {
      "program": "verifier.py::verify_count_dns_queries"
    }
  }
}
