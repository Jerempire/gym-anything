{
  "id": "http_traffic_json_export@1",
  "version": "1.0",
  "env_id": "wireshark_env@0.1",
  "description": "Extract metadata from HTTP Request packets (excluding responses) in /home/ga/Documents/captures/http.cap. Export the fields 'frame.number', 'frame.time_epoch', 'ip.src', 'http.host', 'http.request.method', and 'http.request.uri' as a JSON array to /home/ga/Documents/captures/http_requests.json.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/http_traffic_json_export/setup_task.sh",
    "post_task": "/workspace/tasks/http_traffic_json_export/export_result.sh"
  },
  "metadata": {
    "pcap_path": "/home/ga/Documents/captures/http.cap",
    "output_path": "/home/ga/Documents/captures/http_requests.json",
    "required_fields": [
      "frame.number",
      "frame.time_epoch",
      "ip.src",
      "http.host",
      "http.request.method",
      "http.request.uri"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_http_traffic_json_export"
    }
  }
}
