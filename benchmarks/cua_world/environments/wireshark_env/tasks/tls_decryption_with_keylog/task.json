{
  "id": "tls_decryption_with_keylog@1",
  "version": "1.0",
  "env_id": "wireshark_env@0.1",
  "description": "Configure Wireshark to decrypt the HTTPS traffic in '~/Documents/captures/secure_api.pcap' using the session keys provided in '~/Documents/captures/session_keys.log'. Analyze the decrypted traffic to find the UUID value associated with the label 'SECRET_FLAG:' and save only the UUID to '~/Documents/decrypted_flag.txt'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/tls_decryption_with_keylog/setup_task.sh",
    "post_task": "/workspace/tasks/tls_decryption_with_keylog/export_result.sh"
  },
  "metadata": {
    "pcap_path": "/home/ga/Documents/captures/secure_api.pcap",
    "keylog_path": "/home/ga/Documents/captures/session_keys.log",
    "output_path": "/home/ga/Documents/decrypted_flag.txt",
    "ground_truth_path": "/var/lib/app/ground_truth/secret_uuid.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_tls_decryption"
    }
  }
}
