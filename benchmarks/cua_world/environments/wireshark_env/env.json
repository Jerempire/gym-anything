{
  "id": "example.wireshark_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Wireshark network protocol analyzer environment for packet capture analysis, filtering, and network forensics tasks",
  "observation": [
    {"type": "rgb_screen", "fps": 10, "resolution": [1920, 1080], "inline": false}
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/wireshark_env/artifacts"
  },
  "vnc": {
    "enable": false,
    "host_port": -1,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true,
    "runtime": "sysbox-runc"
  },
  "resources": {
    "cpu": 4,
    "mem_gb": 4,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/wireshark_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/wireshark_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_wireshark.sh",
    "post_start": "/workspace/scripts/setup_wireshark.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "analyst",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input", "wireshark"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1"
        }
      }
    }
  ],
  "tags": ["linux", "networking", "security", "wireshark", "desktop", "packet-analysis"]
}
