{
  "id": "example.android_calculator@0.1",
  "version": "0.1",
  "base": "android-14",
  "description": "Android Calculator environment for arithmetic tasks",
  "observation": [
    {"type": "rgb_screen", "fps": 10, "resolution": [1920, 1080], "inline": false}
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": true,
    "output_dir": "benchmarks/cua_world/environments/android_calculator_env/artifacts"
  },
  "vnc": {
    "enable": true,
    "host_port": -1,
    "view_only": false,
    "password": "password",
    "fallback_only": true
  },
  "adb": {
    "host_port": -1,
    "guest_port": 5555,
    "timeout": 180
  },
  "security": {
    "user": "root",
    "privileged": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/android_calculator_env/scripts",
      "target": "/sdcard/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/android_calculator_env/tasks",
      "target": "/sdcard/tasks",
      "mode": "ro"
    }
  ],
  "hooks": {
    "post_start": "/sdcard/scripts/setup_calculator.sh"
  },
  "tags": ["android", "calculator", "math", "arithmetic"]
}
