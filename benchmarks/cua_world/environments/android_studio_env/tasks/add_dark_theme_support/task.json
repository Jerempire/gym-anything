{
  "id": "add_dark_theme_support@1",
  "version": "1.0",
  "env_id": "android_studio_env@0.1",
  "description": "Add full dark theme (DayNight) support to the 'WeatherApp' project. Configure the app theme in 'app/src/main/res/values/themes.xml' to use a DayNight parent and define dark mode colors in 'app/src/main/res/values-night/colors.xml'. Implement a theme toggle mechanism in 'MainActivity.kt' and verify the project builds successfully.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_dark_theme_support/setup_task.sh",
    "post_task": "/workspace/tasks/add_dark_theme_support/export_result.sh"
  },
  "metadata": {
    "project_dir": "/home/ga/AndroidStudioProjects/WeatherApp",
    "theme_file": "app/src/main/res/values/themes.xml",
    "night_colors_file": "app/src/main/res/values-night/colors.xml",
    "light_colors_file": "app/src/main/res/values/colors.xml",
    "main_activity_file": "app/src/main/java/com/example/weatherapp/MainActivity.kt",
    "required_colors": [
      "colorPrimary",
      "colorSurface",
      "colorBackground"
    ],
    "min_dark_colors": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_dark_theme_support"
    }
  }
}
