<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1C1C1E"
    tools:context=".CalcActivity">

    <!-- History display -->
    <TextView
        android:id="@+id/history"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:textColor="#FF8E8E93"
        android:textSize="14sp"
        android:maxLines="5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main display -->
    <TextView
        android:id="@+id/display"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:textColor="@android:color/white"
        android:textSize="64sp"
        android:maxLines="1"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="24sp"
        android:autoSizeMaxTextSize="64sp"
        tools:text="0"
        app:layout_constraintBottom_toTopOf="@id/button_grid"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Button grid -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/button_grid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Row 1: Clear, Negate, Percent, Divide -->
        <Button android:id="@+id/btn_clear" android:layout_width="0dp" android:layout_height="72dp"
            android:text="@string/btn_clear" android:textSize="24sp"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/btn_negate"
            app:layout_constraintTop_toTopOf="parent" android:layout_margin="4dp" />
        <Button android:id="@+id/btn_negate" android:layout_width="0dp" android:layout_height="72dp"
            android:text="@string/btn_negate" android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/btn_clear" app:layout_constraintEnd_toStartOf="@id/btn_percent"
            app:layout_constraintTop_toTopOf="parent" android:layout_margin="4dp" />
        <Button android:id="@+id/btn_percent" android:layout_width="0dp" android:layout_height="72dp"
            android:text="@string/btn_percent" android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/btn_negate" app:layout_constraintEnd_toStartOf="@id/btn_divide"
            app:layout_constraintTop_toTopOf="parent" android:layout_margin="4dp" />
        <Button android:id="@+id/btn_divide" android:layout_width="0dp" android:layout_height="72dp"
            android:text="@string/btn_divide" android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/btn_percent" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" android:layout_margin="4dp" />

        <!-- Row 2: 7, 8, 9, Multiply -->
        <Button android:id="@+id/btn_7" android:layout_width="0dp" android:layout_height="72dp"
            android:text="7" android:textSize="24sp"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/btn_8"
            app:layout_constraintTop_toBottomOf="@id/btn_clear" android:layout_margin="4dp" />
        <Button android:id="@+id/btn_8" android:layout_width="0dp" android:layout_height="72dp"
            android:text="8" android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/btn_7" app:layout_constraintEnd_toStartOf="@id/btn_9"
            app:layout_constraintTop_toBottomOf="@id/btn_negate" android:layout_margin="4dp" />
        <Button android:id="@+id/btn_9" android:layout_width="0dp" android:layout_height="72dp"
            android:text="9" android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/btn_8" app:layout_constraintEnd_toStartOf="@id/btn_multiply"
            app:layout_constraintTop_toBottomOf="@id/btn_percent" android:layout_margin="4dp" />
        <Button android:id="@+id/btn_multiply" android:layout_width="0dp" android:layout_height="72dp"
            android:text="@string/btn_multiply" android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/btn_9" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_divide" android:layout_margin="4dp" />

        <!-- Row 3: 4, 5, 6, Subtract -->
        <Button android:id="@+id/btn_4" android:layout_width="0dp" android:layout_height="72dp"
            android:text="4" android:textSize="24sp"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/btn_5"
            app:layout_constraintTop_toBottomOf="@id/btn_7" android:layout_margin="4dp" />
        <Button android:id="@+id/btn_5" android:layout_width="0dp" android:layout_height="72dp"
            android:text="5" android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/btn_4" app:layout_constraintEnd_toStartOf="@id/btn_6"
            app:layout_constraintTop_toBottomOf="@id/btn_8" android:layout_margin="4dp" />
        <Button android:id="@+id/btn_6" android:layout_width="0dp" android:layout_height="72dp"
            android:text="6" android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/btn_5" app:layout_constraintEnd_toStartOf="@id/btn_subtract"
            app:layout_constraintTop_toBottomOf="@id/btn_9" android:layout_margin="4dp" />
        <Button android:id="@+id/btn_subtract" android:layout_width="0dp" android:layout_height="72dp"
            android:text="@string/btn_subtract" android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/btn_6" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_multiply" android:layout_margin="4dp" />

        <!-- Row 4: 1, 2, 3, Add -->
        <Button android:id="@+id/btn_1" android:layout_width="0dp" android:layout_height="72dp"
            android:text="1" android:textSize="24sp"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/btn_2"
            app:layout_constraintTop_toBottomOf="@id/btn_4" android:layout_margin="4dp" />
        <Button android:id="@+id/btn_2" android:layout_width="0dp" android:layout_height="72dp"
            android:text="2" android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/btn_1" app:layout_constraintEnd_toStartOf="@id/btn_3"
            app:layout_constraintTop_toBottomOf="@id/btn_5" android:layout_margin="4dp" />
        <Button android:id="@+id/btn_3" android:layout_width="0dp" android:layout_height="72dp"
            android:text="3" android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/btn_2" app:layout_constraintEnd_toStartOf="@id/btn_add"
            app:layout_constraintTop_toBottomOf="@id/btn_6" android:layout_margin="4dp" />
        <Button android:id="@+id/btn_add" android:layout_width="0dp" android:layout_height="72dp"
            android:text="@string/btn_add" android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/btn_3" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_subtract" android:layout_margin="4dp" />

        <!-- Row 5: 0 (wide), Decimal, Equals -->
        <Button android:id="@+id/btn_0" android:layout_width="0dp" android:layout_height="72dp"
            android:text="0" android:textSize="24sp"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/btn_decimal"
            app:layout_constraintTop_toBottomOf="@id/btn_1" android:layout_margin="4dp"
            app:layout_constraintHorizontal_weight="2" />
        <Button android:id="@+id/btn_decimal" android:layout_width="0dp" android:layout_height="72dp"
            android:text="." android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/btn_0" app:layout_constraintEnd_toStartOf="@id/btn_equals"
            app:layout_constraintTop_toBottomOf="@id/btn_2" android:layout_margin="4dp"
            app:layout_constraintHorizontal_weight="1" />
        <Button android:id="@+id/btn_equals" android:layout_width="0dp" android:layout_height="72dp"
            android:text="@string/btn_equals" android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/btn_decimal" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_add" android:layout_margin="4dp"
            app:layout_constraintHorizontal_weight="1" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
