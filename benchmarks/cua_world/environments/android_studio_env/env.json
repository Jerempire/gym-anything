{
  "id": "android_studio_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Android Studio IDE environment for Android app development, Gradle project management, testing, refactoring, and debugging tasks",
  "category": ["ide", "development", "mobile"],
  "tags": [
    "linux",
    "ide",
    "android",
    "kotlin",
    "java",
    "gradle",
    "android-studio",
    "junit",
    "refactoring",
    "desktop"
  ],
  "licence": "Apache-2.0",
  "upstream_url": "https://developer.android.com/studio",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/android_studio_env/artifacts",
    "video_fps": 10,
    "video_resolution": [1920, 1080],
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": false,
    "host_port": 5964,
    "container_port": 5900,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/android_studio_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/android_studio_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/android_studio_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/android_studio_env/utils", "target": "/workspace/utils", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/android_studio_env/data", "target": "/workspace/data", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_android_studio.sh",
    "post_start": "/workspace/scripts/setup_android_studio.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk-amd64",
          "ANDROID_SDK_ROOT": "/opt/android-sdk",
          "ANDROID_HOME": "/opt/android-sdk"
        }
      }
    }
  ]
}
