{
  "id": "bayesian_correlation_exam@1",
  "version": "1.0",
  "env_id": "jasp_env@0.1",
  "description": "Using the 'ExamAnxiety.csv' dataset in '/home/ga/Documents/JASP/', perform a Bayesian Correlation Matrix analysis on the 'Exam', 'Anxiety', and 'Revise' variables. The analysis must include Pearson correlations, credible intervals, and pairwise scatter plots. Save the resulting JASP file to '/home/ga/Documents/JASP/BayesianCorrelationExam.jasp'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bayesian_correlation_exam/setup_task.sh",
    "post_task": "/workspace/tasks/bayesian_correlation_exam/export_result.sh"
  },
  "metadata": {
    "dataset_path": "/home/ga/Documents/JASP/ExamAnxiety.csv",
    "expected_output_path": "/home/ga/Documents/JASP/BayesianCorrelationExam.jasp",
    "min_file_size_kb": 20,
    "required_variables": [
      "Exam",
      "Anxiety",
      "Revise"
    ],
    "analysis_type_keywords": [
      "Bayesian",
      "Correlation"
    ],
    "required_options": [
      "credibleInterval",
      "scatterPlot"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bayesian_correlation"
    }
  }
}
