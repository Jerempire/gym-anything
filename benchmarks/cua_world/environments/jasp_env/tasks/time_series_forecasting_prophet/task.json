{
  "id": "time_series_forecasting_prophet@1",
  "version": "1.0",
  "env_id": "jasp_env@0.1",
  "description": "Perform a time series forecast on the airline passenger data located at ~/Documents/JASP/AirlinePassengers.csv. Using the Prophet forecasting module, set 'Passengers' as the dependent variable and 'Month' as the time variable. Configure the analysis to forecast 12 months and produce a plot. Save the final results to ~/Documents/JASP/PassengerForecast.jasp.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/time_series_forecasting_prophet/setup_task.sh",
    "post_task": "/workspace/tasks/time_series_forecasting_prophet/export_result.sh"
  },
  "metadata": {
    "expected_filename": "PassengerForecast.jasp",
    "expected_path": "/home/ga/Documents/JASP/PassengerForecast.jasp",
    "data_url": "https://raw.githubusercontent.com/jbrownlee/Datasets/master/airline-passengers.csv",
    "required_module": "Prophet",
    "forecast_periods": 12,
    "dependent_variable": "Passengers",
    "time_variable": "Month"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_time_series_forecasting_prophet"
    }
  }
}
