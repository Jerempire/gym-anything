{
  "id": "distribution_fitting_anxiety@1",
  "version": "1.0",
  "env_id": "jasp_env@0.1",
  "description": "Model the 'Anxiety' variable from the 'Exam Anxiety' dataset located at '/home/ga/Documents/JASP/ExamAnxiety.csv'. Fit both 'Normal' and 'Gamma' distributions to the data with parameter estimation enabled. Save the resulting JASP project to '/home/ga/Documents/JASP/Anxiety_Distributions.jasp'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
