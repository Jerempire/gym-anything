    "post_task": "/workspace/tasks/distribution_fitting_anxiety/export_result.sh"
  },
  "metadata": {
    "dataset_path": "/home/ga/Documents/JASP/ExamAnxiety.csv",
    "expected_output_path": "/home/ga/Documents/JASP/Anxiety_Distributions.jasp",
    "target_variable": "Anxiety",
    "required_distributions": [
      "Normal",
      "Gamma"
    ],
    "analysis_type_keywords": [
      "Distribution",
      "Continuous",
      "Fit"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_distribution_fitting"
    }
  }
