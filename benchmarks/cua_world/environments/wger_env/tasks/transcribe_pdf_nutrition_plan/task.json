{
  "id": "transcribe_pdf_nutrition_plan@1",
  "version": "1.0",
  "env_id": "wger_env@0.1",
  "description": "Your sports nutritionist just sent you a new daily meal protocol as a PDF document located at ~/Documents/nutrition_protocol.pdf. Log in to wger (username: admin, password: adminadmin) and transcribe the exact plan from the PDF into a new Nutrition Plan named \"Nutritionist Protocol\". Recreate the meals and add the specified ingredients with their exact target weights in grams. All required ingredients are already available in the wger database.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/transcribe_pdf_nutrition_plan/setup_task.sh",
    "post_task": "/workspace/tasks/transcribe_pdf_nutrition_plan/export_result.sh"
  },
  "metadata": {
    "expected_plan_name": "Nutritionist Protocol",
    "pdf_path": "/home/ga/Documents/nutrition_protocol.pdf",
    "expected_items": [
      {
        "name": "Rolled Oats",
        "amount": 80.0
      },
      {
        "name": "Whole Milk",
        "amount": 250.0
      },
      {
        "name": "Chicken Breast (Raw)",
        "amount": 200.0
      },
      {
        "name": "Brown Rice",
        "amount": 150.0
      },
      {
        "name": "Broccoli",
        "amount": 100.0
      },
      {
        "name": "Beef Steak",
        "amount": 250.0
      },
      {
        "name": "Sweet Potato",
        "amount": 200.0
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_transcribe_pdf_nutrition_plan"
    }
  }
}
