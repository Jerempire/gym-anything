    "post_task": "/workspace/tasks/add_meal_items/export_result.sh"
  },
  "metadata": {
    "expected_plan": "Shift Day Nutrition",
    "expected_meal": "Lunch",
    "ingredients": [
      {
        "name": "Chicken Breast Raw",
        "amount": 200
      },
      {
        "name": "Brown Rice Cooked",
        "amount": 150
      },
      {
        "name": "Broccoli Raw",
        "amount": 100
      }
    ],
    "amount_tolerance_grams": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_meal_items"
    }
  }
