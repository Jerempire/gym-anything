    "original_amounts": {
      "quinoa": 75,
      "salmon": 180,
      "sweet_potato": 200,
      "spinach": 85
    },
    "expected_scaled_amounts": {
      "quinoa": 1875,
      "salmon": 4500,
      "sweet_potato": 5000,
      "spinach": 2125
