{
  "id": "export_routine_logbook@1",
  "version": "1.0",
  "env_id": "wger_env@0.1",
  "description": "You are logged into the wger fitness manager at http://localhost as the admin user (username: admin, password: adminadmin). Export the logbook for the existing 'Push-Pull-Legs' workout routine as a PDF and save it to /home/ga/Downloads/Push-Pull-Legs-Logbook.pdf.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_routine_logbook/setup_task.sh",
    "post_task": "/workspace/tasks/export_routine_logbook/export_result.sh"
  },
  "metadata": {
    "expected_file_path": "/home/ga/Downloads/Push-Pull-Legs-Logbook.pdf",
    "expected_routine_name": "Push-Pull-Legs",
    "min_file_size_bytes": 1024
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_routine_logbook"
    }
  }
}
