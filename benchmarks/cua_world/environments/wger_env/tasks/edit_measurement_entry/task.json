{
  "id": "edit_measurement_entry@1",
  "version": "1.0",
  "env_id": "wger_env@0.1",
  "description": "As the admin user logged into the wger fitness manager at http://localhost, update the most recent 'Waist' body measurement entry from 82.0 cm to 79.5 cm. Do not add new entries or modify any other measurement data.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/edit_measurement_entry/setup_task.sh",
    "post_task": "/workspace/tasks/edit_measurement_entry/export_result.sh"
  },
  "metadata": {
    "target_category": "Waist",
    "expected_value": 79.5,
    "initial_value": 82.0,
    "tolerance": 0.05
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_edit_measurement_entry"
    }
  }
}
