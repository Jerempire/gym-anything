{
  "id": "log_nutrition_diary_entries@1",
  "version": "1.0",
  "env_id": "wger_env@0.1",
  "description": "You are a cafeteria cook tracking your daily macros. Log in to wger (username: admin, password: adminadmin) and record 50g of 'Rolled Oats' and 250g of 'Whole Milk' in the Nutrition Diary for today's date.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/log_nutrition_diary_entries/setup_task.sh",
    "post_task": "/workspace/tasks/log_nutrition_diary_entries/export_result.sh"
  },
  "metadata": {
    "expected_ingredients": [
      {
        "name": "Rolled Oats",
        "amount": 50
      },
      {
        "name": "Whole Milk",
        "amount": 250
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_log_nutrition_diary_entries"
    }
  }
}
