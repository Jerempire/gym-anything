{
  "id": "reorder_workout_exercises@1",
  "version": "1.0",
  "env_id": "wger_env@0.1",
  "description": "You are logged into the wger fitness manager as admin. Reorder the exercises in the 'Lower Body Focus' training day of the 'Strength & Size Phase 1' routine so that Squat is first, Leg Extension is second, and Standing Calf Raises is third. Do not add or delete any exercises.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/reorder_workout_exercises/setup_task.sh",
    "post_task": "/workspace/tasks/reorder_workout_exercises/export_result.sh"
  },
  "metadata": {
    "routine_name": "Strength & Size Phase 1",
    "day_name": "Lower Body Focus",
    "expected_order": [
      "Squat",
      "Leg Extension",
      "Standing Calf Raises"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reorder_exercises"
    }
  }
}
