{
  "id": "edit_gym_config@1",
  "version": "1.0",
  "env_id": "wger_env@0.1",
  "description": "As the admin user in wger fitness manager, update the details for the gym 'Downtown Fitness Hub'. Rename it to 'Iron Peak Athletics' and update its contact information to: Phone '+1-555-842-9631', Street '742 Evergreen Terrace', City 'Springfield', and Zip Code '62704'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 35,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/edit_gym_config/setup_task.sh",
    "post_task": "/workspace/tasks/edit_gym_config/export_result.sh"
  },
  "metadata": {
    "old_name": "Downtown Fitness Hub",
    "expected_name": "Iron Peak Athletics",
    "expected_phone": "+1-555-842-9631",
    "expected_street": "742 Evergreen Terrace",
    "expected_city": "Springfield",
    "expected_zip": "62704"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_edit_gym_config"
    }
  }
}
