{
  "id": "populate_workout_day@1",
  "version": "1.0",
  "env_id": "wger_env@0.1",
  "description": "You are logged into the wger fitness manager at http://localhost as the admin user (username: admin, password: adminadmin). In the existing 'Mechanic Strength Program' routine, add three exercises to the 'Upper Body Day': 'Bench Press' (4 sets of 8 reps), 'Bent Over Barbell Row' (3 sets of 10 reps), and 'Military Press' (3 sets of 12 reps). Ensure all exercises and their set/rep configurations are saved to the training day.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/populate_workout_day/setup_task.sh",
    "post_task": "/workspace/tasks/populate_workout_day/export_result.sh"
  },
  "metadata": {
    "routine_name": "Mechanic Strength Program",
    "day_name": "Upper Body Day",
    "expected_exercises": [
      {
        "keywords": [
          "bench",
          "press"
        ],
        "sets": 4,
        "reps": 8
      },
      {
        "keywords": [
          "row",
          "bent over"
        ],
        "sets": 3,
        "reps": 10
      },
      {
        "keywords": [
          "press",
          "military",
          "shoulder",
          "overhead"
        ],
        "sets": 3,
        "reps": 12
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_populate_workout_day"
    }
  }
}
