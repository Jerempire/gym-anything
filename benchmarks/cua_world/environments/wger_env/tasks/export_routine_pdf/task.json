{
  "id": "export_routine_pdf@1",
  "version": "1.0",
  "env_id": "wger_env@0.1",
  "description": "You are logged into the wger fitness manager as admin (password: adminadmin). Rename the existing 'Push-Pull-Legs' routine to 'Push-Pull-Legs (Hypertrophy Phase)' and export the updated routine as a PDF to /home/ga/Downloads/.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_routine_pdf/setup_task.sh",
    "post_task": "/workspace/tasks/export_routine_pdf/export_result.sh"
  },
  "metadata": {
    "expected_old_name": "Push-Pull-Legs",
    "expected_new_name": "Push-Pull-Legs (Hypertrophy Phase)",
    "download_dir": "/home/ga/Downloads/",
    "scoring": {
      "db_renamed": 20,
      "pdf_exists_and_timed": 20,
      "pdf_text_correct": 30,
      "vlm_verification": 30
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_routine_pdf"
    }
  }
}
