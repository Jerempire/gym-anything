# Secret keys - change for production
SECRET_KEY=wger-docker-supersecret-key-gym-anything-1234567890abc
SIGNING_KEY=wger-jwt-signing-key-gym-anything-9876543210xyz

# Database
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_DATABASE=wger
DJANGO_DB_USER=wger
DJANGO_DB_PASSWORD=wger
DJANGO_DB_HOST=db
DJANGO_DB_PORT=5432

# Redis / Celery
CELERY_BROKER=redis://cache:6379/2
CELERY_BACKEND=redis://cache:6379/2
# Use django_redis backend with proper client class (avoids CLIENT_CLASS kwarg error with redis-py 6.x)
DJANGO_CACHE_BACKEND=django_redis.cache.RedisCache
DJANGO_CACHE_LOCATION=redis://cache:6379/1
DJANGO_CACHE_CLIENT_CLASS=django_redis.client.DefaultClient

# Application server
WGER_USE_GUNICORN=True
GUNICORN_WORKERS=2
GUNICORN_THREADS=2

# Site
SITE_URL=http://localhost
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Registration / Users
ALLOW_REGISTRATION=True
ALLOW_GUEST_USERS=False

# Admin superuser (created on first start)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=adminadmin
DJANGO_SUPERUSER_EMAIL=admin@example.com

# Disable brute-force protection (simplifies benchmark tasks)
AXES_ENABLED=False

# Disable Celery (no celery_worker/celery_beat containers in this env)
USE_CELERY=False

# Disable optional features that slow startup
SYNC_EXERCISES_CELERY=False
SYNC_INGREDIENTS_CELERY=False
SYNC_EXERCISE_IMAGES_CELERY=False
SYNC_EXERCISE_VIDEOS_CELERY=False

# Prometheus metrics disabled
EXPOSE_PROMETHEUS_METRICS=False

# Disable debug mode — REQUIRED for collectstatic to run on container startup
DJANGO_DEBUG=False
