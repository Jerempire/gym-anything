{
  "id": "query_and_export_chemical_subset@1",
  "version": "1.0",
  "env_id": "cameo_data_manager_env@0.1",
  "description": "Search for all chemical inventory records for 'Chlorine' (CAS 7782-50-5) and export the results to 'C:\\Users\\Docker\\Documents\\chlorine_facilities.csv'. The export must contain only facilities storing Chlorine and include the fields 'Facility Name', 'Chemical Name', and 'Maximum Daily Amount'. Ensure records for other chemicals, such as Ammonia or Sulfuric Acid, are excluded.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\query_and_export_chemical_subset\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\query_and_export_chemical_subset\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\Users\\Docker\\Documents\\chlorine_facilities.csv",
    "required_columns": [
      "Facility Name",
      "Chemical Name",
      "Maximum Daily Amount"
    ],
    "positive_matches": [
      "Water Treatment Plant A",
      "Community Pool",
      "Agri-Chem Supply"
    ],
    "negative_matches": [
      "Cold Storage Logistics",
      "Industrial Solvents Inc"
    ],
    "chemical_name": "Chlorine"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_query_and_export"
    }
  }
}
