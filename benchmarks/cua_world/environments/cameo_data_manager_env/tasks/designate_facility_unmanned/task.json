{
  "id": "designate_facility_unmanned@1",
  "version": "1.0",
  "env_id": "cameo_data_manager_env@0.1",
  "description": "Update the regulatory status for the 'North Creek Lift Station' facility in CAMEO Data Manager. As this remote pumping station is no longer staffed, update its status to unmanned and document that emergency plans are located at 'Public Works HQ, 100 Municipal Way'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\designate_facility_unmanned\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\designate_facility_unmanned\\export_result.ps1"
  },
  "metadata": {
    "facility_name": "North Creek Lift Station",
    "expected_plan_location": "Public Works HQ, 100 Municipal Way",
    "db_path": "C:\\Users\\Docker\\Documents\\CAMEOfm\\cameo_data.mdb"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_designate_facility_unmanned"
    }
  }
}
