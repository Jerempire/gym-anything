{
  "id": "new_facility_onboarding@1",
  "version": "1.0",
  "env_id": "cameo_data_manager_env@0.1",
  "description": "Your corporation has acquired two industrial facilities in Vermont that must be onboarded into CAMEO Data Manager for Tier II compliance reporting. Import and onboard Champlain Plastics (champlain_plastics.xml) and Essex Chemical (essex_chemical.xml) from C:\\workspace\\data\\. Each facility record must include the designated emergency contact, correct contact type, and assigned fire district as specified in the records' notes and certifier information. Export the final dataset to C:\\Users\\Docker\\Documents\\CAMEO\\new_facilities.xml.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 150,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\new_facility_onboarding\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\new_facility_onboarding\\export_result.ps1"
  },
  "metadata": {
    "facility_1": {
      "name": "Champlain Plastics and Composites",
      "source_file": "C:\\workspace\\data\\champlain_plastics.xml",
      "fire_district": "Burlington Central Fire Station 3",
      "contact": {
        "first_name": "James",
        "last_name": "Kowalski",
        "title": "Corporate EHS Director",
        "phone": "802-555-0451",
        "contact_type": "Fac. Emergency Coordinator"
      }
    },
    "facility_2": {
      "name": "Essex Chemical and Coatings",
      "source_file": "C:\\workspace\\data\\essex_chemical.xml",
      "fire_district": "Essex Fire District 1",
      "contact": {
        "first_name": "Sandra",
        "last_name": "Obrecht",
        "title": "Site Safety Manager",
        "phone": "802-555-0523",
        "contact_type": "Emergency Contact"
      }
    },
    "expected_export_file": "C:\\Users\\Docker\\Documents\\CAMEO\\new_facilities.xml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_new_facility_onboarding"
    }
  }
}
