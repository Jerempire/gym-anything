{
  "id": "set_chemical_storage_conditions@1",
  "version": "1.0",
  "env_id": "cameo_data_manager_env@0.1",
  "description": "Update the 'Hydrochloric Acid' inventory record at the 'Westside Chemical Processing' facility with the following storage conditions: Physical State: 'Liquid'; Storage Type Codes: 'A' (Above ground tank) and 'E' (Plastic or non-metallic drum); Storage Pressure: 'Ambient'; and Storage Temperature: 'Ambient'.",
