{
  "id": "ehs_chemical_correction@1",
  "version": "1.0",
  "env_id": "cameo_data_manager_env@0.1",
  "description": "The Vermont SERC has issued a compliance audit notice (C:\\workspace\\data\\ehs_audit_report.txt) flagging potential EHS substance designation errors in the Tier II data for Northfield Paper Mill and Essex Wire and Cable. Using CAMEO Data Manager, correct the EHS designations in the dataset (C:\\workspace\\data\\ehs_audit_data.xml) to ensure compliance with the EPA EHS List (40 CFR Part 355). Export the corrected Tier II dataset as XML to C:\\Users\\Docker\\Documents\\CAMEO\\ehs_corrected.xml.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\ehs_chemical_correction\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\ehs_chemical_correction\\export_result.ps1"
  },
  "metadata": {
    "facility_1": "Northfield Paper Mill",
    "facility_2": "Essex Wire and Cable",
    "ehs_corrections": [
      {
        "name": "Chlorine Dioxide",
        "cas": "10049-04-4",
        "facility": "Northfield Paper Mill",
        "tpq_lbs": 10
      },
      {
        "name": "Ammonia, Anhydrous",
        "cas": "7664-41-7",
        "facility": "Essex Wire and Cable",
        "tpq_lbs": 500
      },
      {
        "name": "Hydrofluoric Acid",
        "cas": "7664-39-3",
        "facility": "Essex Wire and Cable",
        "tpq_lbs": 100
      }
    ],
    "expected_export_file": "C:\\Users\\Docker\\Documents\\CAMEO\\ehs_corrected.xml",
    "audit_report_file": "C:\\workspace\\data\\ehs_audit_report.txt",
    "source_data_file": "C:\\workspace\\data\\ehs_audit_data.xml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ehs_chemical_correction"
    }
  }
}
