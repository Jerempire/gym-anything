{
  "id": "export_filtered_facilities_kml@1",
  "version": "1.0",
  "env_id": "cameo_data_manager_env@0.1",
  "description": "Create three facility records in CAMEO Data Manager: 'Riverview Water Treatment' (City: Riverview, TX, Lat: 29.7001, Long: -95.3001), 'Riverview High School' (City: Riverview, TX, Lat: 29.7002, Long: -95.3002), and 'Hilltop Cold Storage' (City: Hilltop, TX, Lat: 30.1001, Long: -95.5001). Export the subset of facilities located in the city of 'Riverview' to a KML file named 'riverview_facilities.kml' at C:\\Users\\Docker\\Desktop\\riverview_facilities.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_filtered_facilities_kml\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_filtered_facilities_kml\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "riverview_facilities.kml",
    "expected_path": "C:\\Users\\Docker\\Desktop\\riverview_facilities.kml",
    "target_facilities": [
      "Riverview Water Treatment",
      "Riverview High School"
    ],
    "distractor_facility": "Hilltop Cold Storage",
    "target_city": "Riverview",
    "coordinates": {
      "Riverview Water Treatment": {
        "lat": 29.7001,
        "long": -95.3001
      },
      "Riverview High School": {
        "lat": 29.7002,
        "long": -95.3002
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_filtered_facilities_kml"
    }
  }
}
