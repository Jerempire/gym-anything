{
  "id": "generate_tier2_report@1",
  "version": "1.0",
  "env_id": "cameo_data_manager_env@0.1",
  "description": "Generate the 2024 Tier II submission report for 'Valley Industrial Supply Co.' using the facility data already loaded in CAMEO Data Manager. Save the report as a PDF to C:\\Users\\Docker\\Documents\\TierII_Report_Valley_Industrial.pdf.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\generate_tier2_report\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\generate_tier2_report\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\Users\\Docker\\Documents\\TierII_Report_Valley_Industrial.pdf",
    "facility_name": "Valley Industrial Supply",
    "required_chemicals": [
      "Sulfuric Acid",
      "Diesel Fuel",
      "Anhydrous Ammonia"
    ],
    "reporting_year": "2024",
    "min_file_size_kb": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_tier2_report"
    }
  }
}
