{
  "id": "generate_chemical_facility_listing@1",
  "version": "1.0",
  "env_id": "cameo_data_manager_env@0.1",
  "description": "Generate a report containing the names and addresses of all facilities in the database storing 'Ammonia' (anhydrous, CAS 7664-41-7) and save it to C:\\Users\\Docker\\Documents\\ammonia_facility_report.txt. The report must include all matching facilities and exclude any that do not store Ammonia.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\generate_chemical_facility_listing\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\generate_chemical_facility_listing\\export_result.ps1"
  },
  "metadata": {
    "expected_filename_base": "ammonia_facility_report",
    "allowed_extensions": [
      ".txt",
      ".csv",
      ".pdf",
      ".html",
      ".rtf",
      ".xls",
      ".xlsx"
    ],
    "chemical_name": "Ammonia",
    "cas_number": "7664-41-7",
    "expected_facilities": [
      "Green Valley Water Facility",
      "Cold Storage Logistics",
      "Agri-Coop West"
    ],
    "excluded_facilities": [
      "Downtown Office Complex",
      "Riverside Apartments"
    ],
    "output_dir": "C:\\Users\\Docker\\Documents"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_chemical_facility_listing"
    }
  }
}
