{
  "id": "register_transport_route@1",
  "version": "1.0",
  "env_id": "cameo_data_manager_env@0.1",
  "description": "Create a new transportation route record in the CAMEO Data Manager Routes module. The record must include the Route Name 'Norfolk Southern - Heartland Corridor', Type 'Rail', Description 'Primary double-stack intermodal route running East-West through the central business district.', and Comments/Notes 'High frequency transport of Chlorine (CAS 7782-50-5) and Vinyl Chloride.'",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\register_transport_route\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\register_transport_route\\export_result.ps1"
  },
  "metadata": {
    "expected_name": "Norfolk Southern - Heartland Corridor",
    "expected_type": "Rail",
    "expected_description_part": "double-stack intermodal",
    "expected_comment_part": "Chlorine",
    "db_path_hints": [
      "C:\\Users\\Public\\Documents\\CAMEO Data Manager\\CAMEOData.mdb",
      "C:\\Users\\Docker\\Documents\\CAMEO Data Manager\\CAMEOData.mdb",
      "C:\\Program Files (x86)\\CAMEO Data Manager\\CAMEOData.mdb"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_register_transport_route"
    }
  }
}
