{
  "id": "lab_result_import_alert@1",
  "version": "1.0",
  "env_id": "medintux_env@0.1",
  "description": "Process the lab results for the 4 patients listed in '~/Documents/incoming_labs.txt' by creating clinical notes in MedinTux. For abnormal results (HIGH or LOW), the note title must start with 'ALERT:' (e.g., 'ALERT: Potassium'). For normal results, the note title must start with 'Lab:' (e.g., 'Lab: Ferritin'). Include the test name, value, unit, and range in the note body.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/lab_result_import_alert/setup_task.sh",
    "post_task": "/workspace/tasks/lab_result_import_alert/export_result.sh"
  },
  "metadata": {
    "input_file": "/home/ga/Documents/incoming_labs.txt",
    "expected_entries": [
      {
        "name": "DUBOIS",
        "firstname": "Thomas",
        "dob": "1980-05-12",
        "test": "Potassium",
        "value": "6.2",
        "status": "HIGH",
        "expected_title_prefix": "ALERT"
      },
      {
        "name": "LEROY",
        "firstname": "Sophie",
        "dob": "1992-11-30",
        "test": "Ferritin",
        "value": "45",
        "status": "NORMAL",
        "expected_title_prefix": "Lab"
      },
      {
        "name": "MOREAU",
        "firstname": "Lucas",
        "dob": "1955-03-22",
        "test": "Glucose",
        "value": "0.95",
        "status": "NORMAL",
        "expected_title_prefix": "Lab"
      },
      {
        "name": "PETIT",
        "firstname": "Emma",
        "dob": "2001-08-14",
        "test": "Hemoglobin",
        "value": "8.1",
        "status": "LOW",
        "expected_title_prefix": "ALERT"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_lab_result_import_alert"
    }
  }
}
