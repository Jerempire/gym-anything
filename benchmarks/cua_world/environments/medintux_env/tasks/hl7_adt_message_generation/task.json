{
  "id": "hl7_adt_message_generation@1",
  "version": "1.0",
  "env_id": "medintux_env@0.1",
  "description": "Extract all patient records from the MedinTux 'DrTuxTest' MySQL database (user: 'root', no password) and generate a file of HL7 v2.4 ADT^A04 (Register a Patient) messages. Each message must include MSH, EVN, PID, and PV1 segments. Ensure patients MOREAU Claire, BERNARD Philippe, and PETIT Isabelle are included and correctly formatted. Save the output to ~/hl7_output/adt_messages.hl7.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/hl7_adt_message_generation/setup_task.sh",
    "post_task": "/workspace/tasks/hl7_adt_message_generation/export_result.sh"
  },
  "metadata": {
    "output_path": "/home/ga/hl7_output/adt_messages.hl7",
    "required_patients": [
      {
        "lastname": "MOREAU",
        "firstname": "Claire",
        "dob": "19870422",
        "sex": "F",
        "city": "Paris",
        "nir_fragment": "2870475"
      },
      {
        "lastname": "BERNARD",
        "firstname": "Philippe",
        "dob": "19551103",
        "sex": "M",
        "city": "Lyon",
        "nir_fragment": "1551169"
      },
      {
        "lastname": "PETIT",
        "firstname": "Isabelle",
        "dob": "20010815",
        "sex": "F",
        "city": "Marseille",
        "nir_fragment": "2010813"
      }
    ],
    "hl7_specs": {
      "version": "2.4",
      "message_type": "ADT^A04",
      "encoding_chars": "^~\\&",
      "sending_app": "MEDINTUX"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_hl7_generation"
    }
  }
}
