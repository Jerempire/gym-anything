{
  "id": "update_local_procedure_tariffs@1",
  "version": "1.0",
  "env_id": "medintux_env@0.1",
  "description": "Update the fee schedule for medical procedures in the 'DrTuxTest' database (MySQL user 'root', no password) using the 2025 tariffs provided in '~/Documents/tariffs_2025.csv'. Update the 'Tarif' column in the 'CCAM_Local_Tarifs' table for only the codes specified in the CSV file. Generate a log file listing the updated codes at '~/Documents/update_log.txt'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_local_procedure_tariffs/setup_task.sh",
    "post_task": "/workspace/tasks/update_local_procedure_tariffs/export_result.sh"
  },
  "metadata": {
    "csv_path": "/home/ga/Documents/tariffs_2025.csv",
    "log_path": "/home/ga/Documents/update_log.txt",
    "database": "DrTuxTest",
    "table": "CCAM_Local_Tarifs",
    "target_updates": {
      "CS": 30.0,
      "APC": 55.0,
      "K": 20.0,
      "IMP": 25.5
    },
    "control_values": {
      "C": 25.0,
      "V": 33.0,
      "COE": 46.0
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_local_procedure_tariffs"
    }
  }
}
