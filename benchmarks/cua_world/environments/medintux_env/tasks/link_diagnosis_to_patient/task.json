{
  "id": "link_diagnosis_to_patient@1",
  "version": "1.0",
  "env_id": "medintux_env@0.1",
  "description": "Assign the CIM-10 code 'I10' (Hypertension artérielle essentielle) to the medical dossier of patient 'DUBOIS Marie' (born 1958-06-12) in MedinTux. Save the patient name, the code 'I10', and the diagnosis label on separate lines to /home/ga/diagnosis_result.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/link_diagnosis_to_patient/setup_task.sh",
    "post_task": "/workspace/tasks/link_diagnosis_to_patient/export_result.sh"
  },
  "metadata": {
    "patient_nom": "DUBOIS",
    "patient_prenom": "Marie",
    "target_code": "I10",
    "target_label_keyword": "Hypertension",
    "output_file": "/home/ga/diagnosis_result.txt",
    "database_name": "DrTuxTest"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_link_diagnosis"
    }
  }
}
