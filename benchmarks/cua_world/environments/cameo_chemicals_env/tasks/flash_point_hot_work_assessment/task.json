{
  "id": "flash_point_hot_work_assessment@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "Using CAMEO Chemicals (https://cameochemicals.noaa.gov/), generate a flash point assessment for Acetone, Methanol, Toluene, Xylenes, Acetic acid (glacial), and Ethylene glycol. The assessment must rank the chemicals from most hazardous (lowest flash point) to least hazardous and classify each as 'HIGH RISK' (flash point below 100°F) or 'LOWER RISK' (flash point 100°F or above). Save the results to /home/ga/Documents/hot_work_flash_point_assessment.txt using the format:\nRANKING (most hazardous to least hazardous):\n1. [Chemical] | Flash Point: [Value] °F | [RISK]\n...\nHIGH RISK COUNT",
  "difficulty": "medium",
  "tags": [
    "cameo",
    "flash-point",
    "ranking",
    "safety",
    "hot-work",
    "classification"
  ],
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/flash_point_hot_work_assessment/setup_task.sh",
    "post_task": "/workspace/tasks/flash_point_hot_work_assessment/export_result.sh"
  },
  "metadata": {
    "output_path": "/home/ga/Documents/hot_work_flash_point_assessment.txt",
    "threshold_temp_f": 100,
    "chemicals": {
      "Acetone": {
        "expected_flash_f": -4,
        "tolerance": 10,
        "classification": "HIGH RISK"
      },
      "Toluene": {
        "expected_flash_f": 40,
        "tolerance": 10,
        "classification": "HIGH RISK"
      },
      "Methanol": {
        "expected_flash_f": 52,
        "tolerance": 10,
        "classification": "HIGH RISK"
      },
      "Xylenes": {
        "expected_flash_f": 81,
        "tolerance": 10,
        "classification": "HIGH RISK"
      },
      "Acetic acid": {
        "expected_flash_f": 104,
        "tolerance": 10,
        "classification": "LOWER RISK",
        "aliases": [
          "Acetic acid, glacial"
        ]
      },
      "Ethylene glycol": {
        "expected_flash_f": 232,
        "tolerance": 15,
        "classification": "LOWER RISK"
      }
    },
    "expected_high_risk_count": 4,
    "expected_order": [
      "Acetone",
      "Toluene",
      "Methanol",
      "Xylenes",
      "Acetic acid",
      "Ethylene glycol"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_flash_point_assessment"
    }
  }
}
