{
  "id": "legacy_chemical_inventory_standardization@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "You are an EHS manager standardizing an old chemical inventory. Using the list of 6 common chemical names in 'legacy_inventory_list.txt' on the Desktop, find the official Standard Name, CAS Number, and UN/NA Number for each using the CAMEO Chemicals website (https://cameochemicals.noaa.gov/). Create a standardized inventory CSV file at '~/Documents/standardized_inventory.csv' containing a header row and 6 data rows with the columns: 'Input Name', 'Standard Name', 'CAS Number', 'UN Number'.",
  "difficulty": "medium",
  "tags": [
    "cameo",
    "data-entry",
    "csv",
    "chemistry",
    "normalization"
  ],
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/legacy_chemical_inventory_standardization/setup_task.sh",
    "post_task": "/workspace/tasks/legacy_chemical_inventory_standardization/export_result.sh"
  },
  "metadata": {
    "input_list_path": "/home/ga/Desktop/legacy_inventory_list.txt",
    "expected_output_path": "/home/ga/Documents/standardized_inventory.csv",
    "required_columns": [
      "Input Name",
      "Standard Name",
      "CAS Number",
      "UN Number"
    ],
    "ground_truth": {
      "muriatic acid": {
        "cas": "7647-01-0",
        "un": "1789"
      },
      "caustic soda": {
        "cas": "1310-73-2",
        "un": "1823"
      },
      "wood alcohol": {
        "cas": "67-56-1",
        "un": "1230"
      },
      "mek": {
        "cas": "78-93-3",
        "un": "1193"
      },
      "oil of vitriol": {
        "cas": "7664-93-9",
        "un": "1830"
      },
      "dry ice": {
        "cas": "124-38-9",
        "un": "1845"
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_legacy_inventory"
    }
  }
}
