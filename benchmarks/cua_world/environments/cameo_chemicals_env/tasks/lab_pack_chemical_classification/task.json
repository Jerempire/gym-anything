{
  "id": "lab_pack_chemical_classification@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "Create a 'Lab Pack Inventory' for hazardous waste disposal by researching five chemicals on the CAMEO Chemicals website (https://cameochemicals.noaa.gov/): Allyl Alcohol, Phosphorus Oxychloride, Potassium Permanganate, Triethylamine, and Divinylbenzene. Generate a CSV file at '~/Documents/lab_pack_inventory.csv' with the header 'Chemical Name,UN Number,DOT Hazard Class,Reactive Group' containing the corresponding data from each chemical's datasheet.",
  "difficulty": "medium",
  "tags": [
    "cameo",
    "chemicals",
    "hazmat",
    "lab-pack",
    "compliance",
    "csv"
  ],
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/lab_pack_chemical_classification/setup_task.sh",
    "post_task": "/workspace/tasks/lab_pack_chemical_classification/export_result.sh"
  },
  "metadata": {
    "output_file_path": "/home/ga/Documents/lab_pack_inventory.csv",
    "expected_chemicals": [
      {
        "name": "Allyl Alcohol",
        "un": "1098",
        "class": "6.1",
        "group": "Alcohols and Glycols"
      },
      {
        "name": "Phosphorus Oxychloride",
        "un": "1810",
        "class": "8",
        "group": "Acids, Strong Non-oxidizing"
      },
      {
        "name": "Potassium Permanganate",
        "un": "1490",
        "class": "5.1",
        "group": "Oxidizing Agents, Strong"
      },
      {
        "name": "Triethylamine",
        "un": "1296",
        "class": "3",
        "group": "Amines, Aliphatic and Aromatic"
      },
      {
        "name": "Divinylbenzene",
        "un": "1993",
        "class": "3",
        "group": "Hydrocarbons, Aromatic"
      }
    ],
    "scoring": {
      "file_exists": 10,
      "correct_headers": 5,
      "per_chemical_points": 17
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_lab_pack_inventory"
    }
  }
}
