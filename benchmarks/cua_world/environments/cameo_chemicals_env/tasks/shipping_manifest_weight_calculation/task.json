{
  "id": "shipping_manifest_weight_calculation@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "Create a shipping manifest at /home/ga/Documents/shipping_manifest.txt for a shipment of five liquid chemicals: Acetone (200 L), Sulfuric Acid (50 L), Toluene (150 L), Ethylene Glycol (100 L), and Carbon Tetrachloride (30 L). Use CAMEO Chemicals (https://cameochemicals.noaa.gov/) to determine the mass in kilograms for each chemical based on its specific gravity. The manifest must include the calculated weight for each item, the total shipment weight, and identify the heaviest single item.",
  "difficulty": "medium",
  "tags": [
    "cameo",
    "logistics",
    "calculation",
    "data-entry",
    "search"
  ],
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/shipping_manifest_weight_calculation/setup_task.sh",
    "post_task": "/workspace/tasks/shipping_manifest_weight_calculation/export_result.sh"
  },
  "metadata": {
    "expected_output_file": "/home/ga/Documents/shipping_manifest.txt",
    "chemicals": {
      "Acetone": {
        "volume": 200,
        "sg_target": 0.79,
        "sg_tolerance": 0.15
      },
      "Sulfuric Acid": {
        "volume": 50,
        "sg_target": 1.84,
        "sg_tolerance": 0.15
      },
      "Toluene": {
        "volume": 150,
        "sg_target": 0.87,
        "sg_tolerance": 0.15
      },
      "Ethylene Glycol": {
        "volume": 100,
        "sg_target": 1.11,
        "sg_tolerance": 0.15
      },
      "Carbon Tetrachloride": {
        "volume": 30,
        "sg_target": 1.59,
        "sg_tolerance": 0.15
      }
    },
    "expected_heaviest": "Acetone"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_shipping_manifest"
    }
  }
}
