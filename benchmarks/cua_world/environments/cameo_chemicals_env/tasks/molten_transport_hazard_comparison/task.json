{
  "id": "molten_transport_hazard_comparison@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "Using CAMEO Chemicals (https://cameochemicals.noaa.gov/), identify the UN Number and ERG Guide Number for both the solid (or default) and molten forms of Sulfur, Naphthalene, Phenol, and Phosphorus (White). Record these values in a CSV file at '~/Desktop/molten_hazards.csv' with the header 'Chemical,Solid_UN,Solid_Guide,Molten_UN,Molten_Guide'.",
  "difficulty": "medium",
  "tags": [
    "cameo",
    "chemicals",
    "transport",
    "hazmat",
    "molten",
    "comparison"
  ],
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/molten_transport_hazard_comparison/setup_task.sh",
    "post_task": "/workspace/tasks/molten_transport_hazard_comparison/export_result.sh"
  },
  "metadata": {
    "output_path": "/home/ga/Desktop/molten_hazards.csv",
    "expected_header": [
      "Chemical",
      "Solid_UN",
      "Solid_Guide",
      "Molten_UN",
      "Molten_Guide"
    ],
    "ground_truth": {
      "Sulfur": {
        "solid": {
          "un": "1350",
          "guide": "133"
        },
        "molten": {
          "un": "2448",
          "guide": "128"
        }
      },
      "Naphthalene": {
        "solid": {
          "un": "1334",
          "guide": "133"
        },
        "molten": {
          "un": "2304",
          "guide": "128"
        }
      },
      "Phenol": {
        "solid": {
          "un": "1671",
          "guide": "153"
        },
        "molten": {
          "un": "2312",
          "guide": "153"
        }
      },
      "Phosphorus": {
        "solid": {
          "un": "1381",
          "guide": "136"
        },
        "molten": {
          "un": "2447",
          "guide": "136"
        }
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_molten_transport_hazard_comparison"
    }
  }
}
