{
  "id": "dot_shipping_classification@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "Compile a DOT shipping classification report for Acetone, Sulfuric Acid, Sodium Cyanide, Potassium Permanganate, and Sodium using the CAMEO Chemicals website (https://cameochemicals.noaa.gov/). For each chemical, record the UN/NA Number, DOT Hazard Class, and Packing Group. Save the report to ~/Desktop/dot_shipping_report.txt, listing each chemical name followed by its classification details.",
  "difficulty": "medium",
  "tags": [
    "cameo",
    "dot",
    "shipping",
    "hazmat",
    "compliance",
    "classification",
    "un-number"
  ],
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/dot_shipping_classification/setup_task.sh",
    "post_task": "/workspace/tasks/dot_shipping_classification/export_result.sh"
  },
  "metadata": {
    "output_file": "/home/ga/Desktop/dot_shipping_report.txt",
    "chemicals": [
      {
        "name": "Acetone",
        "un": "1090",
        "class": "3",
        "pg": "II"
      },
      {
        "name": "Sulfuric Acid",
        "un": "1830",
        "class": "8",
        "pg": "II"
      },
      {
        "name": "Sodium Cyanide",
        "un": "1689",
        "class": "6.1",
        "pg": "I"
      },
      {
        "name": "Potassium Permanganate",
        "un": "1490",
        "class": "5.1",
        "pg": "II"
      },
      {
        "name": "Sodium",
        "un": "1428",
        "class": "4.3",
        "pg": "I"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_dot_shipping_classification"
    }
  }
}
