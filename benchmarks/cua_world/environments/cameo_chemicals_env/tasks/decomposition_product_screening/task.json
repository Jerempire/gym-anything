{
  "id": "decomposition_product_screening@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "You are helping a hazmat team captain prepare a pre-incident plan for a chemical distribution warehouse. The captain needs to know what toxic decomposition products each stored chemical could release if involved in a fire. Using the CAMEO Chemicals website (https://cameochemicals.noaa.gov/), identify the hazardous decomposition products for the following chemicals:\n\n- Sodium Azide (CAS 26628-22-8)\n- Carbon Disulfide (CAS 75-15-0)\n- Methyl Isocyanate (CAS 624-83-9)\n- Phosphorus Trichloride (CAS 7719-12-2)\n\nCreate a report at ~/Documents/decomposition_report.txt including the chemical name, CAS number, and the hazardous decomposition products for each chemical in clearly labeled sections.",
  "difficulty": "medium",
  "category": "chemical_safety",
  "tags": [
    "cameo",
    "hazmat",
    "reactivity",
    "research",
    "report-generation"
  ],
  "init": {
    "timeout_sec": 1200,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/decomposition_product_screening/setup_task.sh",
    "post_task": "/workspace/tasks/decomposition_product_screening/export_result.sh"
  },
  "metadata": {
    "output_path": "/home/ga/Documents/decomposition_report.txt",
    "chemicals": [
      {
        "name": "Sodium Azide",
        "cas": "26628-22-8",
        "expected_terms": [
          "nitrogen",
          "sodium oxide",
          "sodium hydroxide",
          "toxic fumes"
        ]
      },
      {
        "name": "Carbon Disulfide",
        "cas": "75-15-0",
        "expected_terms": [
          "sulfur dioxide",
          "sulfur oxide",
          "carbon monoxide",
          "SO2",
          "CO"
        ]
      },
      {
        "name": "Methyl Isocyanate",
        "cas": "624-83-9",
        "expected_terms": [
          "hydrogen cyanide",
          "nitrogen oxide",
          "carbon monoxide",
          "HCN",
          "NOx"
        ]
      },
      {
        "name": "Phosphorus Trichloride",
        "cas": "7719-12-2",
        "expected_terms": [
          "hydrogen chloride",
          "hydrochloric acid",
          "phosphorus oxide",
          "phosphoric acid",
          "HCl"
        ]
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_decomposition_product_screening"
    }
  }
}
