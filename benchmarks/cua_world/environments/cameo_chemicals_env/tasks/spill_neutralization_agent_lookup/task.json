{
  "id": "spill_neutralization_agent_lookup@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "Research spill neutralization agents for hazardous materials using the CAMEO Chemicals website (https://cameochemicals.noaa.gov/). Identify the specific neutralizing agents recommended in the 'Non-Fire Response' section for the following chemicals:\n\n1. Nitric Acid, Red Fuming (CAS 7697-37-2)\n2. Sodium Hydroxide, Solution (CAS 1310-73-2)\n3. Hydrofluoric Acid (CAS 7664-39-3)\n4. Hydrazine, Anhydrous (CAS 302-01-2)\n5. Toluene (CAS 108-88-3)\n\nCreate a CSV file at '~/Documents/neutralizer_inventory.csv' with the header 'Chemical,Recommended_Neutralizers'. For each chemical, list the neutralizing agents found in the 'Non-Fire Response' section. If the datasheet does not recommend a specific neutralizing agent (e.g., it only provides absorption or diking instructions), record 'None'.",
  "difficulty": "medium",
  "tags": [
    "cameo",
    "hazmat",
    "neutralization",
    "research",
    "csv"
  ],
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/spill_neutralization_agent_lookup/setup_task.sh",
    "post_task": "/workspace/tasks/spill_neutralization_agent_lookup/export_result.sh"
  },
  "metadata": {
    "output_path": "/home/ga/Documents/neutralizer_inventory.csv",
    "chemicals": [
      {
        "name": "Nitric Acid, Red Fuming",
        "cas": "7697-37-2",
        "keywords": [
          "lime",
          "soda ash",
          "bicarbonate",
          "base"
        ],
        "type": "acid"
      },
      {
        "name": "Sodium Hydroxide, Solution",
        "cas": "1310-73-2",
        "keywords": [
          "dilute acid",
          "vinegar",
          "acetic"
        ],
        "type": "base"
      },
      {
        "name": "Hydrofluoric Acid",
        "cas": "7664-39-3",
        "keywords": [
          "calcium",
          "lime",
          "hydroxide"
        ],
        "type": "acid_special"
      },
      {
        "name": "Hydrazine, Anhydrous",
        "cas": "302-01-2",
        "keywords": [
          "hypochlorite",
          "acid",
          "hth"
        ],
        "type": "reactive"
      },
      {
        "name": "Toluene",
        "cas": "108-88-3",
        "keywords": [
          "none",
          "n/a",
          "absorb"
        ],
        "forbidden": [
          "lime",
          "acid",
          "base",
          "vinegar"
        ],
        "type": "solvent"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_spill_neutralization_agent_lookup"
    }
  }
}
