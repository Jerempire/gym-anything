{
  "id": "isomer_physical_state_differentiation@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "Determine whether the three isomers of Dichlorobenzene (1,2-, 1,3-, and 1,4-) in CAMEO Chemicals are liquid or solid at a standard ambient temperature of 20°C (68°F) based on their melting points. Create a summary file at ~/Documents/isomer_analysis.txt listing each isomer's Name, CAS Number, Melting Point, and Physical State (Liquid/Solid).",
  "difficulty": "medium",
  "tags": [
    "cameo",
    "chemistry",
    "isomers",
    "physical-properties",
    "melting-point",
    "phase-change"
  ],
  "init": {
    "timeout_sec": 420,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/isomer_physical_state_differentiation/setup_task.sh",
    "post_task": "/workspace/tasks/isomer_physical_state_differentiation/export_result.sh"
  },
  "metadata": {
    "output_path": "/home/ga/Documents/isomer_analysis.txt",
    "ambient_temp_c": 20,
    "isomers": {
      "1,2-Dichlorobenzene": {
        "cas": "95-50-1",
        "mp_c_approx": -17,
        "state_at_20c": "LIQUID",
        "keywords": [
          "1,2",
          "ortho",
          "o-dichlorobenzene"
        ]
      },
      "1,3-Dichlorobenzene": {
        "cas": "541-73-1",
        "mp_c_approx": -24.8,
        "state_at_20c": "LIQUID",
        "keywords": [
          "1,3",
          "meta",
          "m-dichlorobenzene"
        ]
      },
      "1,4-Dichlorobenzene": {
        "cas": "106-46-7",
        "mp_c_approx": 53,
        "state_at_20c": "SOLID",
        "keywords": [
          "1,4",
          "para",
          "p-dichlorobenzene"
        ]
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_isomer_physical_state"
    }
  }
}
