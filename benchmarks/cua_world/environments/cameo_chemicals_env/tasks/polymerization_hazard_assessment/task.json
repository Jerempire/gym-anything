{
  "id": "polymerization_hazard_assessment@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "Assess Styrene, Acrylic Acid, Vinyl Acetate, Acetone, Methyl Methacrylate, and Toluene on the CAMEO Chemicals website (https://cameochemicals.noaa.gov/) to determine if they can undergo hazardous polymerization and identify any triggering conditions. Create a CSV file at '~/Documents/polymerization_assessment.csv' with the columns: 'Chemical Name', 'CAS Number', 'Polymerization Hazard' (YES/NO), and 'Triggering Conditions' (list conditions for YES, or N/A for NO).",
  "difficulty": "medium",
  "tags": [
    "cameo",
    "polymerization",
    "reactivity",
    "research",
    "csv"
  ],
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/polymerization_hazard_assessment/setup_task.sh",
    "post_task": "/workspace/tasks/polymerization_hazard_assessment/export_result.sh"
  },
  "metadata": {
    "output_path": "/home/ga/Documents/polymerization_assessment.csv",
    "ground_truth": {
      "styrene": {
        "cas": "100-42-5",
        "polymerizes": true,
        "triggers": [
          "heat",
          "peroxid",
          "inhibitor",
          "catalyst"
        ]
      },
      "acrylic acid": {
        "cas": "79-10-7",
        "polymerizes": true,
        "triggers": [
          "heat",
          "peroxid",
          "light",
          "inhibitor"
        ]
      },
      "vinyl acetate": {
        "cas": "108-05-4",
        "polymerizes": true,
        "triggers": [
          "heat",
          "light",
          "peroxid"
        ]
      },
      "acetone": {
        "cas": "67-64-1",
        "polymerizes": false,
        "triggers": []
      },
      "methyl methacrylate": {
        "cas": "80-62-6",
        "polymerizes": true,
        "triggers": [
          "heat",
          "light",
          "peroxid",
          "inhibitor"
        ]
      },
      "toluene": {
        "cas": "108-88-3",
        "polymerizes": false,
        "triggers": []
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_polymerization_hazard_assessment"
    }
  }
}
