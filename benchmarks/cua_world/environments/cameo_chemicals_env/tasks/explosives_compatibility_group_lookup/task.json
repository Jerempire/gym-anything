{
  "id": "explosives_compatibility_group_lookup@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "Research the following UN numbers on CAMEO Chemicals (https://cameochemicals.noaa.gov/): UN 0029, UN 0065, UN 0241, UN 0456, and UN 0331. For each item, identify the Proper Shipping Name, DOT Hazard Class, and the Compatibility Group letter from the Hazmat Table (49 CFR 172.101). Create a CSV file at ~/Documents/explosives_manifest.csv with the header UN_Number,Proper_Shipping_Name,Hazard_Class,Compatibility_Group. The Compatibility_Group column must contain only the single letter suffix from the hazard class.",
  "difficulty": "medium",
  "tags": [
    "cameo",
    "explosives",
    "dot",
    "hazmat",
    "compatibility-group",
    "regulatory"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/explosives_compatibility_group_lookup/setup_task.sh",
    "post_task": "/workspace/tasks/explosives_compatibility_group_lookup/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/explosives_manifest.csv",
    "items": [
      {
        "un": "0029",
        "class": "1.1B",
        "group": "B",
        "name_keywords": [
          "Detonators",
          "non-electric"
        ]
      },
      {
        "un": "0065",
        "class": "1.1D",
        "group": "D",
        "name_keywords": [
          "Cord",
          "detonating"
        ]
      },
      {
        "un": "0241",
        "class": "1.1D",
        "group": "D",
        "name_keywords": [
          "Explosive",
          "blasting"
        ]
      },
      {
        "un": "0456",
        "class": "1.4S",
        "group": "S",
        "name_keywords": [
          "Detonators",
          "electric"
        ]
      },
      {
        "un": "0331",
        "class": "1.5D",
        "group": "D",
        "name_keywords": [
          "Explosive",
          "blasting"
        ]
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_explosives_compatibility"
    }
  }
}
