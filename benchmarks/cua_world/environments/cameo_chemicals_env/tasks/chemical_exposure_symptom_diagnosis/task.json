{
  "id": "chemical_exposure_symptom_diagnosis@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "As a Site Safety Officer, diagnose three chemical exposure incidents (A, B, and C) described in 'incident_reports.txt' on the Desktop. Using the CAMEO Chemicals website (https://cameochemicals.noaa.gov/), research the 'Health Hazards' of the chemicals in the facility's inventory to identify which chemical is responsible for each incident based on reported symptoms. Create a diagnosis report at '/home/ga/Documents/exposure_diagnosis_report.txt' that identifies the suspected chemical for each incident and includes a supporting quote from the datasheet.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/chemical_exposure_symptom_diagnosis/setup_task.sh",
    "post_task": "/workspace/tasks/chemical_exposure_symptom_diagnosis/export_result.sh"
  },
  "metadata": {
    "output_path": "/home/ga/Documents/exposure_diagnosis_report.txt",
    "incident_data_path": "/home/ga/Desktop/incident_reports.txt",
    "inventory": [
      "Hydrogen Sulfide",
      "Hydrofluoric Acid",
      "Phenol",
      "Nitrogen Dioxide",
      "Sulfuric Acid"
    ],
    "answers": {
      "Incident A": {
        "chemical": "Hydrogen Sulfide",
        "keywords": [
          "olfactory",
          "smell",
          "fatigue",
          "sense",
          "rotten"
        ]
      },
      "Incident B": {
        "chemical": "Hydrofluoric Acid",
        "keywords": [
          "delayed",
          "deep",
          "hours",
          "calcification",
          "hypocalcemia"
        ]
      },
      "Incident C": {
        "chemical": "Phenol",
        "keywords": [
          "white",
          "blanching",
          "numb",
          "anesthetic"
        ]
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_chemical_exposure_symptom_diagnosis"
    }
  }
}
