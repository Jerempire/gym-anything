{
  "id": "physical_description_field_id@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "Compile a physical description reference document for Bromine, Potassium permanganate, Hydrazine, Carbon disulfide, and Titanium tetrachloride using the CAMEO Chemicals website (https://cameochemicals.noaa.gov/). For each chemical, record the Physical State, Color, Odor, Boiling Point (in both °F and °C), and Melting/Freezing Point (in both °F and °C). Save the compiled information, organized by chemical name, to ~/Desktop/field_id_reference.txt.",
  "difficulty": "medium",
  "tags": [
    "cameo",
    "research",
    "data-entry",
    "physical-properties",
    "hazmat"
  ],
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/physical_description_field_id/setup_task.sh",
    "post_task": "/workspace/tasks/physical_description_field_id/export_result.sh"
  },
  "metadata": {
    "output_file": "/home/ga/Desktop/field_id_reference.txt",
    "chemicals": [
      {
        "name": "Bromine",
        "keywords": {
          "state": [
            "liquid"
          ],
          "color": [
            "reddish-brown",
            "dark red",
            "red-brown"
          ],
          "odor": [
            "suffocating",
            "irritating",
            "pungent"
          ],
          "bp_f": 138,
          "bp_c": 59,
          "mp_f": 19,
          "mp_c": -7
        }
      },
      {
        "name": "Potassium permanganate",
        "keywords": {
          "state": [
            "solid",
            "crystalline"
          ],
          "color": [
            "purple",
            "dark purple",
            "bronze"
          ],
          "odor": [
            "odorless"
          ],
          "bp_text": [
            "decomposes"
          ],
          "mp_f": 464,
          "mp_c": 240
        }
      },
      {
        "name": "Hydrazine",
        "keywords": {
          "state": [
            "liquid"
          ],
          "color": [
            "colorless",
            "clear"
          ],
          "odor": [
            "ammonia",
            "fishy"
          ],
          "bp_f": 236,
          "bp_c": 113,
          "mp_f": 35,
          "mp_c": 2
        }
      },
      {
        "name": "Carbon disulfide",
        "keywords": {
          "state": [
            "liquid"
          ],
          "color": [
            "colorless",
            "clear",
            "yellow"
          ],
          "odor": [
            "sweet",
            "ether",
            "pleasant",
            "rotten",
            "foul"
          ],
          "bp_f": 115,
          "bp_c": 46,
          "mp_f": -169,
          "mp_c": -112
        }
      },
      {
        "name": "Titanium tetrachloride",
        "keywords": {
          "state": [
            "liquid"
          ],
          "color": [
            "colorless",
            "yellow",
            "light yellow"
          ],
          "odor": [
            "acrid",
            "sharp",
            "fumes"
          ],
          "bp_f": 277,
          "bp_c": 136,
          "mp_f": -11,
          "mp_c": -24
        }
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_physical_description_field_id"
    }
  }
}
