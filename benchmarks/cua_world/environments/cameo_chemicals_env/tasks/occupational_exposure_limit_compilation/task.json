{
  "id": "occupational_exposure_limit_compilation@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "Using CAMEO Chemicals (https://cameochemicals.noaa.gov/), find the OSHA PEL and NIOSH IDLH values for Hydrogen Cyanide, Ammonia, Carbon Monoxide, Chlorine, and Methyl Ethyl Ketone. Create a report at ~/Documents/exposure_limits_report.txt listing the name, OSHA PEL (value and units), and IDLH (value and units) for each chemical. Identify the chemical with the lowest IDLH value at the end of the file using the format 'LOWEST_IDLH: <Chemical Name>'.",
  "difficulty": "medium",
  "tags": [
    "cameo",
    "osha",
    "niosh",
    "safety",
    "exposure-limits",
    "data-extraction"
  ],
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/occupational_exposure_limit_compilation/setup_task.sh",
    "post_task": "/workspace/tasks/occupational_exposure_limit_compilation/export_result.sh"
  },
  "metadata": {
    "report_path": "/home/ga/Documents/exposure_limits_report.txt",
    "lowest_idlh_chemical": "Chlorine",
    "chemicals": [
      {
        "name": "Hydrogen Cyanide",
        "pel_val": 10,
        "idlh_val": 50,
        "regex_name": "Hydrogen\\s*Cyanide"
      },
      {
        "name": "Ammonia",
        "pel_val": 50,
        "idlh_val": 300,
        "regex_name": "Ammonia"
      },
      {
        "name": "Carbon Monoxide",
        "pel_val": 50,
        "idlh_val": 1200,
        "regex_name": "Carbon\\s*Monoxide"
      },
      {
        "name": "Chlorine",
        "pel_val": 1,
        "idlh_val": 10,
        "regex_name": "Chlorine"
      },
      {
        "name": "Methyl Ethyl Ketone",
        "pel_val": 200,
        "idlh_val": 3000,
        "regex_name": "Methyl\\s*Ethyl\\s*Ketone|MEK|2-Butanone"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_occupational_exposure_limit_compilation"
    }
  }
}
