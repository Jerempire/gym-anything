{
  "id": "fire_fighting_foam_compatibility_audit@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "You are a Fire Marshal auditing a chemical storage facility's fire suppression systems. Using CAMEO Chemicals (https://cameochemicals.noaa.gov/), identify the ERG Guide Number and determine whether Alcohol-Resistant (AR-AFFF) foam is required or if standard foam is sufficient for the following chemicals:\n\n1. Acetone\n2. Benzene\n3. Isopropyl Alcohol\n4. n-Hexane\n5. Methyl Ethyl Ketone (2-Butanone)\n6. Turpentine\n\nCreate a report at '~/Documents/foam_audit.txt' with the following format for each chemical:\n\n[Chemical Name]\nERG Guide: [Number]\nRequirement: [AR-AFFF REQUIRED / STANDARD AFFF SUFFICIENT]\n\nExample:\nEthanol\nERG Guide: 127\nRequirement: AR-AFFF REQUIRED",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 360,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/fire_fighting_foam_compatibility_audit/setup_task.sh",
    "post_task": "/workspace/tasks/fire_fighting_foam_compatibility_audit/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/foam_audit.txt",
    "chemicals": [
      {
        "name": "Acetone",
        "erg": "127",
        "type": "AR-AFFF REQUIRED",
        "keywords": [
          "127",
          "alcohol-resistant",
          "AR-AFFF"
        ]
      },
      {
        "name": "Benzene",
        "erg": "130",
        "type": "STANDARD AFFF SUFFICIENT",
        "keywords": [
          "130",
          "regular foam",
          "standard"
        ]
      },
      {
        "name": "Isopropyl Alcohol",
        "erg": "129",
        "type": "AR-AFFF REQUIRED",
        "keywords": [
          "129",
          "alcohol-resistant",
          "AR-AFFF"
        ]
      },
      {
        "name": "n-Hexane",
        "erg": "128",
        "type": "STANDARD AFFF SUFFICIENT",
        "keywords": [
          "128",
          "regular foam",
          "standard"
        ]
      },
      {
        "name": "Methyl Ethyl Ketone",
        "erg": "127",
        "type": "AR-AFFF REQUIRED",
        "keywords": [
          "127",
          "alcohol-resistant",
          "AR-AFFF"
        ]
      },
      {
        "name": "Turpentine",
        "erg": "128",
        "type": "STANDARD AFFF SUFFICIENT",
        "keywords": [
          "128",
          "regular foam",
          "standard"
        ]
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_fire_fighting_foam_compatibility_audit"
    }
  }
}
