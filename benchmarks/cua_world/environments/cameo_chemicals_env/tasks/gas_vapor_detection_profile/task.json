{
  "id": "gas_vapor_detection_profile@1",
  "version": "1.0",
  "env_id": "cameo_chemicals_env@0.1",
  "description": "Research and compile a sensory detection profile report for Chlorine, Carbon Monoxide, Hydrogen Sulfide, Nitrogen Dioxide, Phosgene, and Ammonia using CAMEO Chemicals (https://cameochemicals.noaa.gov/). For each chemical, document the appearance/color, odor description, vapor density relative to air, and an assessment of whether the chemical provides adequate sensory warning to humans before dangerous levels are reached (including brief justification regarding olfactory fatigue or odor thresholds). Save the compiled report to /home/ga/Desktop/gas_detection_profiles.txt.",
  "difficulty": "medium",
  "tags": [
    "cameo",
    "research",
    "hazmat",
    "safety",
    "chemicals",
    "sensory-warning"
  ],
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/gas_vapor_detection_profile/setup_task.sh",
    "post_task": "/workspace/tasks/gas_vapor_detection_profile/export_result.sh"
  },
  "metadata": {
    "output_path": "/home/ga/Desktop/gas_detection_profiles.txt",
    "required_chemicals": [
      "Chlorine",
      "Carbon Monoxide",
      "Hydrogen Sulfide",
      "Nitrogen Dioxide",
      "Phosgene",
      "Ammonia"
    ],
    "ground_truth": {
      "Chlorine": {
        "color": [
          "green",
          "yellow"
        ],
        "odor": [
          "bleach",
          "pungent"
        ],
        "density": [
          "heavier"
        ],
        "warning": "yes"
      },
      "Carbon Monoxide": {
        "color": [
          "colorless"
        ],
        "odor": [
          "odorless"
        ],
        "density": [
          "lighter",
          "approximate",
          "same"
        ],
        "warning": "no"
      },
      "Hydrogen Sulfide": {
        "color": [
          "colorless"
        ],
        "odor": [
          "rotten",
          "egg"
        ],
        "density": [
          "heavier"
        ],
        "warning": "no",
        "risk_keywords": [
          "fatigue",
          "desensitize",
          "paralyze"
        ]
      },
      "Nitrogen Dioxide": {
        "color": [
          "red",
          "brown"
        ],
        "odor": [
          "pungent",
          "acrid"
        ],
        "density": [
          "heavier"
        ],
        "warning": "yes"
      },
      "Phosgene": {
        "color": [
          "colorless"
        ],
        "odor": [
          "hay",
          "grass",
          "corn",
          "musty"
        ],
        "density": [
          "heavier"
        ],
        "warning": "no",
        "risk_keywords": [
          "threshold",
          "delayed",
          "insidious"
        ]
      },
      "Ammonia": {
        "color": [
          "colorless"
        ],
        "odor": [
          "pungent",
          "sharp"
        ],
        "density": [
          "lighter"
        ],
        "warning": "yes"
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_gas_detection_profile"
    }
  }
}
