{
  "id": "cameo_chemicals_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "CAMEO Chemicals environment for hazardous materials lookup, chemical reactivity prediction, and emergency response planning using the NOAA/EPA CAMEO Chemicals web application.",
  "category": ["web", "browser", "chemistry", "safety"],
  "tags": ["cameo", "chemicals", "hazmat", "reactivity", "emergency-response", "noaa", "epa", "firefox"],
  "resources": {
    "cpu": 4,
    "mem_gb": 4,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "mounts": [
    {"source": "benchmarks/cua_world/environments/cameo_chemicals_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/cameo_chemicals_env/data", "target": "/workspace/data", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/cameo_chemicals_env/tasks", "target": "/workspace/tasks", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_cameo_chemicals.sh",
    "post_start": "/workspace/scripts/setup_cameo_chemicals.sh"
  },
  "vnc": {
    "enable": true,
    "password": "password"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ]
}
