{
  "id": "establish_document_relations@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Establish semantic relations between documents in the Nuxeo repository by creating three specific Dublin Core relations: 'Annual Report 2023' (in Projects) Is Based On 'Project Proposal' (in Projects); 'Annual Report 2023' (in Projects) References 'Q3 Status Report' (in Projects); and 'Contract Template' (in Templates) Conforms To 'Annual Report 2023' (in Projects). Create a summary file at /home/ga/nuxeo_relations_report.txt listing the relations in the format 'Source Predicate Target' with one relation per line.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/establish_document_relations/setup_task.sh",
    "post_task": "/workspace/tasks/establish_document_relations/export_result.sh"
  },
  "metadata": {
    "expected_report_path": "/home/ga/nuxeo_relations_report.txt",
    "required_relations": [
      {
        "source": "/default-domain/workspaces/Projects/Annual-Report-2023",
        "predicate": "http://purl.org/dc/terms/IsBasedOn",
        "target": "/default-domain/workspaces/Projects/Project-Proposal"
      },
      {
        "source": "/default-domain/workspaces/Projects/Annual-Report-2023",
        "predicate": "http://purl.org/dc/terms/References",
        "target": "/default-domain/workspaces/Projects/Q3-Status-Report"
      },
      {
        "source": "/default-domain/workspaces/Templates/Contract-Template",
        "predicate": "http://purl.org/dc/terms/ConformsTo",
        "target": "/default-domain/workspaces/Projects/Annual-Report-2023"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_establish_document_relations"
    }
  }
}
