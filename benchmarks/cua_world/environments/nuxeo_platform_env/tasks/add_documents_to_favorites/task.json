{
  "id": "add_documents_to_favorites@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Add the 'Annual Report 2023' document from the Projects workspace and the 'Contract Template' document from the Templates workspace to your Favorites. Verify that both documents appear in your Favorites list.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_documents_to_favorites/setup_task.sh",
    "post_task": "/workspace/tasks/add_documents_to_favorites/export_result.sh"
  },
  "metadata": {
    "doc_1_path": "/default-domain/workspaces/Projects/Annual-Report-2023",
    "doc_2_path": "/default-domain/workspaces/Templates/Contract-Template",
    "expected_collection_name": "Favorites"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_documents_to_favorites"
    }
  }
}
