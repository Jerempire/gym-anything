{
  "id": "download_picture_rendition@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "In Nuxeo Platform, download the 'Medium' rendition of the picture asset named 'Launch Day Event' located in the 'Assets' workspace. Do NOT download the original high-resolution file or the thumbnail. Save the downloaded file to '/home/ga/Downloads/event_medium.jpg'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/download_picture_rendition/setup_task.sh",
    "post_task": "/workspace/tasks/download_picture_rendition/export_result.sh"
  },
  "metadata": {
    "download_path": "/home/ga/Downloads/event_medium.jpg",
    "min_width": 400,
    "max_width": 1600,
    "original_min_width": 2500,
    "thumbnail_max_width": 300,
    "source_image_url": "https://upload.wikimedia.org/wikipedia/commons/8/82/Paranal_Platform_After_Sunset_%28ESO%29.jpg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_download_picture_rendition"
    }
  }
}