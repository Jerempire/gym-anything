{
  "id": "create_user_group@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "As an Administrator in the Nuxeo Platform, create a new user group with the ID 'compliance-team' and the label 'Compliance Team'. Assign existing users 'jsmith' and 'mwilson' as members of this group.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_user_group/setup_task.sh",
    "post_task": "/workspace/tasks/create_user_group/export_result.sh"
  },
  "metadata": {
    "target_group_id": "compliance-team",
    "target_group_label": "Compliance Team",
    "target_members": [
      "jsmith",
      "mwilson"
    ],
    "api_endpoint": "http://localhost:8080/nuxeo/api/v1/group/compliance-team"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_user_group"
    }
  }
}
