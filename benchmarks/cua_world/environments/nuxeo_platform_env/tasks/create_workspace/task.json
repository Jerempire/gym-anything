{
  "id": "create_workspace@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "In Nuxeo Platform, create a new Workspace titled 'Marketing Materials' within the 'Workspaces' section of the Default Domain.",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_workspace/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_workspace"
    }
  }
}
