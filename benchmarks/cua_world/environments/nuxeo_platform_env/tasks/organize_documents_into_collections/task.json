{
  "id": "organize_documents_into_collections@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Create two collections named 'Finance Resources' and 'Strategy Resources' in the Projects workspace. Organize the existing documents by adding 'Annual Report 2023' to 'Finance Resources', 'Project Proposal' to 'Strategy Resources', and 'Q3 Status Report' to both collections.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/organize_documents_into_collections/setup_task.sh",
    "post_task": "/workspace/tasks/organize_documents_into_collections/export_result.sh"
  },
  "metadata": {
    "collections": [
      "Finance Resources",
      "Strategy Resources"
    ],
    "assignments": {
      "Annual-Report-2023": [
        "Finance Resources"
      ],
      "Project-Proposal": [
        "Strategy Resources"
      ],
      "Q3-Status-Report": [
        "Finance Resources",
        "Strategy Resources"
      ]
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_organize_documents_into_collections"
    }
  }
}
