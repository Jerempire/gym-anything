{
  "id": "cleanup_obsolete_drafts@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Navigate to the 'Cleanup_Zone' workspace and move all documents described as 'obsolete' or 'superseded' to the Trash. Preserve all documents labeled 'active', 'final', 'approved', or 'permanent'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/cleanup_obsolete_drafts/setup_task.sh",
    "post_task": "/workspace/tasks/cleanup_obsolete_drafts/export_result.sh"
  },
  "metadata": {
    "workspace_path": "/default-domain/workspaces/Cleanup_Zone",
    "targets": {
      "Project-Alpha-Draft-v1": "deleted",
      "Project-Alpha-Draft-v2": "deleted",
      "Project-Alpha-Final": "project",
      "Project-Beta-Draft": "project",
      "Regulatory-Reference": "project"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_cleanup_obsolete_drafts"
    }
  }
}
