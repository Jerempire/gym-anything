{
  "id": "identify_approved_asset@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "In the 'Campaign Assets' workspace, identify which of the two candidate image documents ('Candidate-Alpha' or 'Candidate-Beta') contains the red 'APPROVED' stamp. Rename the approved document to 'Final-Banner' while leaving the 'DRAFT' document unchanged.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/identify_approved_asset/setup_task.sh",
    "post_task": "/workspace/tasks/identify_approved_asset/export_result.sh"
  },
  "metadata": {
    "workspace_path": "/default-domain/workspaces/Campaign-Assets",
    "ground_truth_file": "/tmp/ground_truth.json"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_identify_approved_asset"
    }
  }
}
