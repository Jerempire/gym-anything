{
  "id": "bulk_onboard_clients_conditional@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Onboard the clients listed in '~/Documents/new_clients.txt' into the 'Clients' workspace in Nuxeo. Create a folder for each client using their exact name. For any client whose name ends with 'LLC', apply the 'Corporate' tag to their folder.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bulk_onboard_clients_conditional/setup_task.sh",
    "post_task": "/workspace/tasks/bulk_onboard_clients_conditional/export_result.sh"
  },
  "metadata": {
    "client_list_path": "/home/ga/Documents/new_clients.txt",
    "target_workspace": "/default-domain/workspaces/Clients",
    "expected_clients": [
      {
        "name": "Riverfront Properties",
        "should_tag": false
      },
      {
        "name": "TechGlobal LLC",
        "should_tag": true,
        "expected_tag": "Corporate"
      },
      {
        "name": "Sarah Jenkins",
        "should_tag": false
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bulk_onboard_clients"
    }
  }
}
