{
  "id": "curate_document_topics@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Correct the subject classification for documents in the 'Projects' workspace. Update 'Project Specifications' by removing the 'Art' subject and assigning 'Sciences' instead. For the 'Gallery Brochure' document, assign the 'Art' subject. Ensure all changes are saved.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/curate_document_topics/setup_task.sh",
    "post_task": "/workspace/tasks/curate_document_topics/export_result.sh"
  },
  "metadata": {
    "target_workspace": "/default-domain/workspaces/Projects",
    "doc1_name": "Project-Specifications",
    "doc1_remove": "art",
    "doc1_add": "sciences",
    "doc2_name": "Gallery-Brochure",
    "doc2_add": "art"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_curate_document_topics"
    }
  }
}
