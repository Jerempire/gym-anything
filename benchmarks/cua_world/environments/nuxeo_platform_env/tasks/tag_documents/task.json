{
  "id": "tag_documents@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "In the Nuxeo Platform 'Projects' workspace, add classification tags to three documents: 'Annual Report 2023' (tags: 'annual-report', 'finance', '2023'), 'Project Proposal' (tags: 'proposal', 'project-planning'), and 'Q3 Status Report' (tags: 'quarterly-report', '2023', 'status'). Ensure all changes are saved.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/tag_documents/setup_task.sh",
    "post_task": "/workspace/tasks/tag_documents/export_result.sh"
  },
  "metadata": {
    "documents": {
      "Annual-Report-2023": {
        "path": "/default-domain/workspaces/Projects/Annual-Report-2023",
        "expected_tags": [
          "annual-report",
          "finance",
          "2023"
        ]
      },
      "Project-Proposal": {
        "path": "/default-domain/workspaces/Projects/Project-Proposal",
        "expected_tags": [
          "proposal",
          "project-planning"
        ]
      },
      "Q3-Status-Report": {
        "path": "/default-domain/workspaces/Projects/Q3-Status-Report",
        "expected_tags": [
          "quarterly-report",
          "2023",
          "status"
        ]
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_tag_documents"
    }
  }
}
