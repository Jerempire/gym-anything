{
  "id": "deduplicate_project_files@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "In the 'Finance' workspace, move the 'Q3 Financials' document with the older 'Last Modified' timestamp to the Trash, ensuring the newer version remains active.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/deduplicate_project_files/setup_task.sh",
    "post_task": "/workspace/tasks/deduplicate_project_files/export_result.sh"
  },
  "metadata": {
    "workspace_path": "/default-domain/workspaces/Finance",
    "document_title": "Q3 Financials"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_deduplicate_project_files"
    }
  }
}
