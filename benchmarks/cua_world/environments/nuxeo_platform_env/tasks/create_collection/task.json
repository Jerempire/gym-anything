{
  "id": "create_collection@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "In Nuxeo Platform, create a new Collection named '2024 Planning Documents'. Collections in Nuxeo allow you to group documents from different locations.",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_collection/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_collection"
    }
  }
}
