    "post_task": "/workspace/tasks/update_published_document/export_result.sh"
  },
  "metadata": {
    "target_section_path": "/default-domain/sections/HR-Intranet",
    "source_doc_path": "/default-domain/workspaces/HR-Workspace/Remote-Work-Policy",
