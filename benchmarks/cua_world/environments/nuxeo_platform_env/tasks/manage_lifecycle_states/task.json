{
  "id": "manage_lifecycle_states@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Perform a quarterly compliance review of documents in the 'Projects' workspace. Update the lifecycle state of 'Annual Report 2023' to Approved, 'Project Proposal' to Approved, and 'Q3 Status Report' to Obsolete. Do not modify any other documents.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/manage_lifecycle_states/setup_task.sh",
    "post_task": "/workspace/tasks/manage_lifecycle_states/export_result.sh"
  },
  "metadata": {
    "documents": {
      "Annual-Report-2023": {
        "path": "/default-domain/workspaces/Projects/Annual-Report-2023",
        "expected_state": "approved"
      },
      "Project-Proposal": {
        "path": "/default-domain/workspaces/Projects/Project-Proposal",
        "expected_state": "approved"
      },
      "Q3-Status-Report": {
        "path": "/default-domain/workspaces/Projects/Q3-Status-Report",
        "expected_state": "obsolete"
      },
      "Contract-Template": {
        "path": "/default-domain/workspaces/Templates/Contract-Template",
        "expected_state": "project"
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_manage_lifecycle_states"
    }
  }
}
