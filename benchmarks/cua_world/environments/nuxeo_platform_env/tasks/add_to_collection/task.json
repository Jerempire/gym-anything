{
  "id": "add_to_collection@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "In Nuxeo Platform, add the document 'Annual Report 2023' located in the 'Projects' workspace to the collection named 'Q4 2023 Documents'.",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_to_collection/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_to_collection"
    }
  }
}
