{
  "id": "deactivate_leaver_accounts@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "A new 'Access Termination Request' note has been posted in the Projects workspace. Identify the employees listed for immediate termination and remove their user accounts from the system, ensuring any employees specified for retention are not deleted.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/deactivate_leaver_accounts/setup_task.sh",
    "post_task": "/workspace/tasks/deactivate_leaver_accounts/export_result.sh"
  },
  "metadata": {
    "target_users_to_delete": [
      "mholloway",
      "clille"
    ],
    "target_users_to_keep": [
      "sdhawan"
    ],
    "admin_user": "Administrator",
    "note_path": "/default-domain/workspaces/Projects/Access-Termination-Request"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_deactivate_leaver_accounts"
    }
  }
}
