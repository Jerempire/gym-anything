{
  "id": "instantiate_project_from_template@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Create a new project workspace named 'Project Phoenix' (ID: 'Project-Phoenix') in the 'Projects' workspace by copying the 'Standard Project Template' from the 'Templates' workspace. The final workspace must contain the same folder structure as the template (01-Planning, 02-Financials, 03-Legal).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/instantiate_project_from_template/setup_task.sh",
    "post_task": "/workspace/tasks/instantiate_project_from_template/export_result.sh"
  },
  "metadata": {
    "target_path": "/default-domain/workspaces/Projects/Project-Phoenix",
    "target_title": "Project Phoenix",
    "template_path": "/default-domain/workspaces/Templates/Standard-Project-Template",
    "required_children": [
      "01-Planning",
      "02-Financials",
      "03-Legal"
    ],
    "required_file": "Project-Checklist"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_instantiate_project_from_template"
    }
  }
}
