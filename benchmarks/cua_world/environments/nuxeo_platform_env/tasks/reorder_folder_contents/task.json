{
  "id": "reorder_folder_contents@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Rearrange the documents in the 'Onboarding Checklist' folder within the Projects workspace into the correct numerical sequence: 'Step 1: Preparation', 'Step 2: Training', and 'Step 3: Assessment'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/reorder_folder_contents/setup_task.sh",
    "post_task": "/workspace/tasks/reorder_folder_contents/export_result.sh"
  },
  "metadata": {
    "target_folder_path": "/default-domain/workspaces/Projects/Onboarding-Checklist",
    "expected_order": [
      "Step 1: Preparation",
      "Step 2: Training",
      "Step 3: Assessment"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reorder_folder_contents"
    }
  }
}
