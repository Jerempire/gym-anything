{
  "id": "copy_document_to_workspace@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "As a Document Management Specialist, copy the 'Annual Report 2023' document from the 'Projects' workspace to the 'Templates' workspace. The original document must remain in the 'Projects' workspace, and the new document in 'Templates' must be a distinct copy containing the same file.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/copy_document_to_workspace/setup_task.sh",
    "post_task": "/workspace/tasks/copy_document_to_workspace/export_result.sh"
  },
  "metadata": {
    "original_path": "/default-domain/workspaces/Projects/Annual-Report-2023",
    "target_workspace_path": "/default-domain/workspaces/Templates",
    "document_title": "Annual Report 2023"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_copy_document_to_workspace"
    }
  }
}
