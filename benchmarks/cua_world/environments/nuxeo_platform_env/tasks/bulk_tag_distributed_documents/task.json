{
  "id": "bulk_tag_distributed_documents@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Tag all documents containing the phrase 'Legacy Policy' in their title with the tag 'to_archive'. Do not apply this tag to any 'Active Policy' documents.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bulk_tag_distributed_documents/setup_task.sh",
    "post_task": "/workspace/tasks/bulk_tag_distributed_documents/export_result.sh"
  },
  "metadata": {
    "target_tag": "to_archive",
    "targets": [
      {
        "path": "/default-domain/workspaces/Projects/Legacy-Policy-2020",
        "name": "Legacy Policy 2020",
        "should_tag": true
      },
      {
        "path": "/default-domain/workspaces/Templates/Legacy-Policy-Template",
        "name": "Legacy Policy Template",
        "should_tag": true
      },
      {
        "path": "/default-domain/workspaces/DeepStorage/Legacy-Policy-Draft",
        "name": "Legacy Policy Draft",
        "should_tag": true
      },
      {
        "path": "/default-domain/workspaces/Projects/Active-Policy-2024",
        "name": "Active Policy 2024",
        "should_tag": false
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bulk_tag_distributed_documents"
    }
  }
}
