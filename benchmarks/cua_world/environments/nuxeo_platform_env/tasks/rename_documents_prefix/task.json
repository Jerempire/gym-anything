{
  "id": "rename_documents_prefix@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "As a Document Management Specialist, apply a new naming convention to the 'Projects' workspace located at /default-domain/workspaces/Projects. Rename the following documents: 'Annual Report 2023' to 'PROJ-2023-Annual Report 2023', 'Project Proposal' to 'PROJ-2023-Project Proposal', and 'Q3 Status Report' to 'PROJ-2023-Q3 Status Report'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rename_documents_prefix/setup_task.sh",
    "post_task": "/workspace/tasks/rename_documents_prefix/export_result.sh"
  },
  "metadata": {
    "workspace_path": "/default-domain/workspaces/Projects",
    "expected_renames": {
      "/default-domain/workspaces/Projects/Annual-Report-2023": "PROJ-2023-Annual Report 2023",
      "/default-domain/workspaces/Projects/Project-Proposal": "PROJ-2023-Project Proposal",
      "/default-domain/workspaces/Projects/Q3-Status-Report": "PROJ-2023-Q3 Status Report"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rename_documents_prefix"
    }
  }
}
