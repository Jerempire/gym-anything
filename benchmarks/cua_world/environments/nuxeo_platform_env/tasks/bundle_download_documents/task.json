{
  "id": "bundle_download_documents@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Download 'Annual Report 2023' from the 'Projects' workspace and 'Contract Template' from the 'Templates' workspace as a ZIP archive to /home/ga/Downloads/vendor_package.zip.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bundle_download_documents/setup_task.sh",
    "post_task": "/workspace/tasks/bundle_download_documents/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Downloads/vendor_package.zip",
    "required_content": [
      "Annual",
      "Report",
      "Contract",
      "Template"
    ],
    "min_zip_size_bytes": 1000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bundle_download_documents"
    }
  }
}
