{
  "id": "promote_personal_draft_to_shared_workspace@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Move the document 'Draft_Agenda' from your Personal Workspace to the 'Projects' workspace and rename it to 'Board_Meeting_Agenda_Oct2023'. The document must be moved to preserve its original ID, not copied or re-uploaded.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/promote_personal_draft_to_shared_workspace/setup_task.sh",
    "post_task": "/workspace/tasks/promote_personal_draft_to_shared_workspace/export_result.sh"
  },
  "metadata": {
    "target_workspace_path": "/default-domain/workspaces/Projects",
    "target_title": "Board_Meeting_Agenda_Oct2023",
    "original_name": "Draft_Agenda"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_promote_personal_draft_to_shared_workspace"
    }
  }
}
