{
  "id": "purge_trashed_documents@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Permanently delete the expired records 'Anderson Account Agreement 2016', 'Baker Loan Application 2015', and 'Chen Investment Portfolio 2014' from the trash in the 'ClientRecords' workspace within the Default Domain. Ensure that 'Davis Mortgage Records 2018' and 'Evans Trust Documents 2019' are preserved in the trash as they are under legal hold.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/purge_trashed_documents/setup_task.sh",
    "post_task": "/workspace/tasks/purge_trashed_documents/export_result.sh"
  },
  "metadata": {
    "workspace_path": "/default-domain/workspaces/ClientRecords",
    "purge_targets": [
      "Anderson-Account-Agreement-2016",
      "Baker-Loan-Application-2015",
      "Chen-Investment-Portfolio-2014"
    ],
    "preserve_targets": [
      "Davis-Mortgage-Records-2018",
      "Evans-Trust-Documents-2019"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_purge_trashed_documents"
    }
  }
}
