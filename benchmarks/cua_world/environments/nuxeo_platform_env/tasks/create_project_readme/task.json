{
  "id": "create_project_readme@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Create a Note document titled 'Project Readme' in the 'Projects' workspace. The note must include a brief summary and internal hyperlinks to the 'Annual Report 2023' and 'Project Proposal' documents found in the same workspace.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_project_readme/setup_task.sh",
    "post_task": "/workspace/tasks/create_project_readme/export_result.sh"
  },
  "metadata": {
    "workspace_path": "/default-domain/workspaces/Projects",
    "target_doc_1": "Annual-Report-2023",
    "target_doc_2": "Project-Proposal",
    "expected_note_titles": [
      "Project Readme",
      "Project-Readme"
    ],
    "score_note_exists": 20,
    "score_title_correct": 10,
    "score_link1_correct": 35,
    "score_link2_correct": 35
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_project_readme"
    }
  }
}
