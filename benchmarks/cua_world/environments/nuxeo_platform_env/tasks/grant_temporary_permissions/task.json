{
  "id": "grant_temporary_permissions@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Grant the user 'contractor_sam' 'Read & Write' access to the 'VendorContracts' workspace. The permission must be configured to expire automatically on December 31, 2026.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/grant_temporary_permissions/setup_task.sh",
    "post_task": "/workspace/tasks/grant_temporary_permissions/export_result.sh"
  },
  "metadata": {
    "target_user": "contractor_sam",
    "target_workspace_path": "/default-domain/workspaces/VendorContracts",
    "target_permission": "ReadWrite",
    "target_expiration_date": "2026-12-31"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_grant_temporary_permissions"
    }
  }
}
