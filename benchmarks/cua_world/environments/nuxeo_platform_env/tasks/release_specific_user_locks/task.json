{
  "id": "release_specific_user_locks@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "In the Nuxeo Platform 'Projects' workspace, user 'jsmith' is currently unavailable and has left 'Annual Report 2023' and 'Project Proposal' locked. Unlock these two documents while ensuring that 'Q3 Status Report', which is locked by the Administrator, remains locked.",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/release_specific_user_locks/setup_task.sh",
    "post_task": "/workspace/tasks/release_specific_user_locks/export_result.sh"
  },
  "metadata": {
    "target_workspace": "/default-domain/workspaces/Projects",
    "documents": {
      "doc1": {
        "path": "Annual-Report-2023",
        "initial_lock_owner": "jsmith",
        "expected_final_state": "unlocked"
      },
      "doc2": {
        "path": "Project-Proposal",
        "initial_lock_owner": "jsmith",
        "expected_final_state": "unlocked"
      },
      "doc3": {
        "path": "Q3-Status-Report",
        "initial_lock_owner": "Administrator",
        "expected_final_state": "locked"
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_release_locks"
    }
  }
}
