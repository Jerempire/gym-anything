{
  "id": "cancel_stalled_workflow@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Cancel the stalled 'Serial Document Review' workflow on the 'Contract Template' document. The workflow is currently assigned to user 'jsmith' who is unavailable. Abandon the workflow to unlock the document without deleting the document itself.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/cancel_stalled_workflow/setup_task.sh",
    "post_task": "/workspace/tasks/cancel_stalled_workflow/export_result.sh"
  },
  "metadata": {
    "target_document_path": "/default-domain/workspaces/Templates/Contract-Template",
    "target_user": "jsmith",
    "workflow_name": "SerialDocumentReview"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_cancel_stalled_workflow"
    }
  }
}
