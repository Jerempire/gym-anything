{
  "id": "create_saved_search@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "You are a librarian managing a digital institutional repository in Nuxeo. Create a reusable saved search named 'Project Reports Search' that identifies project reports (documents containing 'Report') within the repository.",
  "category": "search",
  "difficulty": "medium",
  "estimated_time_minutes": 10,
  "init": {
    "timeout_sec": 600,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_saved_search/setup_task.sh",
    "post_task": "/workspace/tasks/create_saved_search/export_result.sh"
  },
  "metadata": {
    "target_search_name": "Project Reports Search",
    "required_search_term": "Report",
    "expected_results": [
      "Annual Report 2023",
      "Q3 Status Report"
    ],
    "excluded_result": "Project Proposal"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_saved_search"
    }
  },
  "tags": [
    "search",
    "saved-search",
    "web-ui",
    "librarian",
    "information-retrieval"
  ],
  "occupation": "Librarians and Media Collections Specialists",
  "industry": "Educational Instruction and Library"
}
