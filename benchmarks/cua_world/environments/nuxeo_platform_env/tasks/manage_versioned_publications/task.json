{
  "id": "manage_versioned_publications@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "You are a Product Manager releasing 'Titanium X'. Publish the current version of the 'Titanium X Specs' document in the 'Projects' workspace to the 'Customer Portal' section. Update the document by uploading /home/ga/nuxeo/data/Titanium_X_Internal_Draft.pdf and publish this updated version to the 'Engineering Internal' section.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/manage_versioned_publications/setup_task.sh",
    "post_task": "/workspace/tasks/manage_versioned_publications/export_result.sh"
  },
  "metadata": {
    "source_doc_path": "/default-domain/workspaces/Projects/Titanium-X-Specs",
    "public_section_path": "/default-domain/sections/Customer-Portal",
    "internal_section_path": "/default-domain/sections/Engineering-Internal",
    "draft_file_name": "Titanium_X_Internal_Draft.pdf"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_manage_versioned_publications"
    }
  }
}
