{
  "id": "configure_vocabulary_entries@1",
  "version": "1.0",
  "env_id": "nuxeo_platform_env@0.1",
  "description": "Add three entries to the 'nature' vocabulary directory in the Nuxeo Platform Administration panel: (ID: 'memorandum', Label: 'Memorandum'), (ID: 'policy_brief', Label: 'Policy Brief'), and (ID: 'regulatory_filing', Label: 'Regulatory Filing'). Update the 'Nature' metadata field of the document 'Annual Report 2023' in the Projects workspace to 'Regulatory Filing'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_vocabulary_entries/setup_task.sh",
    "post_task": "/workspace/tasks/configure_vocabulary_entries/export_result.sh"
  },
  "metadata": {
    "target_entries": [
      {
        "id": "memorandum",
        "label": "Memorandum"
      },
      {
        "id": "policy_brief",
        "label": "Policy Brief"
      },
      {
        "id": "regulatory_filing",
        "label": "Regulatory Filing"
      }
    ],
    "target_document_path": "/default-domain/workspaces/Projects/Annual-Report-2023",
    "target_nature_value": "regulatory_filing"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_vocabulary_entries"
    }
  }
}
