{
  "id": "industrial_asset_inventory_digitization@1",
  "version": "1.0",
  "env_id": "sentrifugo_env@0.1",
  "difficulty": "hard",
  "description": "The Plant Manager has requested that newly acquired safety equipment be registered in Sentrifugo's Assets module. Using the physical equipment manifest located at ~/Desktop/new_equipment_manifest.txt, configure the system with the necessary asset categories and vendors, and register the three specified assets into the inventory.",
  "init": {
    "timeout_sec": 900,
    "max_steps": 60,
    "reward_type": "partial"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/industrial_asset_inventory_digitization/setup_task.sh",
    "post_task": "/workspace/tasks/industrial_asset_inventory_digitization/export_result.sh"
  },
  "metadata": {
    "expected_categories": [
      "Two-Way Radios",
      "Gas Detectors",
      "Thermal Cameras"
    ],
    "expected_vendor": "Industrial Safety Supply Co.",
    "expected_assets": [
      "RAD-8821-A",
      "GAS-9910-B",
      "THM-4450-C"
    ],
    "pass_threshold": 70
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_asset_digitization"
    }
  }
}
