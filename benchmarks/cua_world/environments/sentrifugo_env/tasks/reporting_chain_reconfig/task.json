{
  "id": "reporting_chain_reconfig@1",
  "version": "1.0",
  "env_id": "sentrifugo_env@0.1",
  "description": "A mid-year organizational restructure requires updating employee reporting managers. Update the Reporting Manager for the five employees specified in the restructure memo (~/Desktop/reporting_restructure_memo.txt) within Sentrifugo. Do not modify any other fields.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 60,
    "reward_type": "partial"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/reporting_chain_reconfig/setup_task.sh",
    "post_task": "/workspace/tasks/reporting_chain_reconfig/export_result.sh"
  },
  "metadata": {
    "target_employees": [
      "EMP002",
      "EMP006",
      "EMP010",
      "EMP012",
      "EMP014"
    ],
    "pass_threshold": 60,
    "scoring": "20pts per correct reassignment"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reporting_chain_reconfig"
    }
  }
}
