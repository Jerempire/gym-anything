{
  "id": "international_payroll_config@1",
  "version": "1.0",
  "env_id": "sentrifugo_env@0.1",
  "difficulty": "hard",
  "description": "Configure Sentrifugo's payroll master data and register new employees for international expansion according to the specifications in ~/Desktop/intl_payroll_config.txt. The configuration includes adding the specified Currencies, Pay Frequencies, Prefixes, Department, and Job Titles. Register the international employees listed in the document, ensuring they are assigned to the correct Department and Job Title. All entries must be saved and active.",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 100,
    "reward_type": "partial"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/international_payroll_config/setup_task.sh",
    "post_task": "/workspace/tasks/international_payroll_config/export_result.sh"
  },
  "metadata": {
    "expected_currencies": [
      "JPY",
      "BRL",
      "INR"
    ],
    "expected_pay_frequencies": [
      "Semi-Monthly",
      "Quarterly"
    ],
    "expected_prefixes": [
      "Dr.",
      "Sra.",
      "Sri"
    ],
    "expected_department": "International Programs",
    "expected_job_titles": [
      "Country Director",
      "Regional Coordinator"
    ],
    "expected_employees": [
      {
        "empid": "EMP021",
        "firstname": "Yuki",
        "lastname": "Tanaka",
        "dept": "International Programs",
        "title": "Country Director"
      },
      {
        "empid": "EMP022",
        "firstname": "Fernanda",
        "lastname": "Costa",
        "dept": "International Programs",
        "title": "Regional Coordinator"
      },
      {
        "empid": "EMP023",
        "firstname": "Arjun",
        "lastname": "Mehta",
        "dept": "International Programs",
        "title": "Country Director"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_international_payroll_config"
    }
  }
}
