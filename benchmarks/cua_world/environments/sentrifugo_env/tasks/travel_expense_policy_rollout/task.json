{
  "id": "travel_expense_policy_rollout@1",
  "version": "1.0",
  "env_id": "sentrifugo_env@0.1",
  "description": "The Finance Department has issued a new Travel & Expense Policy. Using the configuration details in the memo on your Desktop (TE_Policy_Memo.txt), add the specified Expense Categories and Payment Methods in Sentrifugo. Submit a test Expense Request as detailed in the memo, attaching 'Tokyo_Flight_Receipt.pdf' from your Desktop to the request.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 80,
    "reward_type": "partial"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/travel_expense_policy_rollout/setup_task.sh",
    "post_task": "/workspace/tasks/travel_expense_policy_rollout/export_result.sh"
  },
  "metadata": {
    "expected_categories": [
      "International Airfare",
      "Domestic Lodging",
      "Client Entertainment",
      "Conference Registration"
    ],
    "expected_payment_methods": [
      "Corporate AMEX",
      "Personal Credit Card"
    ],
    "expected_request_title": "Q3 Sales Conference Tokyo",
    "expected_request_amount": "1450",
    "pass_threshold": 70
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_te_policy_rollout"
    }
  }
}
