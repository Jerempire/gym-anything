{
  "id": "corporate_training_catalog_setup@1",
  "version": "1.0",
  "env_id": "sentrifugo_env@0.1",
  "description": "The company has signed contracts with two new external training vendors. Based on the Q3 2026 Corporate Training Vendor Rollout document at ~/Desktop/q3_training_vendors.txt, configure the HRMS Training module by creating the training providers 'Red Cross Safety Institute' and 'TechAdvantage Learning' with their contact details and the three specified training courses, ensuring each course is correctly linked to its respective provider with the correct duration.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/corporate_training_catalog_setup/setup_task.sh",
    "post_task": "/workspace/tasks/corporate_training_catalog_setup/export_result.sh"
  },
  "metadata": {
    "providers": [
      {
        "name": "Red Cross Safety Institute",
        "email": "jane.doe@redcross-mock.org",
        "phone": "555-0192"
      },
      {
        "name": "TechAdvantage Learning",
        "email": "alan.turing@techadvantage-mock.com",
        "phone": "555-0198"
      }
    ],
    "courses": [
      {
        "name": "Occupational First Aid & CPR",
        "provider": "Red Cross Safety Institute",
        "duration": "2"
      },
      {
        "name": "Advanced Python for Data Science",
        "provider": "TechAdvantage Learning",
        "duration": "5"
      },
      {
        "name": "Cloud Architecture Fundamentals",
        "provider": "TechAdvantage Learning",
        "duration": "3"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_training_setup"
    }
  }
}
