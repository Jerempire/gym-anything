{
  "id": "bg_check_compliance_config@1",
  "version": "1.0",
  "env_id": "sentrifugo_env@0.1",
  "description": "Configure Sentrifugo's Background Check module based on the new Department of Energy compliance directive at ~/Desktop/doe_screening_directive.txt. Create the 5 required background screening types and the 3 approved background check vendor agencies with their full contact details (phone and website), ensuring all entries are active.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 900,
    "max_steps": 60,
    "reward_type": "partial"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bg_check_compliance_config/setup_task.sh",
    "post_task": "/workspace/tasks/bg_check_compliance_config/export_result.sh"
  },
  "metadata": {
    "expected_types": [
      "Drug & Substance Screening",
      "Criminal Background Check",
      "Education & Credential Verification",
      "Professional License Verification",
      "Safety Certification Compliance"
    ],
    "expected_agencies": [
      {
        "name": "NationalScreen Inc.",
        "phone": "555-0147",
        "website": "nationalscreen-inc.com"
      },
      {
        "name": "VerifyFirst Solutions",
        "phone": "555-0233",
        "website": "verifyfirstsolutions.com"
      },
      {
        "name": "SafeHire Compliance Group",
        "phone": "555-0391",
        "website": "safehirecompliance.com"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bg_check_compliance"
    }
  }
}
