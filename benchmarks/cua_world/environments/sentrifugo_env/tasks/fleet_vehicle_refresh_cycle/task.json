{
  "id": "fleet_vehicle_refresh_cycle@1",
  "version": "1.0",
  "env_id": "sentrifugo_env@0.1",
  "difficulty": "hard",
  "description": "The Q1 fleet vehicle refresh is underway. Following the directive at ~/Desktop/fleet_refresh_directive.txt, update the Sentrifugo Assets module by creating the 'Electric Vehicles' category, retiring the legacy TRK assets, and adding the new EV assets. Ensure legacy assets have their allocations revoked and status updated to 'Not Working' without being deleted, and that new assets are allocated to their assigned shift supervisors as specified in the directive.",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 80,
    "reward_type": "partial"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/fleet_vehicle_refresh_cycle/setup_task.sh",
    "post_task": "/workspace/tasks/fleet_vehicle_refresh_cycle/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_fleet_vehicle_refresh_cycle"
    }
  },
  "metadata": {
    "new_category": "Electric Vehicles",
    "legacy_assets": [
      "TRK-2015-A",
      "TRK-2015-B",
      "TRK-2015-C"
    ],
    "new_assets": [
      {
        "code": "EV-001",
        "assigned_to": "Sarah Jenkins"
      },
      {
        "code": "EV-002",
        "assigned_to": "Michael Chang"
      },
      {
        "code": "EV-003",
        "assigned_to": "David Rodriguez"
      }
    ],
    "pass_threshold": 70,
    "scoring_weights": {
      "category_created": 10,
      "legacy_retained": 15,
      "legacy_status_updated": 15,
      "legacy_allocations_revoked": 15,
      "new_ev_created": 15,
      "new_ev_allocated": 30
    }
  }
}
