{
  "id": "annual_compensation_adjustment@1",
  "version": "1.0",
  "env_id": "sentrifugo_env@0.1",
  "description": "The Q1 2026 performance review cycle has concluded. The compensation committee has approved salary adjustments for top performers in the Engineering department. A confidential compensation review memo has been placed on the Desktop at ~/Desktop/q1_2026_comp_review.txt. Update the Base Salary and add a Performance Bonus allowance for the four specific employees based on the memo. Ensure you correctly ignore the employee flagged for termination.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/annual_compensation_adjustment/setup_task.sh",
    "post_task": "/workspace/tasks/annual_compensation_adjustment/export_result.sh"
  },
  "metadata": {
    "expected_updates": [
      {
        "empid": "EMP002",
        "salary": "115000",
        "bonus": "10500"
      },
      {
        "empid": "EMP006",
        "salary": "132500",
        "bonus": "14000"
      },
      {
        "empid": "EMP011",
        "salary": "98400",
        "bonus": "7200"
      },
      {
        "empid": "EMP018",
        "salary": "145000",
        "bonus": "18500"
      }
    ],
    "ignored_update": {
      "empid": "EMP014",
      "salary": "105000",
      "bonus": "5000"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_annual_compensation_adjustment"
    }
  }
}
