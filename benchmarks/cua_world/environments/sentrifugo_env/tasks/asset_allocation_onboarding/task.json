{
  "id": "asset_allocation_onboarding@1",
  "version": "1.0",
  "env_id": "sentrifugo_env@0.1",
  "description": "A new shipment of IT equipment has arrived for Q1 2026. The IT equipment manifest has been placed on the Desktop at ~/Desktop/it_equipment_manifest.txt. Update the Sentrifugo Asset Management module by creating two new Asset Categories ('Laptops' and 'Mobile Devices'), registering all four new hardware assets, and allocating them to the correct employees as specified in the manifest.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 80,
    "reward_type": "partial"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/asset_allocation_onboarding/setup_task.sh",
    "post_task": "/workspace/tasks/asset_allocation_onboarding/export_result.sh"
  },
  "metadata": {
    "expected_categories": [
      "Laptops",
      "Mobile Devices"
    ],
    "expected_assets": [
      {
        "serial": "MBP-2026-X1",
        "employeeId": "EMP005",
        "name": "MacBook Pro 16-inch"
      },
      {
        "serial": "DELL-2026-Y2",
        "employeeId": "EMP012",
        "name": "Dell Latitude 7420"
      },
      {
        "serial": "IPH-2026-Z3",
        "employeeId": "EMP005",
        "name": "iPhone 15 Pro"
      },
      {
        "serial": "SAM-2026-W4",
        "employeeId": "EMP019",
        "name": "Samsung Galaxy S24"
      }
    ],
    "pass_threshold": 70,
    "scoring": "10pts per category (20 max) + 20pts per correctly allocated asset (80 max)"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_asset_allocation_onboarding"
    }
  }
}
