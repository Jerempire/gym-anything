{
  "id": "role_access_reconfiguration@1",
  "version": "1.0",
  "env_id": "sentrifugo_env@0.1",
  "description": "An IT audit has mandated that role-based access control (RBAC) in Sentrifugo be tightened. Using the access control memo at ~/Desktop/access_control_memo.txt, create three new custom roles and reassign the specified employees from their default roles to the newly created custom roles. Do not modify or delete any existing roles in the system.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/role_access_reconfiguration/setup_task.sh",
    "post_task": "/workspace/tasks/role_access_reconfiguration/export_result.sh"
  },
  "metadata": {
    "roles_to_create": [
      "Team Lead",
      "Finance Clerk",
      "Program Coordinator"
    ],
    "employee_assignments": {
      "EMP005": "Team Lead",
      "EMP009": "Finance Clerk",
      "EMP014": "Program Coordinator",
      "EMP017": "Team Lead"
    },
    "pass_threshold": 64,
    "scoring": {
      "role_creation": 12,
      "employee_assignment": 16
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_role_access_reconfiguration"
    }
  }
}
