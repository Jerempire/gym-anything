{
  "id": "dei_masterdata_config@1",
  "version": "1.0",
  "env_id": "sentrifugo_env@0.1",
  "description": "The Board's DEI committee has mandated updates to the HRMS master data. Using the manifest at ~/Desktop/dei_masterdata_update.txt, update Sentrifugo by adding the new name prefixes (Mx., Prof., Engr.), ethnic codes (MENA, NHPI, SEA, MRAC), and employment status types (Seasonal Worker, Fellowship). Onboard the new employees Jordan Rivera and Rajan Patel using their specified details and the newly created reference data. Do not delete or deactivate any existing master data.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 80,
    "reward_type": "partial"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/dei_masterdata_config/setup_task.sh",
    "post_task": "/workspace/tasks/dei_masterdata_config/export_result.sh"
  },
  "metadata": {
    "expected_prefixes": [
      "Mx.",
      "Prof.",
      "Engr."
    ],
    "expected_ethnic_codes": [
      {
        "code": "MENA",
        "name": "Middle Eastern or North African"
      },
      {
        "code": "NHPI",
        "name": "Native Hawaiian or Pacific Islander"
      },
      {
        "code": "SEA",
        "name": "Southeast Asian"
      },
      {
        "code": "MRAC",
        "name": "Multiracial"
      }
    ],
    "expected_statuses": [
      "Seasonal Worker",
      "Fellowship"
    ],
    "expected_employees": [
      {
        "empid": "EMP021",
        "firstname": "Jordan",
        "lastname": "Rivera",
        "dept": "Customer Support"
      },
      {
        "empid": "EMP022",
        "firstname": "Rajan",
        "lastname": "Patel",
        "dept": "Engineering"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_dei_masterdata_config"
    }
  }
}
