{
  "id": "employment_status_audit_remediation@1",
  "version": "1.0",
  "env_id": "sentrifugo_env@0.1",
  "description": "The Department of Labor has scheduled a compliance audit for our workforce classifications. Process the manifest located at ~/Desktop/dol_classification_manifest.txt in Sentrifugo by creating any missing employment status types, updating the listed employees' profiles to their correct status, and creating the 'Unpaid Personal Leave' leave type with 0 days and the required code. All misclassifications identified in the manifest must be corrected.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 80,
    "reward_type": "partial"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/employment_status_audit_remediation/setup_task.sh",
    "post_task": "/workspace/tasks/employment_status_audit_remediation/export_result.sh"
  },
  "metadata": {
    "expected_statuses": [
      "Part-Time Regular",
      "Contract - Fixed Term",
      "Seasonal Worker",
      "Intern - Paid"
    ],
    "expected_employees": {
      "EMP005": "Part-Time Regular",
      "EMP008": "Contract - Fixed Term",
      "EMP010": "Part-Time Regular",
      "EMP014": "Seasonal Worker",
      "EMP016": "Intern - Paid",
      "EMP019": "Contract - Fixed Term"
    },
    "expected_leave": {
      "name": "Unpaid Personal Leave",
      "code": "UPL",
      "days": 0
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_employment_status_audit_remediation"
    }
  }
}
