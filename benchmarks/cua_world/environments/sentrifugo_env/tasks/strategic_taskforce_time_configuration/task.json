    "expected_project": "AI Enterprise Integration",
    "expected_tasks": [
      "Vendor Assessment",
      "Security Risk Analysis",
      "Pilot Implementation"
    ],
    "expected_resources": [
      "EMP006",
      "EMP012",
      "EMP015"
    ],
    "pass_threshold": 70
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_strategic_taskforce_time_configuration"
    }
  }
}
