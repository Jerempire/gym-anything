{
  "id": "talent_acquisition_pipeline_setup@1",
  "version": "1.0",
  "env_id": "sentrifugo_env@0.1",
  "description": "Configure the Talent Acquisition module for Q2 expansion using the hiring plan located at ~/Desktop/q2_hiring_plan.txt. Create the two Job Titles, standardize the Interview Rounds pipeline with the three specified rounds, and open the two multi-headcount Job Requisitions linked to the new titles and departments as detailed in the document.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 60,
    "reward_type": "partial"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/talent_acquisition_pipeline_setup/setup_task.sh",
    "post_task": "/workspace/tasks/talent_acquisition_pipeline_setup/export_result.sh"
  },
  "metadata": {
    "expected_titles": [
      "Senior Biomass Process Engineer",
      "Field Safety Inspector"
    ],
    "expected_rounds": [
      "Initial Phone Screen",
      "Technical Plant Assessment",
      "Plant Manager Interview"
    ],
    "requisition1": {
      "title": "Senior Biomass Process Engineer",
      "dept": "Engineering",
      "positions": 2
    },
    "requisition2": {
      "title": "Field Safety Inspector",
      "dept": "Quality Assurance",
      "positions": 3
    },
    "pass_threshold": 70
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_talent_acquisition_pipeline_setup"
    }
  }
}
