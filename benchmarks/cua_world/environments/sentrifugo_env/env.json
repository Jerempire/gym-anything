{
  "id": "sentrifugo_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Sentrifugo 3.2 Human Resource Management System environment for HR workflow tasks including employee management, leave management, department configuration, and holiday calendar management. Uses Apache/PHP 7.4 with MySQL via Docker and Firefox for GUI interaction.",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/sentrifugo_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/sentrifugo_env/config",  "target": "/workspace/config",  "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/sentrifugo_env/tasks",   "target": "/workspace/tasks",   "mode": "ro"}
  ],
  "hooks": {
    "pre_start":  "/workspace/scripts/install_sentrifugo.sh",
    "post_start": "/workspace/scripts/setup_sentrifugo.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ],
  "vnc": {
    "password": "password"
  }
}
