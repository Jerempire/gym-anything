{
  "id": "rename_tiddler@1",
  "version": "1.0",
  "env_id": "tiddly_wiki_env@0.1",
  "description": "Rename the tiddler 'Q1 2024 Product Roadmap' to 'Q1 2024 Engineering Roadmap' while preserving its content and tags.",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rename_tiddler/setup_task.sh",
    "post_task": "/workspace/tasks/rename_tiddler/export_result.sh"
  },
  "metadata": {
    "original_title": "Q1 2024 Product Roadmap",
    "new_title": "Q1 2024 Engineering Roadmap",
    "expected_tags": ["Project Management", "Roadmap", "Q1 2024"],
    "expected_content_keywords": ["API", "Dashboard", "Sprint"]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rename_tiddler"
    }
  }
}
