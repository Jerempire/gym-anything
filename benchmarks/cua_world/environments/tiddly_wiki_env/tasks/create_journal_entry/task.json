{
  "id": "create_journal_entry@1",
  "version": "1.0",
  "env_id": "tiddly_wiki_env@0.1",
  "description": "Create a journal entry for today documenting a productive work day. The tiddler should have the 'Journal' tag and its title should contain today's date. Write at least 50 words.",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_journal_entry/setup_task.sh",
    "post_task": "/workspace/tasks/create_journal_entry/export_result.sh"
  },
  "metadata": {
    "expected_tag": "Journal",
    "min_word_count": 50
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_journal"
    }
  }
}
