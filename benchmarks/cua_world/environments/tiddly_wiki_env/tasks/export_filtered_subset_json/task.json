{
  "id": "export_filtered_subset_json@1",
  "version": "1.0",
  "env_id": "tiddly_wiki_env@0.1",
  "description": "Find all exoplanets tagged with both 'Terrestrial' and 'HabitableZone'. Export these tiddlers as a JSON file to ~/Documents/Habitable_Terrestrials.json. Create a new tiddler titled 'Export Log' with the 'SystemLog' tag, recording the total number of exported planets in the text body.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_filtered_subset_json/setup_task.sh",
    "post_task": "/workspace/tasks/export_filtered_subset_json/export_result.sh"
  },
  "metadata": {
    "expected_titles": [
      "TRAPPIST-1 d",
      "TRAPPIST-1 e",
      "Proxima Centauri b",
      "Kepler-186f",
      "Teegarden's Star b",
      "LHS 1140 b",
      "K2-72e",
      "Gliese 667 Cc"
    ],
    "expected_count": 8,
    "expected_file": "/home/ga/Documents/Habitable_Terrestrials.json"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_filtered_subset_json"
    }
  }
}
