{
  "id": "delete_deprecated_tiddlers@1",
  "version": "1.0",
  "env_id": "tiddly_wiki_env@0.1",
  "description": "Find and delete all tiddlers tagged 'Deprecated' from the research lab wiki, while leaving every other tiddler untouched.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/delete_deprecated_tiddlers/setup_task.sh",
    "post_task": "/workspace/tasks/delete_deprecated_tiddlers/export_result.sh"
  },
  "metadata": {
    "deprecated_tiddlers": [
      "PCR Protocol v1",
      "Supplier List 2022",
      "Old Lab Safety Rules",
      "Western Blot Protocol v2",
      "Budget Proposal Q1 2023"
    ],
    "preserved_tiddlers": [
      "PCR Protocol v3",
      "Western Blot Protocol v4",
      "Lab Meeting Notes 2024-01-15",
      "Current Supplier List",
      "Lab Safety Guidelines 2024",
      "Equipment Inventory",
      "Research Project Alpha",
      "Graduate Student Onboarding"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_delete_deprecated_tiddlers"
    }
  }
}
