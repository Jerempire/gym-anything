{
  "id": "create_tiddler_with_links@1",
  "version": "1.0",
  "env_id": "tiddly_wiki_env@0.1",
  "description": "Create a tiddler titled 'RESTful API Design Guide' containing at least 80 words on API design best practices. Include internal links to 'Agile Methodology Overview' and 'Version Control Best Practices' and tag the entry with 'Technology' and 'API'.",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_tiddler_with_links/setup_task.sh",
    "post_task": "/workspace/tasks/create_tiddler_with_links/export_result.sh"
  },
  "metadata": {
    "expected_title": "RESTful API Design Guide",
    "expected_tags": [
      "Technology",
      "API"
    ],
    "expected_links": [
      "Agile Methodology Overview",
      "Version Control Best Practices"
    ],
    "min_word_count": 80,
    "expected_keywords": [
      "REST",
      "API",
      "HTTP"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_tiddler_with_links"
    }
  }
}
