{
  "id": "add_tags_to_tiddler@1",
  "version": "1.0",
  "env_id": "tiddly_wiki_env@0.1",
  "description": "Add 'Biotechnology' and 'Nobel' tags to the existing 'CRISPR Gene Editing' tiddler while preserving its current tags and content.",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_tags_to_tiddler/setup_task.sh",
    "post_task": "/workspace/tasks/add_tags_to_tiddler/export_result.sh"
  },
  "metadata": {
    "target_tiddler": "CRISPR Gene Editing",
    "existing_tags": ["Science", "Biology", "Genetics"],
    "new_tags": ["Biotechnology", "Nobel"],
    "all_expected_tags": ["Science", "Biology", "Genetics", "Biotechnology", "Nobel"]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_tags"
    }
  }
}
