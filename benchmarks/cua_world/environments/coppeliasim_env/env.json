{
  "id": "coppeliasim_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "CoppeliaSim robot simulation environment with UR5, Panda, KUKA, and other industrial robot arms. Supports scene building, IK configuration, motion planning, and pick-and-place tasks.",
  "category": ["robotics", "simulation", "engineering"],
  "tags": ["linux", "desktop", "robotics", "simulation", "3d"],
  "licence": "CoppeliaSim EDU (free for education/research)",
  "upstream_url": "https://www.coppeliarobotics.com/",
  "resources": {
    "cpu": 4,
    "mem_gb": 6,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse",
      "events": ["move", "click", "drag", "scroll"]
    },
    {
      "type": "keyboard",
      "events": ["press", "release", "type"]
    }
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "mounts": [
    {"source": "benchmarks/cua_world/environments/coppeliasim_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/coppeliasim_env/tasks", "target": "/workspace/tasks", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_coppeliasim.sh",
    "post_start": "/workspace/scripts/setup_coppeliasim.sh"
  },
  "security": {
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "runtime": "sysbox-runc"
  },
  "recording": {
    "enable": true,
    "output_dir": "./artifacts",
    "video_fps": 10,
    "video_resolution": [1920, 1080]
  },
  "vnc": {
    "enable": true,
    "host_port": 5900,
    "password": "password"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "COPPELIASIM_ROOT_DIR": "/opt/CoppeliaSim",
          "LIBGL_ALWAYS_SOFTWARE": "1"
        }
      }
    }
  ]
}
