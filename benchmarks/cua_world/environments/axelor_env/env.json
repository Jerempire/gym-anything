{
  "id": "axelor_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Axelor Open Suite ERP/CRM environment for business process automation, sales, purchasing, contacts, and project management tasks",
  "resources": {
    "cpu": 4,
    "mem_gb": 16,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "width": 1920,
      "height": 1080,
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/axelor_env/artifacts",
    "video_fps": 10,
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": false,
    "host_port": 5962,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/axelor_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/axelor_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/axelor_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/axelor_env/data", "target": "/workspace/data", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/axelor_env/utils", "target": "/workspace/utils", "mode": "ro"}
  ],
  "cache_level": "post_start",
  "hooks": {
    "pre_start": "/workspace/scripts/install_axelor.sh",
    "post_start": "/workspace/scripts/setup_axelor.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "AXELOR_USER": "ga"
        }
      }
    }
  ],
  "tags": ["linux", "erp", "crm", "axelor", "web-application", "docker", "postgresql", "desktop", "business"]
}
