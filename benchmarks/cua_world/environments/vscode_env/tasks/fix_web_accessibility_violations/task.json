{
  "id": "fix_web_accessibility_violations@1",
  "version": "1.0",
  "env_id": "vscode_env@0.1",
  "description": "You are a Web Administrator for a government agency. Fix the 7 WCAG 2.1 Level AA accessibility violations identified in the audit report at /home/ga/workspace/agency_dashboard/AUDIT_REPORT.md. Update the HTML, CSS, and JS files in the workspace to resolve these issues while preserving the dashboard's functionality and structure.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 1800,
    "max_steps": 150,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/fix_web_accessibility_violations/setup_task.sh",
    "post_task": "/workspace/tasks/fix_web_accessibility_violations/export_result.sh"
  },
  "metadata": {
    "occupation": "Web Administrator",
    "occupation_code": "15-1299.08",
    "industry": "Government / Public Sector",
    "soc_major_group": "Computer and Mathematical",
    "features": [
      "web_accessibility",
      "wcag_2_1",
      "html_semantics",
      "css_color_contrast",
      "aria_attributes",
      "multi_file_editing"
    ],
    "workspace_dir": "/home/ga/workspace/agency_dashboard",
    "pass_threshold": 60
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_accessibility_fixes"
    }
  }
}
