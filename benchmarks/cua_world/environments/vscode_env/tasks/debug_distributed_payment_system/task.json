{
  "id": "debug_distributed_payment_system@1",
  "version": "1.0",
  "env_id": "vscode_env@0.1",
  "description": "You are a senior software engineer at a fintech startup. Fix the payment processing system at /home/ga/workspace/payment_service/ to resolve reported duplicate charges, incorrect currency conversions, and balance discrepancies. A failing test suite is available to help identify and verify the root causes.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 1800,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/debug_distributed_payment_system/setup_task.sh",
    "post_task": "/workspace/tasks/debug_distributed_payment_system/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_payment_system"
    }
  },
  "tags": [
    "fintech",
    "payment-processing",
    "debugging",
    "decimal-precision",
    "concurrency",
    "python",
    "very_hard"
  ],
  "metadata": {
    "occupation": "Software Developer",
    "occupation_code": "15-1252.00",
    "industry": "Fintech",
    "soc_major_group": "Computer and Mathematical",
    "features": [
      "debugging",
      "financial_computing",
      "decimal_precision",
      "concurrency",
      "test_driven_development",
      "code_audit"
    ],
    "pass_threshold": 60
  }
}
