{
  "id": "remediate_infrastructure_as_code@1",
  "version": "1.0",
  "env_id": "vscode_env@0.1",
  "description": "You are a DevOps engineer at a SaaS company. An external security audit has flagged critical infrastructure misconfigurations that must be remediated before the company's SOC 2 Type II certification renewal. The infrastructure code is at /home/ga/workspace/platform_infra/. Review and fix all security issues across the infrastructure codebase.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 1800,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/remediate_infrastructure_as_code/setup_task.sh",
    "post_task": "/workspace/tasks/remediate_infrastructure_as_code/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_infrastructure_remediation"
    }
  },
  "tags": ["devops", "security-audit", "infrastructure-as-code", "docker", "kubernetes", "terraform", "nginx", "very_hard"],
  "metadata": {
    "occupation": "Computer Systems Administrator",
    "occupation_code": "15-1244.00",
    "industry": "Cloud Computing",
    "soc_major_group": "Computer and Mathematical",
    "features": [
      "infrastructure_as_code",
      "security_audit",
      "docker",
      "kubernetes",
      "terraform",
      "nginx",
      "multi_format_config"
    ],
    "pass_threshold": 60
  }
}
