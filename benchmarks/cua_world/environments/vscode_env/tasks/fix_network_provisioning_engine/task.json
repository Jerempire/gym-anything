    "post_task": "/workspace/tasks/fix_network_provisioning_engine/export_result.sh"
  },
  "metadata": {
    "occupation": "Network and Computer Systems Administrator",
    "occupation_code": "15-1244.00",
    "industry": "Cloud Computing and Datacenters",
    "soc_major_group": "Computer and Mathematical",
    "features": [
      "ipv4_networking",
      "cidr_math",
      "bgp_routing",
      "python_debugging",
      "test_driven_development"
    ],
    "pass_threshold": 60
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_network_provisioner"
    }
  }
}
