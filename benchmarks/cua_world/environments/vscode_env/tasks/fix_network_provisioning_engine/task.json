{
  "id": "fix_network_provisioning_engine@1",
  "version": "1.0",
  "env_id": "vscode_env@0.1",
  "description": "You are a Network Automation Engineer at a cloud hosting provider. The automated datacenter provisioning engine is failing, causing stalled customer VPC deployments. The engine code is located at /home/ga/workspace/net_provisioner/. Identify and fix the five logic bugs within the backend models to ensure the test suite passes.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 1800,
    "max_steps": 100,
