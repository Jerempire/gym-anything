{
  "id": "abravibe_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "ABRAVIBE vibration analysis environment using GNU Octave with the ABRAVIBE toolbox for noise and vibration signal analysis, spectral estimation, FRF computation, and mechanical system simulation with real CWRU bearing data",
  "resources": {
    "cpu": 4,
    "mem_gb": 4,
    "gpu": 0,
    "net": true
  },
  "vnc": {
    "password": "password"
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/abravibe_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/abravibe_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/abravibe_env/data", "target": "/workspace/data", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_abravibe.sh",
    "post_start": "/workspace/scripts/setup_abravibe.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ]
}
