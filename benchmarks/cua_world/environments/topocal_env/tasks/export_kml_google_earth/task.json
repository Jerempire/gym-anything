{
  "id": "export_kml_google_earth@1",
  "version": "1.0",
  "env_id": "topocal_env@0.1",
  "description": "Export the survey points from 'C:\\Users\\Docker\\Documents\\colorado_site_survey.csv' to a Google Earth KML file for client visualization using TopoCal. Configure the geographic projection parameters for the export to Hemisphere: North (Norte) and UTM Zone: 13 (Huso). Save the resulting KML file to C:\\Users\\Docker\\Documents\\site_export.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_kml_google_earth\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_kml_google_earth\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:/Users/Docker/Documents/site_export.kml",
    "expected_zone": 13,
    "expected_hemisphere": "Norte",
    "min_points": 50,
    "bounding_box": {
      "min_lon": -106.0,
      "max_lon": -104.0,
      "min_lat": 39.0,
      "max_lat": 41.0
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_kml"
    }
  }
}
