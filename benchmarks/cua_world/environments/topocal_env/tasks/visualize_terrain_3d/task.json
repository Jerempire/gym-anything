{
  "id": "visualize_terrain_3d@1",
  "version": "1.0",
  "env_id": "topocal_env@0.1",
  "description": "Create a 3D visualization of the loaded terrain model in TopoCal that clearly shows elevation variations and topographic relief. Save the visualization as a PNG image to C:\\Users\\Docker\\Documents\\terrain_3d_view.png. Note that TopoCal menus are in Spanish.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\visualize_terrain_3d\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\visualize_terrain_3d\\export_result.ps1",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "C:\\Users\\Docker\\Documents\\terrain_3d_view.png",
    "min_file_size_bytes": 51200,
    "min_width": 400,
    "min_height": 300
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_visualize_terrain_3d"
    }
  }
}
