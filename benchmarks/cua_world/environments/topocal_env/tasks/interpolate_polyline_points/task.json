{
  "id": "interpolate_polyline_points@1",
  "version": "1.0",
  "env_id": "topocal_env@0.1",
  "description": "Import the pipeline PI points from C:\\workspace\\data\\pipeline_pis.xyz into TopoCal and create a continuous polyline connecting points 1, 2, 3, and 4 in order. Generate new points along this polyline at 25-meter intervals. Export the generated points to C:\\workspace\\data\\stakeout_points.csv and save the project to C:\\workspace\\data\\pipeline_project.top.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\interpolate_polyline_points\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\interpolate_polyline_points\\export_result.ps1",
    "pre_task_timeout": 60
  },
  "metadata": {
    "input_file": "C:\\workspace\\data\\pipeline_pis.xyz",
    "expected_csv": "C:\\workspace\\data\\stakeout_points.csv",
    "expected_project": "C:\\workspace\\data\\pipeline_project.top",
    "interval_m": 25.0,
    "expected_min_points": 20
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_interpolate_polyline_points"
    }
  }
}
