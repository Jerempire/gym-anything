{
  "id": "extract_points_from_tin_mesh@1",
  "version": "1.0",
  "env_id": "topocal_env@0.1",
  "description": "Import the 3D DXF terrain mesh from 'C:\\workspace\\data\\design_mesh.dxf' into TopoCal. Extract the triangle vertices into the point database and remove duplicate points using a spatial tolerance of 0.01 meters. Export the unique nodes to a CSV file at 'C:\\workspace\\data\\extracted_mesh_nodes.csv' including columns for Point Number, X (Easting), Y (Northing), and Z (Elevation).",
