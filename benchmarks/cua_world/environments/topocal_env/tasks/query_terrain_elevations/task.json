        "y": 5050.0,
        "z": 1847.32
      },
      "NW": {
        "x": 4950.0,
        "y": 5050.0,
        "z": 1852.15
      },
      "SW": {
        "x": 4950.0,
        "y": 4950.0,
        "z": 1849.88
      },
      "SE": {
        "x": 5050.0,
        "y": 4950.0,
