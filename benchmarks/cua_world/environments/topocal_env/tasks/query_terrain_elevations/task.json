{
  "id": "query_terrain_elevations@1",
  "version": "1.0",
  "env_id": "topocal_env@0.1",
  "description": "Using the loaded Colorado foothills survey data in TopoCal, create a triangulated terrain model (MDT). Determine the interpolated terrain elevation at four coordinate locations: NE (X=5050.00, Y=5050.00), NW (X=4950.00, Y=5050.00), SW (X=4950.00, Y=4950.00), and SE (X=5050.00, Y=4950.00). Save the results to C:\\Users\\Docker\\Documents\\building_pad_elevations.txt with one line per corner in the format: CornerLabel, X, Y, Z.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\query_terrain_elevations\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\query_terrain_elevations\\export_result.ps1"
  },
  "metadata": {
    "expected_file": "C:\\Users\\Docker\\Documents\\building_pad_elevations.txt",
