{
  "id": "export_to_dxf@1",
  "version": "1.0",
  "env_id": "topocal_env@0.1",
  "description": "Export the current TopoCal project to DXF format using the Spanish interface. Save the file as /home/ga/Desktop/denver_survey.dxf. The exported file must contain the survey points and their coordinates.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 120,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_to_dxf\\setup_task.ps1",
    "pre_task_timeout": 600
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_to_dxf"
    }
  },
  "metadata": {
    "output_filename": "denver_survey.dxf",
    "output_location": "Desktop",
    "format": "DXF",
    "topocal_menu_language": "Spanish",
    "requires_preloaded_file": "denver_survey.top"
  }
}
