{
  "id": "generate_coordinate_grid@1",
  "version": "1.0",
  "env_id": "topocal_env@0.1",
  "description": "Generate a 50m x 50m cartographic coordinate grid (cuadrícula) with labels and crosses over the topographic survey located at 'C:\\workspace\\data\\foothills_map.top'. Export the resulting drawing as an AutoCAD DXF file to 'C:\\workspace\\data\\foothills_grid_export.dxf' and save the updated TopoCal project to 'C:\\workspace\\data\\foothills_map_gridded.top'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\generate_coordinate_grid\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\generate_coordinate_grid\\export_result.ps1"
  },
  "metadata": {
    "expected_dxf_path": "C:\\workspace\\data\\foothills_grid_export.dxf",
    "expected_top_path": "C:\\workspace\\data\\foothills_map_gridded.top",
    "grid_interval": 50,
    "min_dxf_size_bytes": 1024,
    "topocal_menu_language": "Spanish"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_coordinate_grid"
    }
  }
}
