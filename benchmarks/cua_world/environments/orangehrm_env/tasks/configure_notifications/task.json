{
  "id": "configure_notifications@1",
  "version": "1.0",
  "env_id": "orangehrm_env@0.1",
  "description": "Configure the OrangeHRM system email settings. Set the 'Mail Sent As' address to 'admin@gymhrcorp.com' using SMTP (Host: localhost, Port: 25, Secure Connection: No, SMTP Auth: Disabled). Add 'HR Leave Team' (leave@gymhrcorp.com) as a subscriber for 'Leave Application' notifications and 'Recruitment Team' (jobs@gymhrcorp.com) for 'Job Application' notifications.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_notifications/setup_task.sh",
    "post_task": "/workspace/tasks/configure_notifications/export_result.sh"
  },
  "metadata": {
    "expected_sent_as": "admin@gymhrcorp.com",
    "expected_smtp_host": "localhost",
    "expected_smtp_port": 25,
    "subscribers": [
      {
        "name": "HR Leave Team",
        "email": "leave@gymhrcorp.com",
        "notification_keywords": [
          "Leave Application",
          "Leave Apply"
        ]
      },
      {
        "name": "Recruitment Team",
        "email": "jobs@gymhrcorp.com",
        "notification_keywords": [
          "Job Application",
          "Candidate Application"
        ]
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_notifications"
    }
  }
}
