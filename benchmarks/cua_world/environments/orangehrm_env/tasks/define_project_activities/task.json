{
  "id": "define_project_activities@1",
  "version": "1.0",
  "env_id": "orangehrm_env@0.1",
  "description": "Configure time-tracking activities for the 'Cloud Migration Phase 1' project (Client: TechCorp Solutions). Add the following four billable activities to the project: Infrastructure Audit, Server Provisioning, Data Transfer, and Validation & Testing. Ensure all activities are saved.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/define_project_activities/setup_task.sh",
    "post_task": "/workspace/tasks/define_project_activities/export_result.sh"
  },
  "metadata": {
    "project_name": "Cloud Migration Phase 1",
    "customer_name": "TechCorp Solutions",
    "required_activities": [
      "Infrastructure Audit",
      "Server Provisioning",
      "Data Transfer",
      "Validation & Testing"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_define_project_activities"
    }
  }
}
