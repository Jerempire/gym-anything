{
  "id": "create_export_payroll_report@1",
  "version": "1.0",
  "env_id": "orangehrm_env@0.1",
  "description": "Create a custom PIM report named 'Engineering Payroll' for all employees with the job title 'Software Engineer'. The report must include the Employee Id, First Name, Last Name, and Basic Salary fields. Export the resulting report as a CSV file to the default Downloads folder.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_export_payroll_report/setup_task.sh",
    "post_task": "/workspace/tasks/create_export_payroll_report/export_result.sh"
  },
  "metadata": {
    "expected_report_name": "Engineering Payroll",
    "target_job_title": "Software Engineer",
    "target_salary": "85000",
    "target_employee_name": "Alice Dev",
    "download_dir": "/home/ga/Downloads"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_export_payroll_report"
    }
  }
}
