{
  "id": "complete_new_hire_documentation@1",
  "version": "1.0",
  "env_id": "orangehrm_env@0.1",
  "description": "Update the profile of employee 'James Anderson' by uploading a profile picture and two legal documents. Use '/home/ga/Documents/HR_Docs/james_photo.jpg' for the profile picture. Add '/home/ga/Documents/HR_Docs/signed_offer.pdf' as an attachment with the comment 'Signed Offer Letter 2024' and '/home/ga/Documents/HR_Docs/nda_signed.pdf' as an attachment with the comment 'Executed NDA'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/complete_new_hire_documentation/setup_task.sh",
    "post_task": "/workspace/tasks/complete_new_hire_documentation/export_result.sh"
  },
  "metadata": {
    "target_employee": {
      "first_name": "James",
      "last_name": "Anderson"
    },
    "required_files": [
      {
        "filename": "james_photo.jpg",
        "type": "picture"
      },
      {
        "filename": "signed_offer.pdf",
        "comment_keyword": "Offer",
        "type": "attachment"
      },
      {
        "filename": "nda_signed.pdf",
        "comment_keyword": "NDA",
        "type": "attachment"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_complete_new_hire_documentation"
    }
  }
}
