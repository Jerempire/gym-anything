{
  "id": "configure_pay_grade@1",
  "version": "1.0",
  "env_id": "orangehrm_env@0.1",
  "description": "Create a new pay grade named 'Grade HC-4' and configure it with a United States Dollar (USD) salary range. Set the minimum salary to 72,000.00 and the maximum salary to 104,500.00.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_pay_grade/setup_task.sh",
    "post_task": "/workspace/tasks/configure_pay_grade/export_result.sh"
  },
  "metadata": {
    "target_pay_grade": "Grade HC-4",
    "target_currency": "USD",
    "target_min_salary": 72000,
    "target_max_salary": 104500,
    "salary_tolerance": 1.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_pay_grade"
    }
  }
}
