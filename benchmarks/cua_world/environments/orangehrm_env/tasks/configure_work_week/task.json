{
  "id": "configure_work_week@1",
  "version": "1.0",
  "env_id": "orangehrm_env@0.1",
  "description": "Configure the global Work Week for 'Summer Hours'. Set Monday through Thursday as Full Days, Friday as a Half Day - Morning, and Saturday and Sunday as Non-working Days.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_work_week/setup_task.sh",
    "post_task": "/workspace/tasks/configure_work_week/export_result.sh"
  },
  "metadata": {
    "expected_status_full_day": 0,
    "expected_status_half_day_morning": 1,
    "expected_status_half_day_afternoon": 2,
    "expected_status_non_working": 4,
    "target_fri_status": "Half Day - Morning"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_work_week"
    }
  }
}
