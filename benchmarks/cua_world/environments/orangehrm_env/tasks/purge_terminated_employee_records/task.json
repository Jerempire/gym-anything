{
  "id": "purge_terminated_employee_records@1",
  "version": "1.0",
  "env_id": "orangehrm_env@0.1",
  "description": "Permanently purge the employment records of the former employee 'David Obsolete' (Employee ID: PURGE001) from the system to comply with a data privacy request. Ensure you only purge this specific record and no other employees.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/purge_terminated_employee_records/setup_task.sh",
    "post_task": "/workspace/tasks/purge_terminated_employee_records/export_result.sh"
  },
  "metadata": {
    "target_employee": {
      "firstname": "David",
      "lastname": "Obsolete",
      "id": "PURGE001"
    },
    "control_employee": {
      "firstname": "David",
      "lastname": "Current",
      "id": "KEEP001"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_purge_terminated_employee_records"
    }
  }
}
