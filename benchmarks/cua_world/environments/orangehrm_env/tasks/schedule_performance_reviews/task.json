{
  "id": "schedule_performance_reviews@1",
  "version": "1.0",
  "env_id": "orangehrm_env@0.1",
  "description": "As the Admin, create and activate H2 2025 performance reviews for Michael Chen and Sarah Jenkins. The Engineering Manager, Elena Fisher, is the reviewer for both. Use a review period of 2025-07-01 to 2025-12-31 and a due date of 2026-01-15. Both reviews must be set to ACTIVATED status.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/schedule_performance_reviews/setup_task.sh",
    "post_task": "/workspace/tasks/schedule_performance_reviews/export_result.sh"
  },
  "metadata": {
    "employees": [
      "Michael Chen",
      "Sarah Jenkins"
    ],
    "reviewer": "Elena Fisher",
    "period_start": "2025-07-01",
    "period_end": "2025-12-31",
    "due_date": "2026-01-15"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_schedule_performance_reviews"
    }
  }
}
