{
  "id": "configure_org_structure@1",
  "version": "1.0",
  "env_id": "orangehrm_env@0.1",
  "description": "As an Admin, create a university organizational structure in OrangeHRM under the root node 'GymAnything Corp'. Build the following hierarchy: 'Academic Affairs' (Unit Id: 'ACAD') directly under the root; 'College of Engineering' (Unit Id: 'COE') and 'College of Liberal Arts' (Unit Id: 'CLA') under Academic Affairs; and 'Department of Computer Science' (Unit Id: 'CS') and 'Department of Electrical Engineering' (Unit Id: 'EE') under the College of Engineering. Ensure all parent-child relationships and Unit IDs are correctly assigned.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_org_structure/setup_task.sh",
    "post_task": "/workspace/tasks/configure_org_structure/export_result.sh"
  },
  "metadata": {
    "target_structure": [
      {
        "name": "Academic Affairs",
        "unit_id": "ACAD",
        "parent": "GymAnything Corp",
        "level": 1
      },
      {
        "name": "College of Engineering",
        "unit_id": "COE",
        "parent": "Academic Affairs",
        "level": 2
      },
      {
        "name": "College of Liberal Arts",
        "unit_id": "CLA",
        "parent": "Academic Affairs",
        "level": 2
      },
      {
        "name": "Department of Computer Science",
        "unit_id": "CS",
        "parent": "College of Engineering",
        "level": 3
      },
      {
        "name": "Department of Electrical Engineering",
        "unit_id": "EE",
        "parent": "College of Engineering",
        "level": 3
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_org_structure"
    }
  }
}
