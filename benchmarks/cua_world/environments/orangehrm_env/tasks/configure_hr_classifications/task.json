{
  "id": "configure_hr_classifications@1",
  "version": "1.0",
  "env_id": "orangehrm_env@0.1",
  "description": "Configure the OrangeHRM Admin module with new HR classification standards. Add the following metadata definitions to the system:\n\nEmployment Statuses:\n- Intern - Paid\n- Intern - Unpaid\n- Contractor - Remote\n\nJob Categories:\n- Remote Engineering\n- Campus Recruitment\n\nEducation Levels:\n- Associates Degree - IT\n- Coding Bootcamp Certificate",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_hr_classifications/setup_task.sh",
    "post_task": "/workspace/tasks/configure_hr_classifications/export_result.sh"
  },
  "metadata": {
    "target_employment_statuses": [
      "Intern - Paid",
      "Intern - Unpaid",
      "Contractor - Remote"
    ],
    "target_job_categories": [
      "Remote Engineering",
      "Campus Recruitment"
    ],
    "target_education_levels": [
      "Associates Degree - IT",
      "Coding Bootcamp Certificate"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_hr_classifications"
    }
  }
}
