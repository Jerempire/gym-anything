{
  "id": "upload_employee_profile_photos@1",
  "version": "1.0",
  "env_id": "orangehrm_env@0.1",
  "description": "Upload professional profile photos for James Carter and Linda Chen in the PIM module. Use the source photos located at /home/ga/Documents/Photos/james_carter.jpg and /home/ga/Documents/Photos/linda_chen.jpg respectively.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/upload_employee_profile_photos/setup_task.sh",
    "post_task": "/workspace/tasks/upload_employee_profile_photos/export_result.sh"
  },
  "metadata": {
    "employees": [
      {
        "first_name": "James",
        "last_name": "Carter",
        "photo_path": "/home/ga/Documents/Photos/james_carter.jpg"
      },
      {
        "first_name": "Linda",
        "last_name": "Chen",
        "photo_path": "/home/ga/Documents/Photos/linda_chen.jpg"
      }
    ],
    "min_photo_size_bytes": 2000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_upload_photos"
    }
  }
}
