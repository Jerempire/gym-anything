{
  "id": "establish_international_salary_scales@1",
  "version": "1.0",
  "env_id": "orangehrm_env@0.1",
  "description": "Configure multi-currency salary bands and assign salaries to international employees. For the 'Software Engineer' pay grade, add GBP (Min 45,000, Max 85,000) and EUR (Min 50,000, Max 95,000). For the 'Data Scientist' pay grade, add GBP (Min 55,000, Max 100,000) and EUR (Min 65,000, Max 110,000). Assign a 'Base Salary UK' of 52,000 GBP (Monthly) to Michael Chen and a 'Base Salary EU' of 72,000 EUR (Monthly) to David Morris.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/establish_international_salary_scales/setup_task.sh",
    "post_task": "/workspace/tasks/establish_international_salary_scales/export_result.sh"
  },
  "metadata": {
    "specs": {
      "pay_grades": {
        "Software Engineer": {
          "GBP": {
            "min": 45000,
            "max": 85000
          },
          "EUR": {
            "min": 50000,
            "max": 95000
          }
        },
        "Data Scientist": {
          "GBP": {
            "min": 55000,
            "max": 100000
          },
          "EUR": {
            "min": 65000,
            "max": 110000
          }
        }
      },
      "employees": {
        "Michael Chen": {
          "currency": "GBP",
          "amount": 52000,
          "component": "Base Salary UK"
        },
        "David Morris": {
          "currency": "EUR",
          "amount": 72000,
          "component": "Base Salary EU"
        }
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_salary_scales"
    }
  }
}
