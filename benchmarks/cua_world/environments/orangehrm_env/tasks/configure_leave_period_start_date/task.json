{
  "id": "configure_leave_period_start_date@1",
  "version": "1.0",
  "env_id": "orangehrm_env@0.1",
  "description": "As the Admin user, configure the organization's Leave Period to align with the fiscal year by setting the starting date to April 1st.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_leave_period_start_date/setup_task.sh",
    "post_task": "/workspace/tasks/configure_leave_period_start_date/export_result.sh"
  },
  "metadata": {
    "target_month": "4",
    "target_day": "1",
    "config_table": "hs_hr_config"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_leave_period_start_date"
    }
  }
}
