{
  "id": "manageengine_eventlog_analyzer_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "ManageEngine EventLog Analyzer SIEM environment for log management, security monitoring, compliance reporting, and log analysis tasks. Collects and analyzes real syslog data from the local Ubuntu machine.",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080]
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "vnc": {
    "enable": false,
    "host_port": 5960,
    "password": "password"
  },
  "security": {
    "user": "root",
    "privileged": true,
    "use_systemd": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/manageengine_eventlog_analyzer_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/manageengine_eventlog_analyzer_env/tasks", "target": "/workspace/tasks", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_eventlog_analyzer.sh",
    "post_start": "/workspace/scripts/setup_eventlog_analyzer.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"]
      }
    }
  ],
  "tags": ["linux", "siem", "log-management", "security", "manageengine", "web-application", "syslog"]
}
