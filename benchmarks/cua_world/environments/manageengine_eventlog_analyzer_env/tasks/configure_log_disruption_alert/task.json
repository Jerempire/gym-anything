{
  "id": "configure_log_disruption_alert@1",
  "version": "1.0",
  "env_id": "manageengine_eventlog_analyzer_env@0.1",
  "description": "Configure a system health alert in ManageEngine EventLog Analyzer to notify administrators if log collection for the local host (127.0.0.1) stops for more than 30 minutes. Use the 'Log Collection Status' or 'Device Not Reporting' alert configuration to ensure the alert triggers and is active for this threshold.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_log_disruption_alert/setup_task.sh",
    "post_task": "/workspace/tasks/configure_log_disruption_alert/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_threshold_minutes": 30,
    "alert_type_keywords": [
      "Log Collection",
      "Not Reporting",
      "Device Down"
    ],
    "expected_status": "Enabled"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_log_disruption_alert"
    }
  }
}
