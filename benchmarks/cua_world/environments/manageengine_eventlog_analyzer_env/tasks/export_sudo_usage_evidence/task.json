{
  "id": "export_sudo_usage_evidence@1",
  "version": "1.0",
  "env_id": "manageengine_eventlog_analyzer_env@0.1",
  "description": "Perform a forensic search for 'sudo' usage in ManageEngine EventLog Analyzer to identify privileged command execution. Export the search results for the keyword 'sudo' from the last hour as a PDF file to /home/ga/Documents/sudo_evidence.pdf.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_sudo_usage_evidence/setup_task.sh",
    "post_task": "/workspace/tasks/export_sudo_usage_evidence/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_filename": "sudo_evidence.pdf",
    "expected_path": "/home/ga/Documents/sudo_evidence.pdf",
    "search_keyword": "sudo",
    "min_file_size_bytes": 1000,
    "required_content": [
      "sudo",
      "COMMAND",
      "root"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_sudo_usage_evidence"
    }
  }
}
