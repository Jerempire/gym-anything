{
  "id": "configure_secure_archiving@1",
  "version": "1.0",
  "env_id": "manageengine_eventlog_analyzer_env@0.1",
  "description": "Configure the global log archive settings in ManageEngine EventLog Analyzer to ensure data security and compliance. Enable archive encryption with the password 'SecureLogPass2025!' and set the log retention period to 365 days.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_secure_archiving/setup_task.sh",
    "post_task": "/workspace/tasks/configure_secure_archiving/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_retention_days": "365",
    "expected_password": "SecureLogPass2025!",
    "settings_url_fragment": "archive",
    "db_config_table_hint": "SystemSettings or GlobalConfig"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_secure_archiving"
    }
  }
}
