{
  "id": "configure_https_console@1",
  "version": "1.0",
  "env_id": "manageengine_eventlog_analyzer_env@0.1",
  "description": "Secure the ManageEngine EventLog Analyzer web console (admin/admin) by enabling HTTPS on port 8443. Create a confirmation file at /home/ga/https_configured.txt containing the text: 'HTTPS_ENABLED:8443'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 900,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_https_console/setup_task.sh",
    "post_task": "/workspace/tasks/configure_https_console/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_port": 8443,
    "expected_protocol": "https",
    "marker_file": "/home/ga/https_configured.txt",
    "marker_content": "HTTPS_ENABLED:8443",
    "conf_file_path": "/opt/ManageEngine/EventLog/conf/server.xml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_https_console"
    }
  }
}
