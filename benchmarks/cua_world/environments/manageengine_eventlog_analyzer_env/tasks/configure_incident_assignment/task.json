{
  "id": "configure_incident_assignment@1",
  "version": "1.0",
  "env_id": "manageengine_eventlog_analyzer_env@0.1",
  "description": "Configure an automated incident assignment rule named 'Critical_Response_Auto' in ManageEngine EventLog Analyzer that assigns incidents with 'Critical' severity to the 'admin' user. Export today's audit report documenting this configuration to /home/ga/audit_evidence.csv in CSV format.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_incident_assignment/setup_task.sh",
    "post_task": "/workspace/tasks/configure_incident_assignment/export_result.sh"
  },
  "metadata": {
    "rule_name": "Critical_Response_Auto",
    "assignee": "admin",
    "severity": "Critical",
    "evidence_file": "/home/ga/audit_evidence.csv"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_incident_assignment"
    }
  }
}
