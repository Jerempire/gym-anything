{
  "id": "configure_syslog_forwarding@1",
  "version": "1.0",
  "env_id": "manageengine_eventlog_analyzer_env@0.1",
  "description": "Configure ManageEngine EventLog Analyzer to forward all collected syslog events to an external SIEM collector at 10.200.50.25 on port 1514 using the UDP protocol. Ensure the forwarding rule is saved and active.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_syslog_forwarding/setup_task.sh",
    "post_task": "/workspace/tasks/configure_syslog_forwarding/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_ip": "10.200.50.25",
    "expected_port": "1514",
    "expected_protocol": "UDP",
    "db_table_hint": "SyslogForwarding"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_syslog_forwarding"
    }
  }
}
