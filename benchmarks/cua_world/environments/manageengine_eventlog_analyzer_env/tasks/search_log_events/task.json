{
  "id": "search_log_events@1",
  "version": "1.0",
  "env_id": "manageengine_eventlog_analyzer_env@0.1",
  "description": "Locate all security-related log events containing the keyword 'authentication failure' from the last 7 days across all devices in ManageEngine EventLog Analyzer. Credentials: admin/admin.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/search_log_events/setup_task.sh",
    "pre_task_timeout": 1200
  },
  "metadata": {
    "search_keyword": "authentication failure",
    "time_range_days": 7,
    "search_all_devices": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_search_log_events"
    }
  }
}
