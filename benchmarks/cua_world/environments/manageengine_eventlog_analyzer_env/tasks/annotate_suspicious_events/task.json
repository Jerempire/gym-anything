{
  "id": "annotate_suspicious_events@1",
  "version": "1.0",
  "env_id": "manageengine_eventlog_analyzer_env@0.1",
  "description": "Perform a forensic annotation in ManageEngine EventLog Analyzer following a suspicious burst of failed SSH logins. Locate a failed login event for the user 'forensic_target' and add a forensic note to the event with the text: 'CASE-999: Verified scan'. You are logged in as admin.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/annotate_suspicious_events/setup_task.sh",
    "post_task": "/workspace/tasks/annotate_suspicious_events/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_user": "forensic_target",
    "required_note_content": "CASE-999: Verified scan",
    "log_injection_count": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_annotate_suspicious_events"
    }
  }
}
