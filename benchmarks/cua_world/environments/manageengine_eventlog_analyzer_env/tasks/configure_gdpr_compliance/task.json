{
  "id": "configure_gdpr_compliance@1",
  "version": "1.0",
  "env_id": "manageengine_eventlog_analyzer_env@0.1",
  "description": "Configure the GDPR compliance audit scope in EventLog Analyzer to include the local host (127.0.0.1). Generate a GDPR-specific report (such as User Logons or Policy Changes) and export it to /home/ga/Documents/gdpr_compliance_report.pdf or /home/ga/Documents/gdpr_compliance_report.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_gdpr_compliance/setup_task.sh",
    "post_task": "/workspace/tasks/configure_gdpr_compliance/export_result.sh"
  },
  "metadata": {
    "expected_filename_pdf": "gdpr_compliance_report.pdf",
    "expected_filename_csv": "gdpr_compliance_report.csv",
    "expected_dir": "/home/ga/Documents",
    "min_file_size_bytes": 500
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_gdpr_compliance"
    }
  }
}
