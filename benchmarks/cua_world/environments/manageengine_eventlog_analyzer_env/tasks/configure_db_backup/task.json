{
  "id": "configure_db_backup@1",
  "version": "1.0",
  "env_id": "manageengine_eventlog_analyzer_env@0.1",
  "description": "Configure the database backup settings in ManageEngine EventLog Analyzer. Enable 'Scheduled Database Backup' with the backup directory set to '/opt/ManageEngine/EventLog/backup' and a 'Daily' schedule. Create a confirmation file at '~/backup_config_done.txt' once the configuration is saved.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_db_backup/setup_task.sh",
    "post_task": "/workspace/tasks/configure_db_backup/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "expected_backup_path": "/opt/ManageEngine/EventLog/backup",
    "expected_schedule": "Daily",
    "ela_home": "/opt/ManageEngine/EventLog",
    "report_file": "/home/ga/backup_config_done.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_db_backup"
    }
  }
}
