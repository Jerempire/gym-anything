{
  "id": "generate_compliance_report@1",
  "version": "1.0",
  "env_id": "manageengine_eventlog_analyzer_env@0.1",
  "description": "Access the PCI DSS compliance report for all available log sources in ManageEngine EventLog Analyzer. Log in with username: admin, password: admin.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_compliance_report/setup_task.sh",
    "pre_task_timeout": 1200
  },
  "metadata": {
    "compliance_standard": "PCI DSS",
    "report_type": "compliance",
    "time_range": "current_month"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_compliance_report"
    }
  }
}
