{
  "id": "add_incident_worklog_note@1",
  "version": "1.0",
  "env_id": "manageengine_eventlog_analyzer_env@0.1",
  "description": "Add a worklog note with the text 'Initial triage complete. Escalating to L2.' to the 'Emergency' severity alert containing the message 'CORE_DUMP_DETECTED_001'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_incident_worklog_note/setup_task.sh",
    "post_task": "/workspace/tasks/add_incident_worklog_note/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_alert_message": "CORE_DUMP_DETECTED_001",
    "target_note_text": "Initial triage complete. Escalating to L2.",
    "severity": "Emergency"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_incident_worklog_note"
    }
  }
}
