{
  "id": "schedule_weekly_report@1",
  "version": "1.0",
  "env_id": "manageengine_eventlog_analyzer_env@0.1",
  "description": "Configure a recurring schedule for the 'Successful Logon' report in ManageEngine EventLog Analyzer to run every week on Monday.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/schedule_weekly_report/setup_task.sh",
    "post_task": "/workspace/tasks/schedule_weekly_report/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "target_report": "Successful Logon",
    "expected_frequency": "Weekly",
    "expected_day": "Monday",
    "report_category": "Logon Reports"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_schedule_weekly_report"
    }
  }
}
