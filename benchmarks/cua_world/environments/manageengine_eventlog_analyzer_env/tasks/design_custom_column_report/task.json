{
  "id": "design_custom_column_report@1",
  "version": "1.0",
  "env_id": "manageengine_eventlog_analyzer_env@0.1",
  "description": "Create a custom report profile named 'Executive Failed Logons' in ManageEngine EventLog Analyzer. The report must filter for 'Failed Logons' and include only the 'User', 'Source', and 'Time' columns. Export the generated report as a CSV file to /home/ga/Documents/executive_report.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/design_custom_column_report/setup_task.sh",
    "post_task": "/workspace/tasks/design_custom_column_report/export_result.sh"
  },
  "metadata": {
    "report_name": "Executive Failed Logons",
    "output_path": "/home/ga/Documents/executive_report.csv",
    "max_columns": 5,
    "required_columns": [
      "User",
      "Source",
      "Time"
    ],
    "forbidden_columns": [
      "Severity",
      "Facility",
      "Message"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_design_custom_column_report"
    }
  }
}
