{
  "id": "import_log_file@1",
  "version": "1.0",
  "env_id": "manageengine_eventlog_analyzer_env@0.1",
  "description": "Import the Linux authentication log file from /home/ga/log_samples/auth.log into ManageEngine EventLog Analyzer. Ensure the events containing terms like 'sshd', 'pam_unix', or 'sudo' are successfully ingested and searchable in the system. Log in with username: admin, password: admin.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/import_log_file/setup_task.sh",
    "post_task": "/workspace/tasks/import_log_file/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "log_file_path": "/home/ga/log_samples/auth.log",
    "expected_keywords": [
      "sshd",
      "pam_unix",
      "sudo",
      "session opened"
    ],
    "min_event_increase": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_import_log_file"
    }
  }
}
