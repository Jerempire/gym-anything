{
  "id": "water_treatment_scada_tags@1",
  "version": "1.0",
  "env_id": "crimson_env@0.1",
  "description": "A municipal water treatment plant is upgrading its SCADA system. As the process engineer, configure all required process monitoring data tags in Red Lion Crimson 3.0 according to the plant's tag register and WHO/AWWA drinking water quality standards found in the CrimsonTasks folder on the Desktop. Each tag must be configured with the correct data type, engineering range, unit label, description, and alarm thresholds. Save the project as 'water_treatment.c3' in C:\\Users\\Docker\\Documents\\CrimsonProjects\\. Login credentials: Docker / GymAnything123!",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\water_treatment_scada_tags\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\water_treatment_scada_tags\\export_result.ps1"
  },
  "metadata": {
    "task_name": "water_treatment_scada_tags",
    "project_filename": "water_treatment.c3",
    "project_path": "C:\\Users\\Docker\\Documents\\CrimsonProjects\\water_treatment.c3",
    "industry": "Municipal Water Treatment",
    "occupation": "Process Engineer",
    "standard": "WHO Guidelines for Drinking-water Quality (4th Ed, 2022) / AWWA",
    "tags": [
      {
        "name": "CT_101",
        "description": "Free Chlorine Residual - Primary",
        "data_type": "Float",
        "unit": "mg/L",
        "min_value": 0.01,
        "max_value": 8.0,
        "label": "mg per Liter",
        "alarm_low": 0.2,
        "alarm_high": 4.0
      },
      {
        "name": "PH_101",
        "description": "Process Water pH - Inlet",
        "data_type": "Float",
        "unit": "pH",
        "min_value": 4.0,
        "max_value": 11.0,
        "label": "pH Units",
        "alarm_low": 6.5,
        "alarm_high": 8.5
      },
      {
        "name": "TU_101",
        "description": "Turbidity Sensor - Coagulation Outlet",
        "data_type": "Float",
        "unit": "NTU",
        "min_value": 0.0,
        "max_value": 25.0,
        "label": "Nephelometric Turbidity Units",
        "alarm_low": 0.0,
        "alarm_high": 4.0
      },
      {
        "name": "TT_101",
        "description": "Raw Water Inlet Temperature",
        "data_type": "Float",
        "unit": "degC",
        "min_value": 0.0,
        "max_value": 40.0,
        "label": "Degrees Celsius",
        "alarm_low": 1.0,
        "alarm_high": 32.0
      },
      {
        "name": "PT_101",
        "description": "Distribution Pressure Transmitter",
        "data_type": "Float",
        "unit": "kPa",
        "min_value": 0.0,
        "max_value": 700.0,
        "label": "Kilopascals",
        "alarm_low": 138.0,
        "alarm_high": 586.0
      }
    ],
    "tolerance_pct": 2.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_water_treatment_scada_tags"
    }
  }
}
