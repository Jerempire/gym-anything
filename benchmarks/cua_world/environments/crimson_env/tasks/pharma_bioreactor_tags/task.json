{
  "id": "pharma_bioreactor_tags@1",
  "version": "1.0",
  "env_id": "crimson_env@0.1",
  "description": "A pharmaceutical company is qualifying a GMP-compliant SCADA system for a bioreactor manufacturing suite. As the validation engineer responsible for IQ/OQ documentation, configure all critical process monitoring tags in Red Lion Crimson 3.0 per FDA 21 CFR Part 211, ICH Q8(R2), and USP <1058> requirements. Use the bioreactor tag register and the GMP process parameters specification in the CrimsonTasks folder on the Desktop to ensure each tag is correctly configured. Save the project to C:\\Users\\Docker\\Documents\\CrimsonProjects\\pharma_bioreactor.c3. Login credentials: Docker / GymAnything123!",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\pharma_bioreactor_tags\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\pharma_bioreactor_tags\\export_result.ps1"
  },
  "metadata": {
    "task_name": "pharma_bioreactor_tags",
    "project_filename": "pharma_bioreactor.c3",
    "project_path": "C:\\Users\\Docker\\Documents\\CrimsonProjects\\pharma_bioreactor.c3",
    "industry": "Pharmaceutical / Biotechnology Manufacturing",
    "occupation": "Validation Engineer / Automation Engineer",
    "standard": "FDA 21 CFR Part 211 / ICH Q8(R2) / USP <1058>",
    "tags": [
      {
        "name": "TT_301",
        "description": "Bioreactor Temperature - Fermentation",
        "data_type": "Float",
        "unit": "degC",
        "min_value": 30.0,
        "max_value": 45.0,
        "label": "Degrees Celsius",
        "alarm_low": 36.0,
        "alarm_high": 38.0
      },
      {
        "name": "PH_301",
        "description": "Bioreactor Process pH",
        "data_type": "Float",
        "unit": "pH",
        "min_value": 5.0,
        "max_value": 9.0,
        "label": "pH Units",
        "alarm_low": 6.8,
        "alarm_high": 7.4
      },
      {
        "name": "DO_301",
        "description": "Dissolved Oxygen - Bioreactor",
        "data_type": "Float",
        "unit": "pctDO",
        "min_value": 0.0,
        "max_value": 100.0,
        "label": "Percent DO Saturation",
        "alarm_low": 20.0,
        "alarm_high": 80.0
      },
      {
        "name": "AS_301",
        "description": "Agitator Speed - Bioreactor",
        "data_type": "Float",
        "unit": "RPM",
        "min_value": 0.0,
        "max_value": 1500.0,
        "label": "Revolutions per Minute",
        "alarm_low": 50.0,
        "alarm_high": 800.0
      },
      {
        "name": "PT_301",
        "description": "Vessel Headspace Pressure",
        "data_type": "Float",
        "unit": "barg",
        "min_value": 0.0,
        "max_value": 3.0,
        "label": "Bar Gauge",
        "alarm_low": 0.0,
        "alarm_high": 1.5
      }
    ],
    "tolerance_pct": 2.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_pharma_bioreactor_tags"
    }
  }
}
