{
  "id": "datacenter_hvac_tags@1",
  "version": "1.0",
  "env_id": "crimson_env@0.1",
  "description": "A commercial data center is deploying a new BMS/SCADA system to monitor critical environmental conditions in its server rooms. As the facilities engineer responsible for commissioning the system, configure all required environmental monitoring tags in Red Lion Crimson 3.0 per ASHRAE A2 class data center standards. Each tag must include the correct data type, engineering range, unit label, description, and alarm thresholds as defined in the tag register and ASHRAE specification in the CrimsonTasks folder on the Desktop. Save the project as 'datacenter_hvac.c3' in C:\\Users\\Docker\\Documents\\CrimsonProjects\\. Login credentials: Docker / GymAnything123!",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 1080,
    "max_steps": 140,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\datacenter_hvac_tags\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\datacenter_hvac_tags\\export_result.ps1"
  },
  "metadata": {
    "task_name": "datacenter_hvac_tags",
    "project_filename": "datacenter_hvac.c3",
    "project_path": "C:\\Users\\Docker\\Documents\\CrimsonProjects\\datacenter_hvac.c3",
    "industry": "Commercial Real Estate / Data Center Operations",
    "occupation": "Facilities Engineer / Building Automation Engineer",
    "standard": "ASHRAE Standard 90.4-2022 / ASHRAE TC 9.9 / ANSI/BICSI 002-2019",
    "tags": [
      {
        "name": "TT_401",
        "description": "IT Equipment Inlet Temperature",
        "data_type": "Float",
        "unit": "degC",
        "min_value": 0.0,
        "max_value": 50.0,
        "label": "Degrees Celsius",
        "alarm_low": 10.0,
        "alarm_high": 35.0
      },
      {
        "name": "RH_401",
        "description": "Relative Humidity - IT Room",
        "data_type": "Float",
        "unit": "pctRH",
        "min_value": 0.0,
        "max_value": 100.0,
        "label": "Percent Relative Humidity",
        "alarm_low": 20.0,
        "alarm_high": 80.0
      },
      {
        "name": "DP_401",
        "description": "Dew Point Temperature - IT Room",
        "data_type": "Float",
        "unit": "degC",
        "min_value": -20.0,
        "max_value": 30.0,
        "label": "Degrees Celsius",
        "alarm_low": -12.0,
        "alarm_high": 17.0
      },
      {
        "name": "PT_401",
        "description": "CRAC Discharge Static Pressure",
        "data_type": "Float",
        "unit": "inWG",
        "min_value": -2.0,
        "max_value": 2.0,
        "label": "Inches Water Gauge",
        "alarm_low": 0.0,
        "alarm_high": 1.5
      },
      {
        "name": "FT_401",
        "description": "CRAC Unit Airflow Rate",
        "data_type": "Float",
        "unit": "CFM",
        "min_value": 0.0,
        "max_value": 10000.0,
        "label": "Cubic Feet per Minute",
        "alarm_low": 1000.0,
        "alarm_high": 9000.0
      },
      {
        "name": "TT_402",
        "description": "Return Air Temperature - Hot Aisle",
        "data_type": "Float",
        "unit": "degC",
        "min_value": 0.0,
        "max_value": 60.0,
        "label": "Degrees Celsius",
        "alarm_low": 20.0,
        "alarm_high": 45.0
      }
    ],
    "tolerance_pct": 2.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_datacenter_hvac_tags"
    }
  }
}
