{
  "id": "food_pasteurization_tags@1",
  "version": "1.0",
  "env_id": "crimson_env@0.1",
  "description": "A dairy processing company is commissioning SCADA for a new HTST pasteurization line. As the food safety engineer responsible for FDA regulatory compliance, configure all Critical Control Point (CCP) monitoring tags in Red Lion Crimson 3.0 according to the FDA Grade A Pasteurized Milk Ordinance (PMO) and 21 CFR Part 131 using the CCP tag register and critical limits specification found in the CrimsonTasks folder on the Desktop. Save the project as 'food_pasteurization.c3' in C:\\Users\\Docker\\Documents\\CrimsonProjects\\. Login credentials: Docker / GymAnything123!",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\food_pasteurization_tags\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\food_pasteurization_tags\\export_result.ps1"
  },
  "metadata": {
    "task_name": "food_pasteurization_tags",
    "project_filename": "food_pasteurization.c3",
    "project_path": "C:\\Users\\Docker\\Documents\\CrimsonProjects\\food_pasteurization.c3",
    "industry": "Food Manufacturing / Dairy Processing",
    "occupation": "Food Safety Engineer / Quality Assurance Engineer",
    "standard": "FDA Grade A Pasteurized Milk Ordinance (PMO) 2023 / 21 CFR Part 131",
    "tags": [
      {
        "name": "TT_501",
        "description": "HTST Holder Temperature - CCP1",
        "data_type": "Float",
        "unit": "degF",
        "min_value": 140.0,
        "max_value": 200.0,
        "label": "Degrees Fahrenheit",
        "alarm_low": 161.0,
        "alarm_high": 185.0
      },
      {
        "name": "FT_501",
        "description": "HTST Forward Flow Rate",
        "data_type": "Float",
        "unit": "GPM",
        "min_value": 0.0,
        "max_value": 500.0,
        "label": "Gallons per Minute",
        "alarm_low": 5.0,
        "alarm_high": 300.0
      },
      {
        "name": "PT_501",
        "description": "Pasteurized Product Pressure",
        "data_type": "Float",
        "unit": "psi",
        "min_value": 0.0,
        "max_value": 100.0,
        "label": "Pounds per Square Inch",
        "alarm_low": 1.0,
        "alarm_high": 80.0
      },
      {
        "name": "TT_502",
        "description": "Regeneration Balance Temperature",
        "data_type": "Float",
        "unit": "degF",
        "min_value": 100.0,
        "max_value": 200.0,
        "label": "Degrees Fahrenheit",
        "alarm_low": 130.0,
        "alarm_high": 185.0
      },
      {
        "name": "FQ_501",
        "description": "Daily Batch Total Volume",
        "data_type": "Float",
        "unit": "gallons",
        "min_value": 0.0,
        "max_value": 999999.0,
        "label": "Gallons",
        "alarm_low": 0.0,
        "alarm_high": 900000.0
      }
    ],
    "tolerance_pct": 2.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_food_pasteurization_tags"
    }
  }
}
