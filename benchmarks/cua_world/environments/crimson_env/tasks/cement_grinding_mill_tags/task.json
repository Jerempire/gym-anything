{
  "id": "cement_grinding_mill_tags@1",
  "version": "1.0",
  "env_id": "crimson_env@0.1",
  "description": "Red Lion Crimson 3.0 is open. As the controls engineer for a cement manufacturing plant commissioning a new vertical roller mill (VRM-1) raw material grinding circuit, configure the active monitoring tags for VRM-1 according to ISO 10816-3 and ASTM C150 standards. Using the tag register and monitoring standards in the CrimsonTasks folder on the Desktop, configure only the active VRM-1 tags with the required data types, engineering ranges, unit labels, descriptions, and alarm thresholds. Save the project as 'cement_grinding.c3' in C:\\Users\\Docker\\Documents\\CrimsonProjects\\. Login credentials: Docker / GymAnything123!",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 150,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\cement_grinding_mill_tags\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\cement_grinding_mill_tags\\export_result.ps1"
  },
  "metadata": {
    "task_name": "cement_grinding_mill_tags",
    "project_filename": "cement_grinding.c3",
    "project_path": "C:\\Users\\Docker\\Documents\\CrimsonProjects\\cement_grinding.c3",
    "industry": "Cement Manufacturing",
    "occupation": "Crushing, Grinding, and Polishing Machine Setters",
    "standard": "ISO 10816-3:2009 / ASTM C150",
    "tags": [
      {
        "name": "DP_601",
        "data_type": "Float",
        "min_value": 0.0,
        "max_value": 120.0,
        "label": "Millibar"
      },
      {
        "name": "TT_601",
        "data_type": "Float",
        "min_value": 50.0,
        "max_value": 150.0,
        "label": "Degrees Celsius"
      },
      {
