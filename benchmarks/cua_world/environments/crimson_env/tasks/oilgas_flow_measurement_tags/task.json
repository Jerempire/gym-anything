{
  "id": "oilgas_flow_measurement_tags@1",
  "version": "1.0",
  "env_id": "crimson_env@0.1",
  "description": "As a SCADA automation engineer for a natural gas production company, configure the process measurement tags for wellsite W-201 in Red Lion Crimson 3.0 according to AGA-3/API flow measurement standards. Configure only the active and in-service tags identified in the wellsite tag register and measurement standards parameters (found in the CrimsonTasks folder on the Desktop) with the correct data type, engineering range, unit label, description, and alarm thresholds. Save the project as 'oilgas_flow.c3' in C:\\Users\\Docker\\Documents\\CrimsonProjects\\. Login credentials: Docker / GymAnything123!",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 1080,
    "max_steps": 140,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\oilgas_flow_measurement_tags\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\oilgas_flow_measurement_tags\\export_result.ps1"
  },
  "metadata": {
    "task_name": "oilgas_flow_measurement_tags",
    "project_filename": "oilgas_flow.c3",
    "project_path": "C:\\Users\\Docker\\Documents\\CrimsonProjects\\oilgas_flow.c3",
    "industry": "Oil and Gas - Upstream/Midstream",
    "occupation": "SCADA Automation Engineer",
    "standard": "AGA Report No. 3 (2012) / API MPMS Chapter 14.3 / OSHA 29 CFR 1910.1000",
    "tags": [
      {
        "name": "FT_201",
        "description": "Gas Flow Rate - AGA-3 Orifice Meter",
        "data_type": "Float",
        "unit": "MMscfd",
        "min_value": 0.0,
        "max_value": 10.0,
        "label": "Million Std Cubic Feet per Day",
        "alarm_low": 0.5,
        "alarm_high": 8.5
      },
      {
        "name": "PT_201",
        "description": "Upstream Static Pressure - Meter Run",
        "data_type": "Float",
        "unit": "psia",
        "min_value": 0.0,
        "max_value": 1500.0,
        "label": "Pounds per Sq Inch Absolute",
        "alarm_low": 200.0,
        "alarm_high": 1200.0
      },
      {
        "name": "TT_201",
        "description": "Gas Temperature - AGA-3 Meter Run",
        "data_type": "Float",
        "unit": "degF",
        "min_value": -40.0,
        "max_value": 200.0,
        "label": "Degrees Fahrenheit",
        "alarm_low": 10.0,
        "alarm_high": 130.0
      },
      {
        "name": "DP_201",
        "description": "Differential Pressure - Orifice Plate",
        "data_type": "Float",
        "unit": "inH2O",
        "min_value": 0.0,
        "max_value": 250.0,
        "label": "Inches Water Column",
        "alarm_low": 0.0,
        "alarm_high": 200.0
      },
      {
        "name": "AT_201",
        "description": "Hydrogen Sulfide Concentration - Safety",
        "data_type": "Float",
        "unit": "ppm",
        "min_value": 0.0,
        "max_value": 100.0,
        "label": "Parts per Million",
        "alarm_low": 0.0,
        "alarm_high": 10.0
      },
      {
        "name": "FQ_201",
        "description": "Cumulative Gas Volume - Daily Total",
        "data_type": "Float",
        "unit": "Mscf",
        "min_value": 0.0,
        "max_value": 999999.0,
        "label": "Thousand Standard Cubic Feet",
        "alarm_low": 0.0,
        "alarm_high": 500000.0
      }
    ],
    "tolerance_pct": 2.0,
    "inactive_tags": [
      "FT_202",
      "PT_202"
    ],
    "archetype": "batch_with_judgment",
    "archetype_note": "Tag register has 8 entries (6 active W-201, 2 inactive W-202). Agent must configure only active W-201 tags. Configuring FT_202 or PT_202 triggers wrong-wellsite gate (score=0)."
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_oilgas_flow_measurement_tags"
    }
  }
}
