{
  "id": "flour_mill_pneumatic_triggers@1",
  "version": "1.0",
  "env_id": "crimson_env@0.1",
  "description": "Red Lion Crimson 3.0 is open. A grain mill is experiencing intermittent blockages in its pneumatic flour transfer lines. As the controls technician, add diagnostic event logging to the SCADA system using Crimson's Tag Triggers without modifying the PLC code. Configure 6 tags for the pneumatic conveying system based on the 'pneumatic_tag_register.csv' file located in C:\\Users\\Docker\\Desktop\\CrimsonTasks\\. Assign 'Active On' or 'Active Off' triggers and actions to 4 of these tags according to the 'nfpa61_event_logging_rules.txt' specification document found in the same folder. Save the completed project as 'flour_mill_triggers.c3' in C:\\Users\\Docker\\Documents\\CrimsonProjects\\. Login credentials: Docker / GymAnything123!",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\flour_mill_pneumatic_triggers\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\flour_mill_pneumatic_triggers\\export_result.ps1"
  },
  "metadata": {
    "task_name": "flour_mill_pneumatic_triggers",
    "project_filename": "flour_mill_triggers.c3",
    "project_path": "C:\\Users\\Docker\\Documents\\CrimsonProjects\\flour_mill_triggers.c3",
    "industry": "Food Manufacturing / Material Handling",
    "occupation": "Control Systems Technician",
    "expected_tags": [
      {
        "name": "Blower_M101_Run",
        "data_type": "Flag",
        "has_trigger": true,
        "trigger_mode": "Active Off",
        "trigger_action": "LogEvent(\"Blower M101 Stopped\")"
      },
      {
        "name": "Valve_RV102_Fault",
        "data_type": "Flag",
        "has_trigger": true,
        "trigger_mode": "Active On",
        "trigger_action": "LogEvent(\"Rotary Valve RV102 Fault\")"
      },
      {
        "name": "Silo_A_Level_Hi",
        "data_type": "Flag",
        "has_trigger": true,
        "trigger_mode": "Active On",
        "trigger_action": "LogEvent(\"Silo A Full\")"
      },
      {
        "name": "System_Reset_PB",
        "data_type": "Flag",
        "has_trigger": true,
        "trigger_mode": "Active On",
        "trigger_action": "Blockage_Count = 0"
      },
      {
        "name": "Filter_Pulse_Run",
        "data_type": "Flag",
        "has_trigger": false
      },
      {
        "name": "Blockage_Count",
        "data_type": "Integer",
        "has_trigger": false
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_flour_mill_triggers"
    }
  }
}
