{
  "id": "gameday_command_center@1",
  "version": "1.0",
  "env_id": "chrome_env_all@0.1",
  "description": "You are a sports data analyst preparing for Opening Day. Configure the Chrome browser according to the Analytics Department's Game Day Browser Standard located at ~/Desktop/gameday_browser_standard.txt. Implement all requirements for bookmark organization into six folders, a five-tab live workspace, browser flags, font adjustments, privacy/startup policies, and saving the pre-game checklist.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/gameday_command_center/setup_task.sh",
    "post_task": "/workspace/tasks/gameday_command_center/export_result.sh"
  },
  "metadata": {
    "required_folders": [
      "Advanced Analytics",
      "Live Scoring",
      "Historical Reference",
      "Scouting & Player Dev",
      "League Operations",
      "Personal"
    ],
    "required_tabs": [
      "fangraphs.com",
      "baseballsavant.mlb.com",
      "mlb.com/scores",
      "milb.com/scores",
      "baseball-reference.com"
    ],
    "expected_font_size": 20,
    "expected_flags": [
      "enable-parallel-downloading@1",
      "smooth-scrolling@2"
    ],
    "checklist_path": "/home/ga/Desktop/pregame_checklist.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_gameday_command_center"
    }
  }
}
