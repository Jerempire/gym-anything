{
  "id": "logistics_dashboard_configuration@1",
  "version": "1.0",
  "env_id": "example.chrome_env_all@0.1",
  "description": "Configure this shared Chrome browser as an unattended global logistics dashboard according to the specifications in ~/Desktop/dashboard_spec.txt. Requirements include removing personal travel data left by the previous user while preserving maritime tracking data, organizing logistics bookmarks into the specified hierarchy, configuring 'mmsi' and 'container' custom search engines for vessel/freight lookups, setting startup pages, and globally blocking notifications and location prompts so the dashboard can run uninterrupted.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/logistics_dashboard_configuration/setup_task.sh",
    "post_task": "/workspace/tasks/logistics_dashboard_configuration/export_result.sh"
  },
  "metadata": {
    "travel_domains": [
      "expedia.com",
      "airbnb.com",
      "skyscanner.com",
      "kayak.com",
      "booking.com",
      "tripadvisor.com",
      "hotels.com",
      "carnival.com",
      "disneycruise.disney.go.com",
      "vrbo.com",
      "cheapflights.com"
    ],
    "logistics_domains": [
      "marinetraffic.com",
      "vesselfinder.com",
      "searates.com",
      "myshiptracking.com",
      "portoflosangeles.org",
      "polb.com",
      "panynj.gov",
      "portofsavannah.com",
      "up.com",
      "bnsf.com",
      "csx.com"
    ],
    "expected_folders": {
      "Vessel Tracking": [
        "marinetraffic.com",
        "vesselfinder.com",
        "searates.com",
        "myshiptracking.com"
      ],
      "Port Operations": [
        "portoflosangeles.org",
        "polb.com",
        "panynj.gov",
        "portofsavannah.com"
      ],
      "Intermodal Rail": [
        "up.com",
        "bnsf.com",
        "csx.com"
      ]
    },
    "search_engines": {
      "mmsi": "vesselfinder.com/?mmsi=",
      "container": "searates.com/container/tracking/?number="
    },
    "startup_urls": [
      "marinetraffic.com",
      "portoflosangeles.org"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_task"
    }
  }
}
