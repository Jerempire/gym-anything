{
  "id": "wind_farm_scada_console@1",
  "version": "1.0",
  "env_id": "example.chrome_env_all@0.1",
  "description": "A wind turbine maintenance technician must configure their ruggedized field laptop's Chrome browser for the upcoming maintenance season. Implement all requirements specified in ~/Desktop/field_laptop_spec.txt, including bookmark organization and cleanup, Chrome flag configuration for low-bandwidth networks, font adjustments for high-glare environments, custom search engine setup for diagnostic codes, and downloading the latest LOTO manual.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/wind_farm_scada_console/setup_task.sh",
    "post_task": "/workspace/tasks/wind_farm_scada_console/export_result.sh"
  },
  "metadata": {
    "junk_domains": [
      "ign.com",
      "draftkings.com",
      "netflix.com",
      "store.steampowered.com",
      "espn.com",
      "reddit.com",
      "twitch.tv",
      "hulu.com"
    ],
    "expected_folders": [
      "Weather & Forecasting",
      "SCADA Control",
      "OEM Manuals",
      "Safety & LOTO"
    ],
    "flags": {
      "offline_auto_reload": "enable-offline-auto-reload@1",
      "quic_disabled": "enable-quic@2",
      "smooth_scrolling_disabled": "smooth-scrolling@2"
    },
    "fonts": {
      "default_size": 22,
      "minimum_size": 16
    },
    "search_engines": {
      "fault": "kb.blueridge-wind.local/search?fault_code=%s",
      "part": "parts.windoem.com/catalog?sku=%s"
    },
    "pdf_target_path": "/home/ga/Documents/Field_Safety/LOTO_procedure_2026.pdf"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_task"
    }
  }
}
