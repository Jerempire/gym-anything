{
  "id": "field_terminal_browser_config@1",
  "version": "1.0",
  "env_id": "example.chrome_env_all@0.1",
  "description": "Configure Chrome on your field tablet according to the 'Remote Maintenance Terminal Configuration Standard v4.2' located at ~/Desktop/remote_terminal_config_standard.txt. The configuration must include optimized Chrome flags, increased font size and default zoom for outdoor readability, specific notification and geolocation permissions for SCADA and weather sites, organized operational bookmark folders, and hardened privacy settings as defined in the standard.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/field_terminal_browser_config/setup_task.sh",
    "post_task": "/workspace/tasks/field_terminal_browser_config/export_result.sh"
  },
  "metadata": {
    "expected_flags": [
      "smooth-scrolling",
      "enable-parallel-downloading",
      "back-forward-cache"
    ],
    "expected_font_size": 20,
    "expected_min_font_size": 14,
    "scada_domains": [
      "vestas.com",
      "bazefield.com",
      "scada-international.com"
    ],
    "weather_domains": [
      "windy.com",
      "weather.gov",
      "maps.google.com"
    ],
    "homepage_domain": "vestas.com",
    "download_dir": "Field_Reports",
    "bookmark_folders": [
      "Monitoring & SCADA",
      "Parts & Documentation",
      "Weather & Navigation",
      "Personal"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_task"
    }
  }
}
