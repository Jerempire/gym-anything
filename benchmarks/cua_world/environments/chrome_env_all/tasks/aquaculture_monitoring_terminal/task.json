{
  "id": "aquaculture_monitoring_terminal@1",
  "version": "1.0",
  "env_id": "example.chrome_env_all@0.1",
  "description": "A hatchery manager must configure a shared Chrome terminal used for 24/7 environmental monitoring. Organize bookmarks, purge unauthorized entertainment sites, configure startup pages, prevent dashboard tabs from sleeping, allow insecure content for local IoT sensors, and add custom search engines. The full specification is located at ~/Desktop/hatchery_terminal_spec.txt.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/aquaculture_monitoring_terminal/setup_task.sh",
    "post_task": "/workspace/tasks/aquaculture_monitoring_terminal/export_result.sh"
  },
  "metadata": {
    "folders": [
      "Environment",
      "Fish Health",
      "Feed Logistics",
      "Local Sensors"
    ],
    "unauthorized_domains": [
      "youtube.com",
      "reddit.com",
      "netflix.com",
      "hulu.com",
      "twitch.tv",
      "steampowered.com",
      "facebook.com"
    ],
    "startup_urls": [
      "tidesandcurrents.noaa.gov",
      "10.0.0.50"
    ],
    "performance_exceptions": [
      "10.0.0.50",
      "10.0.0.51",
      "10.0.0.52",
      "tidesandcurrents.noaa.gov"
    ],
    "insecure_content_ips": [
      "10.0.0.50",
      "10.0.0.51",
      "10.0.0.52"
    ],
    "search_engines": {
      "fb": "fishbase.se/Summary/SpeciesSummary.php?id=",
      "hach": "hach.com/search?q="
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_task"
    }
  }
}
