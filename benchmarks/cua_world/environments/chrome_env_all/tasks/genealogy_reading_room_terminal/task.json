{
  "id": "genealogy_reading_room_terminal@1",
  "version": "1.0",
  "env_id": "example.chrome_env_all@0.1",
  "description": "Configure the Chrome browser on a shared genealogy reading room terminal according to the standards specified in ~/Desktop/reading_room_spec.txt. The configuration requires organizing bookmarks, adding custom search engine shortcuts, optimizing performance for large historical image files, setting accessibility font sizes, enabling bulk downloading without prompts, and disabling credential saving for privacy.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/genealogy_reading_room_terminal/setup_task.sh",
    "post_task": "/workspace/tasks/genealogy_reading_room_terminal/export_result.sh"
  },
  "metadata": {
    "target_download_dir": "/home/ga/Documents/Archive_Downloads",
    "required_flags": [
      "enable-parallel-downloading",
      "smooth-scrolling",
      "back-forward-cache"
    ],
    "search_engines": [
      {
        "keyword": "loc",
        "url_fragment": "loc.gov"
      },
      {
        "keyword": "nara",
        "url_fragment": "catalog.archives.gov"
      },
      {
        "keyword": "fag",
        "url_fragment": "findagrave.com"
      }
    ],
    "fonts": {
      "default_font_size": 22,
      "minimum_font_size": 16
    },
    "personal_domains": [
      "facebook.com",
      "pinterest.com",
      "youtube.com",
      "etsy.com",
      "netflix.com",
      "instagram.com",
      "hulu.com",
      "spotify.com"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_task"
    }
  }
}
