{
  "id": "antiquities_provenance_workspace@1",
  "version": "1.0",
  "env_id": "example.chrome_env_all@0.1",
  "description": "Configure the Chrome browser for a 'European Antiquities' cataloging session according to the specification at ~/Desktop/appraiser_browser_spec.txt. Organize bookmarks into folders, purge personal data from previous users, configure startup pages, modify site-specific popup and notification permissions, adjust font accessibility settings, and set up download management for catalog assets.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 75,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/antiquities_provenance_workspace/setup_task.sh",
    "post_task": "/workspace/tasks/antiquities_provenance_workspace/export_result.sh"
  },
  "metadata": {
    "expected_folders": [
      "Provenance & Stolen Art",
      "Museum Archives",
      "Auction Records",
      "Internal Admin"
    ],
    "personal_domains": [
      "netflix.com",
      "espn.com",
      "facebook.com",
      "hulu.com"
    ],
    "startup_urls": [
      "artloss.com",
      "artnet.com"
    ],
    "popup_allow_domains": [
      "artnet.com",
      "metmuseum.org"
    ],
    "default_font_size": 18,
    "min_font_size": 14,
    "download_dir": "/home/ga/Documents/Auction_Catalog_Assets"
  },
  "success": {
    "spec": {
      "program": "verifier.py::verify_task"
    }
  }
}
