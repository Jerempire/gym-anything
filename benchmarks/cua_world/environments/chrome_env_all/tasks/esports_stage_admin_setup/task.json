{
  "id": "esports_stage_admin_setup@1",
  "version": "1.0",
  "env_id": "chrome_env_all@0.1",
  "description": "Configure the Chrome browser on the main stage admin terminal for a live broadcast event. Following the protocol at ~/Desktop/stage_admin_protocol.txt, organize the 25 loose bookmarks into five folders, disable Memory Saver to prevent bracket tabs from dropping, set default Audio and Microphone permissions to Block while allowing Discord, disable the QUIC protocol flag for legacy anti-cheat compatibility, add a custom search engine for VLR.gg, and set the startup pages to Battlefy and Discord.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/esports_stage_admin_setup/setup_task.sh",
    "post_task": "/workspace/tasks/esports_stage_admin_setup/export_result.sh"
  },
  "metadata": {
    "expected_folders": {
      "Brackets & Scoring": [
        "smash.gg",
        "challonge.com",
        "liquipedia.net",
        "battlefy.com",
        "toornament.com"
      ],
      "Stream Management": [
        "twitch.tv",
        "youtube.com",
        "restream.io",
        "obs.ninja",
        "vdo.ninja"
      ],
      "Anti-Cheat Portals": [
        "faceit.com",
        "esea.net",
        "riotgames.com",
        "easy.ac",
        "battleye.com"
      ],
      "Team Comms": [
        "discord.com",
        "teamspeak.com",
        "slack.com",
        "mumble.info",
        "guilded.gg"
      ],
      "Personal": [
        "twitter.com",
        "reddit.com",
        "amazon.com",
        "netflix.com",
        "espn.com"
      ]
    },
    "expected_search_keyword": "vlr",
    "expected_search_url": "https://www.vlr.gg/search/?q=%s",
    "expected_startup_domains": [
      "discord.com",
      "battlefy.com"
    ],
    "expected_audio_mic_allow": "discord.com",
    "expected_disabled_flag": "enable-quic@2"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_esports_setup"
    }
  }
}
