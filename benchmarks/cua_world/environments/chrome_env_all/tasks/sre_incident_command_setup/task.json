{
  "id": "sre_incident_command_setup@1",
  "version": "1.0",
  "env_id": "example.chrome_env_all@0.1",
  "description": "Configure the Network Operations Center (NOC) shared wallboard browser according to the requirements in ~/Desktop/noc_display_standard.txt. Organize bookmarks, manage dashboard tabs, configure search engines, set notification rules, adjust display settings, enable performance flags, and set startup pages as specified in the standard.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sre_incident_command_setup/setup_task.sh",
    "post_task": "/workspace/tasks/sre_incident_command_setup/export_result.sh"
  },
  "metadata": {
    "expected_tabs": [
      "datadoghq.com/dashboard/system",
      "pagerduty.com/incidents",
      "console.aws.amazon.com/ec2"
    ],
    "expected_folders": [
      "Alerting",
      "Observability",
      "Cloud Infrastructure",
      "Runbooks"
    ],
    "junk_domains": [
      "facebook.com",
      "netflix.com",
      "twitter.com",
      "reddit.com",
      "pinterest.com",
      "steampowered.com",
      "spotify.com",
      "tiktok.com"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_sre_incident_command"
    }
  }
}
