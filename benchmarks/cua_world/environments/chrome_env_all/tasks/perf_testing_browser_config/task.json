{
  "id": "perf_testing_browser_config@1",
  "version": "1.0",
  "env_id": "example.chrome_env@0.1",
  "description": "Configure Chrome for a web performance testing environment according to the team standard specified in ~/Desktop/perf_testing_standard.txt. Apply all required configurations for experimental flags (chrome://flags), custom search engines, homepage and startup pages, font sizes, the download directory (~/projects/test-artifacts), and privacy/credential settings.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/perf_testing_browser_config/setup_task.sh",
    "post_task": "/workspace/tasks/perf_testing_browser_config/export_result.sh"
  },
  "metadata": {
    "spec_file": "/home/ga/Desktop/perf_testing_standard.txt",
    "download_dir": "/home/ga/projects/test-artifacts",
    "expected_flags": {
      "enable-experimental-web-platform-features": 1,
      "enable-parallel-downloading": 1,
      "enable-quic": 1,
      "smooth-scrolling": 2,
      "enable-force-dark": 2
    },
    "expected_search_engines": {
      "mdn": "developer.mozilla.org",
      "npm": "npmjs.com",
      "gh": "github.com",
      "can": "caniuse.com"
    },
    "expected_fonts": {
      "default": 18,
      "fixed": 15,
      "minimum": 12
    },
    "expected_startup_urls": [
      "github.com/dashboard",
      "developer.chrome.com",
      "web.dev"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_browser_config"
    }
  }
}
