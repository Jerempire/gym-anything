{
  "id": "ag_extension_browser_setup@1",
  "version": "1.0",
  "env_id": "example.chrome_env_all@0.1",
  "description": "Configure the Chrome browser according to the USDA Cooperative Extension Digital Workspace Standard. Implement all requirements from the specification file at ~/Desktop/extension_workspace_standard.txt, including organizing the 30 existing bookmarks into folders on the bookmarks bar named 'Crop Science', 'Livestock & Veterinary', 'Extension Programs', and 'Personal'. Configure Chrome flags for smooth-scrolling, parallel-downloading, and back-forward-cache. Set accessibility font sizes (default: 20, fixed: 18, min: 14) and establish custom search engines 'usda' and 'ext'. Set the homepage to https://www.nifa.usda.gov and startup pages to nifa.usda.gov and ers.usda.gov. Configure the download directory to ~/Documents/Extension_Bulletins with 'Ask where to save' enabled, and disable password saving, address autofill, and payment methods.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/ag_extension_browser_setup/setup_task.sh",
    "post_task": "/workspace/tasks/ag_extension_browser_setup/export_result.sh"
  },
  "metadata": {
    "expected_folders": [
      "Crop Science",
      "Livestock & Veterinary",
      "Extension Programs",
      "Personal"
    ],
    "crop_science_domains": [
      "plants.usda.gov",
      "nass.usda.gov",
      "ers.usda.gov",
      "crops.org",
      "extension.org/crops",
      "nrcs.usda.gov",
      "weather.gov",
      "ipm.ucanr.edu"
    ],
    "livestock_domains": [
      "aphis.usda.gov",
      "nahln.org",
      "beefresearch.org",
      "pork.org",
      "avma.org",
      "extension.org/animals",
      "fsis.usda.gov"
    ],
    "extension_domains": [
      "nifa.usda.gov",
      "extension.org",
      "4-h.org",
      "fsa.usda.gov",
      "rd.usda.gov",
      "mastergardener.extension.org",
      "ffa.org"
    ],
    "personal_domains": [
      "youtube.com",
      "amazon.com",
      "espn.com",
      "mail.google.com",
      "facebook.com",
      "netflix.com",
      "weather.com"
    ],
    "expected_flags": [
      "smooth-scrolling@1",
      "parallel-downloading@1",
      "back-forward-cache@1"
    ],
    "expected_fonts": {
      "default": 20,
      "fixed": 18,
      "min": 14
    },
    "search_engines": [
      {
        "keyword": "usda",
        "url": "https://search.usa.gov/search?affiliate=usda&query=%s"
      },
      {
        "keyword": "ext",
        "url": "https://search.extension.org/search?q=%s"
      }
    ],
    "homepage": "nifa.usda.gov",
    "startup_urls": [
      "nifa.usda.gov",
      "ers.usda.gov"
    ],
    "download_dir_contains": "Extension_Bulletins"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_task"
    }
  }
}
