{
  "id": "system_advisor_model_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "NREL System Advisor Model (SAM) environment for renewable energy techno-economic analysis including photovoltaic, wind, CSP, and battery storage system modeling",
  "category": ["renewable_energy", "engineering", "scientific"],
  "tags": [
    "linux",
    "renewable_energy",
    "photovoltaic",
    "wind",
    "solar",
    "energy_modeling",
    "desktop",
    "scientific",
    "engineering",
    "simulation"
  ],
  "licence": "BSD-3-Clause",
  "authors": [
    "gym-anything team"
  ],
  "upstream_url": "https://sam.nrel.gov/",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [
        1920,
        1080
      ],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": true,
  "step_cycle_ms": 300,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/system_advisor_model_env/artifacts",
    "video_fps": 10,
    "video_resolution": [
      1920,
      1080
    ],
    "video_codec": "libx264",
    "video_crf": 23,
    "audio_rate": 44100,
    "audio_channels": 2,
    "audio_codec": "aac"
  },
  "vnc": {
    "enable": false,
    "host_port": 5962,
    "container_port": 5900,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": [
      "ALL"
    ],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true,
    "runtime": "sysbox-runc"
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/system_advisor_model_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/system_advisor_model_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/system_advisor_model_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/system_advisor_model_env/utils",
      "target": "/workspace/utils",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/system_advisor_model_env/assets",
      "target": "/workspace/assets",
      "mode": "rw"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_sam.sh",
    "post_start": "/workspace/scripts/setup_sam.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "engineer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": [
          "sudo",
          "audio",
          "video",
          "input"
        ],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "SAM_CONFIG": "/home/ga/.SAM"
        }
      }
    }
  ]
}
