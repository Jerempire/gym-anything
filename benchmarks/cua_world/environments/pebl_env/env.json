{
  "id": "pebl_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "PEBL (Psychology Experiment Building Language) environment for running, editing, and analyzing computerized psychology experiments from the PEBL Test Battery",
  "resources": {
    "cpu": 4,
    "mem_gb": 4,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/pebl_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/pebl_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/pebl_env/assets", "target": "/workspace/assets", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_pebl.sh",
    "post_start": "/workspace/scripts/setup_pebl.sh"
  },
  "vnc": {
    "password": "password"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ]
}
