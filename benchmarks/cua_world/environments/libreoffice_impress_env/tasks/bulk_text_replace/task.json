{
  "id": "bulk_text_replace@1",
  "version": "1.0",
  "env_id": "libreoffice_impress_env@0.1",
  "description": "In the WHO Health Workforce Report presentation, replace all instances of the word 'workforce' with 'personnel' across all slides using Find & Replace (Ctrl+H). Save the file after replacement.",
  "difficulty": "medium-hard",
  "init": {
    "timeout_sec": 120,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bulk_text_replace/setup_task.sh",
    "post_task": "/workspace/tasks/bulk_text_replace/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_text_replaced"
    }
  }
}
