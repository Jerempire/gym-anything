{
  "id": "export_pdf@1",
  "version": "1.0",
  "env_id": "libreoffice_impress_env@0.1",
  "description": "Export the presentation to PDF format and save it to /home/ga/Documents/presentation.pdf using the specified quality settings.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 90,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_pdf/setup_task.sh",
    "post_task": "/workspace/tasks/export_pdf/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_pdf_export"
    }
  }
}
