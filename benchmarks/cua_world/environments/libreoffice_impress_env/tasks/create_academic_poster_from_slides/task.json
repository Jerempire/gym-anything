{
  "id": "create_academic_poster_from_slides@1",
  "version": "1.0",
  "env_id": "libreoffice_impress_env@0.1",
  "description": "Convert the 5-slide thesis presentation 'thesis_draft.odp' into a single-slide large-format academic poster (30\" x 20\" Landscape). Consolidate all text content from slides 2 through 5 onto the first slide and remove the extra slides. Save the final poster as '/home/ga/Documents/Presentations/research_poster.odp'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_academic_poster_from_slides/setup_task.sh",
    "post_task": "/workspace/tasks/create_academic_poster_from_slides/export_result.sh"
  },
  "metadata": {
    "expected_filename": "research_poster.odp",
    "expected_width_in": 30,
    "expected_height_in": 20,
    "expected_slide_count": 1,
    "required_keywords": [
      "Urban Green Spaces",
      "mental health outcomes",
      "longitudinal survey",
      "correlation coefficient",
      "policy implications"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_academic_poster"
    }
  }
}
