{
  "id": "apply_distinct_master_slides@1",
  "version": "1.0",
  "env_id": "libreoffice_impress_env@0.1",
  "description": "Apply the 'Midnight' master slide design from the 'Midnight.otp' template on the Desktop to specific slides in the presentation. Apply this master slide only to Slide 1, Slide 3, and Slide 6, ensuring that Slides 2, 4, 5, and 7 retain their default white background. Save the final presentation to /home/ga/Documents/Presentations/Q3_Marketing_Review_Final.odp.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/apply_distinct_master_slides/setup_task.sh",
    "post_task": "/workspace/tasks/apply_distinct_master_slides/export_result.sh"
  },
  "metadata": {
    "input_file": "/home/ga/Documents/Presentations/Q3_Marketing_Review.odp",
    "template_file": "/home/ga/Desktop/Midnight.otp",
    "output_file": "/home/ga/Documents/Presentations/Q3_Marketing_Review_Final.odp",
    "target_slides_indices": [
      0,
      2,
      5
    ],
    "content_slides_indices": [
      1,
      3,
      4,
      6
    ],
    "total_slides": 7
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_master_slides"
    }
  }
}
