{
  "id": "create_basic_presentation@1",
  "version": "1.0",
  "env_id": "libreoffice_impress_env@0.1",
  "description": "Create a 5-slide presentation on the specified topic. Each slide must include a title and 2-3 bullet points. Save the presentation to /home/ga/Documents/presentation.pptx.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_basic_presentation/setup_task.sh",
    "post_task": "/workspace/tasks/create_basic_presentation/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_basic_presentation"
    }
  }
}
