{
  "id": "recolor_shapes_brand_palette@1",
  "version": "1.0",
  "env_id": "libreoffice_impress_env@0.1",
  "description": "Recolor the shapes and title text across all 4 slides of the 'esg_report.odp' presentation to match the new corporate brand palette. Change all Rectangle shapes to Forest Green (#2E7D32), all Ellipse/Circle shapes to Amber (#FF8F00), and all Slide Titles text color to Dark Blue (#0D47A1). Do not modify the body text or other elements. Save the changes to the presentation.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/recolor_shapes_brand_palette/setup_task.sh",
    "post_task": "/workspace/tasks/recolor_shapes_brand_palette/export_result.sh"
  },
  "metadata": {
    "presentation_path": "/home/ga/Documents/Presentations/esg_report.odp",
    "target_colors": {
      "rectangle_fill": "#2E7D32",
      "ellipse_fill": "#FF8F00",
      "title_text": "#0D47A1"
    },
    "initial_colors": {
      "shape_fill": "#C0C0C0",
      "text_color": "#000000"
    },
    "slide_count": 4,
    "shapes_per_slide": {
      "rectangles": 2,
      "ellipses": 1
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_recolor_shapes"
    }
  }
}
