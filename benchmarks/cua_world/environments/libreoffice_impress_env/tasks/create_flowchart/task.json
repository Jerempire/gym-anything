{
  "id": "create_flowchart@1",
  "version": "1.0",
  "env_id": "libreoffice_impress_env@0.1",
  "description": "Create a flowchart diagram representing a process.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_flowchart/setup_task.sh",
    "post_task": "/workspace/tasks/create_flowchart/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_flowchart_created"
    }
  }
}
