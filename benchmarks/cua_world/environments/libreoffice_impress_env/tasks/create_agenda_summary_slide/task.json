{
  "id": "create_agenda_summary_slide@1",
  "version": "1.0",
  "env_id": "libreoffice_impress_env@0.1",
  "description": "Create an 'Agenda' slide as the second slide of the presentation. This slide must contain a bulleted list of the titles of all subsequent slides (Slides 3-7) in their correct order.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_agenda_summary_slide/setup_task.sh",
    "post_task": "/workspace/tasks/create_agenda_summary_slide/export_result.sh"
  },
  "metadata": {
    "expected_slide_count": 7,
    "agenda_slide_index": 1,
    "expected_topics": [
      "Cloud Migration Timeline",
      "Budget Variance Analysis",
      "Talent Acquisition Pipeline",
      "Security Audit Findings",
      "Vendor Renewal Status"
    ],
    "target_file": "/home/ga/Documents/Presentations/strategic_initiatives.odp"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_agenda_slide"
    }
  }
}
