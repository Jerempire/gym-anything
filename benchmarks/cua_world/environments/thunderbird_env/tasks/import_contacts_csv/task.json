{
  "id": "import_contacts_csv@1",
  "version": "1.0",
  "env_id": "thunderbird_env@0.1",
  "description": "You are a receptionist at a regional medical practice. The practice manager has provided you with a CSV file containing contact information for 12 referring physicians located at ~/Documents/referring_physicians.csv. Import all 12 contacts from this CSV file into Thunderbird's Personal Address Book, ensuring all contact details including names, email addresses, organizations, and phone numbers are correctly recorded.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/import_contacts_csv/setup_task.sh",
    "post_task": "/workspace/tasks/import_contacts_csv/export_result.sh"
  },
  "metadata": {
    "csv_path": "/home/ga/Documents/referring_physicians.csv",
    "expected_total_contacts": 12,
    "sentinel_emails": [
      "s.chen@northvalleymed.org",
      "d.abramowitz@pinecrestgi.com",
      "m.kowalski@sunriserheum.org"
    ],
    "all_expected_emails": [
      "s.chen@northvalleymed.org",
      "m.okafor@lakeviewclinic.com",
      "p.reeves@summithealthpartners.org",
      "j.gupta@meridianortho.com",
      "l.nakamura@harborpulmonary.org",
      "r.fernandez@cedardermatology.com",
      "e.johansson@valleyviewpeds.org",
      "d.abramowitz@pinecrestgi.com",
      "a.whitfield@mountainviewent.org",
      "t.patel@riverbendurology.com",
      "m.kowalski@sunriserheum.org",
      "w.baptiste@oaklandendo.com"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_contacts_imported"
    }
  }
}
