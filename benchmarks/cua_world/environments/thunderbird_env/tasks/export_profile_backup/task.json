{
  "id": "export_profile_backup@1",
  "version": "1.0",
  "env_id": "thunderbird_env@0.1",
  "description": "Create a .zip backup archive of your current Thunderbird profile and save it to ~/Documents/ProfileBackup/.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_profile_backup/setup_task.sh",
    "post_task": "/workspace/tasks/export_profile_backup/export_result.sh"
  },
  "metadata": {
    "target_directory": "/home/ga/Documents/ProfileBackup",
    "expected_extension": ".zip",
    "min_size_bytes": 1048576,
    "required_internal_files": [
      "prefs.js",
      "Mail"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_profile"
    }
  }
}
