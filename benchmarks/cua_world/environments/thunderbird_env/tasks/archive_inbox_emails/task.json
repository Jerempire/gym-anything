{
  "id": "archive_inbox_emails@1",
  "version": "1.0",
  "env_id": "thunderbird_env@0.1",
  "description": "Configure Thunderbird's Local Folders archiving settings to use a single folder without yearly or monthly subfolders. Archive all messages currently in the Local Folders Inbox to the 'Archives' folder.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/archive_inbox_emails/setup_task.sh",
    "post_task": "/workspace/tasks/archive_inbox_emails/export_result.sh"
  },
  "metadata": {
    "expected_archive_granularity": 0,
    "min_emails_preserved_percent": 90,
    "target_account": "Local Folders"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_archive_inbox"
    }
  }
}
