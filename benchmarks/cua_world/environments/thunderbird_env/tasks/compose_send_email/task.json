{
  "id": "compose_send_email@1",
  "version": "1.0",
  "env_id": "thunderbird_env@0.1",
  "description": "Compose a new email draft in Thunderbird addressed to 'colleague@example.com' with the subject 'Q4 Budget Review Meeting'. Include a professional message body requesting a meeting to discuss Q4 budget allocations and save the message as a draft. Do not attempt to send the email.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 120,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/compose_send_email/setup_task.sh",
    "post_task": "/workspace/tasks/compose_send_email/export_result.sh"
  },
  "metadata": {
    "expected_recipient": "colleague@example.com",
    "expected_subject": "Q4 Budget Review Meeting",
    "expected_body_keywords": [
      "budget",
      "meeting",
      "Q4"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_compose_send_email"
    }
  }
}
