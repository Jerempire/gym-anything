{
  "id": "subscribe_rss_feed@1",
  "version": "1.0",
  "env_id": "thunderbird_env@0.1",
  "description": "Create a 'Blogs & News Feeds' account in Thunderbird and subscribe to the internal market intelligence RSS feed at 'http://localhost:8080/market_news.xml'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/subscribe_rss_feed/setup_task.sh",
    "post_task": "/workspace/tasks/subscribe_rss_feed/export_result.sh"
  },
  "metadata": {
    "expected_feed_url": "http://localhost:8080/market_news.xml",
    "expected_headline": "Global Equities Rebound Strongly",
    "expected_account_type": "rss"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_subscribe_rss_feed"
    }
  }
}
