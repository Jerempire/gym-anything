{
  "id": "add_contact@1",
  "version": "1.0",
  "env_id": "claude.thunderbird_env@0.1",
  "description": "Add a new contact to the address book with email 'john.doe@example.com' and display name 'John Doe'",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 120,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_contact/setup_task.sh",
    "post_task": "/workspace/tasks/add_contact/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_contact_added"
    }
  }
}
