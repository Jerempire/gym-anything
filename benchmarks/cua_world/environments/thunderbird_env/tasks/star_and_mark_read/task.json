{
  "id": "star_and_mark_read@1",
  "version": "1.0",
  "env_id": "thunderbird_env@0.1",
  "description": "You have returned to a backlog of unread emails. Star the three emails containing the word 'EMBARGOED' in their subject lines so they aren't forgotten, and mark the entire Inbox folder as read to clear the notification badge.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/star_and_mark_read/setup_task.sh",
    "post_task": "/workspace/tasks/star_and_mark_read/export_result.sh"
  },
  "metadata": {
    "target_keyword": "EMBARGOED",
    "target_count": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_star_and_mark_read"
    }
  }
}
