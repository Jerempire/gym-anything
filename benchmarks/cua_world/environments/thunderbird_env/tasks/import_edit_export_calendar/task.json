{
  "id": "import_edit_export_calendar@1",
  "version": "1.0",
  "env_id": "thunderbird_env@0.1",
  "description": "Import '~/Documents/draft_schedule.ics' into Thunderbird's local calendar and update the 'Concrete Pour - Phase 3' event (April 20, 2026) to 10:00 AM – 2:00 PM (14:00) with 'Weather delay' in the description. Export the updated calendar to '~/Documents/updated_schedule.ics' in iCalendar (.ics) format.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/import_edit_export_calendar/setup_task.sh",
    "post_task": "/workspace/tasks/import_edit_export_calendar/export_result.sh"
  },
  "metadata": {
    "source_file": "/home/ga/Documents/draft_schedule.ics",
    "expected_output_path": "/home/ga/Documents/updated_schedule.ics",
    "target_event_name": "Concrete Pour - Phase 3",
    "expected_start_time": "10:00 AM",
    "expected_end_time": "2:00 PM",
    "expected_desc_keyword": "Weather delay"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_calendar_workflow"
    }
  }
}
