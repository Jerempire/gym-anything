{
  "id": "configure_rss_feed_reader@1",
  "version": "1.0",
  "env_id": "thunderbird_env@0.1",
  "description": "Configure Thunderbird as an internal RSS feed reader. Create a new Feed Account named 'Market Intelligence' and subscribe to the internal corporate RSS feed located at http://localhost:8080/industry_news.xml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_rss_feed_reader/setup_task.sh",
    "post_task": "/workspace/tasks/configure_rss_feed_reader/export_result.sh"
  },
  "metadata": {
    "expected_account_name": "Market Intelligence",
    "expected_feed_url": "http://localhost:8080/industry_news.xml",
    "expected_article_title": "Globex Corp Announces Q3 Results"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rss_feed_reader"
    }
  }
}
