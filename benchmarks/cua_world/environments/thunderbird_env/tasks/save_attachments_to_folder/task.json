{
  "id": "save_attachments_to_folder@1",
  "version": "1.0",
  "env_id": "thunderbird_env@0.1",
  "description": "Save the 'project_report.pdf' and 'materials_costs.csv' attachments from the email with the subject 'Site Update - Weekly Report #47' to ~/Documents/ProjectFiles/ without modification.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/save_attachments_to_folder/setup_task.sh",
    "post_task": "/workspace/tasks/save_attachments_to_folder/export_result.sh"
  },
  "metadata": {
    "target_directory": "/home/ga/Documents/ProjectFiles",
    "expected_files": [
      "project_report.pdf",
      "materials_costs.csv"
    ],
    "email_subject": "Site Update - Weekly Report #47"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_save_attachments"
    }
  }
}
