{
  "id": "configure_openpgp_encryption@1",
  "version": "1.0",
  "env_id": "thunderbird_env@0.1",
  "description": "Generate a native OpenPGP key pair for the identity 'testuser@example.com'. Configure Thunderbird to add a digital signature to outgoing emails by default and export the public key to /home/ga/Documents/testuser_pubkey.asc.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_openpgp_encryption/setup_task.sh",
    "post_task": "/workspace/tasks/configure_openpgp_encryption/export_result.sh"
  },
  "metadata": {
    "expected_pubkey_path": "/home/ga/Documents/testuser_pubkey.asc",
    "expected_uid": "testuser@example.com"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_openpgp"
    }
  }
}
