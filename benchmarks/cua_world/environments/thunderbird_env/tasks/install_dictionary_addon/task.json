{
  "id": "install_dictionary_addon@1",
  "version": "1.0",
  "env_id": "thunderbird_env@0.1",
  "description": "Install the Spanish dictionary extension from the local file at '/home/ga/Downloads/es-ES-dictionary.xpi'. Enable the 'Check spelling as you type' feature and set the default spellchecker language to 'Spanish (Spain)'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/install_dictionary_addon/setup_task.sh",
    "post_task": "/workspace/tasks/install_dictionary_addon/export_result.sh"
  },
  "metadata": {
    "expected_addon_id": "es-es@dictionaries.addons.mozilla.org",
    "expected_dict_code": "es-ES",
    "xpi_path": "/home/ga/Downloads/es-ES-dictionary.xpi"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_dictionary_addon"
    }
  }
}
