{
  "id": "create_folder@1",
  "version": "1.0",
  "env_id": "claude.thunderbird_env@0.1",
  "description": "Create a new mail folder named 'Work' in the Local Folders account",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 120,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_folder/setup_task.sh",
    "post_task": "/workspace/tasks/create_folder/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_folder_created"
    }
  }
}
