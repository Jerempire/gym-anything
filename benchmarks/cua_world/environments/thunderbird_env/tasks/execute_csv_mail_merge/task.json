{
  "id": "execute_csv_mail_merge@1",
  "version": "1.0",
  "env_id": "claude.thunderbird_env@0.1",
  "description": "Create 15 personalized office relocation emails in Thunderbird using the data from ~/Documents/vendors.csv (headers: FirstName, LastName, Company, Email). Use the Mail Merge feature to queue the messages in the Outbox (Send Later mode). Each email must have the subject \"Account Update: {{Company}}\" and a body containing the greeting \"Dear {{FirstName}},\", the message \"Please be advised that our corporate office is moving. Please update the billing address for {{Company}} in your records.\", and the sign-off \"Thank you, Operations Team\".",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/execute_csv_mail_merge/setup_task.sh",
    "post_task": "/workspace/tasks/execute_csv_mail_merge/export_result.sh"
  },
