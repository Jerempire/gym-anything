{
  "id": "create_custom_project_tags@1",
  "version": "1.0",
  "env_id": "thunderbird_env@0.1",
  "description": "Create a custom email tag named 'Audit 2026' with the color Purple. Apply this tag to the emails with the subjects 'Internal Audit Schedule - FY26', 'Compliance Review: Q3 Documentation', and 'Vendor Risk Assessment - Action Required'. Do not tag any other emails.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_custom_project_tags/setup_task.sh",
    "post_task": "/workspace/tasks/create_custom_project_tags/export_result.sh"
  },
  "metadata": {
    "expected_tag_name": "Audit 2026",
    "target_subjects": [
      "Internal Audit Schedule - FY26",
      "Compliance Review: Q3 Documentation",
      "Vendor Risk Assessment - Action Required"
    ],
    "bulk_tagging_limit": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_custom_tags"
    }
  }
}
