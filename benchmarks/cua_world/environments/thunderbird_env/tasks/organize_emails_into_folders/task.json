{
  "id": "organize_emails_into_folders@1",
  "version": "1.0",
  "env_id": "thunderbird_env@0.1",
  "description": "Organize your Thunderbird emails by moving at least three messages from the Inbox into a new folder named 'Important' located under Local Folders.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 150,
    "max_steps": 35,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/organize_emails_into_folders/setup_task.sh",
    "post_task": "/workspace/tasks/organize_emails_into_folders/export_result.sh"
  },
  "metadata": {
    "expected_folder_name": "Important",
    "min_emails_to_move": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_organize_emails_into_folders"
    }
  }
}
