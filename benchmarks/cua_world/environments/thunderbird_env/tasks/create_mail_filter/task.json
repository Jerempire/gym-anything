{
  "id": "create_mail_filter@1",
  "version": "1.0",
  "env_id": "thunderbird_env@0.1",
  "description": "Create a message filter in Thunderbird that automatically moves emails containing the word 'urgent' in the subject line to a folder named 'Urgent' under Local Folders.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_mail_filter/setup_task.sh",
    "post_task": "/workspace/tasks/create_mail_filter/export_result.sh"
  },
  "metadata": {
    "expected_filter_name": "Urgent Filter",
    "expected_condition_field": "subject",
    "expected_condition_value": "urgent",
    "expected_action": "Move to folder",
    "expected_target_folder": "Urgent"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_mail_filter"
    }
  }
}
