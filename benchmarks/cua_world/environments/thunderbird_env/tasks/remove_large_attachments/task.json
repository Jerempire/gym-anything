{
  "id": "remove_large_attachments@1",
  "version": "1.0",
  "env_id": "thunderbird_env@0.1",
  "description": "Locate the three emails in your Inbox with subjects starting with 'Case Evidence:' and delete their file attachments to free up space. The emails themselves must be preserved in the Inbox for record-keeping.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/remove_large_attachments/setup_task.sh",
    "post_task": "/workspace/tasks/remove_large_attachments/export_result.sh"
  },
  "metadata": {
    "target_subjects": [
      "Case Evidence: Smith vs Jones (Deposition)",
      "Case Evidence: Exhibit B Scans",
      "Case Evidence: Financial Disclosures"
    ],
    "max_stripped_size_bytes": 100000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_attachments_removed"
    }
  }
}
