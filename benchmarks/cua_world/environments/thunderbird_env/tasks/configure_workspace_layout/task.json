{
  "id": "configure_workspace_layout@1",
  "version": "1.0",
  "env_id": "claude.thunderbird_env@0.1",
  "description": "Configure Thunderbird's layout for high-volume email triage. Set the global layout to 'Vertical View' (reading pane on the right). In the Inbox message list, include the 'Size' and 'Tags' columns, remove the 'Date' column, and sort the messages by 'Size' in descending order.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_workspace_layout/setup_task.sh",
    "post_task": "/workspace/tasks/configure_workspace_layout/export_result.sh"
  },
  "metadata": {
    "expected_layout_pref": 2,
    "target_email_subject": "URGENT: Q4 Financial Report",
    "target_columns": [
      "Size",
      "Tags"
    ],
    "removed_columns": [
      "Date"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_workspace_layout"
    }
  }
}
