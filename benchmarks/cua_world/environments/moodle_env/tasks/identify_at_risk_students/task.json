{
  "id": "identify_at_risk_students@1",
  "version": "1.0",
  "env_id": "moodle_env@0.1",
  "description": "Log in to Moodle as admin (username: admin, password: Admin1234!). In the 'Chemistry 101' (CHEM101) course, send a bulk message to all students who have been inactive for more than 4 weeks. The message body must include the phrase 'catch up' to offer them assistance.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/identify_at_risk_students/setup_task.sh",
    "post_task": "/workspace/tasks/identify_at_risk_students/export_result.sh"
  },
  "metadata": {
    "course_shortname": "CHEM101",
    "target_users": [
      "dlee",
      "epatel"
    ],
    "control_users": [
      "fkim",
      "awilson",
      "bbrown"
    ],
    "required_text": "catch up",
    "inactivity_days": 30
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_identify_at_risk_students"
    }
  }
}
