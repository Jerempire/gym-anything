{
  "id": "import_question_bank@1",
  "version": "1.0",
  "env_id": "moodle_env@0.1",
  "description": "Log in to Moodle (http://localhost/moodle) as admin (username: admin, password: Admin1234!). Create a new question category named \"Pharmacology Module 3\" within the \"Introduction to Biology\" (BIO101) course question bank with the description \"Drug classifications, mechanisms, and clinical applications\". Import the pharmacology questions from the GIFT file located at /home/ga/Documents/pharmacology_questions.gift into this new category.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/import_question_bank/setup_task.sh",
    "post_task": "/workspace/tasks/import_question_bank/export_result.sh"
  },
  "metadata": {
    "target_course_shortname": "BIO101",
    "target_category_name": "Pharmacology Module 3",
    "gift_file_path": "/home/ga/Documents/pharmacology_questions.gift",
    "expected_question_count": 8,
    "expected_question_names": [
      "Penicillin Mechanism",
      "Beta-Blocker Target",
      "Warfarin Antidote",
      "ACE Inhibitor Side Effect",
      "Insulin Storage",
      "Digoxin Toxicity Sign",
      "Nitroglycerin Administration",
      "Heparin Monitoring"
    ],
    "check_answer_key_1": "Vitamin K",
    "check_answer_key_2": "aPTT"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_import_question_bank"
    }
  }
}
