    "post_task": "/workspace/tasks/create_course/export_result.sh"
  },
  "metadata": {
    "expected_fullname": "Data Science 101",
    "expected_shortname": "DS101",
    "expected_category": "Science"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_course"
    }
  }
