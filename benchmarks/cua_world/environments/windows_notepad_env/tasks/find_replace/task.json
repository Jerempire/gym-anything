{
  "id": "find_replace@1",
  "version": "1.0",
  "env_id": "example.windows_notepad@0.1",
  "description": "Use Notepad's features, replace all instance of 'old' with 'new' in the file 'document.txt' and save the file.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\find_replace\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\find_replace\\export_result.ps1"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_find_replace"
    }
  }
}
