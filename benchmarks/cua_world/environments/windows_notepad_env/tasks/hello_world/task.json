{
  "id": "hello_world@1",
  "version": "1.0",
  "env_id": "example.windows_notepad@0.1",
  "description": "Type 'Hello, World!' in Notepad and save the file as hello.txt on the Desktop",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 120,
    "max_steps": 15,
    "reward_type": "sparse",
    "init_pyautogui": [
      {"type": "keys", "keys": ["win", "r"]},
      {"type": "wait", "seconds": 1},
      {"type": "text", "text": "notepad"},
      {"type": "wait", "seconds": 0.5},
      {"type": "keys", "keys": ["enter"]},
      {"type": "wait", "seconds": 2}
    ]
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\hello_world\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\hello_world\\export_result.ps1"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_hello_world"
    }
  }
}
