{
  "id": "save_file@1",
  "version": "1.0",
  "env_id": "example.windows_notepad@0.1",
  "description": "Open the file 'sample.txt' from Desktop/Tasks folder in Notepad, add the line 'This line was added by the agent.' at the end, and save the file.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 120,
    "max_steps": 12,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\save_file\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\save_file\\export_result.ps1"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_file_saved"
    }
  }
}
