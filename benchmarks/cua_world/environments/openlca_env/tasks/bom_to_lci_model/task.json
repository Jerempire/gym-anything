{
  "id": "bom_to_lci_model@1",
  "version": "1.0",
  "env_id": "openlca_env@0.1",
  "description": "Create a Life Cycle Inventory (LCI) model for an 'Electric Kettle Manufacturing' process using the Bill of Materials (BOM) at ~/Documents/kettle_bom.csv and the USLCI database at ~/LCA_Imports/uslci_database.zip. Ensure all input exchanges are linked to specific provider processes within the USLCI database. Generate a product system for this process, perform an LCIA calculation using the TRACI 2.1 method, and export the results to ~/LCA_Results/kettle_impact.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bom_to_lci_model/setup_task.sh",
    "post_task": "/workspace/tasks/bom_to_lci_model/export_result.sh"
  },
  "metadata": {
    "bom_file": "/home/ga/Documents/kettle_bom.csv",
    "target_process_name": "Electric Kettle Manufacturing",
    "target_product_system": "Electric Kettle System",
    "output_file": "/home/ga/LCA_Results/kettle_impact.csv",
    "bom_items": [
      {
        "component": "Polypropylene Casing",
        "amount": 0.85,
        "unit": "kg",
        "keyword": "polypropylene"
      },
      {
        "component": "Steel Heating Element",
        "amount": 0.45,
        "unit": "kg",
        "keyword": "steel"
      },
      {
        "component": "Copper Wiring",
        "amount": 0.12,
        "unit": "kg",
        "keyword": "copper"
      },
      {
        "component": "Assembly Electricity",
        "amount": 1.5,
        "unit": "kWh",
        "keyword": "electricity"
      },
      {
        "component": "Corrugated Packaging",
        "amount": 0.3,
        "unit": "kg",
        "keyword": "corrugated"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bom_to_lci_model"
    }
  }
}
