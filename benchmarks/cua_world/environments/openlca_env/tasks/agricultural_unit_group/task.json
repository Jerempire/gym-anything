{
  "id": "agricultural_unit_group@1",
  "version": "1.0",
  "env_id": "openlca_env@0.1",
  "description": "In openLCA, create a unit group named 'Agricultural Area-Time' containing the units 'ha*season' (reference unit, factor 1.0), 'ac*season' (factor 0.404686), and 'ha*yr' (factor 3.0). Create a flow property named 'Irrigated area-time' that uses this unit group.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/agricultural_unit_group/setup_task.sh",
    "post_task": "/workspace/tasks/agricultural_unit_group/export_result.sh"
  },
  "metadata": {
    "target_unit_group_name": "Agricultural Area-Time",
    "target_flow_property_name": "Irrigated area-time",
    "units": [
      {
        "name": "ha*season",
        "factor": 1.0,
        "is_ref": true
      },
      {
        "name": "ac*season",
        "factor": 0.404686,
        "tolerance": 0.001
      },
      {
        "name": "ha*yr",
        "factor": 3.0,
        "tolerance": 0.1
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_agricultural_unit_group"
    }
  }
}
