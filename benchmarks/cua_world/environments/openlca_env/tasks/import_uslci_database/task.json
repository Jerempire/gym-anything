{
  "id": "import_uslci_database@1",
  "version": "1.0",
  "env_id": "openlca_env@0.1",
  "description": "Create a new database named 'USLCI_Analysis' in openLCA and import the USLCI (U.S. Life Cycle Inventory) database from the JSON-LD zip file at ~/LCA_Imports/uslci_database.zip. Ensure the database is populated with the USLCI processes and flows.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/import_uslci_database/setup_task.sh",
    "post_task": "/workspace/tasks/import_uslci_database/export_result.sh"
  },
  "metadata": {
    "database_name": "USLCI_Analysis",
    "import_file": "uslci_database.zip",
    "expected_min_processes": 10,
    "expected_categories": [
      "Processes",
      "Flows",
      "Flow properties"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_import_uslci_database"
    }
  }
}
