{
  "id": "nw_executive_scoring@1",
  "version": "1.0",
  "env_id": "openlca_env@0.1",
  "description": "Configure a normalization and weighting set named 'US Person-Year 2023' within an LCIA method (e.g., TRACI 2.1) in openLCA using these factors: Global Warming (Norm: 24000, Weight: 0.30), Acidification (Norm: 90, Weight: 0.20), Eutrophication (Norm: 22, Weight: 0.15), Ozone Depletion (Norm: 0.22, Weight: 0.10), and Smog (Norm: 124, Weight: 0.25). Using the USLCI database (~/LCA_Imports/uslci_database.zip) and LCIA",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/nw_executive_scoring/setup_task.sh",
    "post_task": "/workspace/tasks/nw_executive_scoring/export_result.sh"
  },
  "metadata": {
    "target_nw_set_name": "US Person-Year 2023",
    "output_file": "/home/ga/LCA_Results/normalized_weighted_results.csv",
    "required_factors": [
      {
        "category": "Global Warming",
        "norm": 24000,
        "weight": 0.3
      },
      {
        "category": "Acidification",
        "norm": 90,
        "weight": 0.2
      },
      {
        "category": "Eutrophication",
        "norm": 22,
        "weight": 0.15
      },
      {
        "category": "Ozone",
        "norm": 0.22,
        "weight": 0.1
      },
      {
        "category": "Smog",
        "norm": 124,
        "weight": 0.25
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_nw_executive_scoring"
    }
  }
}
