{
  "id": "global_parameter_formulas@1",
  "version": "1.0",
  "env_id": "openlca_env@0.1",
  "description": "Create six global parameters in the openLCA database to model a plastic bottle production scenario. Define three input parameters ('annual_production', 'bottle_weight_g', 'recycled_content_pct') and three dependent parameters ('total_resin_kg', 'virgin_resin_kg', 'recycled_resin_kg') using specific mathematical formulas. Export a summary of the parameter names, formulas, and values to ~/LCA_Results/parameter_summary.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/global_parameter_formulas/setup_task.sh",
    "post_task": "/workspace/tasks/global_parameter_formulas/export_result.sh"
  },
  "metadata": {
    "expected_csv_path": "/home/ga/LCA_Results/parameter_summary.csv",
    "target_parameters": [
      {
        "name": "annual_production",
        "value": 1000000.0,
        "is_input": true
      },
      {
        "name": "bottle_weight_g",
        "value": 25.0,
        "is_input": true
      },
      {
        "name": "total_resin_kg",
        "value": 25000.0,
        "formula_contains": "*"
      },
      {
        "name": "recycled_content_pct",
        "value": 30.0,
        "is_input": true
      },
      {
        "name": "virgin_resin_kg",
        "value": 17500.0,
        "formula_contains": "1 -"
      },
      {
        "name": "recycled_resin_kg",
        "value": 7500.0,
        "formula_contains": "*"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_global_parameter_formulas"
    }
  }
}
