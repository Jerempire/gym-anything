{
  "id": "export_process_jsonld@1",
  "version": "1.0",
  "env_id": "openlca_env@0.1",
  "description": "Import the USLCI database from '~/LCA_Imports/uslci_database.zip' and export a process related to natural gas electricity generation in JSON-LD format. Save the exported file to '~/LCA_Results/natural_gas_electricity.zip'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_process_jsonld/setup_task.sh",
    "post_task": "/workspace/tasks/export_process_jsonld/export_result.sh"
  },
  "metadata": {
    "uslci_zip_path": "/home/ga/LCA_Imports/uslci_database.zip",
    "output_path": "/home/ga/LCA_Results/natural_gas_electricity.zip",
    "required_keywords": [
      "natural gas",
      "electricity",
      "power",
      "generation"
    ],
    "min_json_files": 1,
    "expected_structure": [
      "processes",
      "flows"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_process_jsonld"
    }
  }
}
