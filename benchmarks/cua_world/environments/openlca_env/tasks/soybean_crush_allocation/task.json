{
  "id": "soybean_crush_allocation@1",
  "version": "1.0",
  "env_id": "openlca_env@0.1",
  "description": "Create a process named 'Soybean Crushing (Custom)' with 1000 kg of 'Soybeans (Whole)' as input and two outputs: 180 kg of 'Soybean Oil (Custom)' and 800 kg of 'Soybean Meal (Custom)'. Apply Economic Allocation factors to the outputs based on market prices of $1.00/kg for Soybean Oil and $0.40/kg for Soybean Meal.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/soybean_crush_allocation/setup_task.sh",
    "post_task": "/workspace/tasks/soybean_crush_allocation/export_result.sh"
  },
  "metadata": {
    "process_name": "Soybean Crushing (Custom)",
    "flow_oil": "Soybean Oil (Custom)",
    "flow_meal": "Soybean Meal (Custom)",
    "price_oil": 1.0,
    "price_meal": 0.4,
    "mass_oil": 180,
    "mass_meal": 800,
    "expected_factor_oil": 0.36,
    "expected_factor_meal": 0.64,
    "tolerance": 0.02
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_soybean_crush_allocation"
    }
  }
}
