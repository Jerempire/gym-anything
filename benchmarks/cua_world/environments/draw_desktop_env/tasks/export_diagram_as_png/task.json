{
  "id": "export_diagram_as_png@1",
  "version": "1.0",
  "env_id": "draw_desktop_env@0.1",
  "description": "Export the hospital ER diagram ('hospital_er_base.drawio'), which includes Patient, Doctor, and Appointment tables, to a PNG image. Save the exported file as 'hospital_er_export.png' to /home/ga/Desktop.",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_diagram_as_png/setup_task.sh",
    "post_task": "/workspace/tasks/export_diagram_as_png/export_result.sh"
  },
  "metadata": {
    "expected_filename": "hospital_er_export.png",
    "expected_save_location": "/home/ga/Desktop",
    "source_diagram": "hospital_er_base.drawio",
    "min_file_size_kb": 5,
    "expected_format": "PNG"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_diagram_as_png"
    }
  }
}
