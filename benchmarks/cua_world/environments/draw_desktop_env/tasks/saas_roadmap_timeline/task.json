{
  "id": "saas_roadmap_timeline@1",
  "version": "1.0",
  "env_id": "draw_desktop_env@0.1",
  "description": "Create a 2025 Product Roadmap diagram in draw.io based on the data in '~/Desktop/roadmap_data.txt'. The diagram should use a swimlane or pool structure with three horizontal lanes labeled 'Frontend Team', 'Backend Team', and 'Mobile Team', and a timeline header divided into 'Q1 2025', 'Q2 2025', 'Q3 2025', and 'Q4 2025'. Map the initiatives from the source file to the appropriate team swimlane and quarter column. Use green fill for completed items, blue for planned items, and red for risky items, and include a diamond shape for the 'Product Launch v2.0' milestone at the end of Q2. Save the diagram as '~/Desktop/roadmap.drawio' and export it as '~/Desktop/roadmap.png'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/saas_roadmap_timeline/setup_task.sh",
    "post_task": "/workspace/tasks/saas_roadmap_timeline/export_result.sh"
  },
  "metadata": {
    "data_file": "/home/ga/Desktop/roadmap_data.txt",
    "expected_drawio": "/home/ga/Desktop/roadmap.drawio",
    "expected_png": "/home/ga/Desktop/roadmap.png",
    "teams": [
      "Frontend Team",
      "Backend Team",
      "Mobile Team"
    ],
    "quarters": [
      "Q1 2025",
      "Q2 2025",
      "Q3 2025",
      "Q4 2025"
    ],
    "tasks": [
      {
        "name": "SSO Integration",
        "team": "Backend Team",
        "q": "Q1",
        "status": "Completed"
      },
      {
        "name": "Dashboard Redesign",
        "team": "Frontend Team",
        "q": "Q1",
        "status": "Planned"
      },
      {
        "name": "iOS App Beta",
        "team": "Mobile Team",
        "q": "Q2",
        "status": "Risky"
      },
      {
        "name": "API Migration",
        "team": "Backend Team",
        "q": "Q2",
        "status": "Planned"
      },
      {
        "name": "Android Launch",
        "team": "Mobile Team",
        "q": "Q3",
        "status": "Planned"
      },
      {
        "name": "Dark Mode",
        "team": "Frontend Team",
        "q": "Q4",
        "status": "Planned"
      }
    ],
    "milestone": "Product Launch v2.0"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_saas_roadmap_timeline"
    }
  }
}
