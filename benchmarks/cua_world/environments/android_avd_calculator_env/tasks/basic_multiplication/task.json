{
  "id": "basic_multiplication@1",
  "env_id": "example.android_avd_calculator@0.1",
  "difficulty": "easy",
  "description": "Using the Calculator app on the Android device, compute 6 x 7.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/basic_multiplication/setup_task.sh",
    "post_task": "sh /sdcard/tasks/basic_multiplication/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_calculator_result"
    }
  }
}
