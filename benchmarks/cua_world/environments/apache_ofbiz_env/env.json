{
  "id": "apache_ofbiz_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Apache OFBiz ERP environment for enterprise business process automation. OFBiz is an open-source ERP system with modules for accounting, order management, product catalog, manufacturing, HR, and CRM. Uses Docker-in-QEMU with the official OFBiz Docker image and built-in demo data.",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/apache_ofbiz_env/artifacts",
    "video_fps": 10,
    "video_resolution": [1920, 1080],
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": false,
    "host_port": 5971,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/apache_ofbiz_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
{
      "source": "benchmarks/cua_world/environments/apache_ofbiz_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/apache_ofbiz_env/data",
      "target": "/workspace/data",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_ofbiz.sh",
    "post_start": "/workspace/scripts/setup_ofbiz.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "OFBIZ_USER": "ga"
        }
      }
    }
  ],
  "tags": [
    "linux",
    "erp",
    "apache-ofbiz",
    "web-application",
    "docker",
    "java",
    "business",
    "accounting",
    "order-management",
    "catalog",
    "manufacturing",
    "enterprise"
  ]
}
