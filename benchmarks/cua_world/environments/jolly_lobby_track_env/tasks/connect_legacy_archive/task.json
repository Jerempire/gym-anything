{
  "id": "connect_legacy_archive@1",
  "version": "1.0",
  "env_id": "jolly_lobby_track_env@0.1",
  "description": "Configure Jolly Lobby Track to use the archived database file located at '/home/ga/Documents/visitor_archive_2024.mdb'. The application must remain open and connected to this new database.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/connect_legacy_archive/setup_task.sh",
    "post_task": "/workspace/tasks/connect_legacy_archive/export_result.sh"
  },
  "metadata": {
    "archive_path_base": "/home/ga/Documents/visitor_archive_2024",
    "expected_filename": "visitor_archive_2024.mdb",
    "registry_key_hint": "HKCU\\Software\\Jolly Technologies",
    "lock_file_extensions": [
      ".ldb",
      ".laccdb",
      ".slock"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_connect_legacy_archive"
    }
  }
}
