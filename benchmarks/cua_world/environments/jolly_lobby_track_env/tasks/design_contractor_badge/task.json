{
  "id": "design_contractor_badge@1",
  "version": "1.0",
  "env_id": "jolly_lobby_track_env@0.1",
  "description": "Create a badge template named 'Contractor_Badge' in Jolly Lobby Track. The badge must feature the header 'CONTRACTOR' and include data fields for Visitor Name, Company, and Visit Date. Save the template as 'Contractor_Badge'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/design_contractor_badge/setup_task.sh",
    "post_task": "/workspace/tasks/design_contractor_badge/export_result.sh"
  },
  "metadata": {
    "expected_filename_stem": "Contractor_Badge",
    "required_strings": [
      "CONTRACTOR",
      "Company",
      "Name",
      "Date"
    ],
    "template_locations": [
      "/home/ga/.wine/drive_c/Program Files/Jolly Technologies/Lobby Track/Templates/Badges",
      "/home/ga/.wine/drive_c/users/Public/Documents/Jolly Technologies/Lobby Track/Templates",
      "/home/ga/Documents"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_design_contractor_badge"
    }
  }
}
