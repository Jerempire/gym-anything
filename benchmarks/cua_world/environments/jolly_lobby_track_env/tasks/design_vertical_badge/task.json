{
  "id": "design_vertical_badge@1",
  "version": "1.0",
  "env_id": "jolly_lobby_track_env@0.1",
  "description": "Create a visitor badge template named 'Vertical_Standard' in Jolly Lobby Track. The template must use Portrait orientation to fit new vertical badge holders and include the Visitor Name field. Save the template.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/design_vertical_badge/setup_task.sh",
    "post_task": "/workspace/tasks/design_vertical_badge/export_result.sh"
  },
  "metadata": {
    "target_filename": "Vertical_Standard",
    "required_orientation": "Portrait"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_design_vertical_badge"
    }
  }
}
