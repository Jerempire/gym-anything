{
  "id": "delete_visitor_record@1",
  "version": "1.0",
  "env_id": "jolly_lobby_track_env@0.1",
  "description": "Locate and permanently delete the visitor record for 'John Testentry' from the visitor database. Ensure that all other valid visitor records, including Maria Gonzalez, David Chen, and Sarah Williams, remain intact.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/delete_visitor_record/setup_task.sh",
    "post_task": "/workspace/tasks/delete_visitor_record/export_result.sh"
  },
  "metadata": {
    "target_visitor": {
      "first_name": "John",
      "last_name": "Testentry"
    },
    "preserved_visitors": [
      "Maria Gonzalez",
      "David Chen",
      "Sarah Williams"
    ],
    "db_pattern": "*.mdb"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_delete_visitor_record"
    }
  }
}
