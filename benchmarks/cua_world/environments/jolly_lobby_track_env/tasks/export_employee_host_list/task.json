{
  "id": "export_employee_host_list@1",
  "version": "1.0",
  "env_id": "jolly_lobby_track_env@0.1",
  "description": "Export the complete list of Employee Hosts from Jolly Lobby Track to a CSV file named 'employee_roster.csv' at ~/Documents/employee_roster.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_employee_host_list/setup_task.sh",
    "post_task": "/workspace/tasks/export_employee_host_list/export_result.sh"
  },
  "metadata": {
    "expected_filename": "employee_roster.csv",
    "expected_location": "/home/ga/Documents/employee_roster.csv",
    "required_content": [
      "Wilson",
      "Thompson",
      "Chang",
      "Engineering",
      "Operations"
    ],
    "min_file_size_bytes": 50
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_employee_host_list"
    }
  }
}
