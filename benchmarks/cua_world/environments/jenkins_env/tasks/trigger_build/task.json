{
  "id": "trigger_build@1",
  "version": "1.0",
  "env_id": "jenkins_env@0.1",
  "description": "Trigger a build for the Jenkins job 'Test-Build-Job' and verify the console output of the successful build. You are already logged in as admin. If prompted to log in, use Username: admin, Password: Admin123!",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/trigger_build/setup_task.sh",
    "post_task": "/workspace/tasks/trigger_build/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "test_job_name": "Test-Build-Job",
    "expected_result": "SUCCESS"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_trigger_build"
    }
  }
}
