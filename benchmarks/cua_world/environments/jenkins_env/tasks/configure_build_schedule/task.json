{
  "id": "configure_build_schedule@1",
  "version": "1.0",
  "env_id": "jenkins_env@0.1",
  "description": "Configure the 'Nightly-Backup' Jenkins job to run periodically at midnight every day using the cron syntax 'H 0 * * *'. You are already logged in as admin. If prompted to log in, use Username: admin, Password: Admin123!",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 35,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_build_schedule/setup_task.sh",
    "post_task": "/workspace/tasks/configure_build_schedule/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_job_name": "Nightly-Backup",
    "expected_schedule": "H 0 * * *"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_build_schedule"
    }
  }
}
