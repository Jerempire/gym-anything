{
  "id": "tag_first_failure_build@1",
  "version": "1.0",
  "env_id": "jenkins_env@0.1",
  "description": "The 'Nightly-Quality-Gate' job has been failing for several runs. Identify the chronologically first build that failed with the error 'FATAL: Non-resolvable parent POM' and update its description to 'Regression Start'. Do not modify any other builds or the job configuration.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/tag_first_failure_build/setup_task.sh",
    "post_task": "/workspace/tasks/tag_first_failure_build/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "job_name": "Nightly-Quality-Gate",
    "target_error": "FATAL: Non-resolvable parent POM",
    "target_tag": "Regression Start"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_tag_first_failure_build"
    }
  }
}
