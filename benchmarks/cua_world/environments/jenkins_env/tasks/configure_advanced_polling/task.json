{
  "id": "configure_advanced_polling@1",
  "version": "1.0",
  "env_id": "jenkins_env@0.1",
  "description": "Configure the 'legacy-inventory-sync' Freestyle job to poll SCM every 15 minutes between 8:00 AM and 6:00 PM on weekdays (Monday through Friday) with a Quiet Period of 120 seconds. If prompted, use Username: admin, Password: Admin123!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_advanced_polling/setup_task.sh",
    "post_task": "/workspace/tasks/configure_advanced_polling/export_result.sh"
  },
  "metadata": {
    "job_name": "legacy-inventory-sync",
    "expected_quiet_period": 120,
    "cron_components": {
      "minute": [
        "H/15",
        "*/15",
        "0,15,30,45"
      ],
      "hour": [
        "8-18"
      ],
      "dom": [
        "*"
      ],
      "month": [
        "*"
      ],
      "dow": [
        "1-5",
        "Mon-Fri"
      ]
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_advanced_polling"
    }
  }
}
