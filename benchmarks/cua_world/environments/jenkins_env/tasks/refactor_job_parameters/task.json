{
  "id": "refactor_job_parameters@1",
  "version": "1.0",
  "env_id": "jenkins_env@0.1",
  "description": "Refactor the 'Deploy-Service' Freestyle job to use a choice parameter named 'TARGET_ENV' with the options 'development', 'staging', and 'production'. Update the build script to dynamically echo the deployment message using the selected environment parameter. You are logged in as admin.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/refactor_job_parameters/setup_task.sh",
    "post_task": "/workspace/tasks/refactor_job_parameters/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "job_name": "Deploy-Service",
    "param_name": "TARGET_ENV",
    "param_choices": [
      "development",
      "staging",
      "production"
    ],
    "verification_test_val": "staging",
    "expected_output_pattern": "Deploying service to staging environment"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_refactor_job_parameters"
    }
  }
}
