{
  "id": "install_configure_plugin@1",
  "version": "1.0",
  "env_id": "jenkins_env@0.1",
  "description": "Install the 'Timestamper' plugin and configure the 'QA-Test-Runner' freestyle job to display timestamps in the console output. Verify the setup by executing a build of the job. Login credentials: Username: admin, Password: Admin123!",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/install_configure_plugin/setup_task.sh",
    "post_task": "/workspace/tasks/install_configure_plugin/export_result.sh",
    "pre_task_timeout": 300
  },
  "metadata": {
    "plugin_id": "timestamper",
    "job_name": "QA-Test-Runner",
    "expected_wrapper_class": "hudson.plugins.timestamper.TimestamperBuildWrapper"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_install_configure_plugin"
    }
  }
}
