{
  "id": "draw_basic_shapes@1",
  "version": "1.0",
  "env_id": "active_inspire_env@0.1",
  "name": "Draw Basic Shapes",
  "description": "Create a new ActivInspire flipchart and draw a rectangle and a circle or ellipse on the canvas. Save the flipchart to /home/ga/Documents/Flipcharts/shapes_lesson.flipchart.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/draw_basic_shapes/setup_task.sh",
    "post_task": "/workspace/tasks/draw_basic_shapes/export_result.sh"
  },
  "metadata": {
    "expected_shapes": [
      "rectangle",
      "circle"
    ],
    "min_shapes": 2,
    "expected_filename": "shapes_lesson.flipchart",
    "expected_directory": "/home/ga/Documents/Flipcharts",
    "expected_full_path": "/home/ga/Documents/Flipcharts/shapes_lesson.flipchart"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_draw_basic_shapes"
    }
  },
  "tags": [
    "shapes",
    "drawing",
    "intermediate"
  ]
}
