  "name": "Restaurant Menu Design",
  "description": "Create a 3-page digital menu flipchart for 'The Golden Fork' restaurant. Page 1 is a cover featuring the title 'The Golden Fork' and a logo. Page 2 is titled 'Appetizers' and includes Garlic Bread ($4.50), Mozzarella Sticks ($6.00), and Garden Salad ($5.25). Page 3 is titled 'Entrees' and includes Cheeseburger ($12.00), Grilled Salmon ($18.50), and Pasta Primavera ($14.00). Save the file to /home/ga/Documents/Flipcharts/restaurant_menu.flipchart.",
  "difficulty": "medium",
  "tags": [
    "education",
    "life-skills",
    "menu",
    "layout",
    "text-entry"
  ],
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/restaurant_menu_design/setup_task.sh",
    "post_task": "/workspace/tasks/restaurant_menu_design/export_result.sh"
  },
  "metadata": {
    "expected_filename": "restaurant_menu.flipchart",
    "expected_directory": "/home/ga/Documents/Flipcharts",
    "expected_full_path": "/home/ga/Documents/Flipcharts/restaurant_menu.flipchart",
    "required_strings": [
      "Golden Fork",
      "Appetizers",
      "Garlic Bread",
      "4.50",
      "Mozzarella Sticks",
      "6.00",
      "Garden Salad",
      "5.25",
      "Entrees",
      "Cheeseburger",
      "12.00",
      "Grilled Salmon",
      "18.50",
      "Pasta Primavera",
      "14.00"
    ],
    "expected_page_count": 3
  },
  "success": {
