{
  "id": "active_inspire_env@0.1",
  "version": "0.1",
  "base": "ubuntu-focal-gnome-systemd_highres",
  "description": "ActivInspire interactive whiteboard software environment for creating educational presentations, annotations, and interactive flipcharts. ActivInspire is Promethean's flagship educational software used in classrooms worldwide for creating engaging lesson materials. The public Promethean Linux repository currently exposes Ubuntu 20.04 (focal) packages, while the default highres preset in this repo is Ubuntu 24.04. This environment therefore requires a dedicated focal GNOME base image for supported installation and stable startup.",
  "status": "blocked",
  "status_reason": "Requires a dedicated Ubuntu 20.04 focal base; the current generic highres preset is Ubuntu 24.04 and ActivInspire crashes during startup on newer Ubuntu bases even with compatibility shims.",
  "required_base": "ubuntu-focal-gnome-systemd_highres (Ubuntu 20.04)",
  "category": "education",
  "tags": ["linux", "education", "whiteboard", "presentation", "desktop", "blocked"],
  "licence": "Proprietary (Promethean)",
  "authors": ["gym-anything team"],
  "upstream_url": "https://www.prometheanworld.com/products/software/activinspire/",
  "diagnostics": true,
  "resources": {
    "cpu": 4,
    "mem_gb": 4,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 250,
  "recording": {
    "enable": true,
    "output_dir": "artifacts",
    "video_fps": 10,
    "video_resolution": [1920, 1080],
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": true,
    "host_port": 5960,
    "view_only": false,
    "password": "password"
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/active_inspire_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/active_inspire_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/active_inspire_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/active_inspire_env/assets",
      "target": "/workspace/assets",
      "mode": "rw"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_activinspire.sh",
    "post_start": "/workspace/scripts/setup_activinspire.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "teacher",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1"
        }
      }
    }
  ]
}
