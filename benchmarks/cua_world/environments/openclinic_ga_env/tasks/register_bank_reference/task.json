{
  "id": "register_bank_reference@1",
  "version": "1.0",
  "env_id": "openclinic_ga_env@0.1",
  "description": "A new regional bank partner needs to be added to OpenClinic GA to process incoming checks. Register 'Equity Bank' with the code 'EQTY' in the system. Use credentials User: '4', Password: 'openclinic'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/register_bank_reference/setup_task.sh",
    "post_task": "/workspace/tasks/register_bank_reference/export_result.sh"
  },
  "metadata": {
    "target_bank_name": "Equity Bank",
    "target_bank_code": "EQTY",
    "database": "ocadmin_dbo",
    "table_hints": [
      "OC_BANKS",
      "Banks",
      "OC_FINANCIAL_INSTITUTIONS"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_register_bank_reference"
    }
  }
}
