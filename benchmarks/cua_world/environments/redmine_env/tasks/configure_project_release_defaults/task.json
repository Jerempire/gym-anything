{
  "id": "configure_project_release_defaults@1",
  "version": "1.0",
  "env_id": "redmine_env@0.1",
  "description": "You are the Project Manager for the 'Orion Satellite Interface' project. Configure the project for the 'v2.1-Beta' release so that any new issue created is automatically assigned to Sarah Connor and targeted for the 'v2.1-Beta' version by default.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_project_release_defaults/setup_task.sh",
    "post_task": "/workspace/tasks/configure_project_release_defaults/export_result.sh"
  },
  "metadata": {
    "project_identifier": "orion-satellite",
    "target_version_name": "v2.1-Beta",
    "target_assignee_login": "sconnor",
    "target_assignee_name": "Sarah Connor"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_project_release_defaults"
    }
  }
