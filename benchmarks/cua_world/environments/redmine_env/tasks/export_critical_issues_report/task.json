{
  "id": "export_critical_issues_report@1",
  "version": "1.0",
  "env_id": "redmine_env@0.1",
  "description": "You are a Construction Manager needing a site report. Navigate to the 'West Side Highway' project in Redmine. Export a CSV file to /home/ga/Documents/critical_site_report.csv containing all open issues (not Closed) with High or Urgent priority. The export must include the following columns: Subject, Status, Priority, Due date, and Assignee.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_critical_issues_report/setup_task.sh",
    "post_task": "/workspace/tasks/export_critical_issues_report/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/critical_site_report.csv",
    "project_identifier": "west-side-hwy",
    "required_columns": [
      "Due date",
      "Assignee",
      "Priority",
      "Status",
      "Subject"
    ],
    "target_priorities": [
      "High",
      "Urgent"
    ],
    "forbidden_statuses": [
      "Closed",
      "Rejected"
    ],
    "expected_row_count": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_critical_issues_report"
    }
  }
}
