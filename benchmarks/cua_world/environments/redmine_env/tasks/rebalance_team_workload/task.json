{
  "id": "rebalance_team_workload@1",
  "version": "1.0",
  "env_id": "redmine_env@0.1",
  "description": "Rebalance the sprint workload in the 'Payment Gateway API' project by moving exactly 2 High Priority issues currently assigned to 'Michael Turner' to 'Jane Doe'. Include the note 'Reassigning to balance sprint workload' on the moved issues. Do not move Michael's Normal priority issues or create new issues.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rebalance_team_workload/setup_task.sh",
    "post_task": "/workspace/tasks/rebalance_team_workload/export_result.sh"
  },
  "metadata": {
    "project_identifier": "payment-gateway-api",
    "source_user_login": "mturner",
    "target_user_login": "jdoe",
    "required_move_count": 2,
    "required_priority": "High",
    "required_note": "Reassigning to balance sprint workload"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rebalance_team_workload"
    }
  }
}
