{
  "id": "create_custom_role@1",
  "version": "1.0",
  "env_id": "redmine_env@0.1",
  "description": "Create a Redmine role named 'External Auditor' with the permissions defined in /home/ga/Documents/audit_access_policy.txt. Admin credentials: Username: admin, Password: Admin1234!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_custom_role/setup_task.sh",
    "post_task": "/workspace/tasks/create_custom_role/export_result.sh"
  },
  "metadata": {
    "role_name": "External Auditor",
    "policy_file": "/home/ga/Documents/audit_access_policy.txt",
    "required_permissions": [
      "view_issues",
      "view_documents",
      "view_files",
      "view_wiki_pages",
      "view_changesets",
      "browse_repository"
    ],
    "forbidden_permissions": [
      "edit_issues",
      "add_issues",
      "log_time",
      "view_time_entries",
      "add_messages"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_custom_role"
    }
  }
}
