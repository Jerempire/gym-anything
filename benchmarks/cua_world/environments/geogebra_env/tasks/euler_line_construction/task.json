{
  "id": "euler_line_construction@1",
  "version": "1.0",
  "env_id": "geogebra_env@0.1",
  "description": "Construct the Euler line for triangle ABC with vertices A(1, 1), B(7, 2), and C(4, 6) by geometrically constructing the Centroid (G), Circumcenter (O), and Orthocenter (H). Include a text annotation identifying the centers or describing the line. Save the project to ~/Documents/GeoGebra/projects/euler_line.ggb.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/euler_line_construction/setup_task.sh",
    "post_task": "/workspace/tasks/euler_line_construction/export_result.sh"
  },
  "metadata": {
    "expected_filename": "euler_line.ggb",
    "vertices": {
      "A": [
        1.0,
        1.0
      ],
      "B": [
        7.0,
        2.0
      ],
      "C": [
        4.0,
        6.0
      ]
    },
    "expected_centers": {
      "centroid": [
        4.0,
        3.0
      ],
      "circumcenter": [
        3.796,
        2.722
      ],
      "orthocenter": [
        4.407,
        3.556
      ]
    },
    "tolerance": 0.3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_euler_line_construction"
    }
  }
}
