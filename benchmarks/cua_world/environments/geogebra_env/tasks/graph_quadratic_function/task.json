{
  "id": "graph_quadratic_function@1",
  "version": "1.0",
  "env_id": "geogebra_env@0.1",
  "description": "Graph the quadratic function f(x) = x² - 4x + 3. Identify and mark at least three key points on the resulting parabola, such as the vertex, x-intercepts, or y-intercept. Save the construction to ~/Documents/GeoGebra/projects/quadratic_graph.ggb.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 120,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/graph_quadratic_function/setup_task.sh",
    "post_task": "/workspace/tasks/graph_quadratic_function/export_result.sh"
  },
  "metadata": {
    "expected_filename": "quadratic_graph.ggb",
    "function_expression": "x^2-4*x+3",
    "vertex_x": 2.0,
    "vertex_y": -1.0,
    "root_1": 1.0,
    "root_2": 3.0,
    "y_intercept": 3.0,
    "tolerance": 0.1
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_graph_quadratic_function"
    }
  }
}
