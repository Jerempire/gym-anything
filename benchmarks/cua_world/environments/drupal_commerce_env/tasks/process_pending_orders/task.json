{
  "id": "process_pending_orders@1",
  "version": "1.0",
  "env_id": "drupal_commerce_env@0.1",
  "description": "You are the store manager for Urban Electronics. You have 4 pending draft orders that need processing based on recent customer interactions and inventory checks. Process the four most recent draft orders at /admin/commerce/orders by completing the orders for johndoe (Sony WH-1000XM5) and mikewilson (Samsung Galaxy S24 Ultra), and canceling the orders for janesmith (Logitech MX Master 3S) and johndoe (Apple AirPods Pro 2). Do not create new orders.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/process_pending_orders/setup_task.sh",
    "post_task": "/workspace/tasks/process_pending_orders/export_result.sh"
  },
  "metadata": {
    "orders": [
      {
        "customer": "johndoe",
        "product_sku": "SONY-WH1000XM5",
        "target_action": "complete",
        "expected_states": [
          "completed",
          "fulfillment",
          "validation"
        ]
      },
      {
        "customer": "janesmith",
        "product_sku": "LOGI-MXM3S",
        "target_action": "cancel",
        "expected_states": [
          "canceled"
        ]
      },
      {
        "customer": "mikewilson",
        "product_sku": "SAM-S24ULTRA",
        "target_action": "complete",
        "expected_states": [
          "completed",
          "fulfillment",
          "validation"
        ]
      },
      {
        "customer": "johndoe",
        "product_sku": "APPLE-APP2",
        "target_action": "cancel",
        "expected_states": [
          "canceled"
        ]
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_process_pending_orders"
    }
  }
}
