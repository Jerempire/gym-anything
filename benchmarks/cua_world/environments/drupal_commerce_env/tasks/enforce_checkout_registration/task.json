{
  "id": "enforce_checkout_registration@1",
  "version": "1.0",
  "env_id": "drupal_commerce_env@0.1",
  "description": "Configure the 'Default' checkout flow to strictly require user registration. Ensure that guest checkout is disabled and user registration is enabled for this flow.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/enforce_checkout_registration/setup_task.sh",
    "post_task": "/workspace/tasks/enforce_checkout_registration/export_result.sh"
  },
  "metadata": {
    "config_name": "commerce_checkout_flow.default",
    "expected_guest": false,
    "expected_registration": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enforce_checkout_registration"
    }
  }
}
