{
  "id": "setup_customer_sidebar@1",
  "version": "1.0",
  "env_id": "drupal_commerce_env@0.1",
  "description": "Configure the 'Sidebar' region of the store to display specific tools for logged-in customers while keeping the checkout process distraction-free. Create a custom block named 'Sidebar Support' with the text 'Need help? Call 555-0199'. Place the 'User account menu', 'Shopping Cart', and 'Sidebar Support' blocks in the 'Sidebar' region. Configure all three blocks to be visible only to the 'Authenticated user' role and hidden on pages starting with '/checkout/*'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/setup_customer_sidebar/setup_task.sh",
    "post_task": "/workspace/tasks/setup_customer_sidebar/export_result.sh"
  },
  "metadata": {
    "theme": "olivero",
    "region": "sidebar",
    "expected_blocks": [
      {
        "type": "account_menu",
        "plugins": [
          "system_menu_block:account"
        ]
      },
      {
        "type": "cart",
        "plugins": [
          "views_block:commerce_cart_block-default",
          "commerce_cart"
        ]
      },
      {
        "type": "support",
        "content_string": "555-0199"
      }
    ],
    "visibility": {
      "roles": [
        "authenticated"
      ],
      "pages_mode": "negate",
      "pages": [
        "/checkout/*"
      ]
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_setup_customer_sidebar"
    }
  }
}
