{
  "id": "configure_store_navigation@1",
  "version": "1.0",
  "env_id": "drupal_commerce_env@0.1",
  "description": "Configure the 'Main navigation' menu of the Urban Electronics store to include three specific links in this order: 'Shop' pointing to /products, 'Cart' pointing to /cart, and 'Account' pointing to /user. Additionally, create a custom footer block displaying the text '© 2025 Urban Electronics' and place it in the Footer Bottom region of the default theme (Olivero). Ensure the block is visible on all pages.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_store_navigation/setup_task.sh",
    "post_task": "/workspace/tasks/configure_store_navigation/export_result.sh"
  },
  "metadata": {
    "expected_menu_links": [
      {
        "title": "Shop",
        "path": "/products",
        "regex": "products"
      },
      {
        "title": "Cart",
        "path": "/cart",
        "regex": "cart"
      },
      {
        "title": "Account",
        "path": "/user",
        "regex": "user"
      }
    ],
    "expected_copyright_text": "2025 Urban Electronics",
    "expected_theme": "olivero",
    "expected_region": "footer_bottom"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_store_navigation"
    }
  }
}