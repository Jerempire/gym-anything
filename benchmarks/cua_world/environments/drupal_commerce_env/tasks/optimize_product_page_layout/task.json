{
  "id": "optimize_product_page_layout@1",
  "version": "1.0",
  "env_id": "drupal_commerce_env@0.1",
  "description": "Optimize the 'Default' product variation display settings in Drupal Commerce. Enable the 'SKU' field for display and update the 'Images' field to use the 'Large (480x480)' image style.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/optimize_product_page_layout/setup_task.sh",
    "post_task": "/workspace/tasks/optimize_product_page_layout/export_result.sh"
  },
  "metadata": {
    "config_name": "core.entity_view_display.commerce_product_variation.default.default",
    "expected_image_style": "large",
    "expected_sku_visibility": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_optimize_product_page_layout"
    }
  }
}
