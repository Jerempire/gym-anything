{
  "id": "resolve_duplicate_products@1",
  "version": "1.0",
  "env_id": "drupal_commerce_env@0.1",
  "description": "A botched bulk import has created duplicate product entries in the catalog and corrupted a price. Remove all duplicate products with SKUs starting with 'IMPORT-' from the catalog, ensuring original products remain. Update the price of the 'Bose QuietComfort Ultra' (SKU: BOSE-QCU) to $429.00.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/resolve_duplicate_products/setup_task.sh",
    "post_task": "/workspace/tasks/resolve_duplicate_products/export_result.sh"
  },
  "metadata": {
    "duplicate_skus": [
      "IMPORT-SONY-WH1000XM5",
      "IMPORT-APPLE-MBP16",
      "IMPORT-LOGI-MXM3S",
      "IMPORT-DELL-XPS15"
    ],
    "target_product_sku": "BOSE-QCU",
    "target_correct_price": "429.00",
    "target_corrupt_price": "329.00",
    "expected_final_count": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_resolve_duplicate_products"
    }
  }
}
