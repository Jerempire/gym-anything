{
  "id": "configure_catalog_display@1",
  "version": "1.0",
  "env_id": "drupal_commerce_env@0.1",
  "description": "Optimize the visual presentation of products in the Drupal Commerce store. Update the 'Default' Product display to hide the 'Stores', 'Authored by', and 'Authored on' fields, and hide the label for the 'Body' field. Additionally, configure the 'Default' Product Variation display to use the 'Large (480x480)' image style for product images.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_catalog_display/setup_task.sh",
    "post_task": "/workspace/tasks/configure_catalog_display/export_result.sh"
  },
  "metadata": {
    "product_config_name": "core.entity_view_display.commerce_product.default.default",
    "variation_config_name": "core.entity_view_display.commerce_product_variation.default.default",
    "expected_hidden_fields": [
      "stores",
      "uid",
      "created"
    ],
    "expected_body_label": "hidden",
    "expected_image_style": "large"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_catalog_display"
    }
  }
}
