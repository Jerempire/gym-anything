{
  "id": "add_to_cart@1",
  "version": "1.0",
  "env_id": "drupal_commerce_env@0.1",
  "description": "Add the 'Sony WH-1000XM5 Wireless Headphones' to the shopping cart from the Drupal Commerce storefront catalog at /products.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_to_cart/setup_task.sh",
    "post_task": "/workspace/tasks/add_to_cart/export_result.sh"
  },
  "metadata": {
    "expected_product_title": "Sony WH-1000XM5 Wireless Headphones",
    "expected_product_sku": "SONY-WH1000XM5"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_to_cart"
    }
  }
}
