{
  "id": "configure_variation_image_style@1",
  "version": "1.0",
  "env_id": "drupal_commerce_env@0.1",
  "description": "Create an Image Style named 'Product Main (600x600)' (machine name: product_main_600) that scales and crops images to exactly 600x600 pixels. Configure the 'Default' product variation type's display settings to use this new image style for the Product image field.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_variation_image_style/setup_task.sh",
    "post_task": "/workspace/tasks/configure_variation_image_style/export_result.sh"
  },
  "metadata": {
    "style_name": "product_main_600",
    "style_label": "Product Main (600x600)",
    "effect_name": "image_scale_and_crop",
    "width": 600,
    "height": 600,
    "variation_type": "default",
    "field_name": "field_images"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_variation_image_style"
    }
  }
}
