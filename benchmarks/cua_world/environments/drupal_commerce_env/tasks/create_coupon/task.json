{
  "id": "create_coupon@1",
  "version": "1.0",
  "env_id": "drupal_commerce_env@0.1",
  "description": "Create an active promotion named 'Summer Sale 20% Off' in the Drupal Commerce store that provides a 20% discount on the order subtotal and requires the coupon code 'SUMMER20'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_coupon/setup_task.sh",
    "post_task": "/workspace/tasks/create_coupon/export_result.sh"
  },
  "metadata": {
    "expected_promotion_name": "Summer Sale 20% Off",
    "expected_coupon_code": "SUMMER20",
    "expected_discount_type": "percentage",
    "expected_discount_amount": "20"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_coupon"
    }
  }
}
