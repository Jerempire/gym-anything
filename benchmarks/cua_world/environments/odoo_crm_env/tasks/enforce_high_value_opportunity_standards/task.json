{
  "id": "enforce_high_value_opportunity_standards@1",
  "version": "1.0",
  "env_id": "odoo_crm_env@0.1",
  "description": "The VP of Sales has issued a new policy: All opportunities with an Expected Revenue of $50,000 or more must be marked as High Priority and tagged with 'Key Account'. Review the current CRM pipeline and update all opportunities meeting or exceeding this revenue threshold to reflect these requirements. Do not modify opportunities with revenue under $50,000.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/enforce_high_value_opportunity_standards/setup_task.sh",
    "post_task": "/workspace/tasks/enforce_high_value_opportunity_standards/export_result.sh"
  },
  "metadata": {
    "target_opportunities": [
      {
        "name": "Global Logistics Contract",
        "expected_revenue": 150000,
        "should_be_high_priority": true,
        "should_have_tag": true
      },
      {
        "name": "New HQ Furniture",
        "expected_revenue": 55000,
        "should_be_high_priority": true,
        "should_have_tag": true
      },
      {
        "name": "Server Upgrade",
        "expected_revenue": 12000,
        "should_be_high_priority": false,
        "should_have_tag": false
      }
    ],
    "target_tag": "Key Account",
    "high_priority_values": [
      "1",
      "2",
      "3"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enforce_high_value_opportunity_standards"
    }
  }
}
