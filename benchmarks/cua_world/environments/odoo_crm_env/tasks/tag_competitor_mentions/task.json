{
  "id": "tag_competitor_mentions@1",
  "version": "1.0",
  "env_id": "odoo_crm_env@0.1",
  "description": "The Marketing Director needs to track how often we face the competitor 'OmniTech'. Identify all CRM opportunities where 'OmniTech' is mentioned in the 'Internal Notes' field and tag them with a new CRM Tag named 'Competitor: OmniTech'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/tag_competitor_mentions/setup_task.sh",
    "post_task": "/workspace/tasks/tag_competitor_mentions/export_result.sh"
  },
  "metadata": {
    "target_tag_name": "Competitor: OmniTech",
    "target_keyword": "OmniTech",
    "expected_tagged_count": 2,
    "total_leads_count": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_tag_competitor_mentions"
    }
  }
}
