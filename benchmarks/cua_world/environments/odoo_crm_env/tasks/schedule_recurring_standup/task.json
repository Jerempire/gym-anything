{
  "id": "schedule_recurring_standup@1",
  "version": "1.0",
  "env_id": "odoo_crm_env@0.1",
  "description": "As a Sales Manager, schedule a recurring 'Weekly Sales Standup' meeting for the first Monday after today at 09:00 AM. Set the recurrence to weekly and include the description 'Review pipeline progress and blockers.'",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/schedule_recurring_standup/setup_task.sh",
    "post_task": "/workspace/tasks/schedule_recurring_standup/export_result.sh"
  },
  "metadata": {
    "expected_subject": "Weekly Sales Standup",
    "expected_time": "09:00:00",
    "expected_recurrence": "WEEKLY",
    "expected_description": "Review pipeline progress and blockers."
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_schedule_recurring_standup"
    }
  }
}
