{
  "id": "update_opportunity_details@1",
  "version": "1.0",
  "env_id": "odoo_crm_env@0.1",
  "description": "Update the CRM opportunity 'Office Furniture - Deco Addict' to reflect an Expected Revenue of $75,000, a Probability of 60%, a High priority (2 stars), and include the 'Enterprise' tag. Ensure all changes are saved to the database.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_opportunity_details/setup_task.sh",
    "post_task": "/workspace/tasks/update_opportunity_details/export_result.sh"
  },
  "metadata": {
    "target_revenue": 75000.0,
    "target_probability": 60.0,
    "target_priority": "2",
    "target_tag": "Enterprise",
    "initial_revenue": 25000.0,
    "initial_probability": 20.0,
    "initial_priority": "0"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_opportunity_details"
    }
  }
}
