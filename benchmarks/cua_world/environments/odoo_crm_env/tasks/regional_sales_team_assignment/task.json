{
  "id": "regional_sales_team_assignment@1",
  "version": "1.0",
  "env_id": "odoo_crm_env@0.1",
  "description": "The Sales Director has decided to split the sales organization by territory. A new dedicated team is needed for the West Coast region. Create a new sales team named \"West Coast\" and reassign all active opportunities belonging to customers in California to this team. Ensure opportunities from other states are not moved.",
  "difficulty": "intermediate",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/regional_sales_team_assignment/setup_task.sh",
    "post_task": "/workspace/tasks/regional_sales_team_assignment/export_result.sh"
  },
  "metadata": {
    "target_team_name": "West Coast",
    "target_state_code": "CA",
    "ca_leads": [
      "Golden Gate Software Upgrade",
      "SoCal Surf Shop Franchise",
      "Napa Valley Logistics"
    ],
    "control_leads": [
      "Gotham Trading Platform",
      "Austin Warehouse Automation"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_regional_sales_team_assignment"
    }
  }
}
