{
  "id": "highlight_key_account_opportunities@1",
  "version": "1.0",
  "env_id": "odoo_crm_env@0.1",
  "description": "A sales director wants to prioritize the 'Azure Interior' account. Mark all opportunities for 'Azure Interior' in the CRM pipeline with the Red color. Do not modify opportunities for other customers.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/highlight_key_account_opportunities/setup_task.sh",
    "post_task": "/workspace/tasks/highlight_key_account_opportunities/export_result.sh"
  },
  "metadata": {
    "target_partner": "Azure Interior",
    "target_color_index": 1,
    "target_color_name": "Red"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_highlight_key_account_opportunities"
    }
  }
}
