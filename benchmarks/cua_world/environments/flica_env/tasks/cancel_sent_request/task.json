{
  "id": "cancel_sent_request@1",
  "version": "1.0",
  "env_id": "example.flica_env@0.1",
  "description": "Cancel the pending friend request sent to 'ghost_pilot@example.com'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/cancel_sent_request/setup_task.sh",
    "post_task": "sh /sdcard/tasks/cancel_sent_request/export_result.sh"
  },
  "metadata": {
    "target_email": "ghost_pilot@example.com",
    "required_ui_context": "Sent Requests"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_cancel_request"
    }
  }
}
