{
  "id": "logout_account@1",
  "version": "1.0",
  "env_id": "example.flica_env@0.1",
  "description": "Log out of the current Flight Crew View account, which is currently logged in as a Friend/Family user on the Friends page. Return the app to the Login or Welcome screen.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/logout_account/setup_task.sh",
    "post_task": "sh /sdcard/tasks/logout_account/export_result.sh"
  },
  "metadata": {
    "target_strings_present": [
      "LOG IN",
      "Log In",
      "Create Account",
      "Welcome"
    ],
    "target_strings_absent": [
      "Add New Friend",
      "Friends List"
    ],
    "pkg_name": "com.robert.fcView"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_logout_account"
    }
  }
}
