{
  "id": "force_stop_and_restart@1",
  "version": "1.0",
  "env_id": "example.flica_env@0.1",
  "description": "The Flight Crew View app is currently running. Simulate a troubleshooting step by performing a 'Force Stop' on the Flight Crew View application through the Android System Settings and then relaunching the app to its main screen.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/force_stop_and_restart/setup_task.sh",
    "post_task": "sh /sdcard/tasks/force_stop_and_restart/export_result.sh"
  },
  "metadata": {
    "package_name": "com.robert.fcView",
    "app_name": "Flight Crew View"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_force_stop_and_restart"
    }
  }
}
