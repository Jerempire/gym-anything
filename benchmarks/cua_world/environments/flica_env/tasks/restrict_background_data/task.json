{
  "id": "restrict_background_data@1",
  "version": "1.0",
  "env_id": "example.flica_env@0.1",
  "description": "Configure the Flight Crew View app to restrict background data usage.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/restrict_background_data/setup_task.sh",
    "post_task": "sh /sdcard/tasks/restrict_background_data/export_result.sh"
  },
  "metadata": {
    "package_name": "com.robert.fcView",
    "setting_name": "Background data",
    "target_state": "off"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_restrict_background_data"
    }
  }
}
