{
  "id": "disable_battery_optimization@1",
  "version": "1.0",
  "env_id": "example.flica_env@0.1",
  "description": "Disable battery optimization for the Flight Crew View app (com.robert.fcView) by setting its battery usage to 'Unrestricted'. This ensures the app can reliably check for flight updates and provide background notifications.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/disable_battery_optimization/setup_task.sh",
    "post_task": "sh /sdcard/tasks/disable_battery_optimization/export_result.sh"
  },
  "metadata": {
    "target_package": "com.robert.fcView",
    "expected_state": "unrestricted",
    "pass_threshold": 50
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_battery_optimization"
    }
  }
}
