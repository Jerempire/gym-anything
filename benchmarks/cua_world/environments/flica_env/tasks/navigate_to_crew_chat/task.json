{
  "id": "navigate_to_crew_chat@1",
  "env_id": "example.flica_env@0.1",
  "difficulty": "easy",
  "description": "Navigate to the Crew Chat page in Flight Crew View. The app is currently logged in as a Friend/Family user on the Friends page.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/navigate_to_crew_chat/setup_task.sh",
    "post_task": "sh /sdcard/tasks/navigate_to_crew_chat/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_crew_chat_navigation"
    }
  }
}
