{
  "id": "audit_nav_menu@1",
  "version": "1.0",
  "env_id": "example.flica_env@0.1",
  "description": "Explore the Flight Crew View application to identify its primary navigation structure. List all top-level menu item names from the main navigation menu in the order they appear. Save the list to '/sdcard/menu_audit.txt' with one item per line.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/audit_nav_menu/setup_task.sh",
    "post_task": "/sdcard/tasks/audit_nav_menu/export_result.sh"
  },
  "metadata": {
    "output_file_path": "/sdcard/menu_audit.txt",
    "required_items": [
      "Friends",
      "Settings",
      "Crew Chat",
      "Notifications"
    ],
    "min_item_count": 4
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_audit_nav_menu"
    }
  }
}
