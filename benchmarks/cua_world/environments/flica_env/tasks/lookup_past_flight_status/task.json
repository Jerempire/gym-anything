{
  "id": "lookup_past_flight_status@1",
  "version": "1.0",
  "env_id": "example.flica_env@0.1",
  "description": "Search for American Airlines flight AA100 for yesterday's date. Save a screenshot of the flight details to /sdcard/past_flight_result.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/lookup_past_flight_status/setup_task.sh",
    "post_task": "sh /sdcard/tasks/lookup_past_flight_status/export_result.sh"
  },
  "metadata": {
    "flight_number": "AA100",
    "target_date_offset": -1,
    "expected_output_path": "/sdcard/past_flight_result.png"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_past_flight_lookup"
    }
  }
}
