{
  "id": "send_chat_message@1",
  "version": "1.0",
  "env_id": "example.flica_env@0.1",
  "description": "Send the message 'Arriving gate B7 at 4:30 PM - meet at baggage claim 3' in the Flight Crew View chat.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/send_chat_message/setup_task.sh",
    "post_task": "sh /sdcard/tasks/send_chat_message/export_result.sh"
  },
  "metadata": {
    "target_message": "Arriving gate B7 at 4:30 PM - meet at baggage claim 3",
    "partial_matches": [
      "Arriving gate B7",
      "meet at baggage claim 3",
      "4:30 PM"
    ],
    "forbidden_final_state": "Add New Friend"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_send_chat_message"
    }
  }
}
