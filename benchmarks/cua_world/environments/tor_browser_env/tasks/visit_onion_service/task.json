{
  "id": "visit_onion_service@1",
  "version": "1.0",
  "env_id": "tor_browser_env@0.1",
  "description": "Navigate to the DuckDuckGo onion service (duckduckgogg42xjoc72x3sjasowoarfbgcmvfimaftt6twagswzczad.onion) using Tor Browser and perform a search for 'Tor Project'. Verify that the search results page loads successfully.",
  "difficulty": "medium",
  "tags": [
