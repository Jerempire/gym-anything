  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/visit_onion_service/setup_task.sh",
    "post_task": "/workspace/tasks/visit_onion_service/export_result.sh"
  },
  "metadata": {
    "target_onion_url": "https://duckduckgogg42xjoc72x3sjasowoarfbgcmvfimaftt6twagswzczad.onion/",
    "search_query": "Tor Project",
    "expected_url_pattern": "duckduckgogg42xjoc72x3sjasowoarfbgcmvfimaftt6twagswzczad\\\\.onion",
    "expected_title_pattern": "DuckDuckGo"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_visit_onion_service"
    }
  }
}
