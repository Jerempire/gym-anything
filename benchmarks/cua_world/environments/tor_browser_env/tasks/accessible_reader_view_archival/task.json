{
  "id": "accessible_reader_view_archival@1",
  "version": "1.0",
  "env_id": "tor_browser_env@0.1",
  "description": "Navigate to 'https://en.wikipedia.org/wiki/Internet_censorship'. Use Reader View with the Font set to 'Serif' and the Theme set to 'Dark'. Export the page as a PDF to /home/ga/Documents/accessible_article.pdf.",
  "difficulty": "medium",
  "tags": [
    "tor",
    "accessibility",
    "reader-view",
    "export",
    "pdf"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/accessible_reader_view_archival/setup_task.sh",
    "post_task": "/workspace/tasks/accessible_reader_view_archival/export_result.sh"
  },
  "metadata": {
    "target_url": "https://en.wikipedia.org/wiki/Internet_censorship",
    "expected_pdf_path": "/home/ga/Documents/accessible_article.pdf",
    "expected_theme": "dark",
    "expected_font": "serif",
    "min_pdf_size_bytes": 20480
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_accessible_reader_view_archival"
    }
  }
}
