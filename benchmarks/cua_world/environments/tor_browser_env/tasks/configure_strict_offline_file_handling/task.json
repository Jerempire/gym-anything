{
  "id": "configure_strict_offline_file_handling@1",
  "version": "1.0",
  "env_id": "tor_browser_env@0.1",
  "description": "Configure Tor Browser for strict operational security by disabling the internal PDF viewer, standalone media playback, and clipboard event tracking. Set the browser to always prompt for a download location. Create the directory /home/ga/Documents/MalwareAnalysis/ and save the test PDF artifact from https://www.w3.org/WAI/ER/tests/xhtml/testfiles/resources/pdf/dummy.pdf to /home/ga/Documents/MalwareAnalysis/dummy.pdf.",
  "difficulty": "hard",
  "tags": [
    "tor",
    "security",
    "privacy",
    "about:config",
    "file-handling",
    "opsec"
  ],
  "init": {
    "timeout_sec": 480,
    "max_steps": 65,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_strict_offline_file_handling/setup_task.sh",
    "post_task": "/workspace/tasks/configure_strict_offline_file_handling/export_result.sh"
  },
  "metadata": {
    "expected_artifact_path": "/home/ga/Documents/MalwareAnalysis/dummy.pdf",
    "expected_directory": "/home/ga/Documents/MalwareAnalysis",
    "artifact_url": "https://www.w3.org/WAI/ER/tests/xhtml/testfiles/resources/pdf/dummy.pdf",
    "required_prefs": {
      "pdfjs.disabled": true,
      "media.play-stand-alone": false,
      "dom.event.clipboardevents.enabled": false,
      "browser.download.useDownloadDir": false
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_strict_offline_file_handling"
    }
  }
}
