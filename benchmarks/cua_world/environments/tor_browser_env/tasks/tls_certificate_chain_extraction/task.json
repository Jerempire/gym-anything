{
  "id": "tls_certificate_chain_extraction@1",
  "version": "1.0",
  "env_id": "tor_browser_env@0.1",
  "description": "Visit 'https://community.torproject.org/' using Tor Browser. Download the full certificate chain in PEM format for the website and save it to /home/ga/Documents/target_cert_chain.pem. Capture a screenshot of the Certificate Viewer window and save it to /home/ga/Documents/cert_viewer_screenshot.png.",
  "difficulty": "hard",
  "tags": [
    "tor",
    "security",
    "tls",
    "certificate",
    "osint"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/tls_certificate_chain_extraction/setup_task.sh",
    "post_task": "/workspace/tasks/tls_certificate_chain_extraction/export_result.sh"
  },
  "metadata": {
    "target_domain": "community.torproject.org",
    "expected_cert_path": "/home/ga/Documents/target_cert_chain.pem",
    "expected_screenshot_path": "/home/ga/Documents/cert_viewer_screenshot.png"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_tls_certificate_chain_extraction"
    }
  }
}
