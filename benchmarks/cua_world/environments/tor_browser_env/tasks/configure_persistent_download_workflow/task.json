{
  "id": "configure_persistent_download_workflow@1",
  "version": "1.0",
  "env_id": "tor_browser_env@0.1",
  "description": "Configure Tor Browser to automatically save all downloads to a new directory at /home/ga/Documents/SecureDownloads/. Save the following pages to that directory with these exact filenames: https://check.torproject.org/ as tor_check.html, https://tb-manual.torproject.org/ as tor_manual.html, and https://spec.torproject.org/ as tor_specs.html.",
  "difficulty": "medium",
  "tags": [
    "tor",
    "downloads",
    "configuration",
    "file-management",
    "settings"
  ],
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_persistent_download_workflow/setup_task.sh",
    "post_task": "/workspace/tasks/configure_persistent_download_workflow/export_result.sh"
  },
  "metadata": {
    "expected_download_dir": "/home/ga/Documents/SecureDownloads",
    "expected_files": [
      "tor_check.html",
      "tor_manual.html",
      "tor_specs.html"
    ],
    "target_urls": [
      "check.torproject.org",
      "tb-manual.torproject.org",
      "spec.torproject.org"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_persistent_download_workflow"
    }
  }
}
