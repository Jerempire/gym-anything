{
  "id": "configure_https_exception_for_legacy_site@1",
  "version": "1.0",
  "env_id": "tor_browser_env@0.1",
  "description": "You are an Intelligence Analyst investigating a legacy plaintext website. Create a permanent exception for http://neverssl.com in Tor Browser while maintaining the global HTTPS-Only Mode setting. Navigate to the site and bookmark it with the exact title 'Legacy Target'. Do not use temporary session-based exceptions.",
  "difficulty": "medium",
  "tags": [
    "tor",
    "security",
    "https-only",
    "exceptions",
    "osint"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_https_exception_for_legacy_site/setup_task.sh",
    "post_task": "/workspace/tasks/configure_https_exception_for_legacy_site/export_result.sh"
  },
  "metadata": {
    "target_domain": "neverssl.com",
    "target_url_exact": "http://neverssl.com/",
    "expected_bookmark_title": "Legacy Target"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_https_exception"
    }
  }
}
