{
  "id": "configure_noscript_exceptions@1",
  "version": "1.0",
  "env_id": "tor_browser_env@0.1",
  "description": "You are preparing a secure workstation for a high-risk investigative journalist. Configure Tor Browser to its 'Safest' security level and update the NoScript extension permissions to set 'https://securedrop.org' and 'https://www.propublica.org' as TRUSTED. Export the resulting NoScript configuration to /home/ga/Documents/noscript_policy.txt.",
  "difficulty": "hard",
  "tags": [
    "tor",
    "security",
    "noscript",
    "privacy",
    "configuration",
    "extensions"
  ],
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_noscript_exceptions/setup_task.sh",
    "post_task": "/workspace/tasks/configure_noscript_exceptions/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/noscript_policy.txt",
    "required_domains": [
      "securedrop.org",
      "propublica.org"
    ],
    "target_security_level": "safest",
    "target_security_slider": 4
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_noscript_exceptions"
    }
  }
}
