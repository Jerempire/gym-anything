{
  "id": "onion_performance_har_capture@1",
  "version": "1.0",
  "env_id": "tor_browser_env@0.1",
  "description": "Capture a cold-load network profile of a search for 'tor_network_perf_audit_9921' on the DuckDuckGo Onion service (https://duckduckgogg42xjoc72x3sjasowoarfbgcmvfimaftt6twagswzczad.onion/). Export the resulting network traffic as a HAR file to /home/ga/Documents/onion_performance_baseline.har.",
  "difficulty": "hard",
  "tags": [
    "tor",
    "developer-tools",
    "network",
    "performance",
    "har",
    "onion-service"
  ],
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/onion_performance_har_capture/setup_task.sh",
    "post_task": "/workspace/tasks/onion_performance_har_capture/export_result.sh"
  },
  "metadata": {
    "target_onion_url": "duckduckgogg42xjoc72x3sjasowoarfbgcmvfimaftt6twagswzczad.onion",
    "search_query": "tor_network_perf_audit_9921",
    "target_file": "/home/ga/Documents/onion_performance_baseline.har"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_onion_performance_har_capture"
    }
  }
}
