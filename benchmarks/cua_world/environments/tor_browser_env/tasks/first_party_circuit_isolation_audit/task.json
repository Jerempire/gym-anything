{
  "id": "first_party_circuit_isolation_audit@1",
  "version": "1.0",
  "env_id": "tor_browser_env@0.1",
  "description": "Verify Tor Browser's First-Party Circuit Isolation by extracting the Tor exit node IP address from api.ipify.org, icanhazip.com, and checkip.amazonaws.com. Document the observed IPs in a JSON file at /home/ga/Documents/isolation_audit.json using the service URLs as keys and the observed IPs as values.",
  "difficulty": "medium",
  "tags": [
    "tor",
    "privacy",
    "circuit-isolation",
    "data-extraction",
    "json"
  ],
  "init": {
    "timeout_sec": 480,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/first_party_circuit_isolation_audit/setup_task.sh",
    "post_task": "/workspace/tasks/first_party_circuit_isolation_audit/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/isolation_audit.json",
    "required_domains": [
      "api.ipify.org",
      "icanhazip.com",
      "checkip.amazonaws.com"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_circuit_isolation_audit"
    }
  }
}
