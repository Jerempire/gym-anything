{
  "id": "osint_reader_view_extraction@1",
  "version": "1.0",
  "env_id": "tor_browser_env@0.1",
  "description": "Navigate to 'https://en.wikipedia.org/wiki/Open-source_intelligence' in Tor Browser. Save the article's clean text to '/home/ga/Documents/osint_clean_extract.txt' using Reader View configured with a Dark theme and Serif font. Create a bookmark for this Reader View page named 'OSINT Clean Reading'.",
  "difficulty": "medium",
  "tags": [
    "tor",
    "osint",
    "reader-view",
    "bookmarks",
    "text-extraction"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/osint_reader_view_extraction/setup_task.sh",
    "post_task": "/workspace/tasks/osint_reader_view_extraction/export_result.sh"
  },
  "metadata": {
    "target_url": "https://en.wikipedia.org/wiki/Open-source_intelligence",
    "output_file": "/home/ga/Documents/osint_clean_extract.txt",
    "expected_bookmark_title": "OSINT Clean Reading",
    "expected_reader_theme": "dark",
    "expected_reader_font": "serif"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_osint_reader_view_extraction"
    }
  }
}
