{
  "id": "configure_keyword_search_shortcuts@1",
  "version": "1.0",
  "env_id": "tor_browser_env@0.1",
  "description": "Create a bookmark folder named 'OSINT Search Tools' containing three keyword bookmarks: 'Ahmia Onion Search' (URL: https://ahmia.fi/search/?q=%s, Keyword: @ahmia), 'DuckDuckGo Private' (URL: https://duckduckgogg42xjoc72x3sjasowoarfbgcmvfimaftt6twagswzczad.onion/?q=%s, Keyword: @ddg), and 'Wayback Machine Lookup' (URL: https://web.archive.org/web/*/%s, Keyword: @archive). Verify the shortcuts by performing searches for '@ddg tor project news' and '@ahmia privacy tools' and loading the results.",
  "difficulty": "hard",
  "tags": [
    "tor",
    "bookmarks",
    "search",
    "osint",
    "shortcuts",
    "keywords"
  ],
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_keyword_search_shortcuts/setup_task.sh",
    "post_task": "/workspace/tasks/configure_keyword_search_shortcuts/export_result.sh"
  },
  "metadata": {
    "expected_folder": "OSINT Search Tools",
    "bookmarks": [
      {
        "expected_name": "Ahmia Onion Search",
        "expected_url_contains": "ahmia.fi/search/?q=%s",
        "expected_keyword": "@ahmia"
      },
      {
        "expected_name": "DuckDuckGo Private",
        "expected_url_contains": "duckduckgogg42xjoc72x3sjasowoarfbgcmvfimaftt6twagswzczad.onion/?q=%s",
        "expected_keyword": "@ddg"
      },
      {
        "expected_name": "Wayback Machine Lookup",
        "expected_url_contains": "web.archive.org/web/*/%s",
        "expected_keyword": "@archive"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_keyword_search_shortcuts"
    }
  }
}
