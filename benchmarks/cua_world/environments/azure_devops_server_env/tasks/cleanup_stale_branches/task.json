{
  "id": "cleanup_stale_branches@1",
  "version": "1.0",
  "env_id": "azure_devops_server_env@0.1",
  "description": "Clean up the TailwindTraders Git repository by deleting all stale branches. Delete the following 5 stale branches: 'feature/search-api', 'feature/user-auth', 'bugfix/price-calc', 'feature/old-dashboard', and 'feature/experimental-cache'. Ensure the 'main', 'develop', and 'release/v1.0' branches are strictly preserved.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\cleanup_stale_branches\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\cleanup_stale_branches\\export_result.ps1"
  },
  "metadata": {
    "repo_name": "TailwindTraders",
    "branches_to_keep": [
      "main",
      "develop",
      "release/v1.0"
    ],
    "branches_to_delete": [
      "feature/search-api",
      "feature/user-auth",
      "bugfix/price-calc",
      "feature/old-dashboard",
      "feature/experimental-cache"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_cleanup_stale_branches"
    }
  }
}
