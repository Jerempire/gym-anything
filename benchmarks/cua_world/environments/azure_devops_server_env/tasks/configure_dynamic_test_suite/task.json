{
  "id": "configure_dynamic_test_suite@1",
  "version": "1.0",
  "env_id": "azure_devops_server_env@0.1",
  "description": "The QA team needs to automate the regression testing selection process. Create a 'Nightly Regression' Test Plan containing an 'Auto-Regression' Query-Based Test Suite that automatically selects all Test Cases with Priority = 1 AND the 'Regression' tag.\n\nLogin credentials:\n- User: Docker\n- Password: GymAnything123!",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_dynamic_test_suite\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_dynamic_test_suite\\export_result.ps1"
  },
  "metadata": {
    "project_name": "TailwindTraders",
    "plan_name": "Nightly Regression",
    "suite_name": "Auto-Regression",
    "expected_suite_type": "DynamicTestSuite",
    "expected_test_case_count": 3,
    "query_must_contain": [
      "Priority",
      "1",
      "Regression"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_dynamic_test_suite"
    }
  }
}
