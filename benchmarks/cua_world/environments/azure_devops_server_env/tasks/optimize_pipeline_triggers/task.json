{
  "id": "optimize_pipeline_triggers@1",
  "version": "1.0",
  "env_id": "azure_devops_server_env@0.1",
  "description": "The 'TailwindTraders' pipeline currently triggers a full build for every commit, wasting resources on documentation updates. Modify the 'azure-pipelines.yml' file in the TailwindTraders repository to optimize the triggers. Configure the pipeline to trigger on the 'main' branch while excluding changes to 'README.md' and the 'docs/' directory.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\optimize_pipeline_triggers\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\optimize_pipeline_triggers\\export_result.ps1"
  },
  "metadata": {
    "repo_name": "TailwindTraders",
    "target_file": "azure-pipelines.yml",
    "required_exclusions": [
      "README.md",
      "docs/*"
    ],
    "required_inclusions": [
      "main"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_optimize_pipeline_triggers"
    }
  }
}
