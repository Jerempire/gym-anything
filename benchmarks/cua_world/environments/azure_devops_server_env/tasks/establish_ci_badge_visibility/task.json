{
  "id": "establish_ci_badge_visibility@1",
  "version": "1.0",
  "env_id": "azure_devops_server_env@0.1",
  "description": "Create a CI pipeline named 'Tailwind-CI' for the TailwindTraders repository using the 'Starter pipeline' template. Add the pipeline's status badge for the main branch to the top of the repository's README.md file.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\establish_ci_badge_visibility\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\establish_ci_badge_visibility\\export_result.ps1"
  },
  "metadata": {
    "project_name": "TailwindTraders",
    "repo_name": "TailwindTraders",
    "pipeline_name": "Tailwind-CI",
    "expected_badge_text": "[![Build Status]",
    "api_base_url": "http://localhost/DefaultCollection"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_establish_ci_badge_visibility"
    }
  }
