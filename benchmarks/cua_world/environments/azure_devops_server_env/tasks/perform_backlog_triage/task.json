{
  "id": "perform_backlog_triage@1",
  "version": "1.0",
  "env_id": "azure_devops_server_env@0.1",
  "description": "You are the Tech Lead for Tailwind Traders. Triage the eight new work items currently in the 'New' state by updating their Priority, Tags, and Area Path. Apply the following rules based on title keywords, using the highest priority (Priority 1 > Priority 2 > Priority 3) if multiple rules apply:\n\nStability (Priority 1): Keywords 'Crash', 'Exception', '500 Error', 'Downtime'. Tag: 'Stability'. Area: Project Root.\nPerformance (Priority 2): Keywords 'Slow', 'Timeout', 'Latency', 'Lag'. Tag: 'Performance'. Area: 'TailwindTraders\\Platform'.\nUI/UX (Priority 3): Keywords 'Typo', 'Color', 'Alignment', 'Icon', 'CSS'. Tag: 'UI'. Area: 'TailwindTraders\\Website'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\perform_backlog_triage\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\perform_backlog_triage\\export_result.ps1"
  },
  "metadata": {
    "ground_truth": [
      {
        "title_keyword": "500 Error",
        "expected_priority": 1,
        "expected_tag": "Stability",
        "expected_area_suffix": "TailwindTraders"
      },
      {
        "title_keyword": "alignment",
        "expected_priority": 3,
        "expected_tag": "UI",
        "expected_area_suffix": "Website"
      },
      {
        "title_keyword": "timeout",
        "expected_priority": 2,
        "expected_tag": "Performance",
        "expected_area_suffix": "Platform"
      },
      {
        "title_keyword": "NullReferenceException",
        "expected_priority": 1,
        "expected_tag": "Stability",
        "expected_area_suffix": "TailwindTraders"
      },
      {
        "title_keyword": "typo",
        "expected_priority": 3,
        "expected_tag": "UI",
        "expected_area_suffix": "Website"
      },
      {
        "title_keyword": "slow",
        "expected_priority": 2,
        "expected_tag": "Performance",
        "expected_area_suffix": "Platform"
      },
      {
        "title_keyword": "crash caused by CSS typo",
        "expected_priority": 1,
        "expected_tag": "Stability",
        "expected_area_suffix": "TailwindTraders"
      },
      {
        "title_keyword": "button color",
        "expected_priority": 3,
        "expected_tag": "UI",
        "expected_area_suffix": "Website"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_perform_backlog_triage"
    }
  }
}
