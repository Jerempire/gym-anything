{
  "id": "provision_project_wiki@1",
  "version": "1.0",
  "env_id": "azure_devops_server_env@0.1",
  "description": "Provision a project wiki for the TailwindTraders project with a structured documentation hierarchy consisting of a Home root page and six sub-pages. The Home page must mention 'TailwindTraders' and 'e-commerce'. Under an 'Architecture' section, create 'System Overview' (describing microservices and naming three or more services) and 'API Design' (mentioning REST, including an endpoint example like 'GET /api...', and status codes). Under a 'Development Guide' section, create 'Getting Started' (including 'Prerequisites', 'git clone', and numbered steps) and 'Coding Standards' (including a code block and naming conventions). Under a 'Runbooks' section, create 'Incident Response' (defining severity levels and escalation steps).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\provision_project_wiki\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\provision_project_wiki\\export_result.ps1"
  },
  "metadata": {
    "project_name": "TailwindTraders",
    "required_pages": [
      "/",
      "/Architecture",
      "/Architecture/System Overview",
      "/Architecture/API Design",
      "/Development Guide",
      "/Development Guide/Getting Started",
      "/Development Guide/Coding Standards",
      "/Runbooks",
      "/Runbooks/Incident Response"
    ],
    "content_requirements": {
      "/": {
        "keywords": [
          "TailwindTraders",
          "e-commerce"
        ],
        "min_words": 50
      },
      "/Architecture/System Overview": {
        "keywords": [
          "microservices"
        ],
        "min_words": 80
      },
      "/Architecture/API Design": {
        "keywords": [
          "REST",
          "GET",
          "POST",
          "200",
          "404"
        ],
        "min_words": 60
      },
      "/Development Guide/Getting Started": {
        "keywords": [
          "Prerequisites",
          "git clone"
        ],
        "min_words": 80
      },
      "/Development Guide/Coding Standards": {
        "keywords": [
          "naming"
        ],
        "min_words": 60
      },
      "/Runbooks/Incident Response": {
        "keywords": [
          "severity",
          "Sev1",
          "Sev2",
          "escalation"
        ],
        "min_words": 80
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_provision_project_wiki"
    }
  }
}
