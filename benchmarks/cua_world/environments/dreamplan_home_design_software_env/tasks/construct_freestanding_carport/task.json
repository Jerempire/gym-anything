{
  "id": "construct_freestanding_carport@1",
  "version": "1.0",
  "env_id": "dreamplan_home_design_software_env@0.1",
  "description": "Construct a freestanding carport in the yard or driveway area of the sample house project. The structure must be an open-sided shelter supported by at least four vertical posts with a roof, rather than an enclosed garage with walls. Save the project as 'Carport_Design'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\construct_freestanding_carport\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\construct_freestanding_carport\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "Carport_Design.dplan",
    "expected_path_defaults": [
      "C:\\Users\\Docker\\Documents\\DreamPlan\\Carport_Design.dplan",
      "C:\\Users\\Docker\\Documents\\Carport_Design.dplan"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_construct_freestanding_carport"
    }
  }
}
