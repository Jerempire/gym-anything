{
  "id": "create_backyard_patio@1",
  "version": "1.0",
  "env_id": "dreamplan_home_design_software_env@0.1",
  "description": "DreamPlan Home Design Software is open with the default sample house loaded. Your goal is to design an outdoor living space behind the house. Create a rectangular stone, flagstone, or paver patio (approximately 12ft x 10ft) in the backyard adjacent to the rear wall of the house. Ensure the patio is distinct from the surrounding grass and connected to the house. Save the project.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_backyard_patio\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_backyard_patio\\export_result.ps1"
  },
  "metadata": {
    "project_path": "C:\\Users\\Docker\\Documents\\DreamPlan Projects\\Sample House.ddp",
    "default_save_path": "C:\\Users\\Docker\\Documents\\DreamPlan Projects",
    "expected_material_keywords": [
      "stone",
      "flagstone",
      "paver",
      "brick",
      "slate"
    ],
    "min_area_sqft": 50
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_backyard_patio"
    }
  }
}
