{
  "id": "install_interior_archway@1",
  "version": "1.0",
  "env_id": "dreamplan_home_design_software_env@0.1",
  "description": "Starting with the default sample house loaded in DreamPlan, install an interior archway (open passage) on an interior wall, such as between the Hall and Living Room. Save the project to preserve the changes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\install_interior_archway\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\install_interior_archway\\export_result.ps1"
  },
  "metadata": {
    "expected_category_keywords": [
      "Arch",
      "Opening",
      "Passage"
    ],
    "forbidden_keywords": [
      "Hinged",
      "Sliding",
      "Bi-fold"
    ],
    "project_path": "C:\\Users\\Docker\\Documents\\DreamPlan Projects",
    "screenshot_path": "C:\\tmp\\task_final.png"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_install_interior_archway"
    }
  }
}
