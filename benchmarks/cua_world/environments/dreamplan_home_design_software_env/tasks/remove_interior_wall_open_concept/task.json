{
  "id": "remove_interior_wall_open_concept@1",
  "version": "1.0",
  "env_id": "dreamplan_home_design_software_env@0.1",
  "description": "Modify the 'Sample House' project in DreamPlan Home Design Software to create an open-concept layout by deleting the interior wall that separates the Kitchen from the Dining/Living area. Ensure all exterior walls remain intact. Save the modified project as 'OpenConcept' in the Documents/Projects folder.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\remove_interior_wall_open_concept\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\remove_interior_wall_open_concept\\export_result.ps1"
  },
  "metadata": {
    "expected_filename_part": "OpenConcept",
    "required_extension_options": [
      ".dp",
      ".ddp"
    ],
    "project_dir": "Documents\\NCH Software\\DreamPlan\\Projects"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_open_concept_wall_removal"
    }
  }
}
