{
  "id": "import_external_3d_model@1",
  "version": "1.0",
  "env_id": "dreamplan_home_design_software_env@0.1",
  "description": "Import 'bunny.obj' from the Documents folder into the DreamPlan project. Place the model in the front yard of the house, scaled to approximately 1 meter (3 feet) in height, and save the project.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\import_external_3d_model\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\import_external_3d_model\\export_result.ps1"
  },
  "metadata": {
    "model_filename": "bunny.obj",
    "model_url": "https://raw.githubusercontent.com/alecjacobson/common-3d-test-models/master/data/bunny.obj",
    "expected_location": "front_yard",
    "min_visible_pixels": 500
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_import_external_3d_model"
    }
  }
}
