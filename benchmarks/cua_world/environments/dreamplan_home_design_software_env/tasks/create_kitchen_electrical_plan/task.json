{
  "id": "create_kitchen_electrical_plan@1",
  "version": "1.0",
  "env_id": "dreamplan_home_design_software_env@0.1",
  "description": "Create a technical electrical layout for the kitchen area of the 'Sample House' project using the 2D Blueprint view. Place four standard outlets along the walls or counters, one light switch near the entrance, and one high voltage outlet near the stove. Save the project and export a screenshot of the kitchen blueprint showing these symbols to C:\\Users\\Docker\\Documents\\kitchen_electrical_plan.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_kitchen_electrical_plan\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_kitchen_electrical_plan\\export_result.ps1"
  },
  "metadata": {
    "expected_screenshot_path": "C:\\Users\\Docker\\Documents\\kitchen_electrical_plan.png",
    "expected_min_symbols": 6,
    "required_symbols": [
      "Standard Outlet",
      "Switch",
      "High Voltage"
    ],
    "project_path_pattern": "C:\\Users\\Docker\\Documents\\*Sample*.dpp"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_kitchen_electrical_plan"
    }
  }
}
