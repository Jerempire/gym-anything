{
  "id": "project_information_authoring@1",
  "version": "1.0",
  "env_id": "blenderbim_env@0.1",
  "description": "You are a BIM Information Manager. Update the metadata for the pre-loaded FZK-Haus model in Bonsai to reflect the 'Riverside Community Hub' project as specified in the project brief located on the desktop. Ensure all fields—Project Name, Description, Organization, Person, Site Name, Building Name, and Postal Address/Town—are accurately recorded according to the brief. Save the final IFC project to /home/ga/BIMProjects/riverside_hub.ifc.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/project_information_authoring/setup_task.sh",
    "post_task": "/workspace/tasks/project_information_authoring/export_result.sh"
  },
  "metadata": {
    "skills": [
      "bim_information_management",
      "ifc_metadata",
      "bonsai_project_info",
      "spatial_hierarchy"
    ],
    "tags": [
      "ifc",
      "bim",
      "metadata",
      "project_information",
      "information_management",
      "aec"
    ],
    "occupation": "bim_manager",
    "industry": "architecture_engineering_construction",
    "result_file": "/tmp/project_info_result.json",
    "spec_doc": "/home/ga/Desktop/riverside_project_brief.txt",
    "output_file": "/home/ga/BIMProjects/riverside_hub.ifc",
    "expected_project_name_substring": "Riverside",
    "expected_org_substring": "Thornton",
    "expected_person_substring": "Okafor",
    "expected_site_substring": "Riverside",
    "expected_building_substrings": [
      "Community",
      "Hub"
    ],
    "expected_town_substring": "Bristol"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_project_information_authoring"
    }
  }
}
