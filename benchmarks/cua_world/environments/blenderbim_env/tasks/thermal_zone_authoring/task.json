{
  "id": "thermal_zone_authoring@1",
  "version": "1.0",
  "env_id": "blenderbim_env@0.1",
  "description": "You are a Building Physics Engineer preparing a model for energy simulation. The FZK-Haus architectural model is pre-loaded in Bonsai (BlenderBIM). Based on the thermal zoning brief on the desktop, group the individual rooms (IfcSpace entities) into thermal zones (IfcZone entities). Ensure the correct number of spaces are assigned to each zone and attach the standard Pset_ZoneCommon property set to at least one zone. Save the modified IFC project to /home/ga/BIMProjects/fzk_thermal_zones.ifc.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/thermal_zone_authoring/setup_task.sh",
    "post_task": "/workspace/tasks/thermal_zone_authoring/export_result.sh"
  },
  "metadata": {
    "skills": [
      "bim_spatial_management",
      "ifc_zone",
      "thermal_analysis_prep",
      "ifc_grouping",
      "bonsai_spatial"
    ],
    "tags": [
      "ifc",
      "bim",
      "zone",
      "thermal",
      "energy",
      "aec",
      "building_physics"
    ],
    "occupation": "building_physics_engineer",
    "industry": "sustainability_consulting",
    "result_file": "/tmp/thermal_zone_result.json",
    "spec_doc": "/home/ga/Desktop/thermal_zoning_brief.txt",
    "required_zones": [
      "Living Zone",
      "Sleeping Zone",
      "Unconditioned Zone"
    ],
    "required_spaces_per_zone": {
      "Living Zone": 4,
      "Sleeping Zone": 3,
      "Unconditioned Zone": 2
    },
    "required_pset": "Pset_ZoneCommon",
    "output_file": "/home/ga/BIMProjects/fzk_thermal_zones.ifc"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_thermal_zone_authoring"
    }
  }
}
