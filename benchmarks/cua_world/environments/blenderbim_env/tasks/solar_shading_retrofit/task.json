{
  "id": "solar_shading_retrofit@1",
  "version": "1.0",
  "env_id": "blenderbim_env@0.1",
  "description": "The FZK-Haus residential building requires an energy retrofit to prevent summer overheating. Add exterior solar shading devices to at least three south-facing windows on the exterior facade. The new elements must be classified as 'IfcShadingDevice' with a PredefinedType of AWNING, LOUVER, or SHUTTER, and must be assigned to an appropriate spatial container (e.g., IfcBuildingStorey) within the project hierarchy. Save the updated IFC project to /home/ga/BIMProjects/fzk_solar_shading.ifc.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 90,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/solar_shading_retrofit/setup_task.sh",
    "post_task": "/workspace/tasks/solar_shading_retrofit/export_result.sh"
  },
  "metadata": {
    "skills": [
      "bim_authoring",
      "energy_retrofit",
      "ifc_classification",
      "solar_shading",
      "bonsai_spatial_hierarchy"
    ],
    "tags": [
      "ifc",
      "bim",
      "sustainability",
      "shading",
      "aec",
      "energy_modeling",
      "geometry"
    ],
    "occupation": "sustainability_consultant",
    "industry": "building_physics",
    "result_file": "/tmp/solar_shading_result.json",
    "required_ifc_class": "IfcShadingDevice",
    "valid_predefined_types": [
      "AWNING",
      "LOUVER",
      "SHUTTER"
    ],
    "min_devices": 3,
    "output_file": "/home/ga/BIMProjects/fzk_solar_shading.ifc"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_solar_shading_retrofit"
    }
  }
}
