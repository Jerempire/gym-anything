{
  "id": "blenderbim_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "BlenderBIM (Bonsai) environment for BIM/IFC architectural modeling tasks",
  "category": "architecture_bim",
  "resources": {
    "cpu": 8,
    "mem_gb": 16,
    "gpu": 1,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "width": 1920,
      "height": 1080,
      "fps": 10
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "mounts": [
    {"source": "benchmarks/cua_world/environments/blenderbim_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/blenderbim_env/tasks", "target": "/workspace/tasks", "mode": "ro"}
  ],
  "vnc": {
    "password": "password"
  },
  "hooks": {
    "pre_start": "/workspace/scripts/install_blenderbim.sh",
    "post_start": "/workspace/scripts/setup_blenderbim.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input", "render"],
        "env_vars": {
          "DISPLAY": ":1"
        }
      }
    }
  ]
}
