{
  "id": "view_ifr_low_chart@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Download and display the IFR Low Altitude Enroute chart for the San Francisco area (KSFO) in Avare. Ensure the map is set to the IFR Low chart type and save a screenshot of the view to /sdcard/ifr_chart_result.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/view_ifr_low_chart/setup_task.sh",
    "post_task": "/sdcard/tasks/view_ifr_low_chart/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "chart_type": "IFR Low",
    "region": "San Francisco",
    "expected_screenshot": "/sdcard/ifr_chart_result.png",
    "data_dir": "/sdcard/com.ds.avare"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_view_ifr_low_chart"
    }
  }
}
