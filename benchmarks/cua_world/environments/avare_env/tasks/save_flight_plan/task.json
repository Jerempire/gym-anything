{
  "id": "save_flight_plan@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Create a round-trip training flight plan in Avare starting and ending at Palo Alto (KPAO), passing through Livermore (KLVK) and Watsonville (KWVI). Save the completed plan with the exact name 'BayAreaTraining'. The app is already installed and the database is loaded.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/save_flight_plan/setup_task.sh",
    "post_task": "sh /sdcard/tasks/save_flight_plan/export_result.sh"
  },
  "metadata": {
    "plan_name": "BayAreaTraining",
    "waypoints": [
      "KPAO",
      "KLVK",
      "KWVI",
      "KPAO"
    ],
    "min_distance_nm": 130,
    "max_distance_nm": 160
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_save_flight_plan"
    }
  }
}
