{
  "id": "navigate_to_coordinates@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "You are a pilot responding to a distress call at the Golden Gate Bridge (37.8199, -122.4783). Identify this location on your chart and center the map on these coordinates.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/navigate_to_coordinates/setup_task.sh",
    "post_task": "sh /sdcard/tasks/navigate_to_coordinates/export_result.sh"
  },
  "metadata": {
    "target_lat": 37.8199,
    "target_lon": -122.4783,
    "target_name": "Golden Gate Bridge",
    "tolerance_degrees": 0.02
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_navigate_to_coordinates"
    }
  }
}
