{
  "id": "download_sectional_chart@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "You are a pilot preparing for a flight in the Bay Area and need the local sectional chart for navigation. Download the 'San Francisco' VFR Sectional Chart using Avare's Download Manager and verify that the chart is correctly installed and visible in the Map view.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/download_sectional_chart/setup_task.sh",
    "post_task": "sh /sdcard/tasks/download_sectional_chart/export_result.sh",
    "pre_task_timeout": 60
  },
  "metadata": {
    "chart_name": "San Francisco",
    "chart_type": "Sectional",
    "min_expected_files": 20,
    "min_expected_size_bytes": 5000000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_download_sectional_chart"
    }
  }
}
