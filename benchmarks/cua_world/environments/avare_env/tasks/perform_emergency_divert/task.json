{
  "id": "perform_emergency_divert@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "You are flying over the San Francisco Bay near the San Mateo Bridge and experience engine roughness. Simulate your position at 37.55°N, 122.30°W and immediately initiate navigation to the nearest airport.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/perform_emergency_divert/setup_task.sh",
    "post_task": "sh /sdcard/tasks/perform_emergency_divert/export_result.sh"
  },
  "metadata": {
    "target_lat": 37.55,
    "target_lon": -122.3,
    "tolerance": 0.01,
    "target_airport": "KSQL",
    "prefs_file": "/data/data/com.ds.avare/shared_prefs/com.ds.avare_preferences.xml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_emergency_divert"
    }
  }
}
