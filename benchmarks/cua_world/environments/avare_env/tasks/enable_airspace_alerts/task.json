{
  "id": "enable_airspace_alerts@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Enable the 'Airspace Warnings' or 'Airspace Alarm' feature in Avare. This is a safety setting that alerts pilots when approaching controlled or special use airspace.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/enable_airspace_alerts/setup_task.sh",
    "post_task": "sh /sdcard/tasks/enable_airspace_alerts/export_result.sh"
  },
  "metadata": {
    "preference_file": "/data/data/com.ds.avare/shared_prefs/com.ds.avare_preferences.xml",
    "target_keys": [
      "Airspace",
      "Alarm",
      "Warning"
    ],
    "expected_value": "true"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enable_airspace_alerts"
    }
  }
}
