{
  "id": "enable_cap_grid_overlay@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Enable the Civil Air Patrol (CAP) grid overlay in Avare and ensure the grid lines are visible on the map view.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/enable_cap_grid_overlay/setup_task.sh",
    "post_task": "/sdcard/tasks/enable_cap_grid_overlay/export_result.sh"
  },
  "metadata": {
    "preference_file": "/data/data/com.ds.avare/shared_prefs/com.ds.avare_preferences.xml",
    "preference_key": "ShowCAP",
    "expected_value": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enable_cap_grid_overlay"
    }
  }
}
