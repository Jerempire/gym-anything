{
  "id": "create_user_waypoint@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Create a User Defined Waypoint (UDW) named 'LKPK' at the coordinates 37.475, -122.170 in the Avare aviation app for the Lake Park reporting point.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/create_user_waypoint/setup_task.sh",
    "post_task": "sh /sdcard/tasks/create_user_waypoint/export_result.sh"
  },
  "metadata": {
    "expected_name": "LKPK",
    "expected_lat": 37.475,
    "expected_lon": -122.17,
    "tolerance_deg": 0.01,
    "udw_filename": "UDW.csv"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_user_waypoint"
    }
  }
}
