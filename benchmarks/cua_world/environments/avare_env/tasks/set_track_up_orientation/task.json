{
  "id": "set_track_up_orientation@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Change the map orientation in Avare to 'Track Up' mode and return to the main map view.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/set_track_up_orientation/setup_task.sh",
    "post_task": "/sdcard/tasks/set_track_up_orientation/export_result.sh"
  },
  "metadata": {
    "preference_file": "/data/data/com.ds.avare/shared_prefs/com.ds.avare_preferences.xml",
    "target_key": "TrackUp",
    "expected_value": "true"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_track_up_orientation"
    }
  }
}
