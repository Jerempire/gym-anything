{
  "id": "enable_auto_diagram@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Configure the Avare aviation app to automatically display the airport diagram upon landing by enabling the 'Auto Show Airport Diagram' setting.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/enable_auto_diagram/setup_task.sh",
    "post_task": "/sdcard/tasks/enable_auto_diagram/export_result.sh"
  },
  "metadata": {
    "target_pref_key_pattern": ".*AirportDiagram.*",
    "target_pref_value": "true",
    "app_package": "com.ds.avare",
    "prefs_file_path": "/data/data/com.ds.avare/shared_prefs/com.ds.avare_preferences.xml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enable_auto_diagram"
    }
  }
}
