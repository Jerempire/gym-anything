{
  "id": "create_custom_checklist@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Create a new custom checklist in Avare titled 'C172 Runup' containing three specific items in order: 'Doors Closed', 'Mags Both', and 'Carb Heat Cold'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/create_custom_checklist/setup_task.sh",
    "post_task": "sh /sdcard/tasks/create_custom_checklist/export_result.sh"
  },
  "metadata": {
    "expected_title": "C172 Runup",
    "expected_items": [
      "Doors Closed",
      "Mags Both",
      "Carb Heat Cold"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_custom_checklist"
    }
  }
}
