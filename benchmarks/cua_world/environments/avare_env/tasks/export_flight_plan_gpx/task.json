{
  "id": "export_flight_plan_gpx@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Create a flight plan from Reid-Hillview (KRHV) to Modesto (KMOD) in Avare and export the route as a GPX file named 'route_export'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/export_flight_plan_gpx/setup_task.sh",
    "post_task": "/sdcard/tasks/export_flight_plan_gpx/export_result.sh"
  },
  "metadata": {
    "expected_filename": "route_export.gpx",
    "waypoint_1": "KRHV",
    "waypoint_2": "KMOD",
    "xml_tag": "<gpx"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_flight_plan_gpx"
    }
  }
}
