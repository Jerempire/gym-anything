{
  "id": "reverse_flight_plan@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Create a multi-leg flight plan for a trip from San Jose (KSJC) to Sacramento (KSMF) and then to Reno (KRNO). Reverse the flight plan for the return trip so that the active plan follows the sequence KRNO -> KSMF -> KSJC.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/reverse_flight_plan/setup_task.sh",
    "post_task": "sh /sdcard/tasks/reverse_flight_plan/export_result.sh"
  },
  "metadata": {
    "waypoints_outbound": [
      "KSJC",
      "KSMF",
      "KRNO"
    ],
    "waypoints_inbound": [
      "KRNO",
      "KSMF",
      "KSJC"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reverse_flight_plan"
    }
  }
}
