{
  "id": "create_radial_dme_waypoint@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Create a user-defined waypoint defined by the San Jose VOR (SJC) 320 degree radial at 15 nautical miles (DME) and add this waypoint to the active flight plan.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/create_radial_dme_waypoint/setup_task.sh",
    "post_task": "/sdcard/tasks/create_radial_dme_waypoint/export_result.sh"
  },
  "metadata": {
    "target_lat": 37.566,
    "target_lon": -122.147,
    "tolerance_deg": 0.05,
    "vor_id": "SJC",
    "radial": 320,
    "dme": 15
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_radial_dme_waypoint"
    }
  }
}
