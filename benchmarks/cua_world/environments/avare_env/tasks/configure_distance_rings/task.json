{
  "id": "configure_distance_rings@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Configure the map distance rings in Avare by setting the inner ring distance to 5 and the outer ring distance to 10. Ensure the rings are enabled and visible on the map view.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/configure_distance_rings/setup_task.sh",
    "post_task": "sh /sdcard/tasks/configure_distance_rings/export_result.sh"
  },
  "metadata": {
    "target_inner_value": "5",
    "target_outer_value": "10",
    "prefs_file_path": "/data/data/com.ds.avare/shared_prefs/com.ds.avare_preferences.xml",
    "screenshot_path": "/sdcard/tasks/configure_distance_rings/final_screenshot.png"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_distance_rings"
    }
  }
}
