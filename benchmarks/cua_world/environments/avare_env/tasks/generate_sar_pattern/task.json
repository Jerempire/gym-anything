{
  "id": "generate_sar_pattern@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Generate a Search and Rescue (SAR) 'Parallel Track' search pattern and load it into the active flight plan. Use the following parameters: Anchor at OAK (Oakland VOR), Heading 360, Leg Length 10 NM, Track Spacing 1 NM, and 6 Legs. The final flight plan must be visible on the map.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/generate_sar_pattern/setup_task.sh",
    "post_task": "/sdcard/tasks/generate_sar_pattern/export_result.sh"
  },
  "metadata": {
    "anchor_id": "OAK",
    "anchor_lat": 37.72,
    "anchor_lon": -122.22,
    "direction": 360,
    "leg_length": 10,
    "spacing": 1,
    "min_waypoints": 6,
    "db_path_internal": "/data/data/com.ds.avare/databases/plans.db",
    "db_path_export": "/sdcard/tasks/generate_sar_pattern/plans.db"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_sar_pattern"
    }
  }
}
