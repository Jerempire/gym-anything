{
  "id": "configure_map_preferences@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Configure Avare's map display settings for a cross-country VFR flight. Set the Map Orientation to 'Track Up', change the Distance/Speed Units to 'Knot', and enable the 'Draw Tracks' option to display flight path breadcrumbs.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/configure_map_preferences/setup_task.sh",
    "post_task": "/sdcard/tasks/configure_map_preferences/export_result.sh"
  },
  "metadata": {
    "prefs_file_path": "/data/data/com.ds.avare/shared_prefs/com.ds.avare_preferences.xml",
    "expected_orientation_substrings": [
      "TrackUp",
      "Track Up",
      "2"
    ],
    "expected_units_substrings": [
      "Knot",
      "Nautical"
    ],
    "expected_tracks_substrings": [
      "true"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_map_preferences"
    }
  }
}
