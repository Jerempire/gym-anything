{
  "id": "lookup_vor_frequency@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Find the frequency of the Oakland VOR (Identifier: OAK) using the Avare aviation GPS app. Ensure you identify the VOR/DME navaid rather than the airport (KOAK). Record the frequency in MHz to /data/local/tmp/vor_frequency.txt in the format: OAK VOR: <frequency> MHz",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/lookup_vor_frequency/setup_task.sh",
    "post_task": "/sdcard/tasks/lookup_vor_frequency/export_result.sh"
  },
  "metadata": {
    "expected_frequency": "116.8",
    "expected_identifier": "OAK",
    "output_file": "/data/local/tmp/vor_frequency.txt",
    "ground_truth_lat": "37.726",
    "ground_truth_lon": "-122.223"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_lookup_vor_frequency"
    }
  }
}
