{
  "id": "amend_flight_plan_insert@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Create a flight plan for the route sequence KLAX -> SLI -> KSAN. Export the completed flight plan to a GPX file named 'amended_clearance'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/amend_flight_plan_insert/setup_task.sh",
    "post_task": "/sdcard/tasks/amend_flight_plan_insert/export_result.sh"
  },
  "metadata": {
    "departure": "KLAX",
    "destination": "KSAN",
    "intermediate": "SLI",
    "expected_sequence": [
      "KLAX",
      "SLI",
      "KSAN"
    ],
    "expected_lat_longs": [
      {
        "id": "KLAX",
        "lat": 33.94,
        "lon": -118.4
      },
      {
        "id": "SLI",
        "lat": 33.77,
        "lon": -118.05
      },
      {
        "id": "KSAN",
        "lat": 32.73,
        "lon": -117.19
      }
    ],
    "tolerance_degrees": 0.05
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_amend_flight_plan_insert"
    }
  }
}
