{
  "id": "plan_vor_route@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Create a flight plan in Avare from KRHV (Reid-Hillview Airport) to KSQL (San Carlos Airport) via the SJC VOR station. Ensure the VOR station 'SJC' is used rather than the airport 'KSJC'. Save the flight plan with the name VOR_PRACTICE.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/plan_vor_route/setup_task.sh",
    "post_task": "/sdcard/tasks/plan_vor_route/export_result.sh"
  },
  "metadata": {
    "plan_name": "VOR_PRACTICE",
    "waypoints": [
      "KRHV",
      "SJC",
      "KSQL"
    ],
    "vor_identifier": "SJC",
    "airport_identifier": "KSJC"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_plan_vor_route"
    }
  }
}
