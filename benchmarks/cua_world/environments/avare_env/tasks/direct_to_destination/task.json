{
  "id": "direct_to_destination@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Set a Direct-To navigation destination to Sacramento Executive Airport (ICAO: KSAC) in the Avare aviation GPS app.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/direct_to_destination/setup_task.sh",
    "post_task": "/sdcard/tasks/direct_to_destination/export_result.sh"
  },
  "metadata": {
    "target_icao": "KSAC",
    "target_name": "Sacramento Executive",
    "target_lid": "SAC",
    "wrong_airport_icao": "KSMF",
    "app_package": "com.ds.avare"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_direct_to_destination"
    }
  }
}
