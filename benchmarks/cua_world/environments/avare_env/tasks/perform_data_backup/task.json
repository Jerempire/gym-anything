{
  "id": "perform_data_backup@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Perform a full backup of your user data, including settings, waypoints, and flight plans, to the device storage.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/scripts/perform_data_backup/setup_task.sh",
    "post_task": "/sdcard/scripts/perform_data_backup/export_result.sh"
  },
  "metadata": {
    "search_paths": [
      "/sdcard/com.ds.avare",
      "/sdcard/Android/data/com.ds.avare/files",
      "/sdcard/Download"
    ],
    "file_patterns": [
      "*backup*",
      "*.json",
      "user.db"
    ],
    "min_size_bytes": 100
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_perform_data_backup"
    }
  }
}
