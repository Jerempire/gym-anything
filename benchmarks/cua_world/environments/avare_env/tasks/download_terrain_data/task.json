{
  "id": "download_terrain_data@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Download the high-resolution Terrain or Elevation data for the San Francisco and Northern California region in Avare to ensure the files are resident on the device for mountain flying safety.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/download_terrain_data/setup_task.sh",
    "post_task": "sh /sdcard/tasks/download_terrain_data/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "data_directory_candidates": [
      "/sdcard/com.ds.avare",
      "/storage/emulated/0/Android/data/com.ds.avare/files",
      "/sdcard/avare"
    ],
    "file_patterns": [
      "terrain",
      "elev",
      ".t",
      ".dt1",
      ".hgt"
    ],
    "min_file_size_bytes": 10240
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_download_terrain_data"
    }
  }
}
