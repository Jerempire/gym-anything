{
  "id": "customize_map_shortcuts@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Customize the Avare main map interface by adding 'Draw' and 'Plate' shortcut buttons to the toolbar. Ensure both buttons are visible on the main map view upon completion.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/customize_map_shortcuts/setup_task.sh",
    "post_task": "sh /sdcard/tasks/customize_map_shortcuts/export_result.sh"
  },
  "metadata": {
    "target_buttons": [
      "Draw",
      "Plate"
    ],
    "prefs_file_location": "/data/data/com.ds.avare/shared_prefs/com.ds.avare_preferences.xml",
    "anti_gaming_timestamp_check": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_customize_map_shortcuts"
    }
  }
}
