{
  "id": "analyze_terrain_profile@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Plan a VFR flight from Sacramento (KSMF) to Reno (KRNO) and analyze the terrain clearance. Create a flight plan between these waypoints and display the route's vertical cross-section in the Profile view, ensuring the graph shows the mountain terrain elevation.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/analyze_terrain_profile/setup_task.sh",
    "post_task": "sh /sdcard/tasks/analyze_terrain_profile/export_result.sh"
  },
  "metadata": {
    "departure": "KSMF",
    "destination": "KRNO",
    "required_feature": "Profile View",
    "terrain_check": "non_flat"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_analyze_terrain_profile"
    }
  }
}
