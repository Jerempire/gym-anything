{
  "id": "configure_traffic_alert_thresholds@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Configure Avare's traffic collision alert settings to reduce nuisance warnings. Set the Traffic Warning Distance to 5 miles and the Traffic Warning Vertical (Height) to 1500 feet.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/configure_traffic_alert_thresholds/setup_task.sh",
    "post_task": "sh /sdcard/tasks/configure_traffic_alert_thresholds/export_result.sh"
  },
  "metadata": {
    "expected_distance": "5",
    "expected_height": "1500",
    "prefs_path": "/data/data/com.ds.avare/shared_prefs/com.ds.avare_preferences.xml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_traffic_settings"
    }
  }
}
