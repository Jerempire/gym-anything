{
  "id": "identify_nearest_vor@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Identify the closest VOR (VHF Omnidirectional Range) station to latitude 37.4000, longitude -120.9500 (Central California). Record the VOR's identifier, frequency, and distance to /sdcard/nearest_vor_result.txt in the following format:\n\nIDENTIFIER: [ID]\nFREQUENCY: [Freq]\nDISTANCE: [Dist]\n\nExample:\nIDENTIFIER: SFO\nFREQUENCY: 115.80\nDISTANCE: 12.5",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/identify_nearest_vor/setup_task.sh",
    "post_task": "sh /sdcard/tasks/identify_nearest_vor/export_result.sh"
  },
  "metadata": {
    "target_lat": "37.4000",
    "target_lon": "-120.9500",
    "expected_vors": [
      "MOD",
      "ECA",
      "PXN"
    ],
    "vor_data": {
      "MOD": {
        "freq": "114.60",
        "lat": 37.6253,
        "lon": -120.9544
      },
      "ECA": {
        "freq": "116.00",
        "lat": 37.8416,
        "lon": -121.1349
      },
      "PXN": {
        "freq": "112.60",
        "lat": 36.7158,
        "lon": -120.7813
      }
    },
    "output_file": "/sdcard/nearest_vor_result.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_identify_nearest_vor"
    }
  }
}
