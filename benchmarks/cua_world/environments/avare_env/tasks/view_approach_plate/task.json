{
  "id": "view_approach_plate@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Download the approach plate data for the San Francisco region and display the Airport Diagram or an available approach plate for San Francisco International Airport (KSFO) in the Plates viewer.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/view_approach_plate/setup_task.sh",
    "post_task": "/sdcard/tasks/view_approach_plate/export_result.sh"
  },
  "metadata": {
    "target_airport": "KSFO",
    "target_region": "San Francisco",
    "data_path_pattern": "*plate*",
    "expected_text_visible": [
      "KSFO",
      "SAN FRANCISCO",
      "AIRPORT DIAGRAM"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_view_approach_plate"
    }
  }
}
