{
  "id": "check_airport_metar@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "You are a VFR pilot preparing for a flight to Oakland International Airport and need to check current weather conditions before departing. Display the current METAR (aviation weather report) for Oakland International Airport (KOAK).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/check_airport_metar/setup_task.sh",
    "post_task": "/sdcard/tasks/check_airport_metar/export_result.sh"
  },
  "metadata": {
    "target_airport": "KOAK",
    "expected_content_type": "METAR",
    "required_strings": [
      "KOAK",
      "KT",
      "SM"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_check_airport_metar"
    }
  }
}
