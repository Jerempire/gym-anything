{
  "id": "configure_adsb_receiver@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Configure Avare to connect to an external Stratux ADS-B receiver using the standard network address 192.168.10.1 and port 4000. Save the configuration details to /sdcard/adsb_config.txt with the following format:\nIP: 192.168.10.1\nPort: 4000",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/configure_adsb_receiver/setup_task.sh",
    "post_task": "/sdcard/tasks/configure_adsb_receiver/export_result.sh"
  },
  "metadata": {
    "expected_ip": "192.168.10.1",
    "expected_port": "4000",
    "prefs_path": "/data/data/com.ds.avare/shared_prefs/com.ds.avare_preferences.xml",
    "output_file": "/sdcard/adsb_config.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_adsb_receiver"
    }
  }
}
