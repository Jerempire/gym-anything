{
  "id": "access_pfd_display@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "The Avare aviation GPS app is open on the main Map view. Navigate to the Primary Flight Display (PFD) to check the flight instruments, and then return to the Map view.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 120,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/access_pfd_display/setup_task.sh",
    "post_task": "sh /sdcard/tasks/access_pfd_display/export_result.sh"
  },
  "metadata": {
    "app_package": "com.ds.avare",
    "pfd_tab_name": "PFD",
    "map_tab_name": "Map"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_access_pfd_display"
    }
  }
}
