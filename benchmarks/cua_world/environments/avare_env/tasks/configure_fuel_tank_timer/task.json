{
  "id": "configure_fuel_tank_timer@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Configure the Avare dashboard to display the Fuel Tank Switch Timer in one of the data field slots on the main Map screen.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/configure_fuel_tank_timer/setup_task.sh",
    "post_task": "sh /sdcard/tasks/configure_fuel_tank_timer/export_result.sh"
  },
  "metadata": {
    "target_feature": "Fuel Tank Switch Timer",
    "expected_display_text": [
      "30:00",
      "Fuel",
      "Timer",
      "Switch"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_fuel_tank_timer"
    }
  }
}
