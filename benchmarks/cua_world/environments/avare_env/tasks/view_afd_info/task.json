{
  "id": "view_afd_info@1",
  "version": "1.0",
  "env_id": "example.avare_env@0.1",
  "description": "Display the Airport/Facility Directory (A/FD) information for San Carlos Airport (KSQL), including details such as elevation and frequencies.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/view_afd_info/setup_task.sh",
    "post_task": "/sdcard/tasks/view_afd_info/export_result.sh"
  },
  "metadata": {
    "target_airport_id": "KSQL",
    "target_airport_name": "San Carlos",
    "target_tab": "A/FD",
    "vlm_verification_criteria": [
      "Search interface accessed",
      "KSQL entered in search",
      "San Carlos/KSQL selected from results",
      "A/FD tab selected and visible",
      "Airport facility details displayed"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_view_afd_info"
    }
  }
}
