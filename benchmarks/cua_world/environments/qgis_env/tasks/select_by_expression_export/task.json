      "Delhi",
      "Shanghai",
      "São Paulo",
      "Mumbai",
      "Cairo",
      "Beijing",
      "Dhaka",
      "Osaka",
      "New York"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_select_by_expression_export"
    }
  }
