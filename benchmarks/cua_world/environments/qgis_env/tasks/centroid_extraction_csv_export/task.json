{
  "id": "centroid_extraction_csv_export@1",
  "version": "1.0",
  "env_id": "qgis_env@0.1",
  "description": "Extract the centroids for all countries in South America using the vector layer located at /home/ga/GIS_Data/natural_earth/ne_110m_admin_0_countries.shp. The output must include new decimal fields for 'longitude' and 'latitude' representing the centroid coordinates. Export the final results to /home/ga/GIS_Data/exports/south_america_centroids.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/centroid_extraction_csv_export/setup_task.sh",
    "post_task": "/workspace/tasks/centroid_extraction_csv_export/export_result.sh"
  },
  "metadata": {
    "data_url": "https://naciscdn.org/naturalearth/110m/cultural/ne_110m_admin_0_countries.zip",
    "source_path": "/home/ga/GIS_Data/natural_earth/ne_110m_admin_0_countries.shp",
    "expected_output_path": "/home/ga/GIS_Data/exports/south_america_centroids.csv",
    "expected_min_rows": 10,
    "expected_max_rows": 15,
    "bbox_sa": {
      "xmin": -85,
      "xmax": -30,
      "ymin": -60,
      "ymax": 15
    },
    "required_countries": [
      "Brazil",
      "Argentina",
      "Chile",
      "Colombia",
      "Peru"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_centroid_extraction"
    }
  }
}
