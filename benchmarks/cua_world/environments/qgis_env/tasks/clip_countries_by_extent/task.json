{
  "id": "clip_countries_by_extent@1",
  "version": "1.0",
  "env_id": "qgis_env@0.1",
  "description": "Load the Natural Earth 110m countries dataset from /home/ga/GIS_Data/natural_earth/ne_110m_admin_0_countries.shp and clip it to the European region defined by the extent: West -25.0, East 45.0, South 35.0, and North 72.0. Save the clipped result as a GeoJSON file to /home/ga/GIS_Data/exports/european_countries.geojson.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/clip_countries_by_extent/setup_task.sh",
    "post_task": "/workspace/tasks/clip_countries_by_extent/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "input_path": "/home/ga/GIS_Data/natural_earth/ne_110m_admin_0_countries.shp",
    "output_path": "/home/ga/GIS_Data/exports/european_countries.geojson",
    "clip_extent": {
      "xmin": -25.0,
      "xmax": 45.0,
      "ymin": 35.0,
      "ymax": 72.0
    },
    "expected_countries": [
      "France",
      "Germany",
      "Italy",
      "Spain",
      "Poland",
      "United Kingdom"
    ],
    "forbidden_countries": [
      "Brazil",
      "Australia",
      "India",
      "South Africa",
      "Japan"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_clip_countries_by_extent"
    }
  }
}
