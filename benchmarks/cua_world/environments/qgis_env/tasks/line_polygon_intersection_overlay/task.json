{
  "id": "line_polygon_intersection_overlay@1",
  "version": "1.0",
  "env_id": "qgis_env@0.1",
  "description": "Perform a vector overlay intersection to split road lines from /home/ga/GIS_Data/sample_lines.geojson at the polygon zone boundaries defined in /home/ga/GIS_Data/sample_polygon.geojson. Ensure the resulting features contain attributes from both input layers and export the final result to /home/ga/GIS_Data/exports/roads_by_zone.geojson.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/line_polygon_intersection_overlay/setup_task.sh",
    "post_task": "/workspace/tasks/line_polygon_intersection_overlay/export_result.sh"
  },
  "metadata": {
    "input_lines": "/home/ga/GIS_Data/sample_lines.geojson",
    "input_polygons": "/home/ga/GIS_Data/sample_polygon.geojson",
    "expected_output": "/home/ga/GIS_Data/exports/roads_by_zone.geojson",
    "expected_feature_count": 3,
    "expected_geometry_type": "LineString"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_line_polygon_intersection_overlay"
    }
  }
}
