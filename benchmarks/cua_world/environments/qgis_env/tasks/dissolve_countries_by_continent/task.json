{
  "id": "dissolve_countries_by_continent@1",
  "version": "1.0",
  "env_id": "qgis_env@0.1",
  "description": "Dissolve the 'ne_110m_admin_0_countries' shapefile from /home/ga/GIS_Data/natural_earth/ into continent regions using the 'CONTINENT' field. Export the resulting dissolved layer as a GeoJSON file to /home/ga/GIS_Data/exports/continents_dissolved.geojson.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/dissolve_countries_by_continent/setup_task.sh",
    "post_task": "/workspace/tasks/dissolve_countries_by_continent/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "input_file": "/home/ga/GIS_Data/natural_earth/ne_110m_admin_0_countries.shp",
    "output_file": "/home/ga/GIS_Data/exports/continents_dissolved.geojson",
    "dissolve_field": "CONTINENT",
    "min_feature_count": 5,
    "max_feature_count": 9,
    "expected_continents": [
      "Africa",
      "Asia",
      "Europe",
      "North America",
      "South America",
      "Oceania",
      "Antarctica"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_dissolve_countries"
    }
  }
}
