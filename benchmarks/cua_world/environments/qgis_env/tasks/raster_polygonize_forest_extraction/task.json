{
  "id": "raster_polygonize_forest_extraction@1",
  "version": "1.0",
  "env_id": "qgis_env@0.1",
  "description": "Convert the land cover raster at /home/ga/GIS_Data/landcover_classification.tif (1=Forest, 2=Water, 3=Urban) to vector polygons. Filter the resulting layer to include only the Forest features (DN=1) and export them to /home/ga/GIS_Data/exports/forest_zones.geojson.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/raster_polygonize_forest_extraction/setup_task.sh",
    "post_task": "/workspace/tasks/raster_polygonize_forest_extraction/export_result.sh"
  },
  "metadata": {
    "input_raster": "/home/ga/GIS_Data/landcover_classification.tif",
    "expected_output": "/home/ga/GIS_Data/exports/forest_zones.geojson",
    "target_class_value": 1,
    "target_class_name": "Forest",
    "expected_feature_count": 4
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_raster_polygonize_forest_extraction"
    }
  }
