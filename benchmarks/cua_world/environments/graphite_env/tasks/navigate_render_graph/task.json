{
  "id": "navigate_render_graph@1",
  "version": "1.0",
  "env_id": "graphite_env@0.1",
  "description": "Render a graph of the EC2 instance 1 CPU utilization data using the metric path servers.ec2_instance_1.cpu.utilization.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/navigate_render_graph/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_navigate_render_graph"
    }
  }
}
