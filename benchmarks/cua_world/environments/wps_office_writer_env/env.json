{
  "id": "wps_office_writer_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "WPS Office Writer word processing environment for document formatting, template creation, business documents, and collaborative editing tasks",
  "category": "office",
  "tags": [
    "linux",
    "office",
    "word-processor",
    "wps-office",
    "writer",
    "desktop",
    "document-formatting",
    "ms-office-compatible"
  ],
  "licence": "Proprietary Freeware",
  "authors": ["gym-anything team"],
  "upstream_url": "https://www.wps.com/",
  "resources": {
    "cpu": 4,
    "mem_gb": 4,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/wps_office_writer_env/artifacts",
    "video_fps": 10,
    "video_resolution": [1920, 1080],
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": false,
    "host_port": 5957,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/wps_office_writer_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/wps_office_writer_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/wps_office_writer_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/wps_office_writer_env/utils", "target": "/workspace/utils", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/wps_office_writer_env/assets", "target": "/workspace/assets", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_wps.sh",
    "post_start": "/workspace/scripts/setup_wps.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "WPS_USER": "ga"
        }
      }
    }
  ]
}
