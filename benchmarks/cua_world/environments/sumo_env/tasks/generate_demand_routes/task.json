{
  "id": "generate_demand_routes@1",
  "version": "1.0",
  "env_id": "sumo_env@0.1",
  "description": "Generate 200 random vehicle trips on the Bologna Acosta road network (~/SUMO_Scenarios/bologna_acosta/) for a 3600-second simulation period. Compute shortest-path routes for these trips. Save the generated trips to ~/SUMO_Output/random_trips.trips.xml and the resulting routes to ~/SUMO_Output/random_trips.rou.xml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_demand_routes/setup_task.sh",
    "post_task": "/workspace/tasks/generate_demand_routes/export_result.sh"
  },
  "metadata": {
    "scenario_dir": "/home/ga/SUMO_Scenarios/bologna_acosta",
    "output_trips": "/home/ga/SUMO_Output/random_trips.trips.xml",
    "output_routes": "/home/ga/SUMO_Output/random_trips.rou.xml",
    "expected_trips": 200,
    "expected_period": 3600
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_demand_routes"
    }
  }
}
