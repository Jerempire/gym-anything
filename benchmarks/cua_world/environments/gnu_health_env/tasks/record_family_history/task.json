{
  "id": "record_family_history@1",
  "version": "1.0",
  "env_id": "gnu_health_env@0.1",
  "description": "Add three family disease records to the patient Ana Betz (Ana Isabel Betz) in the GNU Health system. The records must include: Father (Disease Code: I25), Mother (Disease Code: E11), and Sister (Disease Code: M32). Ensure all entries are saved to the patient record. Login credentials: username 'admin', password 'gnusolidario'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_family_history/setup_task.sh",
    "post_task": "/workspace/tasks/record_family_history/export_result.sh"
  },
  "metadata": {
    "target_patient_firstname": "Ana",
    "target_patient_lastname": "Betz",
    "required_icd10_codes": [
      "I25",
      "E11",
      "M32"
    ],
    "required_relatives": [
      "Father",
      "Mother",
      "Sister"
    ],
    "occupation": "Occupational Health and Safety Technician",
    "industry": "Manufacturing / Industrial Hygiene"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_family_history"
    }
  }
}
