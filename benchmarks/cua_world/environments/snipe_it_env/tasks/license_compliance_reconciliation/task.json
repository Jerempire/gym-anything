{
  "id": "license_compliance_reconciliation@1",
  "version": "1.0",
  "env_id": "snipe_it_env@0.1",
  "description": "As a Software Asset Manager at a technology company, reconcile software licenses in Snipe-IT based on the annual license audit report. Update 'Microsoft 365 Business Premium' to 35 seats and a purchase cost of $9,240.00. Update 'Adobe Creative Cloud - All Apps' to 15 seats and a purchase cost of $9,898.20. For 'Windows 11 Enterprise', update the expiration date to 2028-06-01 and the order number to 'PO-2025-0550-EXT'. Create a new license for 'Slack Business Plus' with serial 'SLACK-BP-2025-001', 20 seats, and category 'Productivity'.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 720,
    "max_steps": 90,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/license_compliance_reconciliation/setup_task.sh",
    "post_task": "/workspace/tasks/license_compliance_reconciliation/export_result.sh"
  },
  "metadata": {
    "occupation": "Software Asset Manager",
    "industry": "Technology",
    "license_changes": {
      "ms365": {
        "new_seats": 35,
        "new_cost": 9240.0
      },
      "adobe_cc": {
        "new_seats": 15,
        "new_cost": 9898.2
      },
      "win11": {
        "new_expiry": "2028-06-01",
        "new_order": "PO-2025-0550-EXT"
      }
    },
    "new_license": {
      "name": "Slack Business Plus",
      "seats": 20
    },
    "scoring_weights": {
      "c1_ms365_seats": 12,
      "c2_ms365_cost": 12,
      "c3_adobe_seats": 12,
      "c4_adobe_cost": 12,
      "c5_win11_expiry": 12,
      "c6_win11_order": 8,
      "c7_new_license_created": 20,
      "c8_no_other_licenses_modified": 12
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_license_compliance_reconciliation"
    }
  }
}
