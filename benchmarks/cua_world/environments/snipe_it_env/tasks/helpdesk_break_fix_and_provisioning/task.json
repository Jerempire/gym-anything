{
  "id": "helpdesk_break_fix_and_provisioning@1",
  "version": "1.0",
  "env_id": "snipe_it_env@0.1",
  "description": "Process three pending IT helpdesk tickets in Snipe-IT as an administrator. For David Taylor (dtaylor), check in laptop LAP-DT-01, update its status to 'Out for Repair' with the note 'Cracked screen, pending replacement', and check out replacement laptop LAP-SPARE-01 to him. For Maria Garcia (mgarcia), check out monitor MON-SPARE-01. For John Smith (jsmith), check out one 'Logitech MX Master 3 Mouse'.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/helpdesk_break_fix_and_provisioning/setup_task.sh",
    "post_task": "/workspace/tasks/helpdesk_break_fix_and_provisioning/export_result.sh"
  },
  "metadata": {
    "target_users": [
      "dtaylor",
      "mgarcia",
      "jsmith"
    ],
    "asset_lap_dt": "LAP-DT-01",
    "asset_lap_spare": "LAP-SPARE-01",
    "asset_mon_spare": "MON-SPARE-01",
    "accessory_name": "Logitech MX Master 3 Mouse",
    "expected_status": "Out for Repair",
    "expected_note": "Cracked screen",
    "scoring_weights": {
      "lap_dt_checked_in": 10,
      "lap_dt_status_updated": 15,
      "lap_dt_notes_updated": 10,
      "lap_spare_checked_out": 15,
      "mon_spare_checked_out": 15,
      "mouse_checked_out": 15,
      "vlm_verification": 20
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_helpdesk_queue"
    }
  }
}
