# Snipe-IT Environment Configuration
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_LOCALE=en-US

# Database
DB_CONNECTION=mysql
DB_HOST=snipeit-db
DB_PORT=3306
DB_DATABASE=snipeit
DB_USERNAME=snipeit
DB_PASSWORD=snipeit_pass
MYSQL_ROOT_PASSWORD=root_pass

# Mail (disabled for testing)
MAIL_DRIVER=log
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDR=snipeit@example.com
MAIL_FROM_NAME=Snipe-IT

# Session
SESSION_LIFETIME=120
EXPIRE_ON_CLOSE=false

# Disable login throttling for testing
LOGIN_MAX_ATTEMPTS=50
LOGIN_LOCKOUT_DURATION=1
