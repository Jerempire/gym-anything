{
  "id": "arkcase_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "ArkCase open-source case management platform for FOIA requests, complaints, and case workflow management",
  "resources": {
    "cpu": 8,
    "mem_gb": 16,
    "gpu": 0,
    "net": true
  },
  "vnc": {"password": "password"},
  "mounts": [
    {"source": "benchmarks/cua_world/environments/arkcase_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/arkcase_env/config",  "target": "/workspace/config",  "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/arkcase_env/tasks",   "target": "/workspace/tasks",   "mode": "ro"}
  ],
  "hooks": {
    "pre_start":  "/workspace/scripts/install_arkcase.sh",
    "post_start": "/workspace/scripts/setup_arkcase.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ]
}
