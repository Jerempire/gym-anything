{
  "id": "set_out_of_office_delegate@1",
  "version": "1.0",
  "env_id": "arkcase_env@0.1",
  "description": "You are going on annual leave and need to ensure your tasks are covered. Configure an Out-of-Office delegation in your User Profile for Sally Acm (sally-acm). The delegation should start today and end 7 days from now.",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/set_out_of_office_delegate/setup_task.sh",
    "post_task": "/workspace/tasks/set_out_of_office_delegate/export_result.sh"
  },
  "metadata": {
    "target_delegate_username": "sally-acm@dev.arkcase.com",
    "target_delegate_name": "Sally Acm",
    "min_duration_days": 5,
    "max_duration_days": 9
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_out_of_office_delegate"
    }
  }
}
