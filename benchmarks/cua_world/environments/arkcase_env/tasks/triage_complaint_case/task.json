{
  "id": "triage_complaint_case@1",
  "version": "1.0",
  "env_id": "arkcase_env@0.1",
  "description": "Log in to ArkCase (admin/ArkCase1234!) and triage the complaint case titled 'Procurement Irregularities - Q3 2024'. Advance the case from its current 'New' state to an 'Active' or 'Triaged' workflow status.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/triage_complaint_case/setup_task.sh",
    "post_task": "/workspace/tasks/triage_complaint_case/export_result.sh"
  },
  "metadata": {
    "target_case_title": "Procurement Irregularities - Q3 2024",
    "initial_status": "NEW",
    "forbidden_statuses": [
      "NEW",
      "CREATED",
      "CLOSED",
      "REJECTED"
    ],
    "target_statuses": [
      "ACTIVE",
      "IN_PROGRESS",
      "TRIAGED",
      "OPEN"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_triage_complaint_case"
    }
  }
}
