{
  "id": "transfer_misfiled_document@1",
  "version": "1.0",
  "env_id": "arkcase_env@0.1",
  "description": "As an administrator, rectify a privacy error where 'medical_evaluation_confidential.pdf' was incorrectly uploaded to 'Parking Violation - Smith'. Transfer this document to the correct case, 'Personal Injury - Smith', and ensure it is removed from the 'Parking Violation' case.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/transfer_misfiled_document/setup_task.sh",
    "post_task": "/workspace/tasks/transfer_misfiled_document/export_result.sh"
  },
  "metadata": {
    "filename": "medical_evaluation_confidential.pdf",
    "source_case_title": "Parking Violation - Smith",
    "target_case_title": "Personal Injury - Smith"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_transfer_misfiled_document"
    }
  }
}
