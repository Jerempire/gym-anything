{
  "id": "transcribe_paper_complaint@1",
  "version": "1.0",
  "env_id": "arkcase_env@0.1",
  "description": "A citizen has emailed a scanned complaint form. Transcribe the details from 'complaint_form_2025-001.pdf' on the Desktop into a new ArkCase complaint. Log in using admin@dev.arkcase.com / ArkCase1234!. Link the requestor to 'Eleanor Rigby'. Use the form's Subject as the Case Title, the Incident Details as the Description, and set the Incident Date to 2025-02-14.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/transcribe_paper_complaint/setup_task.sh",
    "post_task": "/workspace/tasks/transcribe_paper_complaint/export_result.sh"
  },
  "metadata": {
    "expected_title_keywords": [
      "Construction",
      "Noise",
      "Violation"
    ],
    "expected_date": "2025-02-14",
    "expected_complainant_name": "Eleanor Rigby",
    "expected_description_keywords": [
      "funeral",
      "jackhammer",
      "Rice",
      "Street"
    ],
    "pdf_path": "/home/ga/Desktop/complaint_form_2025-001.pdf"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_transcribe_paper_complaint"
    }
  }
}
