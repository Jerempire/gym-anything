{
  "id": "verify_anticoagulant_safety_with_enzalutamide@1",
  "version": "1.0",
  "env_id": "example.liverpool_cancer_ichart_env@0.1",
  "description": "Using Liverpool Cancer iChart, check the drug-drug interaction between the cancer drug 'Enzalutamide' and the co-medication 'Warfarin'. Navigate to the Interaction Details page to display the full clinical recommendation.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/verify_anticoagulant_safety_with_enzalutamide/setup_task.sh",
    "post_task": "/sdcard/tasks/verify_anticoagulant_safety_with_enzalutamide/export_result.sh"
  },
  "metadata": {
    "cancer_drug": "Enzalutamide",
    "co_medication": "Warfarin",
    "expected_color_category": "red_or_orange",
    "clinical_keywords": [
      "CYP2C9",
      "inducer",
      "induction",
      "monitor",
      "INR",
      "bleed"
    ],
    "min_trajectory_screens": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_anticoagulant_safety"
    }
  },
  "tags": [
    "medical",
    "drug-interaction",
    "android",
    "safety-critical"
  ]
}
