{
  "id": "compare_comedication_across_cancer_drugs@1",
  "version": "1.0",
  "env_id": "example.liverpool_cancer_ichart_env@0.1",
  "description": "Using the Liverpool Cancer iChart app, compare the interaction colors of 'Dasatinib' and 'Axitinib' when paired with 'Clarithromycin'. Create a comparison report at /sdcard/Download/clarithromycin_comparison.txt that documents the interaction color for each drug and indicates whether the colors are the same or different.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/compare_comedication_across_cancer_drugs/setup_task.sh",
    "post_task": "sh /sdcard/tasks/compare_comedication_across_cancer_drugs/export_result.sh"
  },
  "metadata": {
    "drug_1": "Dasatinib",
    "drug_2": "Axitinib",
    "co_medication": "Clarithromycin",
    "report_path": "/sdcard/Download/clarithromycin_comparison.txt",
    "expected_keywords": [
      "Dasatinib",
      "Axitinib",
      "Clarithromycin"
    ],
    "color_keywords": [
      "red",
      "orange",
      "yellow",
      "green",
      "grey",
      "gray"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_compare_comedication"
    }
  }
}
