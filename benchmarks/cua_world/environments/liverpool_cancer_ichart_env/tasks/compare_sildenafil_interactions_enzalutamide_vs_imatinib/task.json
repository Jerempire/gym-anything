{
  "id": "compare_sildenafil_interactions_enzalutamide_vs_imatinib@1",
  "version": "1.0",
  "env_id": "example.liverpool_cancer_ichart_env@0.1",
  "description": "Compare the drug interaction safety of Sildenafil (Viagra) with Enzalutamide and Imatinib using the Liverpool Cancer iChart app. Create a report at /sdcard/sildenafil_comparison.txt documenting the interaction traffic-light color for each pair in the following format:\nEnzalutamide: [Color]\nImatinib: [Color]",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/compare_sildenafil_interactions_enzalutamide_vs_imatinib/setup_task.sh",
    "post_task": "sh /sdcard/tasks/compare_sildenafil_interactions_enzalutamide_vs_imatinib/export_result.sh"
  },
  "metadata": {
    "report_path": "/sdcard/sildenafil_comparison.txt",
    "drug_1": "Enzalutamide",
    "drug_2": "Imatinib",
    "comedication": "Sildenafil",
    "valid_colors": [
      "red",
      "orange",
      "amber",
      "yellow",
      "green",
      "grey",
      "gray"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_sildenafil_comparison"
    }
  }
}
