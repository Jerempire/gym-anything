{
  "id": "check_antifungal_interaction@1",
  "version": "1.0",
  "env_id": "example.liverpool_cancer_ichart_env@0.1",
  "description": "Using the Liverpool Cancer iChart Archive app, determine the drug-drug interaction between Dabrafenib and Ketoconazole (located in the Antifungal agents category). Leave the application on the screen displaying the interaction result.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/check_antifungal_interaction/setup_task.sh",
    "post_task": "/sdcard/tasks/check_antifungal_interaction/export_result.sh"
  },
  "metadata": {
    "cancer_drug": "Dabrafenib",
    "category": "Antifungal agents",
    "comedication": "Ketoconazole",
    "expected_colors": [
      "red",
      "orange"
    ],
    "interaction_note": "Potent CYP3A4 inhibition"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_check_antifungal_interaction"
    }
  }
}
