{
  "id": "compare_cancer_drug_interactions@1",
  "version": "1.0",
  "env_id": "example.liverpool_cancer_ichart_env@0.1",
  "description": "Compare the drug interaction severity of two breast cancer treatments, Tamoxifen and Letrozole, when co-administered with the antidepressant Paroxetine. Determine which cancer drug is safer to use by evaluating the interaction status and traffic light color for both drug combinations.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/compare_cancer_drug_interactions/setup_task.sh",
    "post_task": "sh /sdcard/tasks/compare_cancer_drug_interactions/export_result.sh"
  },
  "metadata": {
    "drug_1": "Tamoxifen",
    "drug_2": "Letrozole",
    "co_medication": "Paroxetine",
    "expected_color_1": "Red",
    "expected_color_2": "Green",
    "safer_drug": "Letrozole"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_compare_interactions"
    }
  }
}
