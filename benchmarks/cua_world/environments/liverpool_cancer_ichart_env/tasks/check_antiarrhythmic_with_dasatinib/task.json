{
  "id": "check_antiarrhythmic_with_dasatinib@1",
  "version": "1.0",
  "env_id": "example.liverpool_cancer_ichart_env@0.1",
  "description": "In the Liverpool Cancer iChart Archive app, identify the interaction between the cancer drug 'Dasatinib' and the anti-arrhythmic drug 'Amiodarone'. Record the interaction traffic light color code and the full text of the interaction mechanism/details to /sdcard/task_result.txt using the following format:\nLine 1: Dasatinib\nLine 2: Amiodarone\nLine 3: [Color Code]\nLine 4+: [Full interaction text]",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/check_antiarrhythmic_with_dasatinib/setup_task.sh",
    "post_task": "sh /sdcard/tasks/check_antiarrhythmic_with_dasatinib/export_result.sh"
  },
  "metadata": {
    "cancer_drug": "Dasatinib",
    "co_medication": "Amiodarone",
    "expected_filename": "/sdcard/task_result.txt",
    "valid_colors": [
      "RED",
      "ORANGE",
      "YELLOW",
      "GREEN",
      "GREY"
    ],
    "required_keywords": [
      "QT",
      "prolong",
      "CYP",
      "metabolism",
      "concentration",
      "inhibit",
      "risk",
      "arrhythmia"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_check_antiarrhythmic"
    }
  }
}
