{
  "id": "evaluate_antihypertensive_options_sunitinib@1",
  "version": "1.0",
  "env_id": "example.liverpool_cancer_ichart_env@0.1",
  "description": "Evaluate the interaction traffic light colors for Diltiazem, Ramipril, and Bisoprolol when taken with Sunitinib using the Liverpool Cancer iChart Archive. Create a report at /sdcard/sunitinib_bp_report.txt using the following format:\n\nCancer Drug: Sunitinib\n\nDiltiazem: [Color]\nRamipril: [Color]\nBisoprolol: [Color]",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/evaluate_antihypertensive_options_sunitinib/setup_task.sh",
    "post_task": "sh /sdcard/tasks/evaluate_antihypertensive_options_sunitinib/export_result.sh"
  },
  "metadata": {
    "cancer_drug": "Sunitinib",
    "drugs_to_check": [
      {
        "name": "Diltiazem",
        "expected_risk": "high",
        "valid_colors": [
          "orange",
          "yellow",
          "red"
        ]
      },
      {
        "name": "Ramipril",
        "expected_risk": "low",
        "valid_colors": [
          "green"
        ]
      },
      {
        "name": "Bisoprolol",
        "expected_risk": "low",
        "valid_colors": [
          "green",
          "grey"
        ]
      }
    ],
    "expected_report_path": "/sdcard/sunitinib_bp_report.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_antihypertensive_evaluation"
    }
  }
}
