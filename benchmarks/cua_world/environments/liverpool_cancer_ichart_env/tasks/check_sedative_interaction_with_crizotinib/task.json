{
  "id": "check_sedative_interaction_with_crizotinib@1",
  "version": "1.0",
  "env_id": "example.liverpool_cancer_ichart_env@0.1",
  "description": "Use the Liverpool Cancer iChart Archive app to determine the interaction between the cancer drug Crizotinib and the sedative Midazolam. Document the findings in a file at /sdcard/tasks/crizotinib_midazolam_result.txt including the Cancer Drug name, Co-medication name, Interaction Color, Category name, and a brief summary of the Clinical Note.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/check_sedative_interaction_with_crizotinib/setup_task.sh",
    "post_task": "sh /sdcard/tasks/check_sedative_interaction_with_crizotinib/export_result.sh"
  },
  "metadata": {
    "cancer_drug": "Crizotinib",
    "co_medication": "Midazolam",
    "expected_colors": [
      "RED",
      "ORANGE"
    ],
    "expected_output_path": "/sdcard/tasks/crizotinib_midazolam_result.txt",
    "output_must_contain": [
      "Crizotinib",
      "Midazolam"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_sedative_interaction"
    }
  }
}
