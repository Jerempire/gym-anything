{
  "id": "check_beta_blocker_with_osimertinib@1",
  "version": "1.0",
  "env_id": "example.liverpool_cancer_ichart_env@0.1",
  "description": "The Liverpool Cancer iChart app is installed on the device. Determine the drug-drug interaction between the cancer drug 'Osimertinib' and the co-medication 'Propranolol'. Identify the traffic-light color code of the interaction and write only the color name (e.g., 'red', 'green') to /sdcard/answer.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/check_beta_blocker_with_osimertinib/setup_task.sh",
    "post_task": "sh /sdcard/tasks/check_beta_blocker_with_osimertinib/export_result.sh"
  },
  "metadata": {
    "cancer_drug": "Osimertinib",
    "co_medication": "Propranolol",
    "answer_file": "/sdcard/answer.txt",
    "valid_colors": [
      "red",
      "orange",
      "yellow",
      "green",
      "grey",
      "gray"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_check_beta_blocker_with_osimertinib"
    }
  }
}
