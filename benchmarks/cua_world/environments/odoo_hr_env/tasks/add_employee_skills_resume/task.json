{
  "id": "add_employee_skills_resume@1",
  "version": "1.0",
  "env_id": "odoo_hr_env@0.1",
  "description": "Update Eli Lambert's profile by adding the following professional skills and work experience: an IT skill for Python at Expert level, a Languages skill for Spanish at Intermediate level, and a work experience entry as Senior Developer at TechCorp from 01/01/2019 to 12/31/2023. Save the updated profile.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_employee_skills_resume/setup_task.sh",
    "post_task": "/workspace/tasks/add_employee_skills_resume/export_result.sh"
  },
  "metadata": {
    "employee_name": "Eli Lambert",
    "target_skills": [
      {
        "type": "IT",
        "name": "Python",
        "level": "Expert"
      },
      {
        "type": "Languages",
        "name": "Spanish",
        "level": "Intermediate"
      }
    ],
    "target_resume": {
      "name": "Senior Developer at TechCorp",
      "type": "Experience",
      "start": "2019-01-01",
      "end": "2023-12-31"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_employee_skills_resume"
    }
  }
}
