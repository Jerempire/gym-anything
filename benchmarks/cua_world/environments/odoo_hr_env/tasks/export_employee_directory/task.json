{
  "id": "export_employee_directory@1",
  "version": "1.0",
  "env_id": "odoo_hr_env@0.1",
  "description": "Export the employee directory from Odoo (http://localhost:8069) to an XLSX file. The export must include exactly these four fields in order: Name, Department, Job Position, and Work Phone. Save the resulting file to ~/Downloads/hr.employee.xlsx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_employee_directory/setup_task.sh",
    "post_task": "/workspace/tasks/export_employee_directory/export_result.sh"
  },
  "metadata": {
    "expected_columns": [
      "Name",
      "Department",
      "Job Position",
      "Work Phone"
    ],
    "min_rows": 15,
    "required_names": [
      "Mitchell Admin",
      "Marc Demo",
      "Sarah Mitchell",
      "Abigail Peterson"
    ],
    "download_dir": "/home/ga/Downloads"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_employee_directory"
    }
  }
}
