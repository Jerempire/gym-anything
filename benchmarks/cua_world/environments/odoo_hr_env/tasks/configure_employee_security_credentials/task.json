{
  "id": "configure_employee_security_credentials@1",
  "version": "1.0",
  "env_id": "odoo_hr_env@0.1",
  "description": "Log in to Odoo at http://localhost:8069 with username 'admin' and password 'admin'. Update the security credentials for three employees: Anita Oliver (Badge ID 'AO-9001', PIN Code '1234'), Toni Jimenez (Badge ID 'TJ-9002', PIN Code '5678'), and Jeffrey Kelly (Badge ID 'JK-9003', PIN Code '9090').",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_employee_security_credentials/setup_task.sh",
    "post_task": "/workspace/tasks/configure_employee_security_credentials/export_result.sh"
  },
  "metadata": {
    "targets": [
      {
        "name": "Anita Oliver",
        "expected_barcode": "AO-9001",
        "expected_pin": "1234"
      },
      {
        "name": "Toni Jimenez",
        "expected_barcode": "TJ-9002",
        "expected_pin": "5678"
      },
      {
        "name": "Jeffrey Kelly",
        "expected_barcode": "JK-9003",
        "expected_pin": "9090"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_employee_security_credentials"
    }
  }
}
