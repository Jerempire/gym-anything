{
  "id": "clone_job_position@1",
  "version": "1.0",
  "env_id": "odoo_hr_env@0.1",
  "description": "Create a new job position named 'Senior Python Developer' based on the existing 'Experienced Developer' position. Assign the new position to the 'R&D USA' department and set the recruitment target (Expected New Employees) to 2.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/clone_job_position/setup_task.sh",
    "post_task": "/workspace/tasks/clone_job_position/export_result.sh"
  },
  "metadata": {
    "source_job": "Experienced Developer",
    "target_job": "Senior Python Developer",
    "target_department": "R&D USA",
    "target_recruitment": 2
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_clone_job_position"
    }
  }
}
