{
  "id": "print_employee_badge@1",
  "version": "1.0",
  "env_id": "odoo_hr_env@0.1",
  "description": "Log in to Odoo HR (http://localhost:8069) as admin (password: admin). Print the ID badge for employee 'Anita Oliver' and save the file to /home/ga/badge.pdf.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/print_employee_badge/setup_task.sh",
    "post_task": "/workspace/tasks/print_employee_badge/export_result.sh"
  },
  "metadata": {
    "target_file": "/home/ga/badge.pdf",
    "employee_name": "Anita Oliver",
    "download_dir": "/home/ga/Downloads"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_print_employee_badge"
    }
  }
}
