{
  "id": "configure_leave_accrual_plan@1",
  "version": "1.0",
  "env_id": "odoo_hr_env@0.1",
  "description": "A payroll clerk needs to set up a monthly PTO accrual system. Create a new accrual plan named \"Monthly PTO Accrual\" that accrues 1.67 days monthly with a maximum cap of 20 days. Assign this plan to employee Eli Lambert by creating and validating an Accrual Allocation for Paid Time Off.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_leave_accrual_plan/setup_task.sh",
    "post_task": "/workspace/tasks/configure_leave_accrual_plan/export_result.sh"
  },
  "metadata": {
    "expected_plan_name": "Monthly PTO Accrual",
    "expected_employee": "Eli Lambert",
    "expected_accrual_rate": 1.67,
    "expected_cap": 20,
    "expected_frequency": "monthly"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_leave_accrual_plan"
    }
  }
}
