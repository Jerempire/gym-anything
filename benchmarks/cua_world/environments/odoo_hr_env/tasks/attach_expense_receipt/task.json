{
  "id": "attach_expense_receipt@1",
  "version": "1.0",
  "env_id": "odoo_hr_env@0.1",
  "description": "Locate the expense record for \"Client Lunch\" ($125.50) submitted by employee \"Marc Demo\" in the Expenses module. Attach the receipt file located at \"/home/ga/Documents/receipt_lunch.jpg\" to this expense record.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/attach_expense_receipt/setup_task.sh",
    "post_task": "/workspace/tasks/attach_expense_receipt/export_result.sh"
  },
  "metadata": {
    "target_employee": "Marc Demo",
    "target_description": "Client Lunch",
    "target_amount": 125.5,
    "receipt_path": "/home/ga/Documents/receipt_lunch.jpg",
    "receipt_filename": "receipt_lunch.jpg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_attach_expense_receipt"
    }
  }
}
