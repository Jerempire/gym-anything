{
  "id": "schedule_employee_activity@1",
  "version": "1.0",
  "env_id": "odoo_hr_env@0.1",
  "description": "Log in to Odoo at http://localhost:8069 using the credentials 'admin' for both username and password. Schedule a 'To-Do' activity for the employee 'Marc Demo' with a due date of 12/15/2025. The activity should have the summary 'Q4 Performance Review' and the note 'Discuss project contributions and set goals for next quarter'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/schedule_employee_activity/setup_task.sh",
    "post_task": "/workspace/tasks/schedule_employee_activity/export_result.sh"
  },
  "metadata": {
    "target_employee": "Marc Demo",
    "expected_activity_type": "To-Do",
    "expected_date": "2025-12-15",
    "expected_summary": "Q4 Performance Review",
    "expected_note_keywords": [
      "project contributions",
      "goals",
      "next quarter"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_schedule_employee_activity"
    }
  }
}
