{
  "id": "configure_job_recruitment_settings@1",
  "version": "1.0",
  "env_id": "odoo_hr_env@0.1",
  "description": "Using the admin credentials (password: admin), update the 'Marketing and Community Manager' job position in Odoo. Set the Email Alias to 'social-guru', assign 'Marc Demo' as the Recruiter, and set the Expected New Employees target to 3.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_job_recruitment_settings/setup_task.sh",
    "post_task": "/workspace/tasks/configure_job_recruitment_settings/export_result.sh"
  },
  "metadata": {
    "target_job_name": "Marketing and Community Manager",
    "expected_alias": "social-guru",
    "expected_recruiter_name": "Marc Demo",
    "expected_target": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_job_recruitment_settings"
    }
  }
}
