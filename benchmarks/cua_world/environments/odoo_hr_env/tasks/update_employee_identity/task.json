{
  "id": "update_employee_identity@1",
  "version": "1.0",
  "env_id": "odoo_hr_env@0.1",
  "description": "Update the employee profile for \"Anita Oliver\" in Odoo by uploading the profile photo from /home/ga/Documents/anita_profile.png and setting her Badge ID to \"AO-9942\". Log in with username 'admin' and password 'admin' if prompted.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_employee_identity/setup_task.sh",
    "post_task": "/workspace/tasks/update_employee_identity/export_result.sh"
  },
  "metadata": {
    "target_employee": "Anita Oliver",
    "target_badge_id": "AO-9942",
    "image_path": "/home/ga/Documents/anita_profile.png",
    "required_fields": [
      "image_1920",
      "barcode"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_employee_identity"
    }
  }
}
