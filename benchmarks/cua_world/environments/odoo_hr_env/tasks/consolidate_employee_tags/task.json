{
  "id": "consolidate_employee_tags@1",
  "version": "1.0",
  "env_id": "odoo_hr_env@0.1",
  "description": "The HR department is standardizing employee classification terms. Replace the 'Consultant' tag with a new 'Contractor' tag for all employees in the system, ensuring no employees remain with the 'Consultant' tag.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/consolidate_employee_tags/setup_task.sh",
    "post_task": "/workspace/tasks/consolidate_employee_tags/export_result.sh"
  },
  "metadata": {
    "target_old_tag": "Consultant",
    "target_new_tag": "Contractor",
    "target_employees": [
      "Jeffrey Kelly",
      "Anita Oliver"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_consolidate_employee_tags"
    }
  }
}
