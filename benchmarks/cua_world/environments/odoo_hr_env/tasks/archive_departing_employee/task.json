{
  "id": "archive_departing_employee@1",
  "version": "1.0",
  "env_id": "odoo_hr_env@0.1",
  "description": "Log in to Odoo at http://localhost:8069 with username 'admin' and password 'admin'. Archive the employee record for 'Walter Horton' in the Employees directory. Ensure the record is archived rather than deleted to preserve historical data.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/archive_departing_employee/setup_task.sh",
    "post_task": "/workspace/tasks/archive_departing_employee/export_result.sh"
  },
  "metadata": {
    "target_employee": "Walter Horton",
    "expected_active_state": false,
    "pass_threshold": 70
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_archive_departing_employee"
    }
  }
}
