{
  "id": "configure_dual_leave_approval@1",
  "version": "1.0",
  "env_id": "odoo_hr_env@0.1",
  "description": "Log in to Odoo (admin/admin). Update the \"Training Time Off\" leave type configuration to require approval by both the Employee's Approver and the Time Off Officer. Designate \"Mitchell Admin\" as the Notified Time Off Officer for this leave type.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_dual_leave_approval/setup_task.sh",
    "post_task": "/workspace/tasks/configure_dual_leave_approval/export_result.sh"
  },
  "metadata": {
    "target_leave_type": "Training Time Off",
    "target_validation_type": "both",
    "target_responsible_name": "Mitchell Admin",
    "target_responsible_id": 2,
    "initial_validation_type": "manager"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_dual_leave_approval"
    }
  }
}
