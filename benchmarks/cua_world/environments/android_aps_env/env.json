{
  "id": "android_aps_env@0.1",
  "version": "0.1",
  "base": "android-avd-34",
  "description": "AndroidAPS (AAPS) environment for diabetes insulin management tasks using the open-source artificial pancreas system with virtual pump and simulated CGM data",
  "avd": {
    "variant": "google_apis"
  },
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1080, 2400],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": true,
    "output_dir": "benchmarks/cua_world/environments/android_aps_env/artifacts",
    "video_fps": 10,
    "video_resolution": [1080, 2400],
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": true,
    "host_port": -1,
    "view_only": false,
    "password": "password"
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/android_aps_env/scripts",
      "target": "/sdcard/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/android_aps_env/tasks",
      "target": "/sdcard/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/android_aps_env/data",
      "target": "/sdcard/data",
      "mode": "ro"
    }
  ],
  "hooks": {
    "post_start": "/sdcard/scripts/setup_androidaps.sh"
  },
  "user_accounts": [
    {
      "name": "owner",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "shell": "/system/bin/sh"
      }
    }
  ],
  "apks": [
    "benchmarks/cua_world/environments/android_aps_env/scripts/apks/androidaps-full-debug.apk"
  ],
  "tags": ["android", "avd", "medical", "diabetes", "insulin", "healthcare", "androidaps", "aaps"]
}
