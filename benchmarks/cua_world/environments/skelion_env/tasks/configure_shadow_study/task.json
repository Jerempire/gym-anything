{
  "id": "configure_shadow_study@1",
  "version": "1.0",
  "env_id": "skelion_env@0.1",
  "description": "Configure SketchUp's shadow display to show shadows cast on a residential building model at 10:00 AM on December 21st (winter solstice). Enable shadows on both faces and ground. Save the model to C:\\Users\\Docker\\Documents\\shadow_analysis.skp and export a 2D graphic of the current view to C:\\Users\\Docker\\Documents\\shadow_study_winter_solstice.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_shadow_study\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_shadow_study\\export_result.ps1"
  },
  "metadata": {
    "expected_skp_path": "C:\\Users\\Docker\\Documents\\shadow_analysis.skp",
    "expected_png_path": "C:\\Users\\Docker\\Documents\\shadow_study_winter_solstice.png",
    "target_month": 12,
    "target_day": 21,
    "target_hour": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_shadow_study"
    }
  }
}