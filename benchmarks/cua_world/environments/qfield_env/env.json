{
  "id": "example.qfield_env@0.1",
  "version": "0.1",
  "base": "android-avd-34",
  "description": "Android environment with QField (v3.4.6) mobile GIS app for field data collection tasks including opening QGIS projects, toggling layer visibility, identifying geographic features, adding survey points, and navigating to coordinates using a real-world GeoPackage dataset of world capital cities",
  "avd": {
    "variant": "google_apis_playstore"
  },
  "resources": {
    "cpu": 4,
    "mem_gb": 6,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1080, 2400],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": true,
    "output_dir": "benchmarks/cua_world/environments/qfield_env/artifacts",
    "video_fps": 10,
    "video_resolution": [1080, 2400],
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": true,
    "host_port": -1,
    "view_only": false,
    "password": "password"
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/qfield_env/tasks",
      "target": "/sdcard/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/qfield_env/scripts",
      "target": "/sdcard/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/qfield_env/data",
      "target": "/sdcard/QFieldData",
      "mode": "ro"
    }
  ],
  "hooks": {
    "post_start": "/sdcard/scripts/setup_qfield.sh"
  },
  "user_accounts": [
    {
      "name": "owner",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "shell": "/system/bin/sh"
      }
    }
  ],
  "tags": ["android", "avd", "qfield", "gis", "qgis", "geospatial", "field-data", "geopackage", "emulator"]
}
