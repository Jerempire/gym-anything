{
  "id": "measure_area@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "Using the 'world_survey' project, measure the area of the triangle formed by the capital cities Paris (France), Brussels (Belgium), and Amsterdam (Netherlands). Ensure the measurement result is visible on the screen.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/measure_area/setup_task.sh",
    "post_task": "sh /sdcard/tasks/measure_area/export_result.sh"
  },
  "metadata": {
    "project_file": "world_survey.gpkg",
    "target_cities": [
      "Paris",
      "Brussels",
      "Amsterdam"
    ],
    "expected_area_min_km2": 5000,
    "expected_area_max_km2": 15000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_measure_area"
    }
  }
}
