{
  "id": "locate_distress_beacons@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "Locate three distress beacons and identify the nearest capital city for each. Create points in the 'field_observations' layer named 'Beacon A' (-15.90, -47.95), 'Beacon B' (29.95, 31.10), and 'Beacon C' (35.50, 139.50). Include the name of the nearest capital city in the notes for each point and save all changes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/locate_distress_beacons/setup_task.sh",
    "post_task": "/sdcard/tasks/locate_distress_beacons/export_result.sh"
  },
  "metadata": {
    "gpkg_path": "/sdcard/Android/data/ch.opengis.qfield/files/world_survey.gpkg",
    "export_path": "/sdcard/task_result.gpkg",
    "beacons": [
      {
        "id": "Beacon A",
        "lat": -15.9,
        "lon": -47.95,
        "city": "Brasilia"
      },
      {
        "id": "Beacon B",
        "lat": 29.95,
        "lon": 31.1,
        "city": "Cairo"
      },
      {
        "id": "Beacon C",
        "lat": 35.5,
        "lon": 139.5,
        "city": "Tokyo"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_distress_beacons"
    }
  }
}
