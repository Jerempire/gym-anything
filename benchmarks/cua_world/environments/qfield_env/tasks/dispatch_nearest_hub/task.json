{
  "id": "dispatch_nearest_hub@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "A distress signal has been received at coordinates (9.000, -79.500) near the Panama Canal. Identify the nearest Global Logistics Hub in the 'world_capitals' layer of the 'world_survey.gpkg' project and update its 'notes' attribute to exactly: 'DISPATCHING TO PANAMA'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/dispatch_nearest_hub/setup_task.sh",
    "post_task": "sh /sdcard/tasks/dispatch_nearest_hub/export_result.sh"
  },
  "metadata": {
    "target_lat": 9.0,
    "target_lon": -79.5,
    "target_feature_name": "Panama City",
    "expected_note": "DISPATCHING TO PANAMA",
    "gpkg_path": "/sdcard/Android/data/ch.opengis.qfield/files/world_survey.gpkg",
    "layer_name": "world_capitals"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_dispatch_hub"
    }
  }
}
