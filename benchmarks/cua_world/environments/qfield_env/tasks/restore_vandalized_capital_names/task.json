{
  "id": "restore_vandalized_capital_names@1",
  "version": "1.0",
  "env_id": "qfield_env@0.1",
  "description": "The names of three capital cities in the world_survey project have been vandalized to 'Target_Alpha', 'Target_Bravo', and 'Target_Charlie'. Restore their correct names ('Paris', 'Tokyo', 'Canberra') by identifying their geographic locations in France, Japan, and Australia and updating the name attributes accordingly.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/restore_vandalized_capital_names/setup_task.sh",
    "post_task": "/sdcard/tasks/restore_vandalized_capital_names/export_result.sh"
  },
  "metadata": {
    "target_file": "world_survey.gpkg",
    "corrupted_names": [
      "Target_Alpha",
      "Target_Bravo",
      "Target_Charlie"
    ],
    "corrected_names": [
      "Paris",
      "Tokyo",
      "Canberra"
    ],
    "gpkg_path": "/sdcard/Android/data/ch.opengis.qfield/files/Imported Datasets/world_survey.gpkg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_restored_capitals"
    }
  }
}
