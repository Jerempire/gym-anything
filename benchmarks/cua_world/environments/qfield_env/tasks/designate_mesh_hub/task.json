{
  "id": "designate_mesh_hub@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "Locate the cluster of five 'Sensor Node' points approximately 10km North of Canberra (near -35.20, 149.13) arranged in a 'dice' pattern. Update the 'notes' attribute of the central node to 'Master Hub' and ensure the other four nodes remain 'Unassigned'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/designate_mesh_hub/setup_task.sh",
    "post_task": "sh /sdcard/tasks/designate_mesh_hub/export_result.sh"
  },
  "metadata": {
    "target_coords": {
      "lat": -35.2,
      "lon": 149.13
    },
    "expected_notes": "Master Hub",
    "peripheral_notes": "Unassigned",
    "feature_name": "Sensor Node"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_designate_mesh_hub"
    }
  }
}
