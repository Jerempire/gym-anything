{
  "id": "deduplicate_overlapping_features@1",
  "version": "1.0",
  "env_id": "qfield_env@0.1",
  "description": "In the 'world_survey' project, delete the 'LEGACY_DUPLICATE' point feature located at Rome, Italy, while preserving the valid Rome feature. Save the project changes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/deduplicate_overlapping_features/setup_task.sh",
    "post_task": "/workspace/tasks/deduplicate_overlapping_features/export_result.sh"
  },
  "metadata": {
    "target_city": "Rome",
    "duplicate_marker": "LEGACY_DUPLICATE",
    "gpkg_path_android": "/sdcard/Android/data/ch.opengis.qfield/files/Imported Datasets/world_survey.gpkg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_deduplicate_overlapping_features"
    }
  }
}
