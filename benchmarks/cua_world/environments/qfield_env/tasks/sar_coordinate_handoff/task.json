{
  "id": "sar_coordinate_handoff@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "As part of a Search and Rescue coordination task, open the 'world_survey.gpkg' project in QField. Locate the distress signal coordinates found in the description field of the capital city 'Ottawa'. Navigate to those coordinates and add a new point feature named 'SAR_Team_Alpha' to the 'field_observations' layer at that exact location.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sar_coordinate_handoff/setup_task.sh",
    "post_task": "/workspace/tasks/sar_coordinate_handoff/export_result.sh"
  },
  "metadata": {
    "target_name": "SAR_Team_Alpha",
    "target_lat": 30.1,
    "target_lon": 31.5,
    "tolerance_deg": 0.05,
    "clue_feature": "Ottawa",
    "clue_text": "SAR Target: Lat 30.10, Lon 31.50",
    "gpkg_path_device": "/sdcard/Android/data/ch.opengis.qfield/files/Imported Datasets/world_survey.gpkg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_sar_coordinate_handoff"
    }
  }
}
