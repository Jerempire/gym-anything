{
  "id": "digitize_star_network@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "Digitize a star topology network in the 'world_survey.gpkg' project using the 'network_lines' layer. Create three line features originating precisely from Vienna (Austria) to the capitals of Bratislava (Slovakia), Budapest (Hungary), and Prague (Czechia). Assign the following attributes:\n- Vienna to Bratislava: link_id='VIE-BTS', status='planned'\n- Vienna to Budapest: link_id='VIE-BUD', status='planned'\n- Vienna to Prague: link_id='VIE-PRG', status='planned'",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/digitize_star_network/setup_task.sh",
    "post_task": "/sdcard/tasks/digitize_star_network/export_result.sh"
  },
  "metadata": {
    "gpkg_path": "/sdcard/Android/data/ch.opengis.qfield/files/world_survey.gpkg",
    "layer_name": "network_lines",
    "targets": {
      "center": {
        "name": "Vienna",
        "lat": 48.2082,
        "lon": 16.3738
      },
      "spokes": [
        {
          "name": "Bratislava",
          "lat": 48.1486,
          "lon": 17.1077,
          "id": "VIE-BTS"
        },
        {
          "name": "Budapest",
          "lat": 47.4979,
          "lon": 19.0402,
          "id": "VIE-BUD"
        },
        {
          "name": "Prague",
          "lat": 50.0755,
          "lon": 14.4378,
          "id": "VIE-PRG"
        }
      ]
    },
    "tolerance_km": 25.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_digitize_star_network"
    }
  }
}
