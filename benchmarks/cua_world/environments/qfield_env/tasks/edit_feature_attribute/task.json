{
  "id": "edit_feature_attribute@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "In the QField project 'world_survey.gpkg', update the 'description' field for the capital city 'Paris' (France) to 'Telecom assessment complete. 4G coverage confirmed.'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/edit_feature_attribute/setup_task.sh",
    "post_task": "sh /sdcard/tasks/edit_feature_attribute/export_result.sh"
  },
  "metadata": {
    "target_feature": "Paris",
    "target_attribute": "description",
    "initial_value": "No survey data",
    "expected_value": "Telecom assessment complete. 4G coverage confirmed.",
    "database_file": "world_survey.gpkg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_edit_feature_attribute"
    }
  }
}
