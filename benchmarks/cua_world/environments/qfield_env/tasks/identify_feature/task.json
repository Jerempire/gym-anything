{
  "id": "identify_feature@1",
  "env_id": "example.qfield_env@0.1",
  "difficulty": "medium",
  "description": "QField has the world_survey.gpkg project open, showing world capital cities as markers on a world map. Identify the name, country, and continent attributes for the 'Tokyo' marker (139.7°E, 35.7°N).",
  "init": {
    "timeout_sec": 120,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/identify_feature/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_identify_feature"
    }
  },
  "metadata": {
    "target_feature": {
      "name": "Tokyo",
      "country": "Japan",
      "continent": "Asia",
      "lon": 139.6917,
      "lat": 35.6895
    }
  }
}
