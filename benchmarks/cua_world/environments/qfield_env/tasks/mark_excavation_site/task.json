{
  "id": "mark_excavation_site@1",
  "version": "1.0",
  "env_id": "qfield_env@0.1",
  "description": "Navigate to Brasilia in the QField project and create four point features in the 'field_observations' layer named 'Corner 1', 'Corner 2', 'Corner 3', and 'Corner 4'. The points must form a square surrounding the center point within a 500-meter radius at a scale of 500m or less. Save the project.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/mark_excavation_site/setup_task.sh",
    "post_task": "sh /sdcard/tasks/mark_excavation_site/export_result.sh"
  },
  "metadata": {
    "target_location": {
      "name": "Brasilia",
      "lat": -15.793889,
      "lon": -47.882778
    },
    "max_distance_degrees": 0.005,
    "required_names": [
      "Corner 1",
      "Corner 2",
      "Corner 3",
      "Corner 4"
    ],
    "gpkg_path": "/sdcard/Android/data/ch.opengis.qfield/files/world_survey.gpkg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_excavation_site"
    }
  }
}
