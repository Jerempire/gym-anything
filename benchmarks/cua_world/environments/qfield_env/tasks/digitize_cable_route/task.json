{
  "id": "digitize_cable_route@1",
  "version": "1.0",
  "env_id": "qfield_env@0.1",
  "description": "Digitize a new fiber optic cable route in the 'world_survey' project. Create a polyline in the 'cable_routes' layer connecting Paris (approx 48.86°N, 2.35°E) to Brussels (approx 50.85°N, 4.35°E). The route must include the following attributes: Route Name 'PAR-BRU-F001', Cable Type 'fiber', and Notes 'Main trunk line segment 1'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/scripts/setup_digitize_cable_route.sh",
    "post_task": "/sdcard/scripts/export_digitize_cable_route.sh"
  },
  "metadata": {
    "gpkg_path": "/sdcard/Android/data/ch.opengis.qfield/files/Imported Datasets/world_survey.gpkg",
    "layer_name": "cable_routes",
    "expected_attributes": {
      "route_name": "PAR-BRU-F001",
      "cable_type": "fiber",
      "notes": "Main trunk line segment 1"
    },
    "coordinates": {
      "paris": [
        2.3522,
        48.8566
      ],
      "brussels": [
        4.3517,
        50.8503
      ],
      "tolerance_deg": 2.0
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_digitize_cable_route"
    }
  }
}
