{
  "id": "log_feature_coordinates@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "In the 'world_survey' project, identify the coordinates for Cairo and record them in a new point feature named 'Cairo_Log' within the 'field_observations' layer. The description field of the new feature should contain the Latitude and Longitude values retrieved from the original feature attributes (e.g., 'Lat: 30.04, Lon: 31.23').",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/log_feature_coordinates/setup_task.sh",
    "post_task": "/sdcard/tasks/log_feature_coordinates/export_result.sh"
  },
  "metadata": {
    "target_city": "Cairo",
    "target_layer": "field_observations",
    "log_feature_name": "Cairo_Log",
    "expected_lat": 30.0444,
    "expected_lon": 31.2357,
    "tolerance_deg": 0.05,
    "max_distance_km": 200,
    "gpkg_path": "/sdcard/Android/data/ch.opengis.qfield/files/world_survey.gpkg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_log_feature_coordinates"
    }
  }
}
