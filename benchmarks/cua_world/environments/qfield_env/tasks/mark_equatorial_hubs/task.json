{
  "id": "mark_equatorial_hubs@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "Locate Quito (Ecuador), Nairobi (Kenya), and Singapore to designate them as logistics hubs. Create a point feature in the 'field_observations' layer for each city with the following attributes: Quito (Name: 'Hub_Quito', Notes: 'Region: Americas'), Nairobi (Name: 'Hub_Nairobi', Notes: 'Region: Africa'), and Singapore (Name: 'Hub_Singapore', Notes: 'Region: Asia'). Save all changes to the layer.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/mark_equatorial_hubs/setup_task.sh",
    "post_task": "/sdcard/tasks/mark_equatorial_hubs/export_result.sh"
  },
  "metadata": {
    "gpkg_path": "/sdcard/Android/data/ch.opengis.qfield/files/Imported Datasets/world_survey.gpkg",
    "targets": [
      {
        "city": "Quito",
        "lat": -0.22,
        "lon": -78.51,
        "expected_name": "Hub_Quito",
        "expected_notes": "Region: Americas"
      },
      {
        "city": "Nairobi",
        "lat": -1.29,
        "lon": 36.82,
        "expected_name": "Hub_Nairobi",
        "expected_notes": "Region: Africa"
      },
      {
        "city": "Singapore",
        "lat": 1.28,
        "lon": 103.83,
        "expected_name": "Hub_Singapore",
        "expected_notes": "Region: Asia"
      }
    ],
    "tolerance_degrees": 1.5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mark_equatorial_hubs"
    }
  }
}
