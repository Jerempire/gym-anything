{
  "id": "remove_decommissioned_sensors@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "Perform a database cleanup in the 'world_survey.gpkg' project by managing field observation points 'Sensor 1' through 'Sensor 6'. Delete features where the 'notes' attribute is 'Status: Decommissioned' and preserve those marked 'Status: Active'. Do not modify or delete any other features.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/remove_decommissioned_sensors/setup_task.sh",
    "post_task": "sh /sdcard/tasks/remove_decommissioned_sensors/export_result.sh"
  },
  "metadata": {
    "target_file": "world_survey.gpkg",
    "table_name": "field_observations",
    "active_count": 3,
    "decommissioned_count": 3,
    "target_ids": [
      1,
      2,
      3,
      4,
      5,
      6
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_sensor_cleanup"
    }
  }
}
