{
  "id": "triangulate_coordinate_intersection@1",
  "version": "1.0",
  "env_id": "qfield_env@0.1",
  "description": "Using the 'world_survey.gpkg' project, determine the intersection point of Rome's latitude and Dublin's longitude. Create a new feature at these coordinates in the 'field_observations' layer with the Name/Notes attribute set to 'Climate Control Site'.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/triangulate_coordinate_intersection/setup_task.sh",
    "post_task": "/sdcard/tasks/triangulate_coordinate_intersection/export_result.sh"
  },
  "metadata": {
    "target_lat_source": "Rome",
    "target_lon_source": "Dublin",
    "required_attribute": "Climate Control Site",
    "tolerance_degrees": 0.5,
    "gpkg_path": "/sdcard/Android/data/ch.opengis.qfield/files/Imported Datasets/world_survey.gpkg",
    "layer_capitals": "world_capitals",
    "layer_observations": "field_observations"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_triangulate_coordinate_intersection"
    }
  }
}
