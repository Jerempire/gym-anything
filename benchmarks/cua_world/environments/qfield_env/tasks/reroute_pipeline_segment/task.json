{
  "id": "reroute_pipeline_segment@1",
  "version": "1.0",
  "env_id": "qfield_env@0.1",
  "description": "Reroute the 'Cairo-Baghdad' pipeline feature in the 'pipelines' layer of the world_survey.gpkg project to pass through Amman, Jordan (35.93°E, 31.95°N). The updated pipeline must be a single feature consisting of three vertices in sequence: Cairo, Amman, and Baghdad.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/reroute_pipeline_segment/setup_task.sh",
    "post_task": "sh /sdcard/tasks/reroute_pipeline_segment/export_result.sh"
  },
  "metadata": {
    "target_location": {
      "name": "Amman",
      "lon": 35.93,
      "lat": 31.95,
      "tolerance_deg": 0.5
    },
    "layer_name": "pipelines",
    "feature_name": "Cairo-Baghdad",
    "expected_vertex_count": 3,
    "gpkg_path_android": "/sdcard/Android/data/ch.opengis.qfield/files/world_survey.gpkg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reroute_pipeline"
    }
  }
}
