{
  "id": "identify_latitudinal_extremes@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "Identify the northernmost and southernmost capital cities in the 'world_survey' project. Create a point feature in the 'field_observations' layer at (0, 0) with the findings recorded in the following format: 'North: [CityName], South: [CityName], Span: [Degrees]' (round the span to the nearest whole number).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/identify_latitudinal_extremes/setup_task.sh",
    "post_task": "/sdcard/tasks/identify_latitudinal_extremes/export_result.sh"
  },
  "metadata": {
    "target_layer": "field_observations",
    "capitals_layer": "world_capitals",
    "output_gpkg": "/sdcard/task_result.gpkg",
    "regex_pattern": "North:\\s*(?P<north>[^,]+),\\s*South:\\s*(?P<south>[^,]+),\\s*Span:\\s*(?P<span>\\d+)"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_identify_latitudinal_extremes"
    }
  }
}
