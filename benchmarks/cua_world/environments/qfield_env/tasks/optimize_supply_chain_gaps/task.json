{
  "id": "optimize_supply_chain_gaps@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "Evaluate the supply chain route between the South American capitals of Quito (Ecuador), Lima (Peru), and Santiago (Chile). Determine which segment is longer: 'Quito to Lima' or 'Lima to Santiago'. Create a point feature named 'Rest_Stop' in the 'field_observations' layer at the approximate midpoint of the longer segment with the description 'Midpoint of longest leg' and save the changes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/optimize_supply_chain_gaps/setup_task.sh",
    "post_task": "/sdcard/tasks/optimize_supply_chain_gaps/export_result.sh"
  },
  "metadata": {
    "capitals": {
      "Quito": {
        "lat": -0.22,
        "lon": -78.51
      },
      "Lima": {
        "lat": -12.04,
        "lon": -77.04
      },
      "Santiago": {
        "lat": -33.44,
        "lon": -70.66
      }
    },
    "target_layer": "field_observations",
    "target_feature_name": "Rest_Stop",
    "target_description_keyword": "Midpoint",
    "gpkg_path": "/sdcard/Android/data/ch.opengis.qfield/files/Imported Datasets/world_survey.gpkg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_supply_chain_optimization"
    }
  }
}
