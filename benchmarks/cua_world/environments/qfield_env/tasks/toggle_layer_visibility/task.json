{
  "id": "toggle_layer_visibility@1",
  "env_id": "example.qfield_env@0.1",
  "difficulty": "easy",
  "description": "In the world_survey.gpkg project, hide the 'field_observations' layer (blue square markers) so that only the 'world_capitals' layer (red circle markers) remains visible on the map.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/toggle_layer_visibility/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_toggle_layer"
    }
  },
  "metadata": {
    "target_layer": "field_observations",
    "action": "hide",
    "layers_in_project": [
      "world_capitals",
      "field_observations"
    ]
  }
}
