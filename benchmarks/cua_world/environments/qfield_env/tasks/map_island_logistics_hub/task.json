{
  "id": "map_island_logistics_hub@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "Configure the 'world_survey' project with an OpenStreetMap background layer. Locate Tasmania and create a point feature in the 'field_observations' layer on the landmass. Name the feature 'Tasmania Depot' and set the description to 'Logistics Hub'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/map_island_logistics_hub/setup_task.sh",
    "post_task": "/sdcard/tasks/map_island_logistics_hub/export_result.sh"
  },
  "metadata": {
    "target_bbox": {
      "min_lat": -44.0,
      "max_lat": -40.0,
      "min_lon": 144.0,
      "max_lon": 149.0
    },
    "target_name": "Tasmania Depot",
    "gpkg_path": "/sdcard/Android/data/ch.opengis.qfield/files/Imported Datasets/world_survey.gpkg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_map_island_logistics_hub"
    }
  }
}
