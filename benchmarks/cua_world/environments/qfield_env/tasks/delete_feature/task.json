{
  "id": "delete_feature@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "The 'world_survey' project contains a duplicate record for 'Tokyo' (Japan) in the 'capital_cities' layer. Remove this duplicate feature while preserving all other data in the project.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/delete_feature/setup_task.sh",
    "post_task": "sh /sdcard/tasks/delete_feature/export_result.sh"
  },
  "metadata": {
    "target_feature_name": "Tokyo",
    "layer_table_name": "capital_cities",
    "gpkg_path_android": "/sdcard/Android/data/ch.opengis.qfield/files/Imported Datasets/world_survey.gpkg",
    "sentinel_features": [
      "Paris",
      "Canberra",
      "Brasilia",
      "Washington, D.C."
    ],
    "min_features_expected": 86
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_delete_feature"
    }
  }
}
