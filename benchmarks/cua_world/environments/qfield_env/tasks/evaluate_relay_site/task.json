{
  "id": "evaluate_relay_site@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "Evaluate Kinshasa (DRC), Nairobi (Kenya), and Addis Ababa (Ethiopia) using the 'world_survey.gpkg' project in Imported Datasets to determine which city is geographically closest to the equator. At the winning city's location, add a point feature to the 'field_observations' layer named 'Relay_Uplink_Africa' with a description containing the city name and its latitude.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/evaluate_relay_site/setup_task.sh",
    "post_task": "sh /sdcard/tasks/evaluate_relay_site/export_result.sh"
  },
  "metadata": {
    "candidates": [
      {
        "name": "Nairobi",
        "lat": -1.29,
        "target": true
      },
      {
        "name": "Kinshasa",
        "lat": -4.32,
        "target": false
      },
      {
        "name": "Addis Ababa",
        "lat": 9.02,
        "target": false
      }
    ],
    "target_layer": "field_observations",
    "required_name": "Relay_Uplink_Africa",
    "gpkg_path": "/sdcard/Android/data/ch.opengis.qfield/files/Imported Datasets/world_survey.gpkg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_evaluate_relay_site"
    }
  }
}
