{
  "id": "digitize_burn_area@1",
  "version": "1.0",
  "env_id": "qfield_env@0.1",
  "description": "Digitize a polygon with at least 4 vertices representing a fire perimeter in the 'burn_areas' layer of the 'world_survey.gpkg' project near Brasília (-15.8, -47.9). The polygon must have the following attributes: fire_name 'Cerrado Fire 2024', severity 'high', date_observed '2024-08-15', and area_status 'active'.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/digitize_burn_area/setup_task.sh",
    "post_task": "/sdcard/tasks/digitize_burn_area/export_result.sh"
  },
  "metadata": {
    "target_gpkg_path": "/sdcard/Android/data/ch.opengis.qfield/files/Imported Datasets/world_survey.gpkg",
    "expected_attributes": {
      "fire_name": "Cerrado Fire 2024",
      "severity": "high",
      "date_observed": "2024-08-15",
      "area_status": "active"
    },
    "location_target": {
      "lat_min": -30,
      "lat_max": 0,
      "lon_min": -60,
      "lon_max": -35
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_digitize_burn_area"
    }
  }
}
