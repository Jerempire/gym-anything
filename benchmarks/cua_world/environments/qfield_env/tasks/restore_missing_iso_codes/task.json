{
  "id": "restore_missing_iso_codes@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "Update the 'iso_code' attribute for three capital cities in the 'world_capitals' layer of the 'world_survey' project. Assign the code 'JP' to Tokyo (Japan), 'AU' to Canberra (Australia), and 'BR' to Brasilia (Brazil).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/restore_missing_iso_codes/setup_task.sh",
    "post_task": "/workspace/tasks/restore_missing_iso_codes/export_result.sh"
  },
  "metadata": {
    "target_file": "world_survey.gpkg",
    "target_layer": "world_capitals",
    "targets": {
      "Tokyo": "JP",
      "Canberra": "AU",
      "Brasilia": "BR"
    },
    "android_path": "/sdcard/Android/data/ch.opengis.qfield/files/Imported Datasets/world_survey.gpkg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_restore_missing_iso_codes"
    }
  }
}
