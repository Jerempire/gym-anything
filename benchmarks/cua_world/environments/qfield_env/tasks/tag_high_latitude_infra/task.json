{
  "id": "tag_high_latitude_infra@1",
  "version": "1.0",
  "env_id": "example.qfield_env@0.1",
  "description": "A seasonal maintenance protocol has been activated for northern infrastructure. In the 'world_survey.gpkg' project, update the 'description' attribute to 'Winter Protocol Active' for all capital cities located North of 55.0 degrees Latitude. Do not modify cities south of 55.0 degrees.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/scripts/setup_task.sh",
    "post_task": "/sdcard/scripts/export_result.sh"
  },
  "metadata": {
    "target_latitude_threshold": 55.0,
    "target_text": "Winter Protocol Active",
    "gpkg_path": "/sdcard/Android/data/ch.opengis.qfield/files/Imported Datasets/world_survey.gpkg",
    "northern_capitals": [
      "Reykjavik",
      "Helsinki",
      "Oslo",
      "Stockholm",
      "Tallinn",
      "Riga",
      "Copenhagen",
      "Moscow"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_tag_high_latitude_infra"
    }
  }
}
