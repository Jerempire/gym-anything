{
  "id": "search_flag_security_incident@1",
  "version": "1.0",
  "env_id": "free_scout_env@0.1",
  "description": "A security incident has been reported. Locate the conversation from customer 'Sarah Jones' with the subject containing 'Suspicious invoice'. Apply a new tag named 'Security Alert' to this conversation, assign it to 'Administrator', and add an internal note with the text: 'Escalated for immediate header analysis.'",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/search_flag_security_incident/setup_task.sh",
    "post_task": "/workspace/tasks/search_flag_security_incident/export_result.sh"
  },
  "metadata": {
    "target_customer_name": "Sarah Jones",
    "target_subject_keyword": "Suspicious invoice",
    "required_tag": "Security Alert",
    "required_note_content": "header analysis",
    "required_assignee_email": "admin@helpdesk.local"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_search_flag_security_incident"
    }
  }
