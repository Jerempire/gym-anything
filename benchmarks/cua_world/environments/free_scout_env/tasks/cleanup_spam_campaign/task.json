    "spam_domain": "spam-lottery.xyz",
    "legit_domain": "legit-lotto.com",
    "spam_sender": "winner@spam-lottery.xyz",
    "legit_sender": "account.manager@legit-lotto.com",
    "expected_spam_count": 5,
    "expected_legit_count": 1
