{
  "id": "edit_mailbox_properties@1",
  "version": "1.0",
  "env_id": "free_scout_env@0.1",
  "description": "Edit the properties of the 'Equipment Intake' mailbox. Change the Mailbox Name to 'Field Service Requests' and the Email Address to 'fieldservice@helpdesk.local'. Add 'equipmentintake@helpdesk.local' as an alias so old emails are still captured.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/edit_mailbox_properties/setup_task.sh",
    "post_task": "/workspace/tasks/edit_mailbox_properties/export_result.sh"
  },
  "metadata": {
    "target_original_name": "Equipment Intake",
    "target_original_email": "intake@helpdesk.local",
    "expected_name": "Field Service Requests",
    "expected_email": "fieldservice@helpdesk.local",
    "expected_alias": "equipmentintake@helpdesk.local"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_edit_mailbox_properties"
    }
  }
}
