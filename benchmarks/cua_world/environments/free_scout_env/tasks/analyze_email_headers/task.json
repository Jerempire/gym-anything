{
  "id": "analyze_email_headers@1",
  "version": "1.0",
  "env_id": "free_scout_env@0.1",
  "description": "Extract the X-Originating-IP address from the raw headers of the 'URGENT: Confidential Wire Transfer Request' email in the 'Executive Support' mailbox and save the IP address to /home/ga/submission/suspect_ip.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/analyze_email_headers/setup_task.sh",
    "post_task": "/workspace/tasks/analyze_email_headers/export_result.sh"
  },
  "metadata": {
    "mailbox_name": "Executive Support",
    "ticket_subject": "URGENT: Confidential Wire Transfer Request",
    "submission_path": "/home/ga/submission/suspect_ip.txt",
    "ground_truth_path": "/var/lib/app/ground_truth/origin_ip.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_analyze_email_headers"
    }
  }
}
