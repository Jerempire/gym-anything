{
  "id": "bulk_move_purchase_orders@1",
  "version": "1.0",
  "env_id": "free_scout_env@0.1",
  "description": "A configuration error caused several 'Purchase Order' emails to land in the 'Support' mailbox instead of 'Sales'. Move all tickets with 'Purchase Order' in the subject from the 'Support' mailbox to the 'Sales' mailbox, ensuring no other ticket types are moved.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bulk_move_purchase_orders/setup_task.sh",
    "post_task": "/workspace/tasks/bulk_move_purchase_orders/export_result.sh"
  },
  "metadata": {
    "target_keyword": "Purchase Order",
    "source_mailbox": "Support",
    "destination_mailbox": "Sales",
    "target_subjects": [
      "Purchase Order #3021",
      "Purchase Order #3022",
      "Purchase Order #3023",
      "Purchase Order #3024",
      "Purchase Order #3025"
    ],
    "distractor_subjects": [
      "Printer Jam",
      "Login failed",
      "coffee machine"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bulk_move"
    }
  }
}
