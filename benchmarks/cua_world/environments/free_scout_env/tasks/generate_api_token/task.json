{
  "id": "generate_api_token@1",
  "version": "1.0",
  "env_id": "free_scout_env@0.1",
  "description": "Generate a new API Token named 'MetricsDash' for the admin user (admin@helpdesk.local). Save the generated token string to /home/ga/metrics_token.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_api_token/setup_task.sh",
    "post_task": "/workspace/tasks/generate_api_token/export_result.sh"
  },
  "metadata": {
    "expected_token_name": "MetricsDash",
    "expected_file_path": "/home/ga/metrics_token.txt",
    "admin_email": "admin@helpdesk.local"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_api_token"
    }
  }
}
