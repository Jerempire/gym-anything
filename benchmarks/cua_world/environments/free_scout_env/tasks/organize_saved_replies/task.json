{
  "id": "organize_saved_replies@1",
  "version": "1.0",
  "env_id": "free_scout_env@0.1",
  "description": "Organize the 'Customer Support' mailbox's saved replies by creating a 'Billing' category, moving the 'Refund Template' reply into it, and renaming the reply to 'Standard Refund'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/organize_saved_replies/setup_task.sh",
    "post_task": "/workspace/tasks/organize_saved_replies/export_result.sh"
  },
  "metadata": {
    "mailbox_name": "Customer Support",
    "mailbox_email": "support@helpdesk.local",
    "target_category": "Billing",
    "original_reply_name": "Refund Template",
    "target_reply_name": "Standard Refund"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_organize_saved_replies"
    }
  }
}
