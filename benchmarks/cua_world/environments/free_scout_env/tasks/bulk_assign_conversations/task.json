{
  "id": "bulk_assign_conversations@1",
  "version": "1.0",
  "env_id": "free_scout_env@0.1",
  "description": "Assign all 5 unassigned conversations in the 'Technical Support' mailbox to the support agent 'Marcus Chen' without replying to or closing the tickets.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bulk_assign_conversations/setup_task.sh",
    "post_task": "/workspace/tasks/bulk_assign_conversations/export_result.sh"
  },
  "metadata": {
    "mailbox_name": "Technical Support",
    "assignee_name": "Marcus Chen",
    "assignee_email": "m.chen@helpdesk.local",
    "target_conversation_count": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bulk_assign_conversations"
    }
  }
}
