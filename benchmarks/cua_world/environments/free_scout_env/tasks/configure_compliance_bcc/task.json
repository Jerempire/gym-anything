{
  "id": "configure_compliance_bcc@1",
  "version": "1.0",
  "env_id": "free_scout_env@0.1",
  "description": "Configure the 'Billing Department' mailbox to automatically BCC all outgoing emails to the compliance archive address: 'audit-vault@acme-finance.com'. Ensure the existing SMTP configuration (Host: mail.acme-finance.com) remains intact. Do not modify any other mailboxes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_compliance_bcc/setup_task.sh",
    "post_task": "/workspace/tasks/configure_compliance_bcc/export_result.sh"
  },
  "metadata": {
    "target_mailbox_email": "billing@acme-finance.com",
    "target_mailbox_name": "Billing Department",
    "expected_bcc": "audit-vault@acme-finance.com",
    "expected_smtp_host": "mail.acme-finance.com",
    "expected_smtp_user": "billing@acme-finance.com",
    "decoy_mailbox_email": "support@acme-finance.com"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_compliance_bcc"
    }
  }
}
