{
  "id": "recover_and_purge_trash@1",
  "version": "1.0",
  "env_id": "free_scout_env@0.1",
  "description": "A critical conversation regarding a signed contract was accidentally deleted. Restore the conversation 'Signed Contract - Q3 2024' from the Trash folder to the active inbox and permanently empty the remaining items in the Trash.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/recover_and_purge_trash/setup_task.sh",
    "post_task": "/workspace/tasks/recover_and_purge_trash/export_result.sh"
  },
  "metadata": {
    "target_subject": "Signed Contract - Q3 2024",
    "junk_subjects": [
      "SEO Proposal",
      "You won!",
      "Undelivered Mail"
    ],
    "pass_threshold": 90
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_recover_and_purge_trash"
    }
  }
}
