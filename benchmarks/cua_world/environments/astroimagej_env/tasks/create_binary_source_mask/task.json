{
  "id": "create_binary_source_mask@1",
  "version": "1.0",
  "env_id": "astroimagej_env@0.1",
  "description": "Create a binary mask of the bright sources in ~/AstroImages/masking/hst_wfpc2_sample.fits. The mask must be processed with three iterations of the 'Dilate' morphological operation to expand the source borders. Save the resulting mask as a FITS file to ~/AstroImages/masking/source_mask.fits.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_binary_source_mask/setup_task.sh",
    "post_task": "/workspace/tasks/create_binary_source_mask/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/AstroImages/masking/source_mask.fits",
    "input_path": "/home/ga/AstroImages/masking/hst_wfpc2_sample.fits",
    "required_dilations": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_binary_source_mask"
    }
  }
}
