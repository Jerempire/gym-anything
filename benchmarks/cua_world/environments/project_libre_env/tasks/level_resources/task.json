{
  "id": "level_resources@1",
  "version": "1.0",
  "env_id": "project_libre_env@0.1",
  "description": "The 'Construction Retrofit Project' is currently loaded in ProjectLibre, but there are critical resource over-allocations for Alice Johnson and Emma Davis. Resolve these resource conflicts using resource leveling so that the schedule dates shift to accommodate their availability. Save the corrected project as an XML file to /home/ga/Projects/leveled_project.xml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/level_resources/setup_task.sh",
    "post_task": "/workspace/tasks/level_resources/export_result.sh"
  },
  "metadata": {
    "output_file": "/home/ga/Projects/leveled_project.xml",
    "original_file": "/home/ga/Projects/construction_retrofit.xml",
    "conflicts": [
      {
        "resource_name": "Alice Johnson",
        "task_uids": [
          3,
          4
        ]
      },
      {
        "resource_name": "Emma Davis",
        "task_uids": [
          8,
          9
        ]
      }
    ],
    "min_task_count": 12
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_level_resources"
    }
  }
}
