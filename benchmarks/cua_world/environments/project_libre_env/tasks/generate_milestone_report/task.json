{
  "id": "generate_milestone_report@1",
  "version": "1.0",
  "env_id": "project_libre_env@0.1",
  "description": "A Steering Committee meeting is approaching, and the executives need a high-level summary of the 'Enterprise Software Development Project'. Provide a view of the project showing only the milestones, hiding all detailed tasks. Export this filtered milestone view to '~/Projects/milestones.pdf'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_milestone_report/setup_task.sh",
    "post_task": "/workspace/tasks/generate_milestone_report/export_result.sh"
  },
  "metadata": {
    "project_file": "/home/ga/Projects/samples/sample_project.xml",
    "expected_output_path": "/home/ga/Projects/milestones.pdf",
    "required_text": [
      "Design Review Milestone",
      "Project Completion Milestone"
    ],
    "forbidden_text": [
      "Requirements Gathering",
      "Backend API Development",
      "System Architecture Design"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_milestone_report"
    }
  }
}
