{
  "id": "set_project_baseline@1",
  "version": "1.0",
  "env_id": "project_libre_env@0.1",
  "description": "Set the baseline for all tasks in the 'Enterprise Software Development Project' to capture the current schedule snapshot. Export the project as a Microsoft Project XML file to /home/ga/Projects/baseline_project.xml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/set_project_baseline/setup_task.sh",
    "post_task": "/workspace/tasks/set_project_baseline/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Projects/baseline_project.xml",
    "source_project_path": "/home/ga/Projects/enterprise_project.xml",
    "min_baseline_coverage_percent": 75,
    "min_tasks_count": 15
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_project_baseline"
    }
  }
}
