{
  "id": "generate_top_cost_tasks_report@1",
  "version": "1.0",
  "env_id": "project_libre_env@0.1",
  "description": "Generate a 'Top Cost Tasks' report for the Project Sponsor from the 'Enterprise Software Development Project'. Configure the Gantt Chart view to display only the Indicators, Name, Cost, and Percent Complete columns. Sort the tasks by Cost in descending order and export the resulting view to /home/ga/Desktop/top_cost_report.pdf.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_top_cost_tasks_report/setup_task.sh",
    "post_task": "/workspace/tasks/generate_top_cost_tasks_report/export_result.sh"
  },
  "metadata": {
    "expected_pdf_path": "/home/ga/Desktop/top_cost_report.pdf",
    "required_columns": [
      "Cost",
      "Name"
    ],
    "forbidden_columns": [
      "Start",
      "Finish",
      "Predecessors",
      "Duration"
    ],
    "sort_column": "Cost",
    "sort_direction": "descending"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_top_cost_tasks_report"
    }
  }
}
