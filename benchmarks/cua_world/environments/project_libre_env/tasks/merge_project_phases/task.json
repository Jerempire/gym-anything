{
  "id": "merge_project_phases@1",
  "version": "1.0",
  "env_id": "project_libre_env@0.1",
  "description": "Merge 'frontend_phase.xml' and 'backend_phase.xml' (from ~/Projects/phases/) into a single master schedule. The consolidated project must contain the Frontend tasks followed by the Backend tasks. Save the final project as 'full_release.xml' in ~/Projects/output/.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/merge_project_phases/setup_task.sh",
    "post_task": "/workspace/tasks/merge_project_phases/export_result.sh"
  },
  "metadata": {
    "frontend_file": "/home/ga/Projects/phases/frontend_phase.xml",
    "backend_file": "/home/ga/Projects/phases/backend_phase.xml",
    "output_file": "/home/ga/Projects/output/full_release.xml",
    "frontend_marker_task": "Login UI Component",
    "backend_marker_task": "Auth API Endpoint",
    "frontend_unique_resource": "UI Designer",
    "backend_unique_resource": "Backend Dev"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_merge_project_phases"
    }
  }
}
