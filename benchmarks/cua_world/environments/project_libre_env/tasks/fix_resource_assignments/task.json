{
  "id": "fix_resource_assignments@1",
  "version": "1.0",
  "env_id": "project_libre_env@0.1",
  "description": "A junior scheduler for a three-story office building construction project in ProjectLibre has accidentally reassigned several tasks to the wrong trade contractors. Review all resource assignments across the project and ensure each task is assigned to the contractor whose specialty matches the work scope described in the task name. Save the corrected project to /home/ga/Documents/office_building_project.pod.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 640,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/fix_resource_assignments/setup_task.sh"
  },
  "metadata": {
    "project_file": "/home/ga/Projects/current_task.xml",
    "injected_errors": [
      {
        "task_uid": 48,
        "task_name": "Erect steel columns, beams and joist - 1st and 2nd floors",
        "wrong_resource_uid": 9,
        "wrong_resource_name": "G.C. Labor Crew",
        "correct_resource_uid": 21,
        "correct_resource_name": "Steel Erection Contractor"
      },
      {
        "task_uid": 84,
        "task_name": "Install tile in toilet rooms",
        "wrong_resource_uid": 32,
        "wrong_resource_name": "Painting Contractor",
        "correct_resource_uid": 25,
        "correct_resource_name": "Tile Contractor"
      },
      {
        "task_uid": 90,
        "task_name": "Install seamless roofing material",
        "wrong_resource_uid": 29,
        "wrong_resource_name": "Carpet Contractor",
        "correct_resource_uid": 26,
        "correct_resource_name": "Roofing Contractor"
      },
      {
        "task_uid": 127,
        "task_name": "Set equipment in mechanical room",
        "wrong_resource_uid": 19,
        "wrong_resource_name": "Elevator Contractor",
        "correct_resource_uid": 17,
        "correct_resource_name": "HVAC Contractor"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_fix_resource_assignments"
    }
  }
}
