{
  "id": "auto_white_balance@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply automatic white balance correction to the photograph to fix color temperature issues.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/auto_white_balance/setup_white_balance_task.sh",
    "post_task": "/workspace/tasks/auto_white_balance/export_white_balance.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_auto_white_balance"
    }
  }
}
