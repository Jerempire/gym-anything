{
  "id": "motion_blur@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a horizontal motion blur effect to the action/sports image to simulate movement.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/motion_blur/setup_motion_blur.sh",
    "post_task": "/workspace/tasks/motion_blur/export_motion_blur.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_motion_blur"
    }
  }
}
