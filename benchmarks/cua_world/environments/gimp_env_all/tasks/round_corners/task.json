{
  "id": "round_corners@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a rounded corners effect to the image and export the result to /home/ga/Documents/output.png.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/round_corners/setup_corners_task.sh",
    "post_task": "/workspace/tasks/round_corners/export_corners.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_round_corners"
    }
  }
}
