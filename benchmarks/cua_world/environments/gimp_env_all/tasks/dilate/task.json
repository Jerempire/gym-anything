{
  "id": "dilate@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply the Dilate morphological filter to the image to expand bright regions.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/dilate/setup_dilate_task.sh",
    "post_task": "/workspace/tasks/dilate/export_dilate.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_dilate_effect"
    }
  }
}
