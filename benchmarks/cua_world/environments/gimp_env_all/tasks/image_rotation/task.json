{
  "id": "image_rotation@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Straighten the tilted landscape photo and export the result to /home/ga/Documents/straightened_landscape.png.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/image_rotation/setup_rotation_task.sh",
    "post_task": "/workspace/tasks/image_rotation/export_rotation.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_image_rotation"
    }
  }
}
