{
  "id": "despeckle@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Reduce noise in the speckled image using the Despeckle filter and save the result.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 7,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/despeckle/setup_despeckle.sh",
    "post_task": "/workspace/tasks/despeckle/export_despeckle.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_despeckle"
    }
  }
}
