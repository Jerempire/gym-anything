{
  "id": "pixelize@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Create a mosaic effect with uniform color blocks using the pixelize filter.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/pixelize/setup_pixelize_task.sh",
    "post_task": "/workspace/tasks/pixelize/export_pixelize.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_pixelize"
    }
  }
}
