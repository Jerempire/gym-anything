{
  "id": "color_sample@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Fill a rectangular selection with the color of the purple flower.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/color_sample/setup_sample_task.sh",
    "post_task": "/workspace/tasks/color_sample/export_sample.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_color_sampling"
    }
  }
}
