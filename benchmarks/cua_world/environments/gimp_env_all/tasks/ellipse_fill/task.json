{
  "id": "ellipse_fill@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Draw a red circle in the center of the image.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/ellipse_fill/setup_ellipse_task.sh",
    "post_task": "/workspace/tasks/ellipse_fill/export_ellipse.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_ellipse_fill"
    }
  }
}
