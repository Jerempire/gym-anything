{
  "id": "saturation_increase@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Increase the saturation of the image to make the colors more vibrant and vivid.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/saturation_increase/setup_saturation_task.sh",
    "post_task": "/workspace/tasks/saturation_increase/export_saturation.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_saturation_increase"
    }
  }
}
