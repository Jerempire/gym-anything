{
  "id": "grayscale_convert@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Convert the color image to grayscale mode.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/grayscale_convert/setup_grayscale_task.sh",
    "post_task": "/workspace/tasks/grayscale_convert/export_grayscale.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_grayscale_conversion"
    }
  }
}
