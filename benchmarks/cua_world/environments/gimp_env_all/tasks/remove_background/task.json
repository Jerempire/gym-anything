{
  "id": "remove_background@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Remove the white background from the image and save the result as a transparent PNG to /home/ga/Documents/output.png.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/remove_background/setup_background_task.sh",
    "post_task": "/workspace/tasks/remove_background/export_transparent.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_background_removal"
    }
  }
}
