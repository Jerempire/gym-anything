{
  "id": "draw_line@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Draw a straight red line on the canvas.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 7,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/draw_line/setup_line_task.sh",
    "post_task": "/workspace/tasks/draw_line/export_line.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_line_drawing"
    }
  }
}
