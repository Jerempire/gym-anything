{
  "id": "paintbrush_drawing@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Create visible brush strokes on a blank canvas.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/paintbrush_drawing/setup_painting_task.sh",
    "post_task": "/workspace/tasks/paintbrush_drawing/export_painting.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_paintbrush_drawing"
    }
  }
}
