{
  "id": "oilify@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Transform the photograph into an artistic oil painting and save the result to /home/ga/Documents/oil_painting.png.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/oilify/setup_oilify_task.sh",
    "post_task": "/workspace/tasks/oilify/export_oilify.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_oil_painting_effect"
    }
  }
}
