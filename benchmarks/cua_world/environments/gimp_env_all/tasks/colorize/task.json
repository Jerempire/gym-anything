{
  "id": "colorize@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Convert the image to a monochromatic sepia tone and save the result to /home/ga/Documents/output.png.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 6,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/colorize/setup_colorize_task.sh",
    "post_task": "/workspace/tasks/colorize/export_colorize.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_colorize"
    }
  }
}
