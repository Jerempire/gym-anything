{
  "id": "square_crop@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Crop the image to a 1:1 aspect ratio.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 6,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/square_crop/setup_square_task.sh",
    "post_task": "/workspace/tasks/square_crop/export_square.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_square_crop"
    }
  }
}
