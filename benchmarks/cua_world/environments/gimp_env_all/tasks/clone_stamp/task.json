{
  "id": "clone_stamp@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Remove the marked object from the image using the clone tool.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/clone_stamp/setup_clone_task.sh",
    "post_task": "/workspace/tasks/clone_stamp/export_clone.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_clone_stamp"
    }
  }
}
