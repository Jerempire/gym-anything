{
  "id": "threshold@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Convert the grayscale image to pure black-and-white and export the result to /home/ga/Documents/output.png.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/threshold/setup_threshold_task.sh",
    "post_task": "/workspace/tasks/threshold/export_threshold.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_threshold_conversion"
    }
  }
}
