{
  "id": "color_enhance@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Improve the color distribution and vibrancy of the photograph and save the result to /home/ga/Documents/enhanced_photo.png.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/color_enhance/setup_enhance_task.sh",
    "post_task": "/workspace/tasks/color_enhance/export_enhance.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_color_enhance"
    }
  }
}
