{
  "id": "hue_rotation@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Rotate all hues in the image by 60 degrees.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 7,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/hue_rotation/setup_hue_task.sh",
    "post_task": "/workspace/tasks/hue_rotation/export_hue.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_hue_rotation"
    }
  }
}
