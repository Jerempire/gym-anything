{
  "id": "soft_glow@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply GIMP's Soft Glow filter to create a dreamy, luminous effect on a portrait image",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/soft_glow/setup_softglow_task.sh",
    "post_task": "/workspace/tasks/soft_glow/export_softglow.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_soft_glow"
    }
  }
}
