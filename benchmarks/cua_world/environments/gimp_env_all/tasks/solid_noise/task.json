{
  "id": "solid_noise@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Generate a procedural noise texture using the Solid Noise filter.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 6,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/solid_noise/setup_noise_task.sh",
    "post_task": "/workspace/tasks/solid_noise/export_noise.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_solid_noise"
    }
  }
}
