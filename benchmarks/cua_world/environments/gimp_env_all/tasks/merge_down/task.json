{
  "id": "merge_down@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Merge the top layer with the layer immediately below it in the multi-layer composition.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/merge_down/setup_merge_task.sh",
    "post_task": "/workspace/tasks/merge_down/export_merge.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_merge_down"
    }
  }
}
