{
  "id": "sharpen_unsharp@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply the Unsharp Mask filter to the image to enhance detail and edge definition.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sharpen_unsharp/setup_sharpen_task.sh",
    "post_task": "/workspace/tasks/sharpen_unsharp/export_sharpen.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_sharpen_unsharp"
    }
  }
}
