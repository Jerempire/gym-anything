{
  "id": "feather_selection@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Demonstrate soft edge blending by creating a white rectangle with feathered edges.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/feather_selection/setup_feather_task.sh",
    "post_task": "/workspace/tasks/feather_selection/export_feather.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_feather_selection"
    }
  }
}
