{
  "id": "canvas_resize@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Expand the image canvas to 1000x800 pixels and center the original content.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/canvas_resize/setup_canvas_task.sh",
    "post_task": "/workspace/tasks/canvas_resize/export_canvas.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_canvas_resize"
    }
  }
}
