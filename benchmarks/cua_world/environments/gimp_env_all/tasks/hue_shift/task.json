{
  "id": "hue_shift@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a uniform hue shift to the entire image.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/hue_shift/setup_hue_task.sh",
    "post_task": "/workspace/tasks/hue_shift/export_hue.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_hue_shift"
    }
  }
}
