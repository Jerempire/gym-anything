{
  "id": "print_resolution@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Set the image print resolution to 300 DPI while maintaining the original pixel dimensions.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/print_resolution/setup_resolution_task.sh",
    "post_task": "/workspace/tasks/print_resolution/export_resolution.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_print_resolution"
    }
  }
}
