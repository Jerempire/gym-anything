{
  "id": "layer_offset@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Shift the texture content by applying a layer offset transformation with wrap-around.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/layer_offset/setup_offset_task.sh",
    "post_task": "/workspace/tasks/layer_offset/export_offset.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_layer_offset"
    }
  }
}
