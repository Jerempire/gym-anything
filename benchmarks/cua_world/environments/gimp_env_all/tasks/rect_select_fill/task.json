{
  "id": "rect_select_fill@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Add a red rectangular overlay to the center of the image.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rect_select_fill/setup_rect_task.sh",
    "post_task": "/workspace/tasks/rect_select_fill/export_rect.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_rectangle_fill"
    }
  }
}
