{
  "id": "border_stroke@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Add a border to the image.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 7,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/border_stroke/setup_border_task.sh",
    "post_task": "/workspace/tasks/border_stroke/export_border.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_border_stroke"
    }
  }
}
