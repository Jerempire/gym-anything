{
  "id": "add_border@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Add a colored border to the image.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_border/setup_border_task.sh",
    "post_task": "/workspace/tasks/add_border/export_border.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_border_added"
    }
  }
}
