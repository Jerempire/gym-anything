{
  "id": "autocrop@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Remove the uniform borders from the image.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 4,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/autocrop/setup_autocrop_task.sh",
    "post_task": "/workspace/tasks/autocrop/export_autocrop.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_autocrop"
    }
  }
}
