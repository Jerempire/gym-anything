{
  "id": "tile_seamless@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Create a seamlessly tileable texture from the image.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/tile_seamless/setup_tile_task.sh",
    "post_task": "/workspace/tasks/tile_seamless/export_seamless.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_tile_seamless"
    }
  }
}
