{
  "id": "desaturate_bw@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Convert the color image to black and white.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/desaturate_bw/setup_desaturate.sh",
    "post_task": "/workspace/tasks/desaturate_bw/export_desaturate.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_desaturate_bw"
    }
  }
}
