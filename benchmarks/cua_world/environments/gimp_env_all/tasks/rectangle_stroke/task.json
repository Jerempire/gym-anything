{
  "id": "rectangle_stroke@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Create a rectangular stroke outline on the image.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rectangle_stroke/setup_rectangle_task.sh",
    "post_task": "/workspace/tasks/rectangle_stroke/export_rectangle.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_rectangle_stroke"
    }
  }
}
