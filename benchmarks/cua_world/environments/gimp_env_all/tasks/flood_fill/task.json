{
  "id": "flood_fill@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Fill the white shape in the image with a bright color.",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/flood_fill/setup_flood_task.sh",
    "post_task": "/workspace/tasks/flood_fill/export_flood.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_flood_fill"
    }
  }
}
