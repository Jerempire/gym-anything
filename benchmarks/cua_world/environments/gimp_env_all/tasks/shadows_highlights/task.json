{
  "id": "shadows_highlights@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Brighten the shadows and improve the tonal balance of the underexposed image. Save the adjusted image to /home/ga/Documents/output.png.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 7,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/shadows_highlights/setup_shadows_task.sh",
    "post_task": "/workspace/tasks/shadows_highlights/export_shadows.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_shadows_highlights"
    }
  }
}
