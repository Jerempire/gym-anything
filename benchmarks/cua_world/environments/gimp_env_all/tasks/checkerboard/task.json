{
  "id": "checkerboard@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Create a checkerboard pattern in GIMP.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/checkerboard/setup_checkerboard_task.sh",
    "post_task": "/workspace/tasks/checkerboard/export_checkerboard.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_checkerboard_pattern"
    }
  }
}
