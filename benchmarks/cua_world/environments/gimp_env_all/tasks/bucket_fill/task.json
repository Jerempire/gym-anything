{
  "id": "bucket_fill@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Flood-fill a bounded area with bright red color.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bucket_fill/setup_bucket_task.sh",
    "post_task": "/workspace/tasks/bucket_fill/export_bucket.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_bucket_fill"
    }
  }
}
