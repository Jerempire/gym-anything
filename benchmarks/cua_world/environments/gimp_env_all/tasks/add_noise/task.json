{
  "id": "add_noise@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Add RGB noise to the image to create a film grain texture.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_noise/setup_noise_task.sh",
    "post_task": "/workspace/tasks/add_noise/export_noise.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_noise_addition"
    }
  }
}
