{
  "id": "noise_reduce@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply noise reduction to the grainy image using the despeckle filter and save the result.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 7,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/noise_reduce/setup_noise_task.sh",
    "post_task": "/workspace/tasks/noise_reduce/export_noise.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_noise_reduction"
    }
  }
}
