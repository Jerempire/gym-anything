{
  "id": "rotate_45@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Rotate the image by 45 degrees.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 6,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rotate_45/setup_rotate_task.sh",
    "post_task": "/workspace/tasks/rotate_45/export_rotate.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_45_rotation"
    }
  }
}
