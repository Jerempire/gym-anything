{
  "id": "indexed_color@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Convert the image to Indexed Color mode using a 16-color palette.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/indexed_color/setup_indexed_task.sh",
    "post_task": "/workspace/tasks/indexed_color/export_indexed.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_indexed_conversion"
    }
  }
}
