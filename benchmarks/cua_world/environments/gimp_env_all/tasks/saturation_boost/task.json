{
  "id": "saturation_boost@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Increase the saturation of the landscape image to make the colors more vibrant.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/saturation_boost/setup_saturation_task.sh",
    "post_task": "/workspace/tasks/saturation_boost/export_saturation.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_saturation_boost"
    }
  }
}
