{
  "id": "sharpen_details@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Sharpen the image details and enhance edge definition using the Unsharp Mask filter.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sharpen_details/setup_sharpen_task.sh",
    "post_task": "/workspace/tasks/sharpen_details/export_sharpen.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_image_sharpening"
    }
  }
}
