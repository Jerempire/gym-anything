{
  "id": "rectangle_clear@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Clear the top-left quarter of the image.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 6,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rectangle_clear/setup_rect_task.sh",
    "post_task": "/workspace/tasks/rectangle_clear/export_rect.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_rectangle_clear"
    }
  }
}
