{
  "id": "pixelate@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a pixelation filter to the image to create a mosaic or block effect.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 6,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/pixelate/setup_pixelate_task.sh",
    "post_task": "/workspace/tasks/pixelate/export_pixelate.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_pixelate_filter"
    }
  }
}
