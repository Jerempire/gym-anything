{
  "id": "ripple_effect@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a ripple distortion effect to the image to create wave patterns.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 6,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/ripple_effect/setup_ripple_task.sh",
    "post_task": "/workspace/tasks/ripple_effect/export_ripple.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_ripple_effect"
    }
  }
}
