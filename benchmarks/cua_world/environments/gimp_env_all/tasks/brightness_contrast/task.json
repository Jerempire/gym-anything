{
  "id": "brightness_contrast@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Improve the underexposed image in GIMP by adjusting its brightness and contrast.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/brightness_contrast/setup_brightness_task.sh",
    "post_task": "/workspace/tasks/brightness_contrast/export_brightness.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_brightness_contrast"
    }
  }
}
