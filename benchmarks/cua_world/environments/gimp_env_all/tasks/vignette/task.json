{
  "id": "vignette@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a vignette effect to the image to darken the edges while keeping the center bright.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/vignette/setup_vignette_task.sh",
    "post_task": "/workspace/tasks/vignette/export_vignette.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_vignette_effect"
    }
  }
}
