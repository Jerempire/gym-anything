{
  "id": "wind_effect@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a wind effect to the image to create directional motion streaks.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 6,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/wind_effect/setup_wind_task.sh",
    "post_task": "/workspace/tasks/wind_effect/export_wind.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_wind_effect"
    }
  }
}
