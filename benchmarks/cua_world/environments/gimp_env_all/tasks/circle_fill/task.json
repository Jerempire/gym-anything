{
  "id": "circle_fill@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Fill a centered circular area of the image with red.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 7,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/circle_fill/setup_circle_task.sh",
    "post_task": "/workspace/tasks/circle_fill/export_circle.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_circle_fill"
    }
  }
}
