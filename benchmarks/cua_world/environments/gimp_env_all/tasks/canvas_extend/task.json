{
  "id": "canvas_extend@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Increase the canvas dimensions by 200px in width and 150px in height, ensuring the original image remains centered.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/canvas_extend/setup_canvas_task.sh",
    "post_task": "/workspace/tasks/canvas_extend/export_canvas.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_canvas_extension"
    }
  }
}
