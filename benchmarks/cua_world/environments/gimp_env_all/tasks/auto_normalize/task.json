{
  "id": "auto_normalize@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Normalize the image contrast and tonal distribution.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/auto_normalize/setup_normalize_task.sh",
    "post_task": "/workspace/tasks/auto_normalize/export_normalize.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_auto_normalize"
    }
  }
}
