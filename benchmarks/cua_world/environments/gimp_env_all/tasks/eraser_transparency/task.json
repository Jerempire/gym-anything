{
  "id": "eraser_transparency@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Create transparent regions in the image and save the modified file to /home/ga/Documents/output.png.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/eraser_transparency/setup_eraser_task.sh",
    "post_task": "/workspace/tasks/eraser_transparency/export_erased.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_eraser_transparency"
    }
  }
}
