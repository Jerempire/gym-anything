{
  "id": "paintbrush_stroke@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Add a visible brushstroke to the image.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 7,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/paintbrush_stroke/setup_paintbrush_task.sh",
    "post_task": "/workspace/tasks/paintbrush_stroke/export_painted.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_paintbrush_stroke"
    }
  }
}
