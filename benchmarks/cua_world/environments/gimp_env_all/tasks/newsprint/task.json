{
  "id": "newsprint@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a newsprint halftone effect to the image to create a dot pattern characteristic of newspaper printing.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/newsprint/setup_newsprint_task.sh",
    "post_task": "/workspace/tasks/newsprint/export_newsprint.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_newsprint_effect"
    }
  }
}
