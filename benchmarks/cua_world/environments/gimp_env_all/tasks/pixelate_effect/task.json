{
  "id": "pixelate_effect@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a pixelate filter to the image to create a blocky, mosaic-style effect.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/pixelate_effect/setup_pixelate.sh",
    "post_task": "/workspace/tasks/pixelate_effect/export_pixelate.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_pixelate_effect"
    }
  }
}
