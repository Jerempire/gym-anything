{
  "id": "offset_wrap@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Shift the image content 100px horizontally and 80px vertically using an offset transformation with wrap-around.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/offset_wrap/setup_offset_task.sh",
    "post_task": "/workspace/tasks/offset_wrap/export_offset.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_offset_wrap"
    }
  }
}
