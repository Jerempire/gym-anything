{
  "id": "layer_duplicate@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Duplicate the active layer in GIMP to create a two-layer document.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/layer_duplicate/setup_layer_task.sh",
    "post_task": "/workspace/tasks/layer_duplicate/export_layers.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_layer_duplication"
    }
  }
}
