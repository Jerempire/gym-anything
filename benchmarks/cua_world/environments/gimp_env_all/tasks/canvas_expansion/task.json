{
  "id": "canvas_expansion@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Expand the canvas size by 100 pixels in both width and height while keeping the original image centered.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/canvas_expansion/setup_canvas_task.sh",
    "post_task": "/workspace/tasks/canvas_expansion/export_canvas.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_canvas_expansion"
    }
  }
}
