{
  "id": "offset_image@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Offset the image 150 pixels right and 100 pixels down using the wrap-around method.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 7,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/offset_image/setup_offset_task.sh",
    "post_task": "/workspace/tasks/offset_image/export_offset.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_image_offset"
    }
  }
}
