{
  "id": "border_add@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Add a white border around the image.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/border_add/setup_border_task.sh",
    "post_task": "/workspace/tasks/border_add/export_border.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_border_addition"
    }
  }
}
