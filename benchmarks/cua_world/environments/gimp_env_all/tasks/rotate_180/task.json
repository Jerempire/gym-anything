{
  "id": "rotate_180@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Rotate the image 180 degrees.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rotate_180/setup_rotate_task.sh",
    "post_task": "/workspace/tasks/rotate_180/export_rotate.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_rotate_180"
    }
  }
}
