{
  "id": "cubism_effect@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a cubism effect to the image.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/cubism_effect/setup_cubism_task.sh",
    "post_task": "/workspace/tasks/cubism_effect/export_cubism.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_cubism_effect"
    }
  }
}
