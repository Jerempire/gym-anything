{
  "id": "rounded_corners@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Add rounded corners to the rectangular image.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rounded_corners/setup_rounded_task.sh",
    "post_task": "/workspace/tasks/rounded_corners/export_rounded.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_rounded_corners"
    }
  }
}
