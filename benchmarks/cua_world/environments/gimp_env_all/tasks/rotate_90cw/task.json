{
  "id": "rotate_90cw@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Rotate the image 90 degrees clockwise.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rotate_90cw/setup_rotate_task.sh",
    "post_task": "/workspace/tasks/rotate_90cw/export_rotate.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_rotation_90cw"
    }
  }
}
