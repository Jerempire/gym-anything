{
  "id": "object_erase@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Remove the small object from the image and ensure the area is transparent.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/object_erase/setup_erase_task.sh",
    "post_task": "/workspace/tasks/object_erase/export_erase.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_object_erase"
    }
  }
}
