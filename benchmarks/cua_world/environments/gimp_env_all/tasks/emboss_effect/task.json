{
  "id": "emboss_effect@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply an emboss filter to the image to create a 3D raised relief effect.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 6,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/emboss_effect/setup_emboss_task.sh",
    "post_task": "/workspace/tasks/emboss_effect/export_emboss.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_emboss_effect"
    }
  }
}
