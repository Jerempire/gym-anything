{
  "id": "threshold_bw@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Convert the color image to pure black and white.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 6,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/threshold_bw/setup_threshold_task.sh",
    "post_task": "/workspace/tasks/threshold_bw/export_threshold.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_threshold_conversion"
    }
  }
}
