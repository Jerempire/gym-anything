{
  "id": "saturation_enhance@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Enhance the saturation and vibrancy of the nature image.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/saturation_enhance/setup_saturation_task.sh",
    "post_task": "/workspace/tasks/saturation_enhance/export_saturation.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_saturation_enhancement"
    }
  }
}
