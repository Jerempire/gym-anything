{
  "id": "sepia_tone@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Convert the color photograph to a vintage sepia tone.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sepia_tone/setup_sepia_task.sh",
    "post_task": "/workspace/tasks/sepia_tone/export_sepia.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_sepia_tone"
    }
  }
}
