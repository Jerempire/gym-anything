{
  "id": "sharpen_filter@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Enhance the image detail and edge definition using a sharpen filter.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sharpen_filter/setup_sharpen_task.sh",
    "post_task": "/workspace/tasks/sharpen_filter/export_sharpen.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_sharpen_filter"
    }
  }
}
