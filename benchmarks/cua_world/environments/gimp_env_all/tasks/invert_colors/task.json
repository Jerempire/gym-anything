{
  "id": "invert_colors@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Invert the colors of the image.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/invert_colors/setup_invert_task.sh",
    "post_task": "/workspace/tasks/invert_colors/export_invert.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_color_inversion"
    }
  }
}
