{
  "id": "lens_flare@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a lens flare lighting effect to the outdoor image.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/lens_flare/setup_flare_task.sh",
    "post_task": "/workspace/tasks/lens_flare/export_flare.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_lens_flare"
    }
  }
}
