{
  "id": "duplicate_layer@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Duplicate the current layer in GIMP to create two identical layers.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/duplicate_layer/setup_duplicate_task.sh",
    "post_task": "/workspace/tasks/duplicate_layer/export_xcf.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_layer_duplication"
    }
  }
}
