{
  "id": "color_temperature@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Adjust the color temperature of the image to create a warmer tone.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 6,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/color_temperature/setup_temperature_task.sh",
    "post_task": "/workspace/tasks/color_temperature/export_temperature.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_color_temperature"
    }
  }
}
