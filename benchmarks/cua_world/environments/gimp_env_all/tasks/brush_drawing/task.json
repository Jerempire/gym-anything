{
  "id": "brush_drawing@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Paint visible strokes on a blank canvas.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/brush_drawing/setup_brush_task.sh",
    "post_task": "/workspace/tasks/brush_drawing/export_brush.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_brush_drawing"
    }
  }
}
