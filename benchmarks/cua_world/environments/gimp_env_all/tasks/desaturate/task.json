{
  "id": "desaturate@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Convert the color image to grayscale.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/desaturate/setup_desaturate.sh",
    "post_task": "/workspace/tasks/desaturate/export_desaturate.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_desaturate"
    }
  }
}
