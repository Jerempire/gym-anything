{
  "id": "shear_horizontal@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a horizontal shear transformation to the image.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 7,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/shear_horizontal/setup_shear_task.sh",
    "post_task": "/workspace/tasks/shear_horizontal/export_shear.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_horizontal_shear"
    }
  }
}
