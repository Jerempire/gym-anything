{
  "id": "render_grid@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Add a grid overlay to the image.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 6,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/render_grid/setup_grid_task.sh",
    "post_task": "/workspace/tasks/render_grid/export_grid.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_grid_render"
    }
  }
}
