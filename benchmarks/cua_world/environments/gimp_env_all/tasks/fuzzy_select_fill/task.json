{
  "id": "fuzzy_select_fill@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Select the uniform background and fill it with light blue.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/fuzzy_select_fill/setup_fuzzy_task.sh",
    "post_task": "/workspace/tasks/fuzzy_select_fill/export_fuzzy.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_fuzzy_select_fill"
    }
  }
}
