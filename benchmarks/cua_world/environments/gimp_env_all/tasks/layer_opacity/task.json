{
  "id": "layer_opacity@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Set the active layer opacity to 65%.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/layer_opacity/setup_opacity_task.sh",
    "post_task": "/workspace/tasks/layer_opacity/export_opacity.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_layer_opacity"
    }
  }
}
