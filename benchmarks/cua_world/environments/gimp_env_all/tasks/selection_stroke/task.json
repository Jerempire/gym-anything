{
  "id": "selection_stroke@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply an 8-pixel red stroke outline to an elliptical selection around the flower.",
  "init": {
    "timeout_sec": 100,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/selection_stroke/setup_stroke_task.sh",
    "post_task": "/workspace/tasks/selection_stroke/export_stroke.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_selection_stroke"
    }
  }
}
