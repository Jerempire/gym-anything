{
  "id": "posterize@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a posterize effect to the image to reduce the color levels to 4, creating a poster-like appearance.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/posterize/setup_posterize_task.sh",
    "post_task": "/workspace/tasks/posterize/export_posterize.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_posterize_effect"
    }
  }
}
