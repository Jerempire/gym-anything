{
  "id": "partial_erase@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Create transparent regions in the image and save the result.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/partial_erase/setup_erase_task.sh",
    "post_task": "/workspace/tasks/partial_erase/export_erase.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_partial_erase"
    }
  }
}
