{
  "id": "neon_edges@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply neon edge detection to the image to create glowing edges on a dark background.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/neon_edges/setup_neon_task.sh",
    "post_task": "/workspace/tasks/neon_edges/export_neon.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_neon_effect"
    }
  }
}
