{
  "id": "grayscale_mode@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Convert the image from RGB mode to Grayscale mode in GIMP.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/grayscale_mode/setup_grayscale_task.sh",
    "post_task": "/workspace/tasks/grayscale_mode/export_grayscale.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_grayscale_mode"
    }
  }
}
