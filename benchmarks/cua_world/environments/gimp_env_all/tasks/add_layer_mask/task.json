{
  "id": "add_layer_mask@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Add a layer mask with white (full opacity) initialization to the current layer",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_layer_mask/setup_mask_task.sh",
    "post_task": "/workspace/tasks/add_layer_mask/export_mask.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_layer_mask"
    }
  }
}
