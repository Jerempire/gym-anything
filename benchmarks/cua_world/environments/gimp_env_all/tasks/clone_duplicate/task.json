{
  "id": "clone_duplicate@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Duplicate an element from one part of the image to another location.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/clone_duplicate/setup_clone_task.sh",
    "post_task": "/workspace/tasks/clone_duplicate/export_clone.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_clone_duplicate"
    }
  }
}
