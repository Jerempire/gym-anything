{
  "id": "emboss@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply an emboss effect to the color photograph to create a grayscale relief appearance.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/emboss/setup_emboss_task.sh",
    "post_task": "/workspace/tasks/emboss/export_emboss.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_emboss_effect"
    }
  }
}
