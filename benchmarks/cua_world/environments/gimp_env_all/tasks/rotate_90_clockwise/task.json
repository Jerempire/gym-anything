{
  "id": "rotate_90_clockwise@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Rotate the image 90 degrees clockwise.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rotate_90_clockwise/setup_rotation_task.sh",
    "post_task": "/workspace/tasks/rotate_90_clockwise/export_rotation.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_90_degree_rotation"
    }
  }
}
