{
  "id": "gradient_fill@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a horizontal gradient fill from left to right across the entire image",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/gradient_fill/setup_gradient_task.sh",
    "post_task": "/workspace/tasks/gradient_fill/export_gradient.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_gradient_fill"
    }
  }
}
