{
  "id": "contrast_adjust@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Increase the contrast of the image.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 6,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/contrast_adjust/setup_contrast_task.sh",
    "post_task": "/workspace/tasks/contrast_adjust/export_contrast.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_contrast_adjustment"
    }
  }
}
