{
  "id": "pattern_fill@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a pattern fill to a rectangular area in the upper-left of the image.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/pattern_fill/setup_pattern_task.sh",
    "post_task": "/workspace/tasks/pattern_fill/export_pattern.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_pattern_fill"
    }
  }
}
