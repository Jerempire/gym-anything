{
  "id": "threshold_effect@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Convert the image to high-contrast black and white using the threshold tool.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/threshold_effect/setup_threshold_task.sh",
    "post_task": "/workspace/tasks/threshold_effect/export_threshold.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_threshold_effect"
    }
  }
}
