{
  "id": "scale_image@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Scale the image to 600x400 pixels.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/scale_image/setup_scale_task.sh",
    "post_task": "/workspace/tasks/scale_image/export_scale.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_scale_image"
    }
  }
}
