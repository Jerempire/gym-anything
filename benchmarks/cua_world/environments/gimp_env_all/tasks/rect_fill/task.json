{
  "id": "rect_fill@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Fill a rectangular selection in the center of the image with blue.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rect_fill/setup_rect_task.sh",
    "post_task": "/workspace/tasks/rect_fill/export_rect.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_rect_fill"
    }
  }
}
