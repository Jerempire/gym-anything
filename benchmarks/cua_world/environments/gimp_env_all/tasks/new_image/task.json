{
  "id": "new_image@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Create a new blank image with dimensions 640x480 pixels and white background",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/new_image/setup_new_task.sh",
    "post_task": "/workspace/tasks/new_image/export_new_image.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_new_image"
    }
  }
}
