{
  "id": "scale_to_width@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Scale the image to a width of 800 pixels while maintaining the aspect ratio.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 6,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/scale_to_width/setup_scale_task.sh",
    "post_task": "/workspace/tasks/scale_to_width/export_scale.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_scale_to_width"
    }
  }
}
