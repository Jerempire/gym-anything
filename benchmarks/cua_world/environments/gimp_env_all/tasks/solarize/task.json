{
  "id": "solarize@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a photo-solarization effect to the image.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 3,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/solarize/setup_solarize_task.sh",
    "post_task": "/workspace/tasks/solarize/export_solarize.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_solarize"
    }
  }
}
