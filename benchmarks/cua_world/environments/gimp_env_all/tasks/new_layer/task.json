{
  "id": "new_layer@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Create a new white layer named 'Overlay Layer' in GIMP.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 7,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/new_layer/setup_layer_task.sh",
    "post_task": "/workspace/tasks/new_layer/export_layer.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_new_layer"
    }
  }
}
