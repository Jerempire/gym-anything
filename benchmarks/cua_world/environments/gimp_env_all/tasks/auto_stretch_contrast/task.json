{
  "id": "auto_stretch_contrast@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Improve the tonal range and contrast of the flat, low-contrast image.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/auto_stretch_contrast/setup_contrast_task.sh",
    "post_task": "/workspace/tasks/auto_stretch_contrast/export_contrast.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_auto_stretch_contrast"
    }
  }
}
