{
  "id": "scale_by_percentage@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Scale the image to 50% of its original size while maintaining the aspect ratio. Save the result to /home/ga/Documents/scaled_image.png.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/scale_by_percentage/setup_scale_task.sh",
    "post_task": "/workspace/tasks/scale_by_percentage/export_scale.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_percentage_scaling"
    }
  }
}
