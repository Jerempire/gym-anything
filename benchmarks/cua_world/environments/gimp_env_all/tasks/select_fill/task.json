{
  "id": "select_fill@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Create a red rectangle in the upper-left area.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/select_fill/setup_select_task.sh",
    "post_task": "/workspace/tasks/select_fill/export_select.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_rectangle_selection_fill"
    }
  }
}
