{
  "id": "edge_detect@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply an edge detection filter to the image to highlight boundaries and create a sketch-like effect.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 7,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/edge_detect/setup_edge_task.sh",
    "post_task": "/workspace/tasks/edge_detect/export_edge.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_edge_detection"
    }
  }
}
