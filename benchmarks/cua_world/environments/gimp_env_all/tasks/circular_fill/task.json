{
  "id": "circular_fill@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Create a circular selection in the center of the image and fill it with a bright color. Save the result to /home/ga/Documents/output.png.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/circular_fill/setup_circle_task.sh",
    "post_task": "/workspace/tasks/circular_fill/export_circle.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_circular_fill"
    }
  }
}
