{
  "id": "levels_adjust@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Brighten the underexposed image.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/levels_adjust/setup_levels_task.sh",
    "post_task": "/workspace/tasks/levels_adjust/export_levels.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_levels_adjustment"
    }
  }
}
