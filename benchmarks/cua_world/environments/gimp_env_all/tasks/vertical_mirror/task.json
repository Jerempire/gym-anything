{
  "id": "vertical_mirror@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Flip the flower image vertically.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/vertical_mirror/setup_vertical_task.sh",
    "post_task": "/workspace/tasks/vertical_mirror/export_vertical.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_vertical_mirror"
    }
  }
}
