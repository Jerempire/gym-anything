{
  "id": "cartoon@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Transform the photograph into a cartoon-style illustration using the cartoon filter in GIMP and export the result to /home/ga/Pictures/cartoon_output.png.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/cartoon/setup_cartoon_task.sh",
    "post_task": "/workspace/tasks/cartoon/export_cartoon.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_cartoon_effect"
    }
  }
}
