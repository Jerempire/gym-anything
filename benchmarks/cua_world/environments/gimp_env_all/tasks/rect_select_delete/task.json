{
  "id": "rect_select_delete@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Delete a rectangular area in the upper-right portion of the image.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rect_select_delete/setup_rect_task.sh",
    "post_task": "/workspace/tasks/rect_select_delete/export_rect.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_rect_deletion"
    }
  }
}
