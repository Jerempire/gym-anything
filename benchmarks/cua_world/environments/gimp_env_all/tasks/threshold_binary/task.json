{
  "id": "threshold_binary@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Convert the image to pure black and white and save the result to /home/ga/Documents/output.png.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 7,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/threshold_binary/setup_threshold_task.sh",
    "post_task": "/workspace/tasks/threshold_binary/export_threshold.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_threshold_binary"
    }
  }
}
