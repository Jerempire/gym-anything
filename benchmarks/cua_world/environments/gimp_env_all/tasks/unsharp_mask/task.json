{
  "id": "unsharp_mask@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Enhance the image sharpness using the Unsharp Mask filter with appropriate parameters.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/unsharp_mask/setup_unsharp_task.sh",
    "post_task": "/workspace/tasks/unsharp_mask/export_unsharp.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_unsharp_mask"
    }
  }
}
