{
  "id": "brightness_adjust@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Adjust the brightness of the underexposed image to improve visibility and tonal balance.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/brightness_adjust/setup_brightness_task.sh",
    "post_task": "/workspace/tasks/brightness_adjust/export_brightness.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_brightness_adjustment"
    }
  }
}
