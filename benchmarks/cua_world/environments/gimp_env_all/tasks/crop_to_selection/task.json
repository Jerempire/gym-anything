{
  "id": "crop_to_selection@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Crop the image to a rectangular region.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 7,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/crop_to_selection/setup_crop_selection_task.sh",
    "post_task": "/workspace/tasks/crop_to_selection/export_crop_selection.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_crop_to_selection"
    }
  }
}
