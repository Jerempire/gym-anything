{
  "id": "autocrop_image@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Automatically remove the borders and whitespace from the image.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/autocrop_image/setup_autocrop_task.sh",
    "post_task": "/workspace/tasks/autocrop_image/export_autocrop.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_autocrop_image"
    }
  }
}
