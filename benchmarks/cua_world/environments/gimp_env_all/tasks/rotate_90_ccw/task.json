{
  "id": "rotate_90_ccw@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Rotate the image 90 degrees counter-clockwise.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rotate_90_ccw/setup_rotate_task.sh",
    "post_task": "/workspace/tasks/rotate_90_ccw/export_rotate.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_rotation_ccw"
    }
  }
}
