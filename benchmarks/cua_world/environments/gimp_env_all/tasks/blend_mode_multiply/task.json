{
  "id": "blend_mode_multiply@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Set the top layer's blend mode to Multiply to darken the underlying image.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/blend_mode_multiply/setup_blend_task.sh",
    "post_task": "/workspace/tasks/blend_mode_multiply/export_blend.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_blend_mode_multiply"
    }
  }
}
