{
  "id": "desaturate_grayscale@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Convert the image to grayscale.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/desaturate_grayscale/setup_desaturate_task.sh",
    "post_task": "/workspace/tasks/desaturate_grayscale/export_grayscale.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_desaturate_grayscale"
    }
  }
}
