{
  "id": "rgb_noise@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Add RGB noise to the image using GIMP and save the result to /home/ga/Documents/noisy_image.png.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rgb_noise/setup_noise_task.sh",
    "post_task": "/workspace/tasks/rgb_noise/export_noise.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_rgb_noise"
    }
  }
}
