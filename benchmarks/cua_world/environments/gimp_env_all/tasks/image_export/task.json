{
  "id": "image_export@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Export the image as a PNG to /home/ga/Documents/output.png.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/image_export/setup_export_task.sh",
    "post_task": "/workspace/tasks/image_export/finalize_export.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_image_export"
    }
  }
}
