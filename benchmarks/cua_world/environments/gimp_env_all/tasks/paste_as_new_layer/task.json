{
  "id": "paste_as_new_layer@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Create a new layer in the image by copying a selected region.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/paste_as_new_layer/setup_paste_task.sh",
    "post_task": "/workspace/tasks/paste_as_new_layer/export_paste.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_paste_as_new_layer"
    }
  }
}
