{
  "id": "color_to_alpha@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Remove the white background from the image to create transparency. Export the result to /home/ga/Documents/output.png.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/color_to_alpha/setup_alpha_task.sh",
    "post_task": "/workspace/tasks/color_to_alpha/export_alpha.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_color_to_alpha"
    }
  }
}
