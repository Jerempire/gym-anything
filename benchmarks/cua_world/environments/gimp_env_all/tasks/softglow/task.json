{
  "id": "softglow@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply the Soft Glow filter to the image to create a dreamy, luminous effect.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/softglow/setup_softglow.sh",
    "post_task": "/workspace/tasks/softglow/export_softglow.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_softglow_effect"
    }
  }
}
