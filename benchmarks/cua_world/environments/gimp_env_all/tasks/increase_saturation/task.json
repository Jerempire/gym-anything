{
  "id": "increase_saturation@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Increase the color saturation of the image.",
  "init": {
    "timeout_sec": 60,
    "max_steps": 5,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/increase_saturation/setup_saturation.sh",
    "post_task": "/workspace/tasks/increase_saturation/export_saturation.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_saturation_increase"
    }
  }
}
