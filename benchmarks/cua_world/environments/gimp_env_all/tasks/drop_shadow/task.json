{
  "id": "drop_shadow@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Apply a drop shadow effect to the text or graphics.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/drop_shadow/setup_shadow_task.sh",
    "post_task": "/workspace/tasks/drop_shadow/export_shadow.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_drop_shadow"
    }
  }
}
