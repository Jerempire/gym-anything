{
  "id": "auto_levels@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Improve the image exposure and contrast using the auto levels enhancement.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/auto_levels/setup_levels_task.sh",
    "post_task": "/workspace/tasks/auto_levels/export_levels.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_auto_levels"
    }
  }
}
