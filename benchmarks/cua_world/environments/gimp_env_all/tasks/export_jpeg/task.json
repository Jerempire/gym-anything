{
  "id": "export_jpeg@1",
  "version": "1.0",
  "env_id": "example.gimp_env@0.1",
  "description": "Export the PNG image as a JPEG optimized for web use.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 8,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_jpeg/setup_export_task.sh",
    "post_task": "/workspace/tasks/export_jpeg/export_finalize.sh"
  },
  "success": {
    "spec": {
      "program": "verifier.py::check_jpeg_export"
    }
  }
}
