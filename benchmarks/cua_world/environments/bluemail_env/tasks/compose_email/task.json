{
  "id": "compose_email@1",
  "version": "1.0",
  "env_id": "bluemail_env@0.1",
  "description": "Compose an email in BlueMail to 'marketing@example.com' with the subject 'Monthly Report Summary - January 2024'. The message should professionally summarize monthly sales figures, marketing campaign results, and upcoming initiatives. Send the email or save it as a draft.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/compose_email/setup_task.sh",
    "post_task": "/workspace/tasks/compose_email/export_result.sh"
  },
  "metadata": {
    "expected_recipient": "marketing@example.com",
    "expected_subject": "Monthly Report Summary - January 2024",
    "expected_body_keywords": [
      "sales",
      "marketing",
      "campaign"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_compose_email"
    }
  }
}
