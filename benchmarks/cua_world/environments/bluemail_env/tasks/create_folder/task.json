{
  "id": "create_folder@1",
  "version": "1.0",
  "env_id": "bluemail_env@0.1",
  "description": "Organize your BlueMail inbox by creating a folder named 'Important' and moving at least two emails from your inbox into it.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 35,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_folder/setup_task.sh",
    "post_task": "/workspace/tasks/create_folder/export_result.sh"
  },
  "metadata": {
    "expected_folder_name": "Important",
    "expected_min_emails_moved": 2
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_folder"
    }
  }
}
