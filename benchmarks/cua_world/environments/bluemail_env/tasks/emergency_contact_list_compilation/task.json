{
  "id": "emergency_contact_list_compilation@1",
  "version": "1.0",
  "env_id": "bluemail_env@0.1",
  "description": "A severe storm is forecast and you need to create an offline contact list. Create an email draft addressed to 'emergency-contacts@internal.org' with the subject 'Emergency Phone List' containing the names and phone numbers of at least 3 distinct colleagues found in your inbox email signatures.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/emergency_contact_list_compilation/setup_task.sh",
    "post_task": "/workspace/tasks/emergency_contact_list_compilation/export_result.sh"
  },
  "metadata": {
    "target_recipient": "emergency-contacts@internal.org",
    "required_subject_keywords": [
      "emergency",
      "phone",
      "contact",
      "list"
    ],
    "min_contacts_required": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_emergency_contact_list"
    }
  }
}
