{
  "id": "reply_and_forward@1",
  "version": "1.0",
  "env_id": "bluemail_env@0.1",
  "description": "Locate the email regarding 'razor' (case-insensitive) in the inbox. Reply to the sender with the phrase 'received your message' and forward the email to 'dev-team@consultancy.com' with a note to 'review' the thread. Emails may be sent or saved as drafts.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/reply_and_forward/setup_task.sh",
    "post_task": "/workspace/tasks/reply_and_forward/export_result.sh"
  },
  "metadata": {
    "target_keyword": "razor",
    "forward_recipient": "dev-team@consultancy.com",
    "reply_required_phrase": "received your message",
    "forward_required_phrase": "review"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reply_and_forward"
    }
  }
}
