{
  "id": "search_email@1",
  "version": "1.0",
  "env_id": "bluemail_env@0.1",
  "description": "Locate and open an email containing the keyword 'Sequences Window' in the BlueMail inbox.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 150,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/search_email/setup_task.sh",
    "post_task": "/workspace/tasks/search_email/export_result.sh"
  },
  "metadata": {
    "search_keyword": "Sequences Window",
    "expected_min_results": 1
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_search_email"
    }
  }
}
