{
  "id": "professional_signature_and_introduction@1",
  "version": "1.0",
  "env_id": "bluemail_env@0.1",
  "description": "Configure a professional email signature in BlueMail for Alex Morgan, Marketing Coordinator at TechVision Inc. (Phone: +1 (555) 234-5678). Send an email to marketing-team@techvision.com with a subject containing 'Introduction' and ensure the signature is included in the message.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/professional_signature_and_introduction/setup_task.sh",
    "post_task": "/workspace/tasks/professional_signature_and_introduction/export_result.sh"
  },
  "metadata": {
    "required_signature": {
      "name": "Alex Morgan",
      "title": "Marketing Coordinator",
      "company": "TechVision Inc.",
      "phone": "+1 (555) 234-5678"
    },
    "required_email": {
      "recipient": "marketing-team@techvision.com",
      "subject_keyword": "introduction"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_professional_signature_and_introduction"
    }
  }
}
