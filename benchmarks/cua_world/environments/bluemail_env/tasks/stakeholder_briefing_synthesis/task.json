{
  "id": "stakeholder_briefing_synthesis@1",
  "version": "1.0",
  "env_id": "bluemail_env@0.1",
  "description": "You are an Engineering Manager with 50 unread emails from technical mailing lists (SAdev, ILUG, IRR, etc.). Synthesize this information into briefings for your stakeholders. Compose and send briefing emails to engineering-lead@techcorp.com (summarizing development, code, and tooling), infrastructure-lead@techcorp.com (summarizing systems, linux, and networking), and compliance-officer@techcorp.com (summarizing security, spam, and abuse). Each email must include 'Briefing' or 'Report' in the subject line. Additionally, create a consolidated text file with a structured summary of all three areas at ~/Documents/weekly_briefing.txt.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/stakeholder_briefing_synthesis/setup_task.sh",
    "post_task": "/workspace/tasks/stakeholder_briefing_synthesis/export_result.sh"
  },
  "metadata": {
    "recipients": {
      "engineering": "engineering-lead@techcorp.com",
      "infrastructure": "infrastructure-lead@techcorp.com",
      "compliance": "compliance-officer@techcorp.com"
    },
    "required_subject_keywords": [
      "briefing",
      "summary",
      "update",
      "weekly",
      "report"
    ],
    "keywords": {
      "engineering": [
        "code",
        "patch",
        "bug",
        "release",
        "dev",
        "build",
        "test",
        "api",
        "module",
        "commit",
        "perl",
        "java",
        "python"
      ],
      "infrastructure": [
        "linux",
        "server",
        "network",
        "route",
        "system",
        "kernel",
        "dns",
        "config",
        "host",
        "admin",
        "ip",
        "routing"
      ],
      "compliance": [
        "spam",
        "security",
        "filter",
        "abuse",
        "block",
        "phish",
        "policy",
        "rule",
        "scan",
        "threat",
        "black list",
        "whitelist"
      ]
    },
    "briefing_file_path": "/home/ga/Documents/weekly_briefing.txt"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_stakeholder_briefing"
    }
  }
}
