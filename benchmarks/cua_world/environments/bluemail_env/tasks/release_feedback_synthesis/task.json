{
  "id": "release_feedback_synthesis@1",
  "version": "1.0",
  "env_id": "bluemail_env@0.1",
  "description": "Synthesize community feedback regarding software releases by identifying and starring at least three relevant emails in your inbox. Create a draft email to 'product-team@company.com' with the subject 'Community Release Feedback' that lists the exact subject lines of the three starred emails.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/release_feedback_synthesis/setup_task.sh",
    "post_task": "/workspace/tasks/release_feedback_synthesis/export_result.sh"
  },
  "metadata": {
    "target_keywords": [
      "release",
      "version",
      "v2",
      "announce",
      "candidate",
      "build"
    ],
    "min_flagged_count": 3,
    "recipient": "product-team@company.com",
    "draft_subject_keywords": [
      "release",
      "feedback"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_release_feedback_synthesis"
    }
  }
}
