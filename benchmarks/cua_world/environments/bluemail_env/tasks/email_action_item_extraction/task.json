{
  "id": "email_action_item_extraction@1",
  "version": "1.0",
  "env_id": "bluemail_env@0.1",
  "description": "Identify actionable emails (requests, bugs, deadlines, or tasks) in your inbox. Organize at least 5 of these emails into a new folder named 'Action-Required'. Send an email to ga@example.com with the subject 'Action Items' containing a bulleted or numbered list of at least 3 specific tasks derived from the identified emails.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/email_action_item_extraction/setup_task.sh",
    "post_task": "/workspace/tasks/email_action_item_extraction/export_result.sh"
  },
  "metadata": {
    "target_folder": "Action-Required",
    "min_emails_to_move": 5,
    "summary_recipient": "ga@example.com",
    "subject_keywords": [
      "action",
      "todo",
      "to-do",
      "tasks",
      "follow-up"
    ],
    "action_patterns": [
      "please",
      "can you",
      "could you",
      "need to",
      "needs to",
      "todo",
      "to-do",
      "fix",
      "test this",
      "review",
      "patch",
      "update",
      "deadline",
      "asap",
      "action required",
      "volunteer",
      "help needed",
      "respond",
      "reply",
      "submit",
      "send me",
      "let me know",
      "by friday",
      "by monday",
      "urgent",
      "request",
      "asking",
      "would you",
      "should we",
      "must be",
      "assigned"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_email_action_item_extraction"
    }
  }
}
