{
  "id": "threat_intelligence_campaign_sorting@1",
  "version": "1.0",
  "env_id": "bluemail_env@0.1",
  "description": "As a Threat Intelligence Analyst, triage the spam in the Junk folder by categorizing emails into specific campaign folders. Create a folder named 'Threat-Financial' and move at least five financial fraud emails (e.g., scams, fake bank alerts) into it. Create another folder named 'Threat-Commercial' and move at least five commercial spam emails (e.g., advertisements, newsletters) into it. Draft an email to intel-team@security-corp.com with the subject 'Weekly Fraud Report' containing the subject lines of the identified financial fraud emails in the body. Categorize the emails based on their content.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/threat_intelligence_campaign_sorting/setup_task.sh",
    "post_task": "/workspace/tasks/threat_intelligence_campaign_sorting/export_result.sh"
  },
  "metadata": {
    "financial_folder": "Threat-Financial",
    "commercial_folder": "Threat-Commercial",
    "report_recipient": "intel-team@security-corp.com",
    "report_subject_keyword": "Fraud Report",
    "min_samples_per_folder": 5,
    "financial_keywords": [
      "fund",
      "transfer",
      "bank",
      "account",
      "inheritance",
      "lottery",
      "winner",
      "million",
      "dollar",
      "urgent",
      "confidential",
      "kin",
      "business proposal",
      "transaction",
      "beneficiary",
      "atm",
      "payment",
      "wire"
    ],
    "commercial_keywords": [
      "pill",
      "viagra",
      "cialis",
      "medication",
      "pharmacy",
      "drug",
      "replica",
      "watch",
      "rolex",
      "software",
      "dvd",
      "adobe",
      "microsoft",
      "offer",
      "discount",
      "click",
      "unsubscribe",
      "marketing",
      "newsletter",
      "deal"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_threat_sorting"
    }
  }
}
