{
  "id": "phishing_training_prep@1",
  "version": "1.0",
  "env_id": "bluemail_env@0.1",
  "description": "You are an IT Security Trainer preparing for a phishing awareness session. Curate at least five distinct real-world phishing examples from the Junk folder into a new folder named 'Training-Examples'. Compose an email to 'all-staff@company.com' with the subject 'Upcoming Phishing Awareness Training' describing at least three specific phishing techniques observed in those examples.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 900,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/phishing_training_prep/setup_task.sh",
    "post_task": "/workspace/tasks/phishing_training_prep/export_result.sh"
  },
  "metadata": {
    "target_folder": "Training-Examples",
    "min_examples": 5,
    "recipient": "all-staff@company.com",
    "required_technique_categories": 3,
    "technique_keywords": {
      "deception": [
        "phishing",
        "impersonat",
        "spoof",
        "fake",
        "forg",
        "suspicious sender"
      ],
      "urgency": [
        "urgent",
        "prize",
        "winner",
        "congratulat",
        "million",
        "lottery",
        "free",
        "offer",
        "act now",
        "immediate"
      ],
      "commercial": [
        "pharma",
        "medication",
        "viagra",
        "pill",
        "supplement",
        "discount",
        "cheap",
        "buy"
      ],
      "financial": [
        "money",
        "transfer",
        "bank",
        "account",
        "invest",
        "nigeria",
        "wire",
        "fund"
      ],
      "technical": [
        "link",
        "click",
        "html",
        "header",
        "subject line",
        "reply-to",
        "attachment"
      ]
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_phishing_training_prep"
    }
  }
}
