{
  "id": "create_custom_user_status@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Log in to Rocket.Chat (Username: admin, Password: Admin1234!) and create a new Custom User Status to indicate when engineers are busy deploying code. The status must be named 'Deploying' with a 'Busy' presence type and the status text 'Executing critical release deployment'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 45,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_custom_user_status/setup_task.sh",
    "post_task": "/workspace/tasks/create_custom_user_status/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_name": "Deploying",
    "expected_type": "busy",
    "expected_message": "Executing critical release deployment"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_custom_user_status"
    }
  }
}
