{
  "id": "upload_release_summary@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "You are a Software Developer managing a Rocket.Chat deployment. Log in to Rocket.Chat at http://localhost:3000 using the username 'admin' and password 'Admin1234!'. Upload the file /home/ga/Documents/release_summary.csv to the 'release-updates' channel. Include the message 'Release summary for team review - contains recent RC release dates and versions' with the file attachment.",
  "difficulty": "medium",
  "occupation": "Software Developers",
  "industry": "Computer and Mathematical",
  "tags": [
    "rocket.chat",
    "file-upload",
    "channel-interaction",
    "web-ui"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/upload_release_summary/setup_task.sh",
    "post_task": "/workspace/tasks/upload_release_summary/export_result.sh"
  },
  "metadata": {
    "target_channel": "release-updates",
    "target_filename": "release_summary.csv",
    "required_text_phrases": [
      "release summary",
      "team review",
      "release dates",
      "versions"
    ],
    "admin_username": "admin",
    "admin_password": "Admin1234!"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_upload_release_summary"
    }
  }
}
