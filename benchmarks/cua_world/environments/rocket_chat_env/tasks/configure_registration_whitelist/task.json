{
  "id": "configure_registration_whitelist@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Log in to Rocket.Chat using the credentials admin / Admin1234!. Secure the workspace by configuring the account settings to set the Registration Form to 'Public', restrict the Allowed Domains List to 'rocketchat.local', and disable both 'Allow User Profile Change' and 'Allow Name Change'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 45,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_registration_whitelist/setup_task.sh",
    "post_task": "/workspace/tasks/configure_registration_whitelist/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_registration_form": "Public",
    "expected_allowed_domains": "rocketchat.local",
    "expected_allow_profile_change": false,
    "expected_allow_name_change": false
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_registration_whitelist"
    }
  }
}
