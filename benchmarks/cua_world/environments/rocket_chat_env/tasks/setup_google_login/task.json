{
  "id": "setup_google_login@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Configure the Rocket.Chat workspace to allow users to log in with their Google accounts. Use the administrator credentials (Username: admin, Password: Admin1234!) to enable the Google OAuth provider with Client ID '49204819204-novatech.apps.googleusercontent.com' and Client Secret 'GOCSPX-NovaTechSecretKey2026'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/setup_google_login/setup_task.sh",
    "post_task": "/workspace/tasks/setup_google_login/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_setting_enable": "Accounts_OAuth_Google",
    "target_setting_id": "Accounts_OAuth_Google_id",
    "target_setting_secret": "Accounts_OAuth_Google_secret",
    "expected_id_value": "49204819204-novatech.apps.googleusercontent.com",
    "expected_secret_value": "GOCSPX-NovaTechSecretKey2026"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_setup_google_login"
    }
  }
}
