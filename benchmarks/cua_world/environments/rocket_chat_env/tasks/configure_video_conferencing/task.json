{
  "id": "configure_video_conferencing@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Log in to Rocket.Chat (Username: admin, Password: Admin1234!) and configure the Jitsi video conference integration. Set the domain to meet.secure-internal.example.com, enable 'Open New Window' and 'Enable in Channels', and disable 'Enable in Direct Messages'. Ensure all changes are saved.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_video_conferencing/setup_task.sh",
    "post_task": "/workspace/tasks/configure_video_conferencing/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_settings": {
      "Jitsi_Enabled": "true",
      "Jitsi_Domain": "meet.secure-internal.example.com",
      "Jitsi_Open_New_Window": "true",
      "Jitsi_Enable_Channels": "true",
      "Jitsi_Enable_Direct_Messages": "false"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_video_conferencing"
    }
  }
}
