{
  "id": "configure_custom_notification_sound@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Rocket.Chat is open at the login screen. Log in with username 'admin' and password 'Admin1234!'. Create a custom sound named 'release_ping' using the audio file at /home/ga/release_ping.wav. Configure the #release-updates channel to use the 'release_ping' sound for its notifications.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_custom_notification_sound/setup_task.sh",
    "post_task": "/workspace/tasks/configure_custom_notification_sound/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_channel": "release-updates",
    "target_sound_name": "release_ping",
    "target_sound_path": "/home/ga/release_ping.wav"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_custom_notification_sound"
    }
  }
}
