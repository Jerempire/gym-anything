{
  "id": "configure_api_rate_limiter@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "You are a Systems Administrator for a Rocket.Chat instance. Harden the security by enabling the API Rate Limiter and setting the 'Default Number of Requests' to exactly 20.\n\nLog in with:\n- Username: admin\n- Password: Admin1234!",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_api_rate_limiter/setup_task.sh",
    "post_task": "/workspace/tasks/configure_api_rate_limiter/export_result.sh"
  },
  "metadata": {
    "target_setting_enable": "API_Enable_Rate_Limiter",
    "target_setting_count": "API_Default_Count",
    "expected_count_value": 20,
    "admin_user": "admin",
    "admin_pass": "Admin1234!"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_api_rate_limiter"
    }
  }
}
