{
  "id": "react_to_release_messages@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Log in to Rocket.Chat (Username: admin, Password: Admin1234!). In the #release-updates channel, add a ✅ (:white_check_mark:) reaction to the oldest announcement message and a 👀 (:eyes:) reaction to the newest announcement message.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 45,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/react_to_release_messages/setup_task.sh",
    "post_task": "/workspace/tasks/react_to_release_messages/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "oldest_emoji": ":white_check_mark:",
    "newest_emoji": ":eyes:",
    "target_channel": "release-updates"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_react_to_release_messages"
    }
  }
}
