{
  "id": "configure_account_highlights@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Configure your account to highlight the urgent keywords: \"error, critical, deploy\".\n\nLogin credentials:\n- Username: admin\n- Password: Admin1234!",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_account_highlights/setup_task.sh",
    "post_task": "/workspace/tasks/configure_account_highlights/export_result.sh"
  },
  "metadata": {
    "target_keywords": [
      "error",
      "critical",
      "deploy"
    ],
    "username": "admin"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_account_highlights"
    }
  }
}
