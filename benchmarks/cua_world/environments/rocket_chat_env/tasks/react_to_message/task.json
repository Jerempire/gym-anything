{
  "id": "react_to_message@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Add a thumbs-up emoji reaction (:thumbsup:) to the message announcing release 8.1.0 (published 2026-02-10) in the #release-updates channel on Rocket.Chat. Credentials: Username: admin, Password: Admin1234!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 45,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/react_to_message/setup_task.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_channel": "release-updates",
    "target_release_tag": "8.1.0",
    "target_release_date": "2026-02-10",
    "target_emoji": "thumbsup"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_react_to_message"
    }
  }
}
