{
  "id": "register_oauth_application@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Log in to Rocket.Chat using the credentials (Username: admin, Password: Admin1234!) and register a new active OAuth Application named 'Release Dashboard' with the Redirect URI 'http://dashboard.internal/callback'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/register_oauth_application/setup_task.sh",
    "post_task": "/workspace/tasks/register_oauth_application/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_app_name": "Release Dashboard",
    "target_redirect_uri": "http://dashboard.internal/callback"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_register_oauth_application"
    }
  }
}
