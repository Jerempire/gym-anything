{
  "id": "configure_global_notification_defaults@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Rocket.Chat is open at the login screen. Log in with Username: admin and Password: Admin1234!. To ensure team members don't miss critical alerts, update the workspace's default user preferences so that both 'Desktop Notifications' and 'Mobile Notifications' are set to 'All Messages' for new users.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 45,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_global_notification_defaults/setup_task.sh",
    "post_task": "/workspace/tasks/configure_global_notification_defaults/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_setting_id": "Accounts_Default_User_Preferences",
    "expected_desktop_val": "all",
    "expected_mobile_val": "all"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_global_notification_defaults"
    }
  }
}
