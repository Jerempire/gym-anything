{
  "id": "enable_katex_math_rendering@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Log in to Rocket.Chat using the credentials admin / Admin1234!. Enable the 'KaTeX Enabled', 'KaTeX Dollar Syntax', and 'KaTeX Parenthesis Syntax' settings within the workspace message configuration. Post the message \"The final equation is $E = mc^2$\" to the #general channel to verify the configuration.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 45,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/enable_katex_math_rendering/setup_task.sh",
    "post_task": "/workspace/tasks/enable_katex_math_rendering/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_channel": "general",
    "target_message": "The final equation is $E = mc^2$",
    "katex_enabled_setting": "Message_Katex_Enabled",
    "katex_dollar_setting": "Message_Katex_Dollar_Syntax",
    "katex_parenthesis_setting": "Message_Katex_Parenthesis_Syntax"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enable_katex_math_rendering"
    }
  }
}
