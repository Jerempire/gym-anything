{
  "id": "configure_smtp_settings@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Configure the Rocket.Chat instance to use the corporate internal email relay for system notifications.\n\nLogin credentials:\n- Username: admin\n- Password: Admin1234!\n\nApply the following SMTP configuration settings:\n- Protocol: smtp\n- Host: smtp.internal.corp\n- Port: 2525\n- IgnoreTLS: Enabled\n- Username/Password: [Empty]",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_smtp_settings/setup_task.sh",
    "post_task": "/workspace/tasks/configure_smtp_settings/export_result.sh"
  },
  "metadata": {
    "expected_protocol": "smtp",
    "expected_host": "smtp.internal.corp",
    "expected_port": "2525",
    "expected_ignore_tls": true,
    "setting_keys": [
      "SMTP_Protocol",
      "SMTP_Host",
      "SMTP_Port",
      "SMTP_IgnoreTLS"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_smtp_settings"
    }
  }
}
