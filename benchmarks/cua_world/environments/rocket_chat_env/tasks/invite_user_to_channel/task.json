{
  "id": "invite_user_to_channel@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Log in to Rocket.Chat using the username 'admin' and password 'Admin1234!'. Create a public channel named 'deployment-log' and add 'agent.user' as a member of this channel.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/invite_user_to_channel/setup_task.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_channel_name": "deployment-log",
    "target_channel_type": "public",
    "target_member": "agent.user"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_invite_user_to_channel"
    }
  }
}
