{
  "id": "star_release_message@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Star the message announcing release 7.10.7 (published 2026-01-13) in the #release-updates channel of Rocket.Chat. Credentials: Username: admin, Password: Admin1234!",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 45,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/star_release_message/setup_task.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_channel": "release-updates",
    "target_release_tag": "7.10.7",
    "target_release_date": "2026-01-13",
    "action": "star"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_star_release_message"
    }
  }
}
