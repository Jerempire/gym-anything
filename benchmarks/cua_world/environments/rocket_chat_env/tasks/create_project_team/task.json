{
  "id": "create_project_team@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Log in to Rocket.Chat with username 'admin' and password 'Admin1234!'. Organize a new working group by creating a Private Team named 'Q2 Marketing' and adding 'agent.user' as a member. Create a private sub-channel named 'social-media' within the 'Q2 Marketing' team.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 45,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_project_team/setup_task.sh",
    "post_task": "/workspace/tasks/create_project_team/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_team_name": "Q2 Marketing",
    "target_team_type": 1,
    "target_member": "agent.user",
    "target_channel_name": "social-media"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_project_team"
    }
  }
}
