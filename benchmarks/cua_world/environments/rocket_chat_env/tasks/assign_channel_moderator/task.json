{
  "id": "assign_channel_moderator@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Log into the Rocket.Chat workspace as the admin user (username: admin, password: Admin1234!) and assign the 'moderator' role to the member 'agent.user' in the 'release-updates' channel.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/assign_channel_moderator/setup_task.sh",
    "post_task": "/workspace/tasks/assign_channel_moderator/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_channel": "release-updates",
    "target_username": "agent.user",
    "target_role": "moderator"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_assign_channel_moderator"
    }
  }
}
