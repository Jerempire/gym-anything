{
  "id": "create_private_channel@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Log in to Rocket.Chat (Username: admin, Password: Admin1234!) and create a private channel named 'security-incidents' with 'agent.user' as a member.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 45,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_private_channel/setup_task.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_channel_name": "security-incidents",
    "target_channel_type": "private",
    "target_member": "agent.user"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_private_channel"
    }
  }
}
