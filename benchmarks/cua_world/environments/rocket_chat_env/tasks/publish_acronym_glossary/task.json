{
  "id": "publish_acronym_glossary@1",
  "version": "1.0",
  "env_id": "rocket_chat_env@0.1",
  "description": "Using Rocket.Chat in Firefox (Login: admin/Admin1234!), populate a new public channel named 'glossary' with the contents of '~/Documents/acronyms.csv' formatted as a Markdown table with 'Acronym' and 'Definition' columns, including a header row.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/publish_acronym_glossary/setup_task.sh",
    "post_task": "/workspace/tasks/publish_acronym_glossary/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_channel": "glossary",
    "expected_terms": [
      {
        "acronym": "API",
        "definition": "Application Programming Interface"
      },
      {
        "acronym": "JSON",
        "definition": "JavaScript Object Notation"
      },
      {
        "acronym": "RBAC",
        "definition": "Role-Based Access Control"
      },
      {
        "acronym": "VPN",
        "definition": "Virtual Private Network"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_publish_acronym_glossary"
    }
  }
}
