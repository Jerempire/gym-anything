{
  "id": "deploy_workload@1",
  "version": "1.0",
  "env_id": "rancher_env@0.1",
  "description": "Create a Deployment named 'web-frontend' in the 'default' namespace of the local cluster using the 'nginx:latest' image and 2 replicas. You are logged in as admin; if prompted, use Username: admin, Password: Admin12345678!.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/deploy_workload/setup_task.sh"
  },
  "metadata": {
    "expected_deployment_name": "web-frontend",
    "expected_namespace": "default",
    "expected_image": "nginx:latest",
    "expected_replicas": 2
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_deploy_workload"
    }
  }
}
