{
  "id": "scale_deployment@1",
  "version": "1.0",
  "env_id": "rancher_env@0.1",
  "description": "Scale the 'nginx-web' deployment in the 'staging' namespace to 4 replicas. You are already logged in as admin and viewing the nginx-web deployment details. If prompted to log in, use Username: admin, Password: Admin12345678!",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/scale_deployment/setup_task.sh"
  },
  "metadata": {
    "expected_deployment": "nginx-web",
    "expected_namespace": "staging",
    "expected_replicas": 4,
    "initial_replicas": 2
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_scale_deployment"
    }
  }
}
