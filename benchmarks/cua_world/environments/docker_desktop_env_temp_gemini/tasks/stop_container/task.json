{
  "id": "stop_container@1",
  "version": "1.0",
  "env_id": "docker_desktop_env@0.1",
  "description": "Stop the running container named 'test-web-server'. Ensure the container is stopped but not removed or deleted.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/stop_container/setup_task.sh",
    "post_task": "/workspace/tasks/stop_container/export_result.sh"
  },
  "metadata": {
    "target_container_name": "test-web-server"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_stop_container"
    }
  }
}
