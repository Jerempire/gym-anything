{
  "id": "configure_daemon_bridge_subnet@1",
  "version": "1.0",
  "env_id": "docker_desktop_env@0.1",
  "description": "Configure Docker Desktop's internal Docker Engine to use the subnet '192.168.200.0/24' for the default bridge network. Set the 'bip' (Bridge IP) property to '192.168.200.1/24' within the Docker Engine configuration.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_daemon_bridge_subnet/setup_task.sh",
    "post_task": "/workspace/tasks/configure_daemon_bridge_subnet/export_result.sh"
  },
  "metadata": {
    "expected_subnet": "192.168.200.0/24",
    "expected_gateway": "192.168.200.1",
    "required_config_key": "bip"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_subnet_config"
    }
  }
}
