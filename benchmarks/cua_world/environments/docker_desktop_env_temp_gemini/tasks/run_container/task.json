{
  "id": "run_container@1",
  "version": "1.0",
  "env_id": "docker_desktop_env@0.1",
  "description": "Run a new container from the 'nginx:alpine' image. The container must be named 'my-nginx-server' and must map port 8888 on the host to port 80 in the container. The task is complete when the container is running and http://localhost:8888 returns a response.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/run_container/setup_task.sh",
    "post_task": "/workspace/tasks/run_container/export_result.sh"
  },
  "metadata": {
    "expected_container_name": "my-nginx-server",
    "expected_image": "nginx:alpine",
    "expected_host_port": 8888,
    "expected_container_port": 80
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_run_container"
    }
  }
}
