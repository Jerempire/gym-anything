{
  "id": "activity_browser_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Activity Browser environment for Life Cycle Assessment (LCA) tasks including impact calculation, supply chain exploration, and inventory modeling using the Brightway2 framework with a custom Energy_and_Materials database (10 activities with published emission factors from IPCC, World Steel Association, IAI, and HBEFA) and the standard biosphere3 database (4709 flows) with 762 LCIA methods",
  "category": ["science", "sustainability", "environmental_engineering"],
  "tags": ["linux", "science", "lca", "sustainability", "brightway", "desktop", "python"],
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "resolution": [1920, 1080],
      "fps": 10,
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "vnc": {
    "enable": true,
    "password": "password"
  },
  "synchronous": true,
  "step_cycle_ms": 200,
  "mounts": [
    {"source": "benchmarks/cua_world/environments/activity_browser_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/activity_browser_env/tasks", "target": "/workspace/tasks", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_activity_browser.sh",
    "post_start": "/workspace/scripts/setup_activity_browser.sh"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {
          "DISPLAY": ":1"
        }
      }
    }
  ]
}
