{
  "id": "consolidate_attribute_values@1",
  "version": "1.0",
  "env_id": "reqview_env@0.1",
  "description": "The ReqView project contains an SRS document with a 'Team' attribute that has inconsistent values due to manual entry errors. Standardize these values by changing all variations of Hardware (such as 'HW', 'H/W', and 'Hard-ware') to the canonical value 'Hardware', and all variations of Software (such as 'SW', 'S/W', and 'Soft') to the canonical value 'Software'. Ensure requirements assigned to 'Systems' are not changed and save the project.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/consolidate_attribute_values/setup_task.sh",
    "post_task": "/workspace/tasks/consolidate_attribute_values/export_result.sh",
    "pre_task_timeout": 180
  },
  "metadata": {
    "project_path": "/home/ga/Documents/ReqView/messy_project",
    "srs_path": "/home/ga/Documents/ReqView/messy_project/documents/SRS.json",
    "attribute_id": "team_attr",
    "canonical_values": {
      "hardware": "Hardware",
      "software": "Software",
      "systems": "Systems"
    },
    "messy_groups": {
      "hardware": [
        "HW",
        "H/W",
        "Hard-ware",
        "Hardware"
      ],
      "software": [
        "SW",
        "S/W",
        "Soft",
        "Software"
      ]
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_consolidate_attribute_values"
    }
  }
}
