{
  "id": "create_inline_link_to_requirement@1",
  "version": "1.0",
  "env_id": "reqview_env@0.1",
  "description": "In the open ReqView project, navigate to requirement SRS-001 in the SRS document. Create an inline hyperlink for the text 'NEED-001' in the description of SRS-001 that points to requirement NEED-001 in the NEEDS document. Save the project.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_inline_link_to_requirement/setup_task.sh",
    "post_task": "/workspace/tasks/create_inline_link_to_requirement/export_result.sh",
    "pre_task_timeout": 180
  },
  "metadata": {
    "srs_path": "/home/ga/Documents/ReqView/create_inline_link_project/documents/SRS.json",
    "needs_path": "/home/ga/Documents/ReqView/create_inline_link_project/documents/NEEDS.json",
    "target_srs_id": "SRS-001",
    "target_needs_id": "NEED-001",
    "link_text": "NEED-001"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_inline_link"
    }
  }
