{
  "id": "classify_sensitive_data_reqs@1",
  "version": "1.0",
  "env_id": "reqview_env@0.1",
  "description": "Perform a security compliance audit on the 'Smart Home' requirements project. For all requirements in the SRS (Software Requirements Specification) document that contain an IPv4 address in their description text, set the 'DataClassification' attribute to 'Confidential'. Save the project changes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/classify_sensitive_data_reqs/setup_task.sh",
    "post_task": "/workspace/tasks/classify_sensitive_data_reqs/export_result.sh",
    "pre_task_timeout": 180
  },
  "metadata": {
    "project_path": "/home/ga/Documents/ReqView/classify_sensitive_project",
    "srs_relative_path": "documents/SRS.json",
    "ground_truth_path": "/var/lib/reqview/ground_truth.json",
    "attribute_name": "DataClassification",
    "target_value": "Confidential"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_classify_sensitive_data_reqs"
    }
  }
}
