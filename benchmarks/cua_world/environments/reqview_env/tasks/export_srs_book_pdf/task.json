{
  "id": "export_srs_book_pdf@1",
  "version": "1.0",
  "env_id": "reqview_env@0.1",
  "description": "Export the SRS (Software Requirements Specification) document to a PDF file at /home/ga/Documents/SRS_Release_1.0.pdf. The export must use a book layout, include a Table of Contents, and have the document title set to 'System Requirements v1.0'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_srs_book_pdf/setup_task.sh",
    "post_task": "/workspace/tasks/export_srs_book_pdf/export_result.sh",
    "pre_task_timeout": 180
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/SRS_Release_1.0.pdf",
    "expected_title": "System Requirements v1.0",
    "expected_toc_marker": "Table of Contents",
    "min_file_size_bytes": 1024
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_srs_book_pdf"
    }
  }
}
