{
  "id": "recover_deleted_requirement@1",
  "version": "1.0",
  "env_id": "reqview_env@0.1",
  "description": "A requirement has been accidentally deleted from the 'Smart Home' project. Your goal is to recover it. Restore the missing requirement SRS-6, which specifies authentication behavior, to the 'Security' section of the project. Ensure the restored requirement is visible in the SRS document and save the project.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/recover_deleted_requirement/setup_task.sh",
    "post_task": "/workspace/tasks/recover_deleted_requirement/export_result.sh",
    "pre_task_timeout": 300
  },
  "metadata": {
    "target_id": "SRS-6",
    "target_text_substring": "authenticate Users",
    "project_path": "/home/ga/Documents/ReqView/RecoverTask_project",
    "srs_relative_path": "documents/SRS.json"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_recover_deleted_requirement"
    }
  }
}
