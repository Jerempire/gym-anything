{
  "id": "instrument_failure_diagnosis@1",
  "version": "1.0",
  "env_id": "bridgecommand_env@0.1",
  "description": "You are an electronics officer aboard a vessel that has experienced multiple instrument malfunctions after an electrical surge. Bridge Command is running with a corrupted configuration and a broken scenario. Diagnose and repair all six faults located within the bc5.ini configuration file and the scenario files at '/opt/bridgecommand/Scenarios/m) Portsmouth Approach Custom/'. Use the ship's normal operating parameters in /home/ga/Documents/vessel_specs.txt as a reference. Document your findings in a detailed fault diagnosis report at /home/ga/Documents/fault_report.txt, including the location, incorrect value, corrected value, and likely cause for each fault. Do not restore from backup. Login: ga / password123.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80
  },
  "hooks": {
    "pre_task": "/workspace/tasks/instrument_failure_diagnosis/setup_task.sh",
    "post_task": "/workspace/tasks/instrument_failure_diagnosis/export_result.sh"
  },
  "metadata": {
    "faults": {
      "bc5_view_angle": {
        "location": "bc5.ini [Graphics]",
        "param": "view_angle",
        "broken_value": "5",
        "correct_value": "90"
      },
      "bc5_radar_resolution": {
        "location": "bc5.ini [RADAR]",
        "param": "radar_range_resolution",
        "broken_value": "8",
        "correct_value": "128"
      },
      "bc5_max_radar_range": {
        "location": "bc5.ini [RADAR]",
        "param": "max_radar_range",
        "broken_value": "2",
        "correct_value": "48"
      },
      "scenario_visibility": {
        "location": "environment.ini",
        "param": "VisibilityRange",
        "broken_value": "0.1",
        "correct_value": "10.0"
      },
      "scenario_ownship_speed": {
        "location": "ownship.ini",
        "param": "InitialSpeed",
        "broken_value": "85.0",
        "correct_value": "8.0"
      },
      "scenario_vessel_count": {
        "location": "othership.ini",
        "param": "Number",
        "broken_value": "0",
        "correct_value": "2"
      }
    },
    "fault_count": 6,
    "scenario_dir": "/opt/bridgecommand/Scenarios/m) Portsmouth Approach Custom",
    "specs_file": "/home/ga/Documents/vessel_specs.txt",
    "report_file": "/home/ga/Documents/fault_report.txt",
    "report_required_fault_count": 6
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_instrument_failure_diagnosis"
    }
  }
}
