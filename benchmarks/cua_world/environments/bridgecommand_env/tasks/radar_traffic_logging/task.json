{
  "id": "radar_traffic_logging@1",
  "version": "1.0",
  "env_id": "bridgecommand_env@0.1",
  "description": "Launch Bridge Command and select the scenario 'z) Traffic Safety Assessment'. Identify the three vessels in range and record their Vessel Name, CPA (in nm), and TCPA (in minutes) for all targets. Save the data to '/home/ga/Documents/traffic_log.csv' using the header 'Name,CPA,TCPA'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/radar_traffic_logging/setup_task.sh",
    "post_task": "/workspace/tasks/radar_traffic_logging/export_result.sh"
  },
  "metadata": {
    "scenario_name": "z) Traffic Safety Assessment",
    "output_file": "/home/ga/Documents/traffic_log.csv",
    "expected_header": "Name,CPA,TCPA",
    "tolerances": {
      "cpa_nm": 0.5,
      "tcpa_min": 5.0
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_radar_traffic_logging"
    }
  }
}
