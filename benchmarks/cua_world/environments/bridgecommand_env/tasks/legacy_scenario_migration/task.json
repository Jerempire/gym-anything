{
  "id": "legacy_scenario_migration@1",
  "version": "1.0",
  "env_id": "bridgecommand_env@0.1",
  "description": "You are a simulator technician upgrading old training content. Migrate three legacy scenarios from '/home/ga/Documents/legacy_scenarios/' to '/opt/bridgecommand/Scenarios/' using the specifications in '/home/ga/Documents/migration_spec.txt'. For each scenario, create a new directory prefixed with 'Migrated - '. Copy 'environment.ini' unchanged. In 'ownship.ini' and 'othership.ini', apply the coordinate datum shift from the spec to all initial Latitude and Longitude positions. In 'othership.ini', also replace deprecated vessel models with the target models defined in the spec. Ensure all numbers are formatted correctly in the INI files.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/legacy_scenario_migration/setup_task.sh",
    "post_task": "/workspace/tasks/legacy_scenario_migration/export_result.sh"
  },
  "metadata": {
    "legacy_dir": "/home/ga/Documents/legacy_scenarios",
    "target_dir": "/opt/bridgecommand/Scenarios",
    "migration_spec": {
      "lat_shift": 0.0015,
      "long_shift": -0.0022,
      "model_map": {
        "Old_Tanker": "Tanker_A",
        "Old_Ferry": "Ferry_Pax_1",
        "Old_Buoy": "Buoy_Cardinal_N"
      }
    },
    "scenarios": {
      "Scenario_A": {
        "original_own_lat": 50.8,
        "original_own_long": -1.1,
        "original_other_lat": 50.81,
        "original_other_long": -1.12,
        "legacy_model": "Old_Tanker"
      },
      "Scenario_B": {
        "original_own_lat": 50.5,
        "original_own_long": -0.5,
        "original_other_lat": 50.51,
        "original_other_long": -0.51,
        "legacy_model": "Old_Ferry"
      },
      "Scenario_C": {
        "original_own_lat": 50.2,
        "original_own_long": -1.5,
        "original_other_lat": 50.205,
        "original_other_long": -1.505,
        "legacy_model": "Old_Buoy"
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_legacy_scenario_migration"
    }
  }
}
