{
  "id": "map_based_destination_selection@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Set Charikar, Afghanistan as the navigation destination. You may search for Kabul to orient yourself, but you must locate Charikar manually by panning North approximately 60km along the highway. Do not use the search function for 'Charikar'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/map_based_destination_selection/setup_task.sh",
    "post_task": "/sdcard/tasks/map_based_destination_selection/export_result.sh"
  },
  "metadata": {
    "target_city": "Charikar",
    "forbidden_text_input": "Charikar",
    "starting_landmark": "Kabul"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_map_selection"
    }
  }
}
