{
  "id": "change_voice_language@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Change the voice guidance language in Sygic GPS Navigation from English to German (Deutsch).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/change_voice_language/setup_task.sh",
    "post_task": "sh /sdcard/tasks/change_voice_language/export_result.sh"
  },
  "metadata": {
    "target_language": "Deutsch",
    "target_language_alt": "German",
    "expected_setting_key": "voice",
    "anti_gaming_check": "preference_modification"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_change_voice_language"
    }
  }
}
