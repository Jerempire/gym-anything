{
  "id": "set_pedestrian_mode@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Switch the vehicle profile to 'Pedestrian' mode in Sygic GPS Navigation and verify the change on the main map view.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/set_pedestrian_mode/setup_task.sh",
    "post_task": "sh /sdcard/tasks/set_pedestrian_mode/export_result.sh"
  },
  "metadata": {
    "target_profile": "Pedestrian",
    "initial_profile": "Car"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_pedestrian_mode"
    }
  }
}
