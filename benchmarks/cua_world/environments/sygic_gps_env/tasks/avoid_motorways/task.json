{
  "id": "avoid_motorways@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure the Sygic GPS Navigation app to strictly avoid highways and motorways for all route calculations.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/avoid_motorways/setup_task.sh",
    "post_task": "sh /sdcard/tasks/avoid_motorways/export_result.sh"
  },
  "metadata": {
    "target_keywords": [
      "motorway",
      "highway",
      "avoid",
      "routing"
    ],
    "negative_keywords": [
      "ferry",
      "toll",
      "unpaved"
    ],
    "prefs_path_container": "/sdcard/task_data/shared_prefs"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_avoid_motorways"
    }
  }
}
