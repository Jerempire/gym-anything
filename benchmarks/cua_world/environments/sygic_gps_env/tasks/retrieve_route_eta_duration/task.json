{
  "id": "retrieve_route_eta_duration@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Plan a driving route to San Jose, CA in Sygic GPS Navigation. Record the estimated trip duration in a text file at /sdcard/trip_duration.txt. The file must contain only the duration string.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/retrieve_route_eta_duration/setup_task.sh",
    "post_task": "sh /sdcard/tasks/retrieve_route_eta_duration/export_result.sh"
  },
  "metadata": {
    "output_file": "/sdcard/trip_duration.txt",
    "destination": "San Jose, CA",
    "target_ui_element": "duration_label"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_retrieve_route_eta_duration"
    }
  }
}
