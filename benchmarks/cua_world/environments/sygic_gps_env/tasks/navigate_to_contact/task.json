{
  "id": "navigate_to_contact@1",
  "env_id": "example.sygic_gps_env@0.1",
  "difficulty": "medium",
  "description": "Navigate to the contact 'Dr. Hameed' at their address in Jalalabad using Sygic GPS Navigation. The task is complete when the route overview or navigation screen is displayed.",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/navigate_to_contact/setup_task.sh",
    "post_task": "sh /sdcard/tasks/navigate_to_contact/export_result.sh"
  },
  "metadata": {
    "contact_name": "Dr. Hameed",
    "contact_address": "Jalalabad",
    "expected_distance_km_range": [
      120,
      170
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_navigate_to_contact"
    }
  }
}
