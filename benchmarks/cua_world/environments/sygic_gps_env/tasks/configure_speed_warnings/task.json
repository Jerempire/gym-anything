{
  "id": "configure_speed_warnings@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure safety warnings in Sygic GPS Navigation. Enable speed limit warnings with a 10 km/h tolerance and enable speed camera warnings.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/configure_speed_warnings/setup_task.sh",
    "post_task": "/sdcard/tasks/configure_speed_warnings/export_result.sh"
  },
  "metadata": {
    "target_tolerance": 10,
    "required_keywords": [
      "speed",
      "warn",
      "limit",
      "radar",
      "camera"
    ],
    "settings_context": "Warnings and Notifications"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_speed_warnings"
    }
  }
}
