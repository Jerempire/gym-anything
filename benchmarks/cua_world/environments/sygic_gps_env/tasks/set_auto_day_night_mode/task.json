{
  "id": "set_auto_day_night_mode@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure Sygic GPS Navigation so that the map color scheme switches automatically between day and night modes based on the time of day.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/set_auto_day_night_mode/setup_task.sh",
    "post_task": "/sdcard/tasks/set_auto_day_night_mode/export_result.sh"
  },
  "metadata": {
    "target_setting": "Color scheme",
    "target_value": "Automatic"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_auto_day_night_mode"
    }
  }
}
