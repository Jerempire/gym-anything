{
  "id": "enable_compass_display@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure Sygic GPS Navigation to always display the compass on the map view. Ensure the North Indicator (Compass) is permanently visible, even when the map is not being rotated.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/enable_compass_display/setup_task.sh",
    "post_task": "/sdcard/tasks/enable_compass_display/export_result.sh"
  },
  "metadata": {
    "target_setting": "Compass",
    "expected_state": "Always",
    "feature_name": "North indicator"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enable_compass_display"
    }
  }
}
