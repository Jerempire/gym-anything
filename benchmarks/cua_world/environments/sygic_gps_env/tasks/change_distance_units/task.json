{
  "id": "change_distance_units@1",
  "env_id": "example.sygic_gps_env@0.1",
  "difficulty": "easy",
  "description": "The Sygic GPS Navigation app is open on the main map screen. Change the distance units from Kilometers to Miles in the application settings.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/change_distance_units/setup_task.sh",
    "post_task": "sh /sdcard/tasks/change_distance_units/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_distance_units"
    }
  },
  "metadata": {
    "target_setting": "Distance units",
    "expected_value": "Miles"
  }
}
