{
  "id": "set_home_location@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure the 'Home' location in Sygic GPS Navigation to the Eiffel Tower (Champ de Mars, 5 Avenue Anatole France, 75007 Paris, France).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/set_home_location/setup_task.sh",
    "post_task": "/sdcard/tasks/set_home_location/export_result.sh"
  },
  "metadata": {
    "target_name": "Eiffel Tower",
    "target_address_keywords": [
      "Champ de Mars",
      "Anatole France",
      "Paris",
      "75007"
    ],
    "expected_ui_text": "Home"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_home_location"
    }
  }
}
