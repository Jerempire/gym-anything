{
  "id": "enable_sharp_curve_warnings@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Enable the 'Sharp curve warning' feature in Sygic GPS Navigation to improve safety for heavy vehicle driving.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/enable_sharp_curve_warnings/setup_task.sh",
    "post_task": "sh /sdcard/tasks/enable_sharp_curve_warnings/export_result.sh"
  },
  "metadata": {
    "target_feature_keywords": [
      "curve",
      "sharp"
    ],
    "expected_state": "true"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_sharp_curve_warnings"
    }
  }
}
