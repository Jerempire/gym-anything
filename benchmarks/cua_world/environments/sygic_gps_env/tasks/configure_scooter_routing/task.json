{
  "id": "configure_scooter_routing@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure Sygic GPS Navigation for a scooter ride by ensuring safe routing settings. Enable the avoidance of motorways (highways) and unpaved roads to prevent the scooter from being routed on high-speed or gravel roads.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/configure_scooter_routing/setup_task.sh",
    "post_task": "sh /sdcard/tasks/configure_scooter_routing/export_result.sh"
  },
  "metadata": {
    "expected_settings": [
      {
        "name": "Avoid motorways",
        "keywords": [
          "motorway",
          "highway",
          "freeway"
        ],
        "expected_state": true
      },
      {
        "name": "Avoid unpaved roads",
        "keywords": [
          "unpaved",
          "gravel",
          "dirt"
        ],
        "expected_state": true
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_scooter_routing"
    }
  }
}
