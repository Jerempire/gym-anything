{
  "id": "add_gas_stop_on_route@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Plan a driving route from Jalalabad to Kabul using Sygic GPS Navigation. Add a petrol station located along the route as an intermediate waypoint. The final state must show the active route overview with the gas station included as a stop before reaching Kabul.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/add_gas_stop_on_route/setup_task.sh",
    "post_task": "sh /sdcard/tasks/add_gas_stop_on_route/export_result.sh"
  },
  "metadata": {
    "destination": "Kabul",
    "poi_category": "Petrol Station",
    "poi_keywords": [
      "Gas",
      "Petrol",
      "Oil",
      "Station",
      "Pump"
    ],
    "required_filter": "On route"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_gas_stop_on_route"
    }
  }
}
