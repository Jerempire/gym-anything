{
  "id": "enable_parking_reminder@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Enable the automatic 'Parking place reminder' feature in Sygic GPS Navigation.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/enable_parking_reminder/setup_task.sh",
    "post_task": "/sdcard/tasks/enable_parking_reminder/export_result.sh"
  },
  "metadata": {
    "search_term": "park",
    "expected_value_indicators": [
      "true",
      "1",
      "on"
    ],
    "feature_name": "Parking place reminder"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_parking_reminder"
    }
  }
}
