{
  "id": "change_app_interface_language@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Change the Sygic GPS Navigation interface language to German (Deutsch). Ensure the application display language is updated throughout the user interface.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/change_app_interface_language/setup_task.sh",
    "post_task": "sh /sdcard/tasks/change_app_interface_language/export_result.sh"
  },
  "metadata": {
    "target_language": "Deutsch",
    "expected_ui_text": [
      "Einstellungen",
      "Karte",
      "Navigation",
      "Suchen"
    ],
    "forbidden_ui_text": [
      "Settings",
      "Map",
      "Search"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_change_app_interface_language"
    }
  }
}
