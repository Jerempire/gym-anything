{
  "id": "set_economical_route@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure Sygic GPS Navigation to use the 'Economical' route computing method to prioritize fuel efficiency.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/set_economical_route/setup_task.sh",
    "post_task": "/workspace/tasks/set_economical_route/export_result.sh"
  },
  "metadata": {
    "target_setting": "Route computing",
    "expected_value": "Economical",
    "package_name": "com.sygic.aura",
    "prefs_path": "/data/data/com.sygic.aura/shared_prefs",
    "prefs_file_pattern": "com.sygic.aura_preferences.xml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_economical_route"
    }
  }
}
