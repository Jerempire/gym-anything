{
  "id": "disable_analytics_collection@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Navigate to the Sygic GPS Navigation privacy settings and disable the collection of product improvement data.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/disable_analytics_collection/setup_task.sh",
    "post_task": "/sdcard/tasks/disable_analytics_collection/export_result.sh"
  },
  "metadata": {
    "target_setting_keywords": [
      "Product improvement",
      "Help improve Sygic",
      "Usage statistics",
      "Consent"
    ],
    "expected_state": "OFF"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_disable_analytics"
    }
  }
}
