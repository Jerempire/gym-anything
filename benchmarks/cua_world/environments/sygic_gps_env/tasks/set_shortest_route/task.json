{
  "id": "set_shortest_route@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Change the route calculation method in Sygic GPS Navigation to 'Shortest'. Ensure the setting is saved and active.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/set_shortest_route/setup_task.sh",
    "post_task": "sh /sdcard/tasks/set_shortest_route/export_result.sh"
  },
  "metadata": {
    "target_setting_text": "Shortest",
    "settings_xml_pattern": "route",
    "expected_keywords": [
      "shortest",
      "route",
      "computing"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_shortest_route"
    }
  }
}
