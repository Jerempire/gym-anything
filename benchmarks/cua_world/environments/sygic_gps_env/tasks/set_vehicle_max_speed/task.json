{
  "id": "set_vehicle_max_speed@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure the vehicle's maximum speed to exactly 90 km/h in Sygic GPS Navigation.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/set_vehicle_max_speed/setup_task.sh",
    "post_task": "sh /sdcard/tasks/set_vehicle_max_speed/export_result.sh"
  },
  "metadata": {
    "target_setting": "Maximum speed",
    "target_value": "90",
    "unit": "km/h"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_vehicle_max_speed"
    }
  }
}
