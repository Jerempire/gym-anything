{
  "id": "plan_remote_route@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Plan a driving route for a convoy starting from Kabul, Afghanistan and ending in Kandahar, Afghanistan. Ensure the route preview displays the path connecting the two cities along with the calculated distance and time. Do not start active navigation.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/plan_remote_route/setup_task.sh",
    "post_task": "sh /sdcard/tasks/plan_remote_route/export_result.sh"
  },
  "metadata": {
    "start_city": "Kabul",
    "end_city": "Kandahar",
    "forbidden_start": "Current Location",
    "map_region": "Afghanistan"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_plan_remote_route"
    }
  }
}
