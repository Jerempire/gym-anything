{
  "id": "disable_3d_buildings@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure Sygic GPS Navigation to disable 3D buildings and landmarks for a cleaner map view. Ensure the changes are applied and return to the main map view.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/disable_3d_buildings/setup_task.sh",
    "post_task": "sh /sdcard/tasks/disable_3d_buildings/export_result.sh"
  },
  "metadata": {
    "expected_setting_name": "Buildings",
    "expected_state": "OFF"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_disable_3d_buildings"
    }
  }
}
