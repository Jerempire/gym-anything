{
  "id": "navigate_to_coordinates@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Navigate to the coordinates 48.85837, 2.29448 in Sygic GPS Navigation using the coordinate input method. Ensure the location is correctly displayed on the map as the selected destination.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/navigate_to_coordinates/setup_task.sh",
    "post_task": "sh /sdcard/tasks/navigate_to_coordinates/export_result.sh"
  },
  "metadata": {
    "target_lat": "48.85837",
    "target_lon": "2.29448",
    "target_name": "Eiffel Tower",
    "expected_context_keywords": [
      "Paris",
      "Eiffel",
      "Tour",
      "Champ de Mars",
      "Anatole France",
      "France",
      "48.85",
      "2.29"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_navigate_to_coordinates"
    }
  }
}
