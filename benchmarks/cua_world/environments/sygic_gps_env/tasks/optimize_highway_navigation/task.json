{
  "id": "optimize_highway_navigation@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "You are a long-haul trucker who needs to configure Sygic GPS Navigation for efficient highway driving. Configure the application to allow highways and toll roads, ensure unpaved roads are avoided, and use the 'Fastest route' computation method. Additionally, enable the compass display, set the driving mode to 2D, disable 3D terrain rendering, and use the bigger map font size.",
  "difficulty": "hard",
  "tags": [
    "navigation",
    "route-planning",
    "view-settings",
    "multi-page",
    "multi-feature"
  ],
  "init": {
    "timeout_sec": 300,
    "max_steps": 40
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/optimize_highway_navigation/setup_task.sh",
    "post_task": "sh /sdcard/tasks/optimize_highway_navigation/export_result.sh"
  },
  "metadata": {
    "expected_values": {
      "avoid_highways": "false",
      "avoid_toll_roads": "false",
      "avoid_unpaved_roads": "true",
      "route_compute": "1",
      "compass_always_on": "true",
      "driving_mode": "0",
      "terrain_3d": "false",
      "font_size": "1"
    },
    "setup_values": {
      "avoid_highways": "true",
      "avoid_toll_roads": "true",
      "avoid_unpaved_roads": "true",
      "route_compute": "0",
      "compass_always_on": "false",
      "driving_mode": "1",
      "terrain_3d": "true",
      "font_size": "0"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_optimize_highway_navigation"
    }
  }
}
