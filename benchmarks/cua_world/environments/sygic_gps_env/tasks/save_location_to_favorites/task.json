{
  "id": "save_location_to_favorites@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Search for Kabul Airport (Hamid Karzai International Airport) and add it to your Favorites. Ensure the Favorites list is open to show the saved location.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/save_location_to_favorites/setup_task.sh",
    "post_task": "sh /sdcard/tasks/save_location_to_favorites/export_result.sh"
  },
  "metadata": {
    "target_location_name": "Kabul Airport",
    "target_location_alt_name": "Hamid Karzai International Airport",
    "expected_ui_context": "Favorites list"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_save_location_to_favorites"
    }
  }
}
