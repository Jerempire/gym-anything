{
  "id": "start_route_simulation@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Plan a route to the 'Golden Gate Bridge' in San Francisco and initiate the route simulation (demo mode) so that the map animates along the route.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/start_route_simulation/setup_task.sh",
    "post_task": "sh /sdcard/tasks/start_route_simulation/export_result.sh"
  },
  "metadata": {
    "target_destination": "Golden Gate Bridge",
    "expected_activity_indicators": [
      "navi",
      "drive",
      "simulation",
      "demo"
    ],
    "result_file_path": "/sdcard/task_result.json",
    "screenshot_path": "/sdcard/task_final.png"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_start_route_simulation"
    }
  }
}
