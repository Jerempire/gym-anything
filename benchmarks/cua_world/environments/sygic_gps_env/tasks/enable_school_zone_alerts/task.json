{
  "id": "enable_school_zone_alerts@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure Sygic GPS Navigation to enable safety alerts for School Zones.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/enable_school_zone_alerts/setup_task.sh",
    "post_task": "sh /sdcard/tasks/enable_school_zone_alerts/export_result.sh"
  },
  "metadata": {
    "target_setting": "School Zone",
    "expected_state": "ON",
    "menu_path": "Settings > Notifications/Sounds > School Zone"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_school_zone_alerts"
    }
  }
}
