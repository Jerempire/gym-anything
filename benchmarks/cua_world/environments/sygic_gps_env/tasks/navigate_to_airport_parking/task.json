{
  "id": "navigate_to_airport_parking@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Navigate to a specific parking garage at San Francisco International Airport (SFO), such as the International Garage or Long Term Parking.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/navigate_to_airport_parking/setup_task.sh",
    "post_task": "sh /sdcard/tasks/navigate_to_airport_parking/export_result.sh"
  },
  "metadata": {
    "target_keywords": [
      "Parking",
      "Garage",
      "Lot"
    ],
    "target_location_name": "San Francisco International Airport",
    "avoid_generic_destination": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_navigate_to_airport_parking"
    }
  }
}
