{
  "id": "enable_speedometer_display@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Enable the 'Speedometer' and 'Speed limit' display overlays on the map view in Sygic GPS Navigation so that both the speedometer widget and the speed limit indicator are visible on the main map.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/enable_speedometer_display/setup_task.sh",
    "post_task": "/sdcard/tasks/enable_speedometer_display/export_result.sh"
  },
  "metadata": {
    "target_features": [
      "Speedometer",
      "Speed limit"
    ],
    "expected_ui_text": [
      "km/h",
      "mph",
      "0"
    ],
    "settings_path": "Settings > View & Units (or Navigation)"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enable_speedometer"
    }
  }
}
