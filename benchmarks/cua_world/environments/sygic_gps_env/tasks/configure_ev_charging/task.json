{
  "id": "configure_ev_charging@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure Sygic GPS Navigation for a Volkswagen ID.4 by enabling EV Mode. Set the charging connector filters so that CCS (Combo 2) and Type 2 (Mennekes) are enabled, and CHAdeMO is disabled.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/configure_ev_charging/setup_task.sh",
    "post_task": "sh /sdcard/tasks/configure_ev_charging/export_result.sh"
  },
  "metadata": {
    "required_connectors": [
      "CCS",
      "Type 2"
    ],
    "forbidden_connectors": [
      "CHAdeMO"
    ],
    "ev_mode_required": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_ev_charging"
    }
  }
}
