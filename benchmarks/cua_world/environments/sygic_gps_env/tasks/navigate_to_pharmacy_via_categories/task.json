{
  "id": "navigate_to_pharmacy_via_categories@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Navigate to the nearest pharmacy in Kabul using the POI category browser. You must select the destination through the category interface without using keyboard input or text search.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/navigate_to_pharmacy_via_categories/setup_task.sh",
    "post_task": "sh /sdcard/tasks/navigate_to_pharmacy_via_categories/export_result.sh"
  },
  "metadata": {
    "target_category": "Pharmacy",
    "target_context": "Health",
    "forbidden_action": "text_search",
    "expected_final_state": "navigation_active"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_category_navigation"
    }
  }
}
