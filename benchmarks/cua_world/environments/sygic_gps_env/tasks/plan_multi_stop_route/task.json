{
  "id": "plan_multi_stop_route@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Plan a driving route from Paris, France to Lyon, France with an intermediate stop in Dijon, France. Ensure the route order is Paris -> Dijon -> Lyon and leave the route overview or itinerary visible on screen.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/plan_multi_stop_route/setup_task.sh",
    "post_task": "/sdcard/tasks/plan_multi_stop_route/export_result.sh"
  },
  "metadata": {
    "cities": [
      "Paris",
      "Lyon",
      "Dijon"
    ],
    "expected_ui_text": [
      "Route",
      "Stop",
      "Waypoint",
      "km",
      "h",
      "min"
    ],
    "min_ui_matches": 2
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_plan_multi_stop_route"
    }
  }
}
