{
  "id": "setup_commute_favorites@1",
  "env_id": "example.sygic_gps_env@0.1",
  "difficulty": "hard",
  "description": "You are a construction worker who needs to set up your daily commute locations in Sygic GPS Navigation. Set your Home address to '1600 Pennsylvania Avenue NW, Washington, DC' and your Work address to '350 5th Avenue, New York, NY'. Additionally, add a Favorite location for any gas station and name it 'Gas Station'.",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/setup_commute_favorites/setup_task.sh",
    "post_task": "sh /sdcard/tasks/setup_commute_favorites/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_setup_commute_favorites"
    }
  },
  "metadata": {
    "home_address": "1600 Pennsylvania Avenue NW, Washington, DC",
    "home_lat": 38.8977,
    "home_lon": -77.0365,
    "work_address": "350 5th Avenue, New York, NY",
    "work_lat": 40.7484,
    "work_lon": -73.9857,
    "favorite_name": "Gas Station",
    "coordinate_tolerance_deg": 0.1
  }
}
