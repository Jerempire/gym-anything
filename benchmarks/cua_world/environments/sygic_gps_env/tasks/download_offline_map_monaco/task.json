{
  "id": "download_offline_map_monaco@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Download the offline map for Monaco in Sygic GPS Navigation and verify it is successfully added to the list of downloaded maps.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/download_offline_map_monaco/setup_task.sh",
    "post_task": "sh /sdcard/tasks/download_offline_map_monaco/export_result.sh",
    "pre_task_timeout": 60
  },
  "metadata": {
    "target_region": "Monaco",
    "map_file_patterns": [
      "mco",
      "monaco"
    ],
    "min_map_size_bytes": 100000,
    "expected_map_dir": "/sdcard/Android/data/com.sygic.aura/files/Maps"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_download_offline_map_monaco"
    }
  }
}
