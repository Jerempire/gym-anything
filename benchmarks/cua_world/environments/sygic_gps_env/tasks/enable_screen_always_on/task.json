{
  "id": "enable_screen_always_on@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Enable the 'Keep screen on' (or 'Prevent screen lock') setting in Sygic GPS Navigation.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/enable_screen_always_on/setup_task.sh",
    "post_task": "/sdcard/tasks/enable_screen_always_on/export_result.sh"
  },
  "metadata": {
    "app_package": "com.sygic.aura",
    "target_setting_keywords": [
      "screen",
      "display",
      "sleep",
      "lock",
      "awake"
    ],
    "expected_value": "true"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enable_screen_always_on"
    }
  }
}
