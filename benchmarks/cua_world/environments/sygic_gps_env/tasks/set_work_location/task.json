{
  "id": "set_work_location@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure the 'Work' location in Sygic GPS Navigation to 'World Trade Center, New York' in Lower Manhattan. Ensure the location is successfully saved and accessible as 'Work' within the application.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/set_work_location/setup_task.sh",
    "post_task": "sh /sdcard/tasks/set_work_location/export_result.sh"
  },
  "metadata": {
    "target_name": "World Trade Center",
    "target_city": "New York",
    "approx_lat": 40.7127,
    "approx_lon": -74.0134,
    "location_tolerance": 0.05
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_work_location"
    }
  }
}
