{
  "id": "find_nearby_gas_stations@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "You are driving through an unfamiliar area and running low on fuel. Use Sygic GPS Navigation to find nearby gas stations by browsing the Points of Interest (POI) categories. Select a station from the results to view its details, including the map preview and address.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/find_nearby_gas_stations/setup_task.sh",
    "post_task": "/sdcard/tasks/find_nearby_gas_stations/export_result.sh"
  },
  "metadata": {
    "target_keywords": [
      "Gas",
      "Fuel",
      "Petrol",
      "Station",
      "Shell",
      "Chevron",
      "Arco",
      "76",
      "Mobil",
      "Costco",
      "Valero",
      "Rotten Robbie",
      "Exxon",
      "Texaco",
      "Speedway"
    ],
    "detail_indicators": [
      "Navigate",
      "Get directions",
      "Start",
      "Address",
      "min",
      "mi",
      "ft",
      "km"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_find_nearby_gas_stations"
    }
  }
}
