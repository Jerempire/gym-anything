{
  "id": "avoid_ferries@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure Sygic GPS Navigation to strictly avoid ferries in route calculations by enabling the 'Avoid Ferries' option in the route planning settings.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/avoid_ferries/setup_task.sh",
    "post_task": "sh /sdcard/tasks/avoid_ferries/export_result.sh"
  },
  "metadata": {
    "target_ui_text": "Ferries",
    "expected_state": "checked/enabled"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_avoid_ferries"
    }
  }
}
