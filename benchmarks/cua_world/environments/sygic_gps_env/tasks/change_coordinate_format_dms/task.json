{
  "id": "change_coordinate_format_dms@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure Sygic GPS Navigation to display GPS coordinates in 'Degrees, Minutes, Seconds' (DMS) format instead of the default Decimal Degrees. Ensure the setting is active and visible.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/change_coordinate_format_dms/setup_task.sh",
    "post_task": "sh /sdcard/tasks/change_coordinate_format_dms/export_result.sh"
  },
  "metadata": {
    "target_setting": "GPS Coordinates",
    "expected_value": "Degrees, Minutes, Seconds",
    "expected_format_example": "N 40° 26' 46\""
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_change_coordinate_format_dms"
    }
  }
}
