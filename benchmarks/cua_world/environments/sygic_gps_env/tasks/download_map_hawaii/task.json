{
  "id": "download_map_hawaii@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Download the offline map for Hawaii in Sygic GPS Navigation.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/download_map_hawaii/setup_task.sh",
    "post_task": "/sdcard/tasks/download_map_hawaii/export_result.sh",
    "pre_task_timeout": 300
  },
  "metadata": {
    "region_name": "Hawaii",
    "hierarchy": [
      "North America",
      "United States"
    ],
    "expected_file_pattern": "us_hawaii",
    "map_directory": "/sdcard/Android/data/com.sygic.aura/files/Maps"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_download_map_hawaii"
    }
  }
}
