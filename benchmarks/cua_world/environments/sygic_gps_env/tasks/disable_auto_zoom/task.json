{
  "id": "disable_auto_zoom@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Disable the 'Auto-zoom' feature in Sygic GPS Navigation to prevent the map from scaling automatically during navigation. Return to the main map view once the setting is disabled.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/disable_auto_zoom/setup_task.sh",
    "post_task": "sh /sdcard/tasks/disable_auto_zoom/export_result.sh"
  },
  "metadata": {
    "target_pref_key": "bAutoZoom",
    "expected_value": "false",
    "settings_path": "Settings > Route & Navigation"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_disable_auto_zoom"
    }
  }
}
