{
  "id": "set_power_saving_always@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure Sygic GPS Navigation to use 'Power saving' mode at all times to conserve battery life. Ensure the 'Power saving' setting is set to 'Always'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/set_power_saving_always/setup_task.sh",
    "post_task": "/sdcard/tasks/set_power_saving_always/export_result.sh"
  },
  "metadata": {
    "target_setting_key": "power_saving",
    "target_value_text": "Always",
    "target_value_int": "2",
    "settings_context": "Battery management"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_power_saving_always"
    }
  }
}
