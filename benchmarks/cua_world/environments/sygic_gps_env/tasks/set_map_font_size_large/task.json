{
  "id": "set_map_font_size_large@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure Sygic GPS Navigation for better accessibility by changing the map font size from 'Default' to 'Large'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/set_map_font_size_large/setup_task.sh",
    "post_task": "sh /sdcard/tasks/set_map_font_size_large/export_result.sh"
  },
  "metadata": {
    "target_setting": "Map font size",
    "expected_value": "Large",
    "settings_file_pattern": "com.sygic.aura_preferences.xml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_map_font_size_large"
    }
  }
}
