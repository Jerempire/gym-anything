{
  "id": "delete_offline_map@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Delete the 'American Samoa' offline map in Sygic GPS Navigation to free up storage space. Ensure the map is no longer listed as downloaded or installed.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/delete_offline_map/setup_task.sh",
    "post_task": "sh /sdcard/tasks/delete_offline_map/export_result.sh"
  },
  "metadata": {
    "target_map_name": "American Samoa",
    "map_filename_pattern": "*samoa*",
    "expected_action": "deletion"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_delete_offline_map"
    }
  }
}
