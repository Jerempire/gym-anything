{
  "id": "allow_cellular_downloads@1",
  "version": "1.0",
  "env_id": "example.sygic_gps_env@0.1",
  "description": "Configure Sygic GPS Navigation to allow map downloads and updates over cellular data by disabling the restriction that limits large downloads to Wi-Fi only. Return to the main map view once the configuration is complete.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/sdcard/tasks/allow_cellular_downloads/setup_task.sh",
    "post_task": "/sdcard/tasks/allow_cellular_downloads/export_result.sh"
  },
  "metadata": {
    "target_setting_keywords": [
      "wifi",
      "connection",
      "download",
      "cellular"
    ],
    "expected_behavior": "toggle_off"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_allow_cellular_downloads"
    }
  }
}
