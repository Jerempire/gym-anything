{
  "id": "create_patient_form_template@1",
  "version": "1.0",
  "env_id": "nosh_env@0.1",
  "description": "Log in as the administrator (User: admin, Pass: Admin1234!) and create a new active patient form template named 'COVID-19 Screening' in NOSH ChartingSystem. The form must include three fields: 'Has Fever?' (Yes/No), 'New Cough?' (Yes/No), and 'Travel History' (Text).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_patient_form_template/setup_task.sh",
    "post_task": "/workspace/tasks/create_patient_form_template/export_result.sh"
  },
  "metadata": {
    "target_form_title": "COVID-19 Screening",
    "required_fields": [
      {
        "label": "Fever",
        "type_keywords": [
          "yes",
          "no",
          "checkbox",
          "radio",
          "boolean"
        ]
      },
      {
        "label": "Cough",
        "type_keywords": [
          "yes",
          "no",
          "checkbox",
          "radio",
          "boolean"
        ]
      },
      {
        "label": "Travel",
        "type_keywords": [
          "text",
          "area",
          "string",
          "input"
        ]
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_patient_form_template"
    }
  }
}
