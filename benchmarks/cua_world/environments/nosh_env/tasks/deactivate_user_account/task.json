{
  "id": "deactivate_user_account@1",
  "version": "1.0",
  "env_id": "nosh_env@0.1",
  "description": "As the Administrator in NOSH ChartingSystem, deactivate the user account for Medical Assistant 'John Doe' (username: 'jdoe'). Set the account status to Inactive without deleting the account.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/deactivate_user_account/setup_task.sh",
    "post_task": "/workspace/tasks/deactivate_user_account/export_result.sh"
  },
  "metadata": {
    "target_username": "jdoe",
    "target_role": "assistant"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_deactivate_user_account"
    }
  }
}
