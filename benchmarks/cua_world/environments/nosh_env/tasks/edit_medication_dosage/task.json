{
  "id": "edit_medication_dosage@1",
  "version": "1.0",
  "env_id": "nosh_env@0.1",
  "description": "As the admin user, update the active medication order for patient Maria Gonzalez (DOB: 08/15/1962). Modify the existing 'Lisinopril' prescription by increasing the dosage from 10 mg to 20 mg and changing the frequency from once daily to twice daily. Ensure the updated record is saved and remains active in her chart.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/edit_medication_dosage/setup_task.sh",
    "post_task": "/workspace/tasks/edit_medication_dosage/export_result.sh"
  },
  "metadata": {
    "patient_pid": 3,
    "patient_name": "Maria Gonzalez",
    "medication_name": "Lisinopril",
    "target_dosage": "20 mg",
    "target_frequency": "twice daily",
    "required_dosage_substring": "20",
    "required_freq_substrings": [
      "twice",
      "bid",
      "2 times",
      "two times"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_edit_medication_dosage"
    }
  }
}
