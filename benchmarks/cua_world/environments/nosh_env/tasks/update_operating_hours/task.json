{
  "id": "update_operating_hours@1",
  "version": "1.0",
  "env_id": "nosh_env@0.1",
  "description": "Update the practice operating hours for Hillside Family Medicine in NOSH ChartingSystem (Username: 'admin', Password: 'Admin1234!') to reflect new 'Summer Fridays'. The Friday schedule must be updated to close at 1:00 PM (13:00) while maintaining the 8:00 AM opening time. All other days must remain unchanged.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_operating_hours/setup_task.sh",
    "post_task": "/workspace/tasks/update_operating_hours/export_result.sh"
  },
  "metadata": {
    "target_day": "Friday",
    "target_field": "fri_c",
    "expected_value_24h": "13:00",
    "expected_value_sql_partial": "13:00:00",
    "initial_value_24h": "17:00",
    "control_fields": {
      "mon_c": "17:00",
      "fri_o": "08:00"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_operating_hours"
    }
  }
}
