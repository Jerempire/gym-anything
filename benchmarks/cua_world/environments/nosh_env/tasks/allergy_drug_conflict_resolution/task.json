{
  "id": "allergy_drug_conflict_resolution@1",
  "version": "1.0",
  "env_id": "nosh_env@0.1",
  "description": "Perform a medication safety audit at Hillside Family Medicine (Credentials: admin / Admin1234!) to identify and resolve allergy-drug conflicts within your patient panel. For patients with active prescriptions conflicting with documented allergies, discontinue the contraindicated medication, prescribe a safe alternative, and create an encounter note documenting the clinical rationale. Do not modify medications for patients whose documented allergies do not conflict with their current prescriptions.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 1440,
    "max_steps": 140,
    "reward_type": "dense"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/allergy_drug_conflict_resolution/setup_task.sh",
    "post_task": "/workspace/tasks/allergy_drug_conflict_resolution/export_result.sh"
  },
  "metadata": {
    "conflict_patients": [
      {
        "pid": 32,
        "name": "Marcus Odom",
        "dob": "1972-04-15",
        "allergy": "Sulfonamides",
        "conflicting_rx": "Trimethoprim-Sulfamethoxazole",
        "conflict_reason": "TMP-SMX contains a sulfonamide antibiotic"
      },
      {
        "pid": 33,
        "name": "Patricia Fenn",
        "dob": "1965-09-28",
        "allergy": "Penicillin",
        "conflicting_rx": "Amoxicillin",
        "conflict_reason": "Amoxicillin is a penicillin-type antibiotic"
      },
      {
        "pid": 34,
        "name": "Theodore Ashe",
        "dob": "1980-02-14",
        "allergy": "Codeine",
        "conflicting_rx": "Codeine Phosphate",
        "conflict_reason": "Direct allergy to codeine"
      }
    ],
    "noise_patient": {
      "pid": 35,
      "name": "Nancy Briggs",
      "dob": "1970-07-03",
      "allergy": "Latex",
      "rx": "Metformin",
      "conflict": false
    },
    "pass_threshold": 60
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_allergy_drug_conflict_resolution"
    }
  }
}
