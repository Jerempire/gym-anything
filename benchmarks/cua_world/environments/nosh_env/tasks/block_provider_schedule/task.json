{
  "id": "block_provider_schedule@1",
  "version": "1.0",
  "env_id": "nosh_env@0.1",
  "description": "Log in as admin (Username: admin, Password: Admin1234!) and block Dr. James Carter's schedule for today from 1:00 PM to 2:00 PM. Create a non-patient event with the reason 'Staff Meeting'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/block_provider_schedule/setup_task.sh",
    "post_task": "/workspace/tasks/block_provider_schedule/export_result.sh"
  },
  "metadata": {
    "target_provider_id": 2,
    "target_provider_name": "James Carter",
    "target_start_time": "13:00:00",
    "target_end_time": "14:00:00",
    "target_reason": "Staff Meeting"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_block_provider_schedule"
    }
  }
}
