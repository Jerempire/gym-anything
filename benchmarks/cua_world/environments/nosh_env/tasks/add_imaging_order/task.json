{
  "id": "add_imaging_order@1",
  "version": "1.0",
  "env_id": "nosh_env@0.1",
  "description": "As provider 'demo_provider' (password: 'Provider1234!'), create an Imaging/Radiology order for patient 'Robert Murphy' (DOB: 08/15/1972) in the NOSH ChartingSystem. The order must specify the study as 'MRI Lumbar Spine without Contrast' and the indication as 'Chronic lower back pain with left-sided radiculopathy'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_imaging_order/setup_task.sh",
    "post_task": "/workspace/tasks/add_imaging_order/export_result.sh"
  },
  "metadata": {
    "patient_fname": "Robert",
    "patient_lname": "Murphy",
    "patient_dob": "1972-08-15",
    "required_terms": [
      "MRI",
      "Lumbar",
      "Spine"
    ],
    "required_indication_terms": [
      "back pain",
      "radiculopathy"
    ],
    "order_type": "rad"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_imaging_order"
    }
  }
}
