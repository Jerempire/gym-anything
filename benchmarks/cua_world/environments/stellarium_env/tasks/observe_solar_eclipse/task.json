{
  "id": "observe_solar_eclipse@1",
  "version": "1.0",
  "env_id": "stellarium_env@0.1",
  "description": "Observe the Total Solar Eclipse of August 21, 2017 (the Great American Eclipse) from Hopkinsville, Kentucky (36.8656° N, 87.4886° W). Center the view on the Sun at approximately 18:24 UTC on August 21, 2017, to show the moment of totality with the Moon fully covering the solar disk.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/observe_solar_eclipse/setup_task.sh"
  },
  "metadata": {
    "eclipse_date": "2017-08-21",
    "eclipse_time_utc": "18:24:28",
    "location_name": "Hopkinsville, Kentucky",
    "location_latitude": 36.8656,
    "location_longitude": -87.4886,
    "totality_duration_sec": 160,
    "eclipse_magnitude": 1.0306,
    "data_source": "NASA Eclipse Database (eclipse.gsfc.nasa.gov)"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_observe_solar_eclipse"
    }
  }
}
