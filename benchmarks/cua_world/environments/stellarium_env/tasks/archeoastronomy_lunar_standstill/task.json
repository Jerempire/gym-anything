{
  "id": "archeoastronomy_lunar_standstill@1",
  "version": "1.0",
  "env_id": "stellarium_env@0.1",
  "description": "Simulate the Major Lunar Standstill northern extreme moonrise at Chimney Rock Great House (37.193° N, 107.309° W, 2300 m) on December 15, 2024, at 23:50:00 UTC. Capture a screenshot of the Moon rising in the northeast, centered in the view, to /home/ga/Pictures/stellarium/. Write an educational brief to /home/ga/Desktop/standstill_brief.txt containing the location name (Chimney Rock), the date of the event, and the measured azimuth of the moonrise.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/archeoastronomy_lunar_standstill/setup_task.sh",
    "post_task": "/workspace/tasks/archeoastronomy_lunar_standstill/export_result.sh"
  },
  "metadata": {
    "location_name": "Chimney Rock Great House",
    "target_lat_deg": 37.193,
    "target_lon_deg": -107.309,
    "target_lat_rad": 0.64914,
    "target_lon_rad": -1.87288,
    "target_altitude_m": 2300,
    "event_date": "2024-12-15",
    "event_time_utc": "23:50:00",
    "required_display_flags": {
      "flag_atmosphere": false,
      "flag_landscape": true,
      "flag_azimuthal_grid": true,
      "flag_cardinal_points": true
    },
    "brief_path": "/home/ga/Desktop/standstill_brief.txt",
    "screenshots_dir": "/home/ga/Pictures/stellarium",
    "min_screenshots": 1
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_archeoastronomy_lunar_standstill"
    }
  }
}
