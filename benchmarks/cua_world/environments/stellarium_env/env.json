{
  "id": "stellarium_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Stellarium desktop planetarium environment for astronomical observation planning, celestial navigation, and sky visualization tasks",
  "category": "science",
  "tags": ["linux", "science", "astronomy", "desktop", "planetarium"],
  "resources": {
    "cpu": 4,
    "mem_gb": 4,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/stellarium_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/stellarium_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/stellarium_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/stellarium_env/data", "target": "/workspace/data", "mode": "ro"}
  ],
  "vnc": {"password": "password"},
  "hooks": {
    "pre_start": "/workspace/scripts/install_stellarium.sh",
    "post_start": "/workspace/scripts/setup_stellarium.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ]
}
