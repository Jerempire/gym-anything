{
  "id": "compose_email@1",
  "version": "1.0",
  "env_id": "claude.thunderbird_env@0.1",
  "description": "Compose and send a new email to recipient@example.com with subject 'Meeting Tomorrow' and body containing the word 'agenda'",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 120,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/compose_email/setup_task.sh",
    "post_task": "/workspace/tasks/compose_email/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_email_sent"
    }
  }
}
