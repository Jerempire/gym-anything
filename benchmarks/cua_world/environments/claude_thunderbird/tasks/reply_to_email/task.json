{
  "id": "reply_to_email@1",
  "version": "1.0",
  "env_id": "claude.thunderbird_env@0.1",
  "description": "Reply to the email from sender@example.com with subject 'Welcome to Thunderbird'. The reply should contain the word 'thanks'",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 120,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/reply_to_email/setup_task.sh",
    "post_task": "/workspace/tasks/reply_to_email/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reply_sent"
    }
  }
}
