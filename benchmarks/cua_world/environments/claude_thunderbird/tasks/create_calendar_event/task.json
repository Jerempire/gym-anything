{
  "id": "create_calendar_event@1",
  "version": "1.0",
  "env_id": "claude.thunderbird_env@0.1",
  "description": "Create a new calendar event titled 'Team Meeting' scheduled for tomorrow at 2:00 PM",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_calendar_event/setup_task.sh",
    "post_task": "/workspace/tasks/create_calendar_event/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_event_created"
    }
  }
}
