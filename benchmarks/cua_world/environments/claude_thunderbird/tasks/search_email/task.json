{
  "id": "search_email@1",
  "version": "1.0",
  "env_id": "claude.thunderbird_env@0.1",
  "description": "Use Thunderbird's search feature to find the email with subject containing 'Welcome to Thunderbird' and mark it as starred/flagged",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 120,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/search_email/setup_task.sh",
    "post_task": "/workspace/tasks/search_email/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_email_flagged"
    }
  }
}
