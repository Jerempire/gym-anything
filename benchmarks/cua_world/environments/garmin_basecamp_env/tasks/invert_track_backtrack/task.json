{
  "id": "invert_track_backtrack@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Create a return path named 'Extraction_Path' by reversing the 'Fells Loop' track. Set the track color to Blue and export the 'Extraction_Path' track to C:\\workspace\\extraction_path.gpx. Do not modify the original Fells Loop track.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\invert_track_backtrack\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\invert_track_backtrack\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\extraction_path.gpx",
    "expected_track_name": "Extraction_Path",
    "expected_color": "Blue",
    "original_track_path": "C:\\workspace\\data\\fells_loop.gpx"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_invert_track_backtrack"
    }
  }
}
