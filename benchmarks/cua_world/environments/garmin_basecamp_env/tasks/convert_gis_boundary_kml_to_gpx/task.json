{
  "id": "convert_gis_boundary_kml_to_gpx@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Import 'C:\\workspace\\data\\fells_boundary.kml', rename the track to 'Fells Reservation Boundary', and set its display color to Magenta. Create a waypoint named 'South Entrance' at 42.438, -71.105. Export both the track and waypoint from the same list as a GPX file to 'C:\\workspace\\output\\patrol_boundary.gpx'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\convert_gis_boundary_kml_to_gpx\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\convert_gis_boundary_kml_to_gpx\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\patrol_boundary.gpx",
    "expected_track_name": "Fells Reservation Boundary",
    "expected_color": "Magenta",
    "expected_waypoint_name": "South Entrance",
    "target_lat": 42.438,
    "target_lon": -71.105,
    "coordinate_tolerance": 0.005,
    "min_track_points": 100
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_kml_to_gpx_conversion"
    }
  }
}
