{
  "id": "reverse_route_direction@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Reverse the direction of the 'Fells Morning Patrol' route in Garmin BaseCamp, rename it 'Fells Return Patrol', and export it as a GPX file to C:\\Users\\Docker\\Documents\\fells_return_patrol.gpx. BaseCamp is open and the route is in My Collection.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\reverse_route_direction\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\reverse_route_direction\\export_result.ps1"
  },
  "metadata": {
    "expected_output_file": "C:\\Users\\Docker\\Documents\\fells_return_patrol.gpx",
    "expected_route_name": "Fells Return Patrol",
    "expected_start_lat": 42.434,
    "expected_end_lat": 42.438,
    "tolerance_deg": 0.001
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reverse_route_direction"
    }
  }
}
