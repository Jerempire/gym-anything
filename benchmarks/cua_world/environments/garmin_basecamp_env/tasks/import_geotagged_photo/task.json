{
  "id": "import_geotagged_photo@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Import the geotagged photo 'campsite_evidence.jpg' from C:\\workspace\\data\\ into Garmin BaseCamp. Rename the resulting waypoint to 'Illegal_Campsite' and export it as a GPX file to 'C:\\workspace\\output\\campsite_report.gpx'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\import_geotagged_photo\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\import_geotagged_photo\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\campsite_report.gpx",
    "expected_waypoint_name": "Illegal_Campsite",
    "expected_lat": 43.4674,
    "expected_lon": 11.8851
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_import_geotagged_photo"
    }
  }
}
