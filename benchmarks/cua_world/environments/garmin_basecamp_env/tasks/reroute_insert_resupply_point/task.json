{
  "id": "reroute_insert_resupply_point@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Modify the 'Fells_Survey' route in Garmin BaseCamp to include the 'Water Cache' waypoint between 'South Gate' and 'Bear Hill'. Update the route's Activity Profile to 'Hiking' (or 'Pedestrian') and export the modified route as a GPX file to 'C:\\workspace\\output\\updated_survey_route.gpx'. BaseCamp is already running with the data loaded in My Collection.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\reroute_insert_resupply_point\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\reroute_insert_resupply_point\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\updated_survey_route.gpx",
    "expected_route_name": "Fells_Survey",
    "expected_sequence": [
      "South Gate",
      "Water Cache",
      "Bear Hill"
    ],
    "expected_profiles": [
      "Hiking",
      "Pedestrian"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reroute"
    }
  }
}
