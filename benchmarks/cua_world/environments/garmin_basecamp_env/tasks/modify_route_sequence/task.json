{
  "id": "modify_route_sequence@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Modify the 'Fells Core Survey' route in Garmin BaseCamp to include the 'Invasive Knotweed Patch' waypoint exactly between 'Intersection 2' and 'Intersection 3' and the 'Ranger Station' waypoint at the end. Rename the route to 'Fells Modified Survey' and export it as a GPX file to C:\\workspace\\output\\modified_survey.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\modify_route_sequence\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\modify_route_sequence\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\modified_survey.gpx",
    "expected_route_name": "Fells Modified Survey",
    "expected_sequence": [
      "Trailhead",
      "Intersection 1",
      "Intersection 2",
      "Invasive Knotweed Patch",
      "Intersection 3",
      "Ranger Station"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_modify_route_sequence"
    }
  }
}
