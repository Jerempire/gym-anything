{
  "id": "analyze_off_trail_detour@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Compare the 'Fells_Baseline' trail track against the 'Volunteer_Log' GPS track in Garmin BaseCamp to identify the apex where the volunteer deviated and turned around. Create a waypoint named 'Illegal_Camp' at this turnaround point and export it to C:\\workspace\\output\\campsite_location.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\analyze_off_trail_detour\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\analyze_off_trail_detour\\export_result.ps1"
  },
  "metadata": {
    "expected_export_path": "C:\\workspace\\output\\campsite_location.gpx",
    "expected_waypoint_name": "Illegal_Camp",
    "distance_thresholds_meters": {
      "high_precision": 15,
      "medium_precision": 50,
      "low_precision": 150
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_analyze_off_trail_detour"
    }
  }
}
