{
  "id": "mark_track_intersection_waypoint@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Identify the intersection of the 'Suspect_Vehicle' and 'Refuge_Boundary' tracks. Create a waypoint named 'Incursion' at this point and export only this waypoint to C:\\workspace\\output\\incursion_point.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\mark_track_intersection_waypoint\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\mark_track_intersection_waypoint\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\incursion_point.gpx",
    "expected_waypoint_name": "Incursion",
    "tolerance_fair_meters": 100.0,
    "tolerance_excellent_meters": 30.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mark_intersection"
    }
  }
}
