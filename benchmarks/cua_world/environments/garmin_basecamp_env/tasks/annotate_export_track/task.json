{
  "id": "annotate_export_track@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Modify the 'fells_loop' track in Garmin BaseCamp by changing its display color to 'Red' and adding the note 'Priority survey area - invasive species detected along ridgeline' to its description. Export the modified track as a GPX file to C:\\workspace\\output\\annotated_track.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\annotate_export_track\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\annotate_export_track\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\annotated_track.gpx",
    "expected_color": "Red",
    "expected_description": "invasive species detected",
    "data_source": "fells_loop.gpx (Middlesex Fells Reservation)"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_annotate_export_track"
    }
  }
}
