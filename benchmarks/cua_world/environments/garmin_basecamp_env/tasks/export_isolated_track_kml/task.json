{
  "id": "export_isolated_track_kml@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Rename the imported track to 'Official Survey Path' and export only this track, excluding any waypoints, as a KML file to C:\\Users\\Docker\\Documents\\survey_path.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_isolated_track_kml\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_isolated_track_kml\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\Users\\Docker\\Documents\\survey_path.kml",
    "expected_track_name": "Official Survey Path"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_isolated_track_kml"
    }
  }
}
