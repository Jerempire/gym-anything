{
  "id": "filter_track_points@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Filter the 'Fells Loop' track to a maximum of 500 points and rename the result to 'Fells_Loop_500'. Export the simplified track as a GPX file to C:\\workspace\\output\\simplified_track.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\filter_track_points\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\filter_track_points\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\simplified_track.gpx",
    "expected_track_name": "Fells_Loop_500",
    "target_max_points": 500,
    "min_points": 100,
    "data_source": "Middlesex Fells Reservation (fells_loop.gpx)"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_filter_track_points"
    }
  }
}
