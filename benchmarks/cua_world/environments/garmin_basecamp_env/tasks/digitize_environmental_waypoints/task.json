{
  "id": "digitize_environmental_waypoints@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Configure Garmin BaseCamp to use Metric units (Meters, Celsius) and Decimal Degrees (hddd.ddddd°) position format. Create three waypoints for Spot Pond water quality stations: 'Station-Alpha' (42.45100, -71.10200, Elevation 44.0m, Depth 3.5m, Temperature 20.0C), 'Station-Beta' (42.45350, -71.09800, Elevation 44.0m, Depth 7.2m, Temperature 18.5C), and 'Station-Gamma' (42.45600, -71.10500, Elevation 44.0m, Depth 2.1m, Temperature 21.3C). Export these three waypoints as a single GPX file to C:\\workspace\\output\\water_quality_stations.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\digitize_environmental_waypoints\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\digitize_environmental_waypoints\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\water_quality_stations.gpx",
    "stations": {
      "Station-Alpha": {
        "lat": 42.451,
        "lon": -71.102,
        "ele": 44.0,
        "depth": 3.5,
        "temp": 20.0
      },
      "Station-Beta": {
        "lat": 42.4535,
        "lon": -71.098,
        "ele": 44.0,
        "depth": 7.2,
        "temp": 18.5
      },
      "Station-Gamma": {
        "lat": 42.456,
        "lon": -71.105,
        "ele": 44.0,
        "depth": 2.1,
        "temp": 21.3
      }
    },
    "tolerances": {
      "coord": 0.0001,
      "ele": 0.5,
      "depth": 0.1,
      "temp": 0.5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_digitize_environmental_waypoints"
    }
  }
}
