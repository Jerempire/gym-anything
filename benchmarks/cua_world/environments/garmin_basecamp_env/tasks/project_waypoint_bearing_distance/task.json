{
  "id": "project_waypoint_bearing_distance@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Rename an existing waypoint in the Fells Loop dataset to 'Origin-Landmark'. Project a new waypoint from 'Origin-Landmark' at a distance of 450 meters and a bearing of 135 degrees, naming it 'Sample-Plot-Alpha'. Export both waypoints to a GPX file at C:\\workspace\\output\\projected_plot.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\project_waypoint_bearing_distance\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\project_waypoint_bearing_distance\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\projected_plot.gpx",
    "target_distance_m": 450,
    "target_bearing_deg": 135,
    "distance_tolerance": 15,
    "bearing_tolerance": 5,
    "origin_name": "Origin-Landmark",
    "target_name": "Sample-Plot-Alpha"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_project_waypoint_bearing_distance"
    }
  }
}
