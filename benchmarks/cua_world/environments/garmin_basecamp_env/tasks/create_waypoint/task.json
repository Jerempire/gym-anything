  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_waypoint\\setup_task.ps1"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_waypoint"
    }
  }
}
