{
  "id": "filter_waypoints_elevation_band@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Identify all waypoints in the amphibian sightings dataset ('C:\\workspace\\data\\amphibian_sightings.gpx') that have an elevation between 200 ft and 400 ft (inclusive). Export only these matching waypoints to 'C:\\workspace\\output\\mid_elevation_sightings.gpx'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/filter_waypoints_elevation_band/setup_task.sh",
    "post_task": "/workspace/tasks/filter_waypoints_elevation_band/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\mid_elevation_sightings.gpx",
    "targets": [
      "Sighting_03",
      "Sighting_04",
      "Sighting_05",
      "Sighting_06",
      "Sighting_07"
    ],
    "out_of_bounds": [
      "Sighting_01",
      "Sighting_02",
      "Sighting_08",
      "Sighting_09",
      "Sighting_10"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_filter_waypoints"
    }
  }
}
