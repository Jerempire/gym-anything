{
  "id": "close_track_loop_edit_point@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Close the 'fells_loop' track boundary by matching the last track point's coordinates to the first. Rename the track to 'Closed_Boundary_Loop', set the display color to 'Yellow', and export the result as a GPX file to C:\\workspace\\output\\closed_boundary.gpx.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\close_track_loop_edit_point\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\close_track_loop_edit_point\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\closed_boundary.gpx",
    "expected_track_name": "Closed_Boundary_Loop",
    "expected_color": "Yellow",
    "min_points_threshold": 20
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_close_track_loop"
    }
  }
}
