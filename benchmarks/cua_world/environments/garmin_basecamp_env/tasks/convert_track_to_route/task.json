{
  "id": "convert_track_to_route@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Convert the 'Fells Loop' GPS track in Garmin BaseCamp into a navigable route named 'Fells Survey Route'. Export the resulting route as a GPX file to C:\\Users\\Docker\\Documents\\fells_survey_export.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\convert_track_to_route\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\convert_track_to_route\\export_result.ps1"
  },
  "metadata": {
    "expected_export_path": "C:\\Users\\Docker\\Documents\\fells_survey_export.gpx",
    "expected_route_name": "Fells Survey Route",
    "min_route_points": 5,
    "geo_bounds": {
      "lat_min": 42.41,
      "lat_max": 42.49,
      "lon_min": -71.14,
      "lon_max": -71.06
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_convert_track_to_route"
    }
  }
}
