{
  "id": "configure_custom_activity_profile@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Create a custom Activity Profile named 'SAR-ATV' configured with a 'Shorter Distance' route preference. Using this profile, draw a route consisting of at least three distinct points within the Middlesex Fells Reservation. Export the resulting route as a GPX file to C:\\workspace\\sar_patrol_route.gpx.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_custom_activity_profile\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_custom_activity_profile\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\sar_patrol_route.gpx",
    "expected_profile_name": "SAR-ATV",
    "min_route_points": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_custom_activity_profile"
    }
  }
}
