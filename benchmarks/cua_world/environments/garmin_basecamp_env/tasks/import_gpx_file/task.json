{
  "id": "import_gpx_file@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Import the GPS track file 'dole_langres_track.gpx' from the Desktop into Garmin BaseCamp. The file contains a GPS track from Dole to Langres, France.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\import_gpx_file\\setup_task.ps1"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_import_gpx_file"
    }
  }
}
