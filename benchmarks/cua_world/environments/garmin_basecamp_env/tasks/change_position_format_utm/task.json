{
  "id": "change_position_format_utm@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Record the UTM coordinates of every waypoint from the imported Fells Loop data into C:\\workspace\\output\\utm_coordinates.txt. Use the format 'WaypointName: ZoneDesignator Easting Northing' (one per line, e.g., 'Summit: 19T 327500 4703200').",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\change_position_format_utm\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\change_position_format_utm\\export_result.ps1"
  },
  "metadata": {
    "expected_output_file": "C:\\workspace\\output\\utm_coordinates.txt",
    "expected_zone": "19T",
    "min_easting": 320000,
    "max_easting": 340000,
    "min_northing": 4690000,
    "max_northing": 4710000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_change_position_format_utm"
    }
  }
}
