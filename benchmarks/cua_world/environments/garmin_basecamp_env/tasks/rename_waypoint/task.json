{
  "id": "rename_waypoint@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Rename the waypoint 'BELLEVUE' to 'Bellevue Parking' in Garmin BaseCamp. The waypoint is located in My Collection within the Bellevue Fells trail data.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\rename_waypoint\\setup_task.ps1"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rename_waypoint"
    }
  }
}
