{
  "id": "measure_burn_area_acreage@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Determine the enclosed area of the 'fells_loop' track in Acres within Garmin BaseCamp. Round the acreage to the nearest whole integer and rename the track to 'Fells_Conservation_[X]_Acres', replacing [X] with the rounded value. Export the renamed track as a GPX file to C:\\workspace\\output\\fells_conservation.gpx",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\measure_burn_area_acreage\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\measure_burn_area_acreage\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\fells_conservation.gpx",
    "expected_regex": "^Fells_Conservation_(\\d+)_Acres$",
    "area_tolerance_percent": 15
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_measure_burn_area_acreage"
    }
  }
}
