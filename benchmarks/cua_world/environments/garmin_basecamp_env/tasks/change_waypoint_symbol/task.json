{
  "id": "change_waypoint_symbol@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Change the map symbol of the waypoint 'BEAR HILL' to the 'Summit' symbol in Garmin BaseCamp. The 'BEAR HILL' waypoint is already loaded in My Collection from the Bellevue Fells trail data.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\change_waypoint_symbol\\setup_task.ps1"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_change_waypoint_symbol"
    }
  }
}
