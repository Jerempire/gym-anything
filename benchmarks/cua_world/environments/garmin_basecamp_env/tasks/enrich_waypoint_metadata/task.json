{
  "id": "enrich_waypoint_metadata@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Create a waypoint named 'Damaged Bridge B-42' at N 42.45100°, W 71.09800° (Middlesex Fells area). Add a web link to the waypoint with the URL 'https://city.gov/engineering/reports/b42.pdf' and description 'Structural Assessment B-42'. Assign the waypoint to a custom category named 'Maintenance_Priority_1' and export the data as a GPX file to C:\\workspace\\output\\maintenance_export.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 45,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\enrich_waypoint_metadata\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\enrich_waypoint_metadata\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "maintenance_export.gpx",
    "expected_output_path": "C:\\workspace\\output\\maintenance_export.gpx",
    "expected_wpt_name": "Damaged Bridge B-42",
    "expected_lat": 42.451,
    "expected_lon": -71.098,
    "expected_link_url": "https://city.gov/engineering/reports/b42.pdf",
    "expected_link_text": "Structural Assessment B-42",
    "expected_category": "Maintenance_Priority_1"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enrich_waypoint_metadata"
    }
  }
}
