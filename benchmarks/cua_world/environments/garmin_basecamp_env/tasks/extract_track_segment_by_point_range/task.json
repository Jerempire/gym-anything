{
  "id": "extract_track_segment_by_point_range@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Create a new track named 'Transect_Soil_Samples' using points from index 250 to 350 inclusive of the 'fells_loop' track. Export only the 'Transect_Soil_Samples' track as a GPX file to C:\\workspace\\output\\transect_extracted.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\extract_track_segment_by_point_range\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\extract_track_segment_by_point_range\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\transect_extracted.gpx",
    "expected_track_name": "Transect_Soil_Samples",
    "expected_point_count": 101,
    "ground_truth_gpx": "C:\\workspace\\data\\fells_loop.gpx",
    "target_start_index": 250
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_extract_track_segment"
    }
  }
}
