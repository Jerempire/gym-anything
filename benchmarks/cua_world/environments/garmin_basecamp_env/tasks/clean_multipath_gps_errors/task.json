{
  "id": "clean_multipath_gps_errors@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Clean the simulated GPS multipath error in the track 'Fells Spiked' within Garmin BaseCamp by removing the anomalous coordinate spikes. Rename the corrected track to 'Fells Cleaned' and export it as a GPX file to 'C:\\workspace\\data\\fells_cleaned.gpx'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\clean_multipath_gps_errors\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\clean_multipath_gps_errors\\export_result.ps1"
  },
  "metadata": {
    "expected_output_file": "C:\\workspace\\data\\fells_cleaned.gpx",
    "expected_track_name": "Fells Cleaned",
    "spike_latitude_threshold": 44.0,
    "minimum_preserved_points": 50
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_clean_multipath_gps_errors"
    }
  }
}
