{
  "id": "export_multiformat_track@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Export the 'fells_loop' track from the Garmin BaseCamp library into two formats. Save the track as a KML file to C:\\workspace\\output\\fells_visual.kml and as a CSV file to C:\\workspace\\output\\fells_data.csv. Ensure the CSV export contains the actual track points (coordinates and elevations) rather than a summary.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_multiformat_track\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_multiformat_track\\export_result.ps1"
  },
  "metadata": {
    "expected_kml": "C:\\workspace\\output\\fells_visual.kml",
    "expected_csv": "C:\\workspace\\output\\fells_data.csv"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_multiformat_track"
    }
  }
}
