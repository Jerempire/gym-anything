{
  "id": "archive_database_backup@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Create a waypoint named 'MIGRATION-CHECKPOINT' containing the note 'Authorized by GIS Dept'. Export a full database backup to C:\\workspace\\output\\BaseCamp_Archive.Backup.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\archive_database_backup\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\archive_database_backup\\export_result.ps1"
  },
  "metadata": {
    "expected_backup_path": "C:\\workspace\\output\\BaseCamp_Archive.Backup",
    "waypoint_name": "MIGRATION-CHECKPOINT",
    "waypoint_note": "Authorized by GIS Dept"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_archive_database_backup"
    }
  }
}
