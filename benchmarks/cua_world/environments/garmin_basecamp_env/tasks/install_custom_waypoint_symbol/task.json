{
  "id": "install_custom_waypoint_symbol@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Create a 32x32 pixel BMP image and save it to C:\\Users\\Docker\\Documents\\My Garmin\\Custom Waypoint Symbols\\001.bmp. Create a waypoint named 'Sensor-Alpha' at 42.445, -71.095 using this custom symbol and export the data to C:\\workspace\\output\\sensor_network.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 400,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\install_custom_waypoint_symbol\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\install_custom_waypoint_symbol\\export_result.ps1"
  },
  "metadata": {
    "lat": 42.445,
    "lon": -71.095,
    "waypoint_name": "Sensor-Alpha"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_install_custom_waypoint_symbol"
    }
  }
}
