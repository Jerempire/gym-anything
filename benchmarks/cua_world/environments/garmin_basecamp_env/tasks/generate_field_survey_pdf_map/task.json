{
  "id": "generate_field_survey_pdf_map@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "In Garmin BaseCamp, print the map view to a PDF file using the 'Microsoft Print to PDF' printer. Configure the page orientation to 'Landscape' and set the map title to 'Fells Loop Volunteer Map'. Save the output to C:\\workspace\\fells_map.pdf.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\generate_field_survey_pdf_map\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\generate_field_survey_pdf_map\\export_result.ps1"
  },
  "metadata": {
    "expected_title": "Fells Loop Volunteer Map",
    "expected_pdf_path": "C:\\workspace\\fells_map.pdf",
    "min_file_size_bytes": 15000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_field_survey_pdf_map"
    }
  }
}
