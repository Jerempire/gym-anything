{
  "id": "prepare_clean_map_screenshot@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Create a BaseCamp List named 'Presentation Map' containing only the track from the 'fells_loop' dataset. Set the track color to Red and ensure only this list is visible on the map. Save a full-screen screenshot to 'C:\\workspace\\output\\clean_map.png' and export the list as a GPX file to 'C:\\workspace\\output\\presentation_map.gpx'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\prepare_clean_map_screenshot\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\prepare_clean_map_screenshot\\export_result.ps1"
  },
  "metadata": {
    "expected_gpx_path": "C:\\workspace\\output\\presentation_map.gpx",
    "expected_png_path": "C:\\workspace\\output\\clean_map.png",
    "expected_track_color": "Red"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_prepare_clean_map_screenshot"
    }
  }
}
