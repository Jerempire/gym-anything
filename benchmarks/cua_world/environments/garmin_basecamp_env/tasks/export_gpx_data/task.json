{
  "id": "export_gpx_data@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Export the 'Fells Loop' trail data from Garmin BaseCamp to a GPX file saved at C:\\Users\\Docker\\Documents\\exported_fells_loop.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_gpx_data\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_gpx_data\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\Users\\Docker\\Documents\\exported_fells_loop.gpx",
    "expected_filename": "exported_fells_loop.gpx",
    "min_file_size_bytes": 500,
    "min_data_points": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_gpx_data"
    }
  }
}
