{
  "id": "set_waypoint_proximity_alerts@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Set a 200-meter proximity alert radius for the first three waypoints (sorted alphabetically) in the imported Fells Loop dataset. Export the complete dataset as a GPX file to C:\\Users\\Docker\\Documents\\fells_proximity_alerts.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\set_waypoint_proximity_alerts\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\set_waypoint_proximity_alerts\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\Users\\Docker\\Documents\\fells_proximity_alerts.gpx",
    "expected_proximity_value": 200,
    "proximity_tolerance": 5,
    "required_proximity_count": 3
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_waypoint_proximity_alerts"
    }
  }
}
