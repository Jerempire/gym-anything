{
  "id": "generate_multiday_trip_planner@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Generate a multi-day trip from 'Port_of_Boston' to 'Chicago_Rail_Yard' using the waypoints in your Library, limited to 8 hours of driving per day. Export the resulting trip as a GPX file to C:\\workspace\\output\\freight_itinerary.gpx",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\generate_multiday_trip_planner\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\generate_multiday_trip_planner\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\freight_itinerary.gpx",
    "boston_lat": 42.34,
    "boston_lon": -71.04,
    "chicago_lat": 41.81,
    "chicago_lon": -87.63,
    "max_driving_hours": 8
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_multiday_trip_planner"
    }
  }
}
