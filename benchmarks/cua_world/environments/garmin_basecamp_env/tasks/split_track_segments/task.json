{
  "id": "split_track_segments@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Split the 'Fells Loop' track at approximately the midpoint of its track point list into two segments named 'Fells North Segment' and 'Fells South Segment'. Export the segments to 'C:\\workspace\\fells_north.gpx' and 'C:\\workspace\\fells_south.gpx' respectively.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\split_track_segments\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\split_track_segments\\export_result.ps1"
  },
  "metadata": {
    "expected_north_name": "Fells North Segment",
    "expected_south_name": "Fells South Segment",
    "min_segment_points": 10,
    "continuity_tolerance_meters": 500
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_split_track"
    }
  }
}
