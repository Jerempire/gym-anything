{
  "id": "mark_track_distance_midpoint@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Garmin BaseCamp is running with `fells_loop.gpx` data pre-imported. Find the halfway point by trail distance of the `fells_loop` track and create a waypoint at that location named `Lunch_Stop` with the notes `Halfway rest point`. Export the `Lunch_Stop` waypoint to `C:\\workspace\\output\\lunch_stop.gpx`.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\mark_track_distance_midpoint\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\mark_track_distance_midpoint\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\lunch_stop.gpx",
    "expected_name": "Lunch_Stop",
    "expected_notes": "Halfway rest point",
    "track_file": "C:\\workspace\\data\\fells_loop.gpx"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mark_track_distance_midpoint"
    }
  }
}
