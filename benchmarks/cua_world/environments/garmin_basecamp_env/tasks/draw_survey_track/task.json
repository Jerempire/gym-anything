{
  "id": "draw_survey_track@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Create a track named 'BBS Transect 7' with at least 6 track points in the vicinity of the existing Fells Loop data. Export the track as a GPX file to C:\\workspace\\output\\bbs_transect_7.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\draw_survey_track\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\draw_survey_track\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\bbs_transect_7.gpx",
    "expected_track_name": "BBS Transect 7",
    "min_track_points": 6
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_draw_survey_track"
    }
  }
}
