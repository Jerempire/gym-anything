{
  "id": "shift_track_timestamps@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "The loaded 'fells_loop' GPS track was recorded with the wrong time zone (UTC instead of local EST). Shift the timestamps of all track points in the 'fells_loop' track exactly 5 hours earlier and export the modified track as a GPX file to C:\\workspace\\output\\time_corrected_fells.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\shift_track_timestamps\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\shift_track_timestamps\\export_result.ps1"
  },
  "metadata": {
    "original_gpx_path": "C:\\workspace\\data\\fells_loop.gpx",
    "expected_output_path": "C:\\workspace\\output\\time_corrected_fells.gpx",
    "expected_time_shift_seconds": -18000,
    "tolerance_seconds": 2
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_shift_track_timestamps"
    }
  }
}
