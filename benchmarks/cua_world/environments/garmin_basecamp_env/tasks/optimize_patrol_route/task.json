{
  "id": "optimize_patrol_route@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Import the camera stations from C:\\workspace\\data\\camera_stations.gpx and create a route connecting all 5 stations optimized for the shortest travel path. Name the route 'Optimized Patrol' and export it to C:\\workspace\\optimized_patrol.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 45,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/optimize_patrol_route/setup_task.sh",
    "post_task": "/workspace/tasks/optimize_patrol_route/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "C:/workspace/optimized_patrol.gpx",
    "expected_route_name": "Optimized Patrol",
    "expected_point_count": 5,
    "max_optimized_distance_km": 8.0,
    "original_distance_km": 12.5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_optimize_patrol_route"
    }
  }
}
