{
  "id": "isolate_waypoints_by_symbol@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Create a list named 'Campsites' containing only the waypoints with the 'Campground' symbol from the 'park_master_data' dataset and export it to C:\\workspace\\output\\campsites.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\isolate_waypoints_by_symbol\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\isolate_waypoints_by_symbol\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\campsites.gpx",
    "expected_waypoint_count": 4,
    "expected_symbol": "Campground",
    "expected_names": [
      "North Camp",
      "South Camp",
      "River Camp",
      "Ridge Camp"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_isolate_waypoints_by_symbol"
    }
  }
}
