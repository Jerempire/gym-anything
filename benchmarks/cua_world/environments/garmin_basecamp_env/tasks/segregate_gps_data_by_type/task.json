{
  "id": "segregate_gps_data_by_type@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Organize the 'fells_loop' data into a List Folder named 'ArcGIS_Staging' containing two lists: 'Waypoints_Layer' for waypoints and 'Track_Layer' for tracks. Export the 'Waypoints_Layer' list to C:\\workspace\\output\\waypoints_layer.gpx and the 'Track_Layer' list to C:\\workspace\\output\\track_layer.gpx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\segregate_gps_data_by_type\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\segregate_gps_data_by_type\\export_result.ps1"
  },
  "metadata": {
    "expected_waypoints_file": "C:\\workspace\\output\\waypoints_layer.gpx",
    "expected_track_file": "C:\\workspace\\output\\track_layer.gpx",
    "min_track_points": 200,
    "scoring": {
      "waypoints_file_exists": 10,
      "track_file_exists": 10,
      "waypoints_pure": 25,
      "track_pure": 25,
      "track_intact": 10,
      "ui_structure_correct": 20
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_segregate_gps_data"
    }
  }
}
