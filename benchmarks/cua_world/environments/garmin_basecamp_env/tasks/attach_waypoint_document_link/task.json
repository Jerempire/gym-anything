{
  "id": "attach_waypoint_document_link@1",
  "version": "1.0",
  "env_id": "garmin_basecamp_env@0.1",
  "description": "Attach the local file 'C:\\workspace\\data\\water_quality_report.pdf' as a link to an existing waypoint in Garmin BaseCamp. Rename the waypoint to 'Test Site A' and export only this modified waypoint as a GPX file to 'C:\\workspace\\output\\linked_waypoint.gpx'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\attach_waypoint_document_link\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\attach_waypoint_document_link\\export_result.ps1"
  },
  "metadata": {
    "expected_output_path": "C:\\workspace\\output\\linked_waypoint.gpx",
    "expected_waypoint_name": "Test Site A",
    "expected_link_substring": "water_quality_report.pdf",
    "pdf_path": "C:\\workspace\\data\\water_quality_report.pdf"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_attach_waypoint_document_link"
    }
  }
}
