{
  "id": "ground_floor_custom_dx_curve@1",
  "version": "1.0",
  "env_id": "equest_env@0.1",
  "description": "Create a quadratic performance curve named 'HighEff_DX_PLR' with coefficients Constant=0.085, x=0.250, and x^2=0.665. Assign this curve to the 'Cooling EIR-f(PLR)' parameter for the Ground Floor PSZ HVAC systems (G.S1, G.E2, G.N3, G.W4, and G.C5). Run the annual DOE-2.2 simulation and save the project.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\ground_floor_custom_dx_curve\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\ground_floor_custom_dx_curve\\export_result.ps1"
  },
  "metadata": {
    "curve_name": "HighEff_DX_PLR",
    "coeffs": [
      0.085,
      0.25,
      0.665
    ],
    "target_systems": [
      "Sys1 (PSZ) (G.S1)",
      "Sys1 (PSZ) (G.E2)",
      "Sys1 (PSZ) (G.N3)",
      "Sys1 (PSZ) (G.W4)",
      "Sys1 (PSZ) (G.C5)"
    ],
    "target_param": "COOL-EIR-FPLR"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ground_floor_custom_dx_curve"
    }
  }
}
