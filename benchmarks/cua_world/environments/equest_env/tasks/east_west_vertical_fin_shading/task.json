{
  "id": "east_west_vertical_fin_shading@1",
  "version": "1.0",
  "env_id": "equest_env@0.1",
  "description": "Reduce solar heat gain in the '4StoreyBuilding' project by adding vertical shading fins to all east- and west-facing windows. For every WINDOW object on exterior walls in zones containing 'E' or 'W' in their names (e.g., G.E02, G.W04) across all four floors, set 'LEFT-FIN-H' and 'RIGHT-FIN-H' to 2.5 feet. Do not add fins to North or South facing windows. Run the building performance simulation and save the project.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\east_west_vertical_fin_shading\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\east_west_vertical_fin_shading\\export_result.ps1"
  },
  "metadata": {
    "project_path": "C:\\Users\\Docker\\Documents\\eQUEST 3-65 Projects\\4StoreyBuilding\\4StoreyBuilding.inp",
    "sim_file_path": "C:\\Users\\Docker\\Documents\\eQUEST 3-65 Projects\\4StoreyBuilding\\4StoreyBuilding.SIM",
    "target_fin_depth": 2.5,
    "target_orientations": [
      "East",
      "West"
    ],
    "zones_east": [
      "G.E",
      "M.E",
      "T.E"
    ],
    "zones_west": [
      "G.W",
      "M.W",
      "T.W"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_east_west_vertical_fin_shading"
    }
  }
}
