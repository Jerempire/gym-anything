{
  "id": "south_window_overhangs@1",
  "version": "1.0",
  "env_id": "equest_env@0.1",
  "description": "Add fixed horizontal overhangs to all south-facing windows (Azimuth 180°) on the Ground, Middle, and Top floors of the 4StoreyBuilding model to reduce solar heat gain. Configure the overhangs with a 3.0 ft depth and 0.5 ft distance above the window, ensuring no modifications are made to windows on other orientations. Run a full annual simulation and save the project.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\south_window_overhangs\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\south_window_overhangs\\export_result.ps1"
  },
  "metadata": {
    "project_path": "C:\\Users\\Docker\\Documents\\eQUEST 3-65 Projects\\4StoreyBuilding\\4StoreyBuilding.inp",
    "target_azimuth": 180,
    "azimuth_tolerance": 5,
    "target_overhang_depth": 3.0,
    "target_overhang_angle": 0.5,
    "tolerance_depth": 0.2,
    "tolerance_angle": 0.1
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_south_window_overhangs"
    }
  }
}
