{
  "id": "ventilation_erv_upgrade@1",
  "version": "1.0",
  "env_id": "equest_env@0.1",
  "description": "Update the five Floor 3 HVAC systems (starting with '3.') in the 4StoreyBuilding eQUEST model with the following parameters: MIN-OUTSIDE-AIR at 0.30, RECOVER-EXHAUST set to YES, ERV-RECOVER-TYPE as ENTHALPY, ERV-SENSIBLE-EFF at 0.76, and ERV-LATENT-EFF at 0.65. Run the annual simulation and save the project.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 70,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\ventilation_erv_upgrade\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\ventilation_erv_upgrade\\export_result.ps1"
  },
  "metadata": {
    "building_model": "4StoreyBuilding",
    "target_floor_prefix": "3.",
    "target_systems_count": 5,
    "target_values": {
      "min_outside_air": 0.3,
      "recover_exhaust": "YES",
      "erv_recover_type": "ENTHALPY",
      "erv_sensible_eff": 0.76,
      "erv_latent_eff": 0.65
    },
    "simulation_required": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ventilation_erv_upgrade"
    }
  }
}
