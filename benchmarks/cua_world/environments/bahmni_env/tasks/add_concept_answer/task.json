{
  "id": "add_concept_answer@1",
  "version": "1.0",
  "env_id": "bahmni_env@0.1",
  "description": "Add 'Bus' as a valid answer to the existing 'Transportation Method' concept in the OpenMRS dictionary. Use the credentials superman/Admin123 to access the system. Ensure that all existing answers for this concept are preserved.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_concept_answer/setup_task.sh",
    "post_task": "/workspace/tasks/add_concept_answer/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_concept_name": "Transportation Method",
    "answer_to_add": "Bus",
    "required_existing_answers": [
      "Walking",
      "Car"
    ],
    "admin_url": "/openmrs/admin",
    "credentials": {
      "username": "superman",
      "password": "Admin123"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_concept_answer"
    }
  }
}
