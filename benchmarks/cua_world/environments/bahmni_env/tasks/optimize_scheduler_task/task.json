{
  "id": "optimize_scheduler_task@1",
  "version": "1.0",
  "env_id": "bahmni_env@0.1",
  "description": "Optimize the 'HL7 Inbound Queue Processor' scheduler task to reduce system load in the OpenMRS Administration interface (Username: superman, Password: Admin123). Update the 'Repeat Interval' for the 'HL7 Inbound Queue Processor' task to 300 seconds.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/optimize_scheduler_task/setup_task.sh",
    "post_task": "/workspace/tasks/optimize_scheduler_task/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_task_name": "HL7 Inbound Queue Processor",
    "target_interval": 300,
    "initial_interval": 5,
    "openmrs_admin_url": "https://localhost/openmrs/admin",
    "admin_user": "superman",
    "admin_pass": "Admin123"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_optimize_scheduler_task"
    }
  }
}
