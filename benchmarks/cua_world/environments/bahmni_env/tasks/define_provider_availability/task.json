{
  "id": "define_provider_availability@1",
  "version": "1.0",
  "env_id": "bahmni_env@0.1",
  "description": "A clinic administrator needs to set up the roster for a specific provider in the future. Using the credentials (Username: superman, Password: Admin123), create an appointment block for provider Superman on March 12, 2026, from 09:00 to 13:00 at the Registration Desk.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/define_provider_availability/setup_task.sh",
    "post_task": "/workspace/tasks/define_provider_availability/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_date": "2026-03-12",
    "target_provider": "Superman",
    "target_start_time": "09:00:00",
    "target_end_time": "13:00:00",
    "target_location": "Registration Desk"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_define_provider_availability"
    }
  }
}
