{
  "id": "create_encounter_type@1",
  "version": "1.0",
  "env_id": "bahmni_env@0.1",
  "description": "Log in to the OpenMRS Administration interface (Username: superman, Password: Admin123) and create a new Encounter Type named 'Telehealth Consultation' with the description 'Remote patient consultation conducted via video or phone call for telehealth program'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_encounter_type/setup_task.sh",
    "post_task": "/workspace/tasks/create_encounter_type/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_name": "Telehealth Consultation",
    "target_description_keywords": [
      "remote",
      "consultation",
      "video",
      "phone"
    ],
    "admin_url": "https://localhost/openmrs/admin",
    "api_endpoint": "/encountertype"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_encounter_type"
    }
  }
}
