{
  "id": "update_concept_limits@1",
  "version": "1.0",
  "env_id": "bahmni_env@0.1",
  "description": "As an administrator ensuring data integrity in OpenMRS, update the 'Weight (kg)' concept (ID: 5089) with the following validation limits: Absolute Low (0.1), Critical Low (2.0), Critical High (150.0), and Absolute High (350.0). Use credentials 'superman' / 'Admin123'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_concept_limits/setup_task.sh",
    "post_task": "/workspace/tasks/update_concept_limits/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "concept_uuid": "5089AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
    "target_low_absolute": 0.1,
    "target_low_critical": 2.0,
    "target_hi_critical": 150.0,
    "target_hi_absolute": 350.0,
    "admin_url": "https://localhost/openmrs/admin"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_concept_limits"
    }
  }
}
