{
  "id": "record_vital_signs@1",
  "version": "1.0",
  "env_id": "bahmni_env@0.1",
  "description": "Log in to Bahmni using username 'superman' and password 'Admin123'. Record the following vital signs for patient James Osei (BAH000011): Weight 72 kg, Height 175 cm, Pulse 78 beats/min, Systolic Blood Pressure 122 mmHg, and Diastolic Blood Pressure 80 mmHg.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 360,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_vital_signs/setup_task.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "target_patient_name": "James Osei",
    "target_patient_identifier": "BAH000011",
    "target_weight_kg": 72,
    "target_height_cm": 175,
    "target_pulse": 78,
    "target_systolic_bp": 122,
    "target_diastolic_bp": 80
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_vital_signs"
    }
  }
}
