{
  "id": "score_1000_points@1",
  "env_id": "example.subway_surfers@0.1",
  "difficulty": "medium",
  "description": "Achieve a score of at least 1000 points in Subway Surfers by running, collecting coins, and avoiding obstacles.",
  "init": {
    "timeout_sec": 180,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/score_1000_points/setup_task.sh",
    "post_task": "sh /sdcard/tasks/score_1000_points/export_result.sh"
  },
  "metadata": {
    "target_score": 1000,
    "game_type": "endless_runner"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_score"
    }
  }
}
