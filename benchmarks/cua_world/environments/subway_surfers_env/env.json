{
  "id": "example.subway_surfers@0.1",
  "version": "0.1",
  "base": "android-avd-34",
  "description": "Subway Surfers environment for mobile gaming tasks on Android AVD emulator",
  "avd": {
    "variant": "google_apis_playstore"
  },
  "resources": {
    "cpu": 4,
    "mem_gb": 6,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 15,
      "resolution": [1080, 2400],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 150,
  "recording": {
    "enable": true,
    "output_dir": "benchmarks/cua_world/environments/subway_surfers_env/artifacts",
    "video_fps": 15,
    "video_resolution": [1080, 2400],
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": true,
    "host_port": -1,
    "view_only": false,
    "password": "password"
  },
  "apks": [
    "benchmarks/cua_world/environments/subway_surfers_env/scripts/apks/subway_surfers.apk"
  ],
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/subway_surfers_env/tasks",
      "target": "/sdcard/tasks",
      "mode": "ro"
    }
  ],
  "hooks": {
    "post_start": "/sdcard/tasks/score_1000_points/launch_game.sh"
  },
  "user_accounts": [
    {
      "name": "owner",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "shell": "/system/bin/sh"
      }
    }
  ],
  "tags": ["android", "avd", "gaming", "subway-surfers", "endless-runner", "emulator"]
}
