{
  "id": "device_snapshot_quick_links_integration@1",
  "version": "1.0",
  "env_id": "manageengine_opmanager_env@0.1",
  "description": "Read the integration specification at ~/Desktop/noc_quick_links_spec.txt and create four parameterized Quick Links in ManageEngine OpManager that allow operators to launch external tools directly from device pages. Credentials: admin/Admin@123 at http://localhost:8060.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/device_snapshot_quick_links_integration/setup_task.sh",
    "post_task": "/workspace/tasks/device_snapshot_quick_links_integration/export_result.sh"
  },
  "metadata": {
    "result_file": "/tmp/quick_links_result.json",
    "links": [
      {
        "name": "Splunk-Host-Search",
        "domain": "splunk.secops.internal"
      },
      {
        "name": "IPAM-Subnet-Lookup",
        "domain": "netbox.infra.internal"
      },
      {
        "name": "Ansible-Playbook-Runner",
        "domain": "awx.infra.internal"
      },
      {
        "name": "Hardware-Warranty-Check",
        "domain": "warranty-tracker.internal"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_quick_links_integration"
    }
  }
}