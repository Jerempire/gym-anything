{
  "id": "performance_threshold_baseline_config@1",
  "version": "1.0",
  "env_id": "manageengine_opmanager_env@0.1",
  "description": "Read the performance baseline policy from ~/Desktop/performance_baseline_policy.txt, then update the CPU, memory, and disk utilization monitor thresholds on the localhost device (127.0.0.1) in OpManager to match the specified warning and critical values. OpManager is accessible at http://localhost:8060 (admin/Admin@123).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/performance_threshold_baseline_config/setup_task.sh",
    "post_task": "/workspace/tasks/performance_threshold_baseline_config/export_result.sh"
  },
  "metadata": {
    "result_file": "/tmp/performance_threshold_result.json",
    "cpu_warning": 75,
    "cpu_critical": 90,
    "mem_warning": 80,
    "mem_critical": 92,
    "disk_warning": 70,
    "disk_critical": 85
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_performance_threshold_baseline_config"
    }
  }
}