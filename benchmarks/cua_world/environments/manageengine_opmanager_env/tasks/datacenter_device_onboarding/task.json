{
  "id": "datacenter_device_onboarding@1",
  "version": "1.0",
  "env_id": "manageengine_opmanager_env@0.1",
  "description": "A new data center expansion has been physically installed. A rack manifest document has been placed on your desktop at ~/Desktop/dc2_rack_manifest.txt. Read the manifest, identify the 5 newly installed devices, and add all of them to ManageEngine OpManager at http://localhost:8060 (credentials: admin / Admin@123) with the exact display names and IP addresses specified. Devices will not be immediately reachable (this is expected).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/datacenter_device_onboarding/setup_task.sh",
    "post_task": "/workspace/tasks/datacenter_device_onboarding/export_result.sh"
  },
  "metadata": {
    "result_file": "/tmp/dc2_onboarding_result.json",
    "devices": [
      {
        "name": "DC2-Core-Switch-01",
        "ip": "10.200.1.1"
      },
      {
        "name": "DC2-Core-Switch-02",
        "ip": "10.200.1.2"
      },
      {
        "name": "DC2-Distribution-FW",
        "ip": "10.200.2.1"
      },
      {
        "name": "DC2-Storage-Array-01",
        "ip": "10.200.3.10"
      },
      {
        "name": "DC2-Hypervisor-Node-01",
        "ip": "10.200.4.1"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_datacenter_device_onboarding"
    }
  }
}