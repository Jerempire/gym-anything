{
  "id": "broadcast_business_view_topology@1",
  "version": "1.0",
  "env_id": "manageengine_opmanager_env@0.1",
  "description": "Read the broadcast infrastructure layout document at ~/Desktop/broadcast_infrastructure_layout.txt. Following its instructions, create three Business Views and one device group in ManageEngine OpManager that match the specification exactly. Application: http://localhost:8060 (admin/Admin@123).",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 1200,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/broadcast_business_view_topology/setup_task.sh",
    "post_task": "/workspace/tasks/broadcast_business_view_topology/export_result.sh"
  },
  "metadata": {
    "result_file": "/tmp/broadcast_topology_result.json",
    "view_1": "Broadcast-Production-Network",
    "view_2": "Master-Control-Room",
    "view_3": "Distribution-Backbone",
    "group_1": "Broadcast-Systems"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_broadcast_topology"
    }
  }
}