{
  "id": "webapp_backup_integrity_monitoring@1",
  "version": "1.0",
  "env_id": "manageengine_opmanager_env@0.1",
  "description": "Read the monitoring specification document at ~/Desktop/backup_monitor_spec.txt. Configure a File Monitor and a Folder Monitor on the 'localhost' (127.0.0.1) device in OpManager to track backup integrity and storage consumption as specified in the document. Application: http://localhost:8060 (admin/Admin@123).",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 1800,
    "max_steps": 120,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/webapp_backup_integrity_monitoring/setup_task.sh",
    "post_task": "/workspace/tasks/webapp_backup_integrity_monitoring/export_result.sh"
  },
  "metadata": {
    "result_file": "/tmp/backup_monitor_result.json",
    "folder_path": "/var/backups/webapp",
    "folder_threshold": 10000,
    "file_path": "/var/backups/webapp/daily_archive.tar.gz",
    "file_threshold": 500
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_webapp_backup_integrity_monitoring"
    }
  }
}