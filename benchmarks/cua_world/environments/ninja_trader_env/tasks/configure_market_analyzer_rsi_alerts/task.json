{
  "id": "configure_market_analyzer_rsi_alerts@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Configure a Market Analyzer window in NinjaTrader 8 for instruments SPY, AAPL, and MSFT. Include an RSI (Period 14) column with conditional formatting: a Red background for values greater than 70 and a Green background for values less than 30. Save the workspace.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 480,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_market_analyzer_rsi_alerts\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_market_analyzer_rsi_alerts\\export_result.ps1"
  },
  "metadata": {
    "instruments": [
      "SPY",
      "AAPL",
      "MSFT"
    ],
    "indicator": "RSI",
    "conditions": [
      {
        "op": "Greater",
        "val": 70,
        "color": "Red"
      },
      {
        "op": "Less",
        "val": 30,
        "color": "Green"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_market_analyzer_rsi_alerts"
    }
  }
}
