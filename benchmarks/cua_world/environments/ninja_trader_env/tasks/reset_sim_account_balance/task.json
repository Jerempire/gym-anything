{
  "id": "reset_sim_account_balance@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Reset the 'Sim101' account initial cash balance to $50,000.00 in NinjaTrader 8. Export the updated account grid to C:\\Users\\Docker\\Documents\\current_accounts.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\reset_sim_account_balance\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\reset_sim_account_balance\\export_result.ps1"
  },
  "metadata": {
    "target_account": "Sim101",
    "target_balance": 50000,
    "target_balance_str": "50,000",
    "output_filename": "current_accounts.csv",
    "expected_output_path": "C:\\Users\\Docker\\Documents\\current_accounts.csv"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_reset_sim_account_balance"
    }
  }
}
