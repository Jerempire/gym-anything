{
  "id": "overlay_multi_instrument_chart@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Create a NinjaTrader 8 chart window displaying both SPY and AAPL (Daily bars) overlaid on the same price panel. Apply a 50-period Simple Moving Average (SMA) indicator to each data series and save the workspace to persist the configuration.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\overlay_multi_instrument_chart\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\overlay_multi_instrument_chart\\export_result.ps1"
  },
  "metadata": {
    "primary_instrument": "SPY",
    "secondary_instrument": "AAPL",
    "indicator": "SMA",
    "indicator_period": 50,
    "timeframe": "Daily"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_overlay_multi_instrument_chart"
    }
  }
}
