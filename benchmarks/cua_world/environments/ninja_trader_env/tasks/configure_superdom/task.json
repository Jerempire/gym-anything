{
  "id": "configure_superdom@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Configure a SuperDOM (Dynamic Order Matrix) window in NinjaTrader 8 for active trading. Set up the SuperDOM for instrument 'SPY' using account 'Sim101' with a default order quantity of '50'. Save the workspace to ensure the configuration is persisted.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_superdom\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_superdom\\export_result.ps1"
  },
  "metadata": {
    "target_instrument": "SPY",
    "target_account": "Sim101",
    "target_quantity": 50,
    "workspace_dir": "C:\\Users\\Docker\\Documents\\NinjaTrader 8\\workspaces",
    "result_path": "C:\\Users\\Docker\\Desktop\\NinjaTraderTasks\\configure_superdom_result.json"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_superdom"
    }
  }
}
