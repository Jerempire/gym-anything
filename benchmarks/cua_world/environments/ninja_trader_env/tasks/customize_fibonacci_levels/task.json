{
  "id": "customize_fibonacci_levels@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Customize the Fibonacci Retracement tool on a Daily chart for SPY to match a 'Golden Pocket' strategy. The configuration must include a new level at 78.6% (0.786), the removal of the 23.6% (0.236) level, and the 61.8% (0.618) level color set to Red. Save the workspace to persist these changes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/customize_fibonacci_levels/setup_task.sh",
    "post_task": "/workspace/tasks/customize_fibonacci_levels/export_result.sh"
  },
  "metadata": {
    "target_instrument": "SPY",
    "required_levels_add": [
      0.786
    ],
    "required_levels_remove": [
      0.236
    ],
    "color_check_level": 0.618,
    "target_color": "Red",
    "xml_search_path": "C:\\Users\\Docker\\Documents\\NinjaTrader 8\\workspaces"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_customize_fibonacci_levels"
    }
  }
}
