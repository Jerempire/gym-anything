{
  "id": "configure_regression_channel_analysis@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Create a Daily chart for SPY in NinjaTrader 8 featuring a Regression Channel (Period: 50, Width: 2) overlaid on price, an R-Squared indicator (Period: 50) in a sub-panel, and a Stochastics indicator (Period D: 3, Period K: 14, Smooth: 3) in a sub-panel. Save the workspace.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_regression_channel_analysis\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_regression_channel_analysis\\export_result.ps1"
  },
  "metadata": {
    "instrument": "SPY",
    "indicators": {
      "RegressionChannel": {
        "period": 50,
        "width": 2
      },
      "RSquared": {
        "period": 50
      },
      "Stochastics": {
        "period_k": 14,
        "period_d": 3,
        "smooth": 3
      }
    },
    "result_path": "C:\\Users\\Docker\\Desktop\\NinjaTraderTasks\\configure_regression_channel_analysis_result.json"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_regression_channel_analysis"
    }
  }
}
