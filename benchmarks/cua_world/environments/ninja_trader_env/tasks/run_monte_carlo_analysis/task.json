{
  "id": "run_monte_carlo_analysis@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Run a Monte Carlo simulation with 1,000 iterations on the backtest results of the 'SampleMACrossover' strategy applied to 'SPY' daily data (Jan 2, 2023 - Dec 29, 2024). Save the workspace to persist the analysis results.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\run_monte_carlo_analysis\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\run_monte_carlo_analysis\\export_result.ps1"
  },
  "metadata": {
    "strategy_name": "SampleMACrossover",
    "instrument": "SPY",
    "iterations": 1000,
    "workspace_dir": "C:\\Users\\Docker\\Documents\\NinjaTrader 8\\workspaces",
    "result_file": "C:\\Users\\Docker\\Desktop\\NinjaTraderTasks\\run_monte_carlo_analysis_result.json"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_run_monte_carlo_analysis"
    }
  }
}
