{
  "id": "create_tabbed_chart_workbook@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Create a single chart window in NinjaTrader 8 containing three tabs for SPY, AAPL, and MSFT, all set to a Daily timeframe. Save the workspace to disk.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_tabbed_chart_workbook\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_tabbed_chart_workbook\\export_result.ps1"
  },
  "metadata": {
    "expected_instruments": [
      "SPY",
      "AAPL",
      "MSFT"
    ],
    "expected_interval": "Daily",
    "min_tabs": 3,
    "max_windows": 1
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_tabbed_chart_workbook"
    }
  }
}
