{
  "id": "export_annual_strategy_performance@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Run a backtest for the 'SampleMACrossover' strategy on 'SPY' (Daily data) from January 2023 to December 2024 using the Strategy Analyzer. Export the annual performance breakdown, including data for 2023 and 2024, to C:\\Users\\Docker\\Documents\\annual_report.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_annual_strategy_performance\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_annual_strategy_performance\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "annual_report.csv",
    "expected_path": "C:\\Users\\Docker\\Documents\\annual_report.csv",
    "required_strings": [
      "2023",
      "2024",
      "Net Profit"
    ],
    "strategy_name": "SampleMACrossover",
    "instrument": "SPY"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_annual_strategy_performance"
    }
  }
}
