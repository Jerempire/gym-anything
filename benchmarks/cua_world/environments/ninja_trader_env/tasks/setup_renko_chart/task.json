{
  "id": "setup_renko_chart@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Configure a specialized technical analysis chart in NinjaTrader 8 for SPY to filter out price noise. Set up a Renko chart with a Brick Size of 2, including an EMA indicator (Period 21) overlaying the price and an ADX indicator (Period 14) in a new panel. Save the workspace to ensure the configuration is stored.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\setup_renko_chart\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\setup_renko_chart\\export_result.ps1"
  },
  "metadata": {
    "target_instrument": "SPY",
    "target_bar_type": "Renko",
    "target_brick_size": 2,
    "target_indicators": [
      "EMA",
      "ADX"
    ],
    "workspace_path": "C:\\Users\\Docker\\Documents\\NinjaTrader 8\\workspaces"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_setup_renko_chart"
    }
  }
}
