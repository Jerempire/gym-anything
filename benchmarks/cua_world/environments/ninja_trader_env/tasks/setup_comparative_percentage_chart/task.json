{
  "id": "setup_comparative_percentage_chart@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Create a comparative performance chart in NinjaTrader 8 for the year 2023 (2023-01-01 to 2023-12-31) using Daily bars. Overlay SPY, AAPL, and MSFT on a single chart panel using a percentage-based vertical axis to compare their relative performance starting from 0%. Save the workspace to preserve the configuration.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\setup_comparative_percentage_chart\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\setup_comparative_percentage_chart\\export_result.ps1"
  },
  "metadata": {
    "instruments": [
      "SPY",
      "AAPL",
      "MSFT"
    ],
    "required_scale_type": "Percent",
    "start_date": "2023-01-01",
    "end_date": "2023-12-31"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_setup_comparative_percentage_chart"
    }
  }
}
