{
  "id": "identify_trend_reversal_setup@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Configure a chart for MSFT to identify trend reversals. The setup must use a Line Break chart type with a value of 3, a Stochastic oscillator (Period K: 14, Period D: 3, Smooth: 3), and an ADX indicator (Period 14). Save the workspace when finished.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 480,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\identify_trend_reversal_setup\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\identify_trend_reversal_setup\\export_result.ps1"
  },
  "metadata": {
    "target_instrument": "MSFT",
    "chart_type": "LineBreak",
    "line_break_value": 3,
    "indicators": [
      {
        "name": "Stochastics",
        "params": {
          "PeriodK": 14,
          "PeriodD": 3,
          "Smooth": 3
        }
      },
      {
        "name": "ADX",
        "params": {
          "Period": 14
        }
      }
    ],
    "workspace_dir": "C:\\Users\\Docker\\Documents\\NinjaTrader 8\\workspaces"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_identify_trend_reversal_setup"
    }
  }
}
