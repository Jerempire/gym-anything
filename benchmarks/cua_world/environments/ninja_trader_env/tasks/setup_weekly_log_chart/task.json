{
  "id": "setup_weekly_log_chart@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "A financial advisor needs a long-term technical chart for a report. Configure a NinjaTrader 8 chart for 'SPY' using a weekly period with 700 days of data. The chart must use logarithmic scaling and include a 40-period Simple Moving Average (SMA) indicator. Save the workspace and export the chart image to C:\\Users\\Docker\\Documents\\weekly_spy_log.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\setup_weekly_log_chart\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\setup_weekly_log_chart\\export_result.ps1"
  },
  "metadata": {
    "target_instrument": "SPY",
    "required_period_type": "Weekly",
    "required_days_load": 700,
    "required_indicator": "SMA",
    "required_indicator_period": 40,
    "expected_image_path": "C:\\Users\\Docker\\Documents\\weekly_spy_log.png",
    "workspace_dir": "C:\\Users\\Docker\\Documents\\NinjaTrader 8\\workspaces"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_setup_weekly_log_chart"
    }
  }
}
