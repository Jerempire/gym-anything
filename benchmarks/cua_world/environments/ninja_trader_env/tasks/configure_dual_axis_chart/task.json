{
  "id": "configure_dual_axis_chart@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "NinjaTrader 8 is open with daily OHLCV data for AAPL and MSFT (Jan 2023 - Dec 2024). Create a comparative chart overlaying both instruments in a single panel. Configure the chart with MSFT on the left vertical axis and AAPL on the right vertical axis to allow for a visual trend comparison. Save the workspace to persist the configuration.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_dual_axis_chart\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_dual_axis_chart\\export_result.ps1"
  },
  "metadata": {
    "instruments": [
      "AAPL",
      "MSFT"
    ],
    "axis_config": {
      "AAPL": "Right",
      "MSFT": "Left"
    },
    "workspace_dir": "C:\\Users\\Docker\\Documents\\NinjaTrader 8\\workspaces",
    "result_path": "C:\\Users\\Docker\\Desktop\\task_result.json"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_dual_axis_chart"
    }
  }
}
