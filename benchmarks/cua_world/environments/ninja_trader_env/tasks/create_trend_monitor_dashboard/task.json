{
  "id": "create_trend_monitor_dashboard@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Create a Market Analyzer dashboard in NinjaTrader 8 to monitor the trend status of SPY, AAPL, and MSFT. Configure the 'Last' price column to change color based on the price's relationship to the 50-period Simple Moving Average (SMA), using a green background when the price is above the SMA and a red background when it is below. Save the workspace to persist your changes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_trend_monitor_dashboard\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_trend_monitor_dashboard\\export_result.ps1"
  },
  "metadata": {
    "instruments": [
      "SPY",
      "AAPL",
      "MSFT"
    ],
    "indicator": "SimpleMovingAverage",
    "period": 50,
    "bullish_colors": [
      "Green",
      "Lime",
      "LightGreen",
      "DarkGreen",
      "SeaGreen"
    ],
    "bearish_colors": [
      "Red",
      "Crimson",
      "LightCoral",
      "Pink",
      "DarkRed"
    ],
    "workspace_dir": "C:\\Users\\Docker\\Documents\\NinjaTrader 8\\workspaces"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_trend_monitor_dashboard"
    }
  }
}
