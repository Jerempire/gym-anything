{
  "id": "create_trading_hours_template@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Create a custom Trading Hours template named 'US Morning Session' for the period 9:30 AM to 12:00 PM Eastern Time, Monday through Friday. Apply this template to a Daily chart of AAPL and save the workspace.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_trading_hours_template\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_trading_hours_template\\export_result.ps1"
  },
  "metadata": {
    "template_name": "US Morning Session",
    "required_start_time": "093000",
    "required_end_time": "120000",
    "instrument": "AAPL",
    "user_dir": "C:\\Users\\Docker\\Documents\\NinjaTrader 8"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_trading_hours_template"
    }
  }
}
