{
  "id": "configure_basket_backtest@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Configure and run a basket backtest in NinjaTrader 8's Strategy Analyzer for a portfolio of SPY, AAPL, and MSFT using the 'SampleMACrossover' strategy. Use Daily bars for the date range 1/1/2024 to 12/31/2024. Save the workspace to persist the configuration. The system has real historical data for these instruments; no data import is required.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_basket_backtest\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_basket_backtest\\export_result.ps1",
    "pre_task_timeout": 300
  },
  "metadata": {
    "strategy_name": "SampleMACrossover",
    "instruments": [
      "SPY",
      "AAPL",
      "MSFT"
    ],
    "start_date": "2024-01-01",
    "end_date": "2024-12-31",
    "bar_type": "Daily",
    "workspace_dir": "C:\\Users\\Docker\\Documents\\NinjaTrader 8\\workspaces",
    "result_file": "C:\\Users\\Docker\\Desktop\\task_result.json"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_basket_backtest"
    }
  }
}
