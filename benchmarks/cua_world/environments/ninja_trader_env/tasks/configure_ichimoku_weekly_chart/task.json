{
  "id": "configure_ichimoku_weekly_chart@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Create a weekly chart for SPY in NinjaTrader 8. Configure the chart with the Ichimoku Cloud indicator (Tenkan-sen=9, Kijun-sen=26, Senkou Span B=52) and the ADX indicator (Period=14). Save the workspace to persist your changes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_ichimoku_weekly_chart\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_ichimoku_weekly_chart\\export_result.ps1"
  },
  "metadata": {
    "target_instrument": "SPY",
    "target_timeframe": "Weekly",
    "ichimoku_params": {
      "tenkan": 9,
      "kijun": 26,
      "senkou_b": 52
    },
    "adx_period": 14,
    "workspace_dir": "C:\\Users\\Docker\\Documents\\NinjaTrader 8\\workspaces",
    "result_path": "C:\\Users\\Docker\\Desktop\\NinjaTraderTasks\\task_result.json"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_ichimoku_weekly_chart"
    }
  }
}
