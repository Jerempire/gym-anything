{
  "id": "create_custom_ninjascript_indicator@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Create a custom NinjaScript indicator named 'ATRP' (Average True Range Percentage) that calculates (ATR(period) / Close) * 100. The indicator should display as a line in a separate panel. Apply the ATRP indicator with a period of 14 to a Daily chart for SPY and save the workspace.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_custom_ninjascript_indicator\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_custom_ninjascript_indicator\\export_result.ps1"
  },
  "metadata": {
    "indicator_name": "ATRP",
    "expected_formula_elements": [
      "ATR",
      "Close",
      "100"
    ],
    "target_instrument": "SPY",
    "result_path": "C:\\Users\\Docker\\Desktop\\task_result.json",
    "indicators_path": "C:\\Users\\Docker\\Documents\\NinjaTrader 8\\bin\\Custom\\Indicators",
    "workspaces_path": "C:\\Users\\Docker\\Documents\\NinjaTrader 8\\workspaces"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_custom_ninjascript_indicator"
    }
  }
}
