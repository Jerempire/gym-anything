  },
  "metadata": {
    "target_instrument": "SPY",
    "line1_price": 450.0,
    "line2_price": 420.0,
    "tolerance": 5.0,
    "workspace_dir": "C:\\Users\\Docker\\Documents\\NinjaTrader 8\\workspaces",
    "result_file": "C:\\Users\\Docker\\Desktop\\NinjaTraderTasks\\annotate_chart_with_drawings_result.json"
