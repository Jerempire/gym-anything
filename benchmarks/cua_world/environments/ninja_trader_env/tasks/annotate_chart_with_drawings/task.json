{
  "id": "annotate_chart_with_drawings@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "You are a technical trader preparing your SPY chart for the morning session. On a daily chart for SPY, create horizontal price lines at $450.00 and $420.00. Ensure the price levels are within ±$5 tolerance and save the workspace so the annotations persist.",
