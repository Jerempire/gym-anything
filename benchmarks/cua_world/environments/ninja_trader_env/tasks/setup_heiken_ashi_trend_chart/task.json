{
  "id": "setup_heiken_ashi_trend_chart@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Configure a trend-following chart for SPY in NinjaTrader 8. Create a Daily chart for instrument 'SPY' using 'Heiken Ashi' bars. Add the 'ADX' indicator with a Period of 14 and the 'Parabolic SAR' indicator with Acceleration 0.02 and Acceleration Max 0.2. Save the workspace to persist the configuration.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\setup_heiken_ashi_trend_chart\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\setup_heiken_ashi_trend_chart\\export_result.ps1"
  },
  "metadata": {
    "instrument": "SPY",
    "bar_type": "HeikenAshi",
    "indicators": [
      {
        "name": "ADX",
        "params": {
          "Period": "14"
        }
      },
      {
        "name": "ParabolicSAR",
        "params": {
          "Acceleration": "0.02",
          "AccelerationMax": "0.2"
        }
      }
    ],
    "result_path": "C:\\Users\\Docker\\Desktop\\task_result.json"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_setup_heiken_ashi_trend_chart"
    }
  }
}
