{
  "id": "configure_commission_template@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Configure two custom commission templates in NinjaTrader 8 to simulate realistic trading costs: 'IB_PerShare' (Per Share type, $0.005 rate, $1.00 minimum) and 'Schwab_PerTrade' (Per Trade type, $4.95 rate). Run a backtest of the SampleMACrossover strategy on SPY (Daily interval) from 2023-01-01 to 2024-12-31 using the 'IB_PerShare' commission template and save the workspace.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_commission_template\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_commission_template\\export_result.ps1"
  },
  "metadata": {
    "templates_dir": "C:\\Users\\Docker\\Documents\\NinjaTrader 8\\templates\\Commission",
    "expected_templates": [
      {
        "name": "IB_PerShare",
        "type_keywords": [
          "PerUnit",
          "PerShare"
        ],
        "rate": 0.005,
        "min": 1.0
      },
      {
        "name": "Schwab_PerTrade",
        "type_keywords": [
          "PerTrade",
          "Flat"
        ],
        "rate": 4.95
      }
    ],
    "strategy_name": "SampleMACrossover",
    "instrument": "SPY",
    "commission_ref": "IB_PerShare"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_commission_template"
    }
  }
}
