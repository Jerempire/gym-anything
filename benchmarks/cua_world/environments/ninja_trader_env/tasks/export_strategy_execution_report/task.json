{
  "id": "export_strategy_execution_report@1",
  "version": "1.0",
  "env_id": "ninja_trader_env@0.1",
  "description": "Run a backtest of the 'SampleMACrossover' strategy on MSFT using daily data for the full year of 2024 (Jan 1, 2024 - Dec 31, 2024). Export the resulting execution list to C:\\Users\\Docker\\Documents\\msft_executions.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_strategy_execution_report\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\export_strategy_execution_report\\export_result.ps1"
  },
  "metadata": {
    "expected_filename": "msft_executions.csv",
    "expected_instrument": "MSFT",
    "expected_year": "2024",
    "min_rows": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_strategy_execution_report"
    }
  }
}
