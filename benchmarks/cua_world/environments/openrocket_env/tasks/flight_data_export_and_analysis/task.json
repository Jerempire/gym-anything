{
  "id": "flight_data_export_and_analysis@1",
  "version": "1.0",
  "env_id": "example.openrocket_env@0.1",
  "description": "As a propulsion research engineer, provide a performance analysis report at /home/ga/Documents/exports/flight_analysis_report.txt for the clustered-motor rocket design at /home/ga/Documents/rockets/flight_analysis.ork. The report should compare all motor configurations and recommend the optimal choice for a 250m target altitude, supported by time-series flight data exported to /home/ga/Documents/exports/flight_data/.",
  "difficulty": "very_hard",
  "tags": [
    "clustered-motors",
    "flight-analysis",
    "data-export",
    "performance-comparison",
    "simulation"
  ],
  "init": {
    "timeout_sec": 900,
    "max_steps": 60,
    "reward_type": "dense"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/flight_data_export_and_analysis/setup_task.sh",
    "post_task": "/workspace/tasks/flight_data_export_and_analysis/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_flight_data_export_and_analysis"
    }
  },
  "metadata": {
    "ork_vm_path": "/home/ga/Documents/rockets/flight_analysis.ork",
    "exports_dir_vm": "/home/ga/Documents/exports/flight_data",
    "report_vm_path": "/home/ga/Documents/exports/flight_analysis_report.txt",
    "source_ork": "clustered_motors.ork",
    "expected_sim_count": 5,
    "min_uptodate_sims": 4,
    "min_csv_files": 3,
    "target_altitude_m": 250,
    "pass_threshold": 65
  }
}
