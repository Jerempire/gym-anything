{
  "id": "stability_analysis_and_repair@1",
  "version": "1.0",
  "env_id": "example.openrocket_env@0.1",
  "description": "The competition rocket design at /home/ga/Documents/rockets/stability_check.ork has been flagged by the safety review committee as potentially unstable. As the team's lead rocketry engineer, ensure the rocket is aerodynamically stable and document the final stability analysis in a report at /home/ga/Documents/exports/stability_report.txt.",
  "difficulty": "very_hard",
  "tags": [
    "stability",
    "aerodynamics",
    "fins",
    "simulation",
    "safety-review"
  ],
  "init": {
    "timeout_sec": 900,
    "max_steps": 60,
    "reward_type": "dense"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/stability_analysis_and_repair/setup_task.sh",
    "post_task": "/workspace/tasks/stability_analysis_and_repair/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_stability_analysis_and_repair"
    }
  },
  "metadata": {
    "ork_vm_path": "/home/ga/Documents/rockets/stability_check.ork",
    "report_vm_path": "/home/ga/Documents/exports/stability_report.txt",
    "source_ork": "dual_parachute_deployment.ork",
    "original_fin_height_m": 0.076,
    "injected_fin_height_m": 0.015,
    "min_acceptable_fin_height_m": 0.05,
    "pass_threshold": 60
  }
}
