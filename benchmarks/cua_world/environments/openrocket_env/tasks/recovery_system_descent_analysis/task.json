{
  "id": "recovery_system_descent_analysis@1",
  "version": "1.0",
  "env_id": "example.openrocket_env@0.1",
  "description": "The IREC competition rocket at /home/ga/Documents/rockets/recovery_analysis.ork has been reported to have dangerously fast descent rates. As the recovery systems engineer, optimize the parachute configuration for safe descent, verify the ground hit velocity, and save a descent rate analysis report to /home/ga/Documents/exports/descent_analysis_report.txt.",
  "difficulty": "very_hard",
  "tags": [
    "recovery",
    "parachute",
    "descent-rate",
    "safety",
    "simulation"
  ],
  "init": {
    "timeout_sec": 900,
    "max_steps": 60,
    "reward_type": "dense"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/recovery_system_descent_analysis/setup_task.sh",
    "post_task": "/workspace/tasks/recovery_system_descent_analysis/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_recovery_system_descent_analysis"
    }
  },
  "metadata": {
    "ork_vm_path": "/home/ga/Documents/rockets/recovery_analysis.ork",
    "report_vm_path": "/home/ga/Documents/exports/descent_analysis_report.txt",
    "source_ork": "dual_parachute_deployment.ork",
    "original_main_diameter_m": 1.0668,
    "injected_main_diameter_m": 0.254,
    "original_drogue_diameter_m": 0.3048,
    "injected_drogue_diameter_m": 0.076,
    "min_main_diameter_m": 0.7,
    "min_drogue_diameter_m": 0.22,
    "max_ground_hit_velocity_ms": 6.5,
    "pass_threshold": 60
  }
}
