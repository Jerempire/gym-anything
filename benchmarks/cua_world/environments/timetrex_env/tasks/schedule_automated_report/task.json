{
  "id": "schedule_automated_report@1",
  "version": "1.0",
  "env_id": "timetrex_env@0.1",
  "description": "Create a new Report Schedule in TimeTrex named 'Weekly Overtime Review' that automatically emails the 'Timesheet Summary' report to supervisor@greenleafwellness.com on a weekly basis. Ensure the schedule status is 'Active'. Login credentials: Username: demoadmin1, Password: demo",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/schedule_automated_report/setup_task.sh",
    "post_task": "/workspace/tasks/schedule_automated_report/export_result.sh"
  },
  "metadata": {
    "expected_name": "Weekly Overtime Review",
    "expected_email": "supervisor@greenleafwellness.com",
    "expected_report": "Timesheet Summary",
    "expected_frequency": "Weekly",
    "expected_frequency_id": "20"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_schedule_automated_report"
    }
  }
}
