{
  "id": "configure_annual_holidays@1",
  "version": "1.0",
  "env_id": "timetrex_env@0.1",
  "description": "Configure the 2026 annual corporate holidays in TimeTrex. Create four holiday records: 'Memorial Day' (2026-05-25), 'Independence Day' (2026-07-03), 'Labor Day' (2026-09-07), and 'Thanksgiving Day' (2026-11-26). Login credentials: Username: demoadmin1, Password: demo",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_annual_holidays/setup_task.sh",
    "post_task": "/workspace/tasks/configure_annual_holidays/export_result.sh"
  },
  "metadata": {
    "expected_holidays": [
      {
        "name": "Memorial Day",
        "date": "2026-05-25"
      },
      {
        "name": "Independence Day",
        "date": "2026-07-03"
      },
      {
        "name": "Labor Day",
        "date": "2026-09-07"
      },
      {
        "name": "Thanksgiving Day",
        "date": "2026-11-26"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_annual_holidays"
    }
  }
}
