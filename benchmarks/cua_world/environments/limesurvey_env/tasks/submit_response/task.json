{
  "id": "submit_response@1",
  "version": "1.0",
  "env_id": "limesurvey_env@0.1",
  "description": "Complete and submit a response for the 'Customer Satisfaction Survey' in LimeSurvey using sample data (e.g., age: 35, satisfaction rating: 4).",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/submit_response/setup_task.sh",
    "post_task": "/workspace/tasks/submit_response/export_result.sh"
  },
  "metadata": {
    "expected_response_field": "age",
    "expected_response_value": "35"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_submit_response"
    }
  }
}
