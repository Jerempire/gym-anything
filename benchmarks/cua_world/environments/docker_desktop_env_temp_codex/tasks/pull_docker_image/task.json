{
  "id": "pull_docker_image@1",
  "version": "1.0",
  "env_id": "docker_desktop_env@0.1",
  "description": "Pull the 'python:3.11-slim' image from Docker Hub so that it is available in your local Docker images list.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/pull_docker_image/setup_task.sh",
    "post_task": "/workspace/tasks/pull_docker_image/export_result.sh"
  },
  "metadata": {
    "expected_image": "python",
    "expected_tag": "3.11-slim",
    "full_image_name": "python:3.11-slim"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_pull_docker_image"
    }
  }
}
