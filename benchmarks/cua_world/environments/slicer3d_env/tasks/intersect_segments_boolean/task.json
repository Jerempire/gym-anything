  "hooks": {
    "pre_task": "/workspace/tasks/intersect_segments_boolean/setup_task.sh",
    "post_task": "/workspace/tasks/intersect_segments_boolean/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "expected_intersection_name": "Tumor_Motor_Overlap",
    "tumor_segment_name": "Tumor",
    "motor_segment_name": "Motor_Region",
    "min_intersection_voxels": 100,
    "max_intersection_voxels": 50000,
    "voxel_count_tolerance_percent": 10,
    "scoring_weights": {
