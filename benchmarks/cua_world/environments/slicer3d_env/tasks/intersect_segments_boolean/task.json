{
  "id": "intersect_segments_boolean@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create a new segment named 'Tumor_Motor_Overlap' that contains the intersection of the existing 'Tumor' and 'Motor_Region' segments. The original segments must remain unchanged. No file export is required.",
