{
  "id": "import_dicom_ct@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Import the chest CT DICOM files from ~/Documents/SlicerData/LIDC/LIDC-IDRI-0001/DICOM/ into the 3D Slicer DICOM database and load the main series into the scene for viewing.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/import_dicom_ct/setup_task.sh",
    "post_task": "/workspace/tasks/import_dicom_ct/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "dicom_folder": "/home/ga/Documents/SlicerData/LIDC/LIDC-IDRI-0001/DICOM",
    "expected_patient_id": "LIDC-IDRI-0001",
    "min_slice_count": 100,
    "expected_modality": "CT",
    "data_source": "LIDC-IDRI (The Cancer Imaging Archive)",
    "scoring_weights": {
      "dicom_module_accessed": 15,
      "study_imported_to_database": 30,
      "volume_loaded_in_scene": 30,
      "ct_visible_in_views": 15,
      "correct_series_selected": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_import_dicom_ct"
    }
  }
}
