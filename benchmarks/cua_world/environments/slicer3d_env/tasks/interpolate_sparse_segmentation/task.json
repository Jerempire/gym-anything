{
  "id": "interpolate_sparse_segmentation@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Interpolate the 'Tumor_Sparse' segment on the loaded BraTS FLAIR MRI to create a continuous 3D segmentation from the existing annotations, which are currently provided on every 5th slice. Save the result to ~/Documents/SlicerData/BraTS/interpolated_scene/.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/interpolate_sparse_segmentation/setup_task.sh",
    "post_task": "/workspace/tasks/interpolate_sparse_segmentation/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "sparse_segmentation_file": "/home/ga/Documents/SlicerData/BraTS/sparse_tumor_seg.nii.gz",
    "output_dir": "/home/ga/Documents/SlicerData/BraTS/interpolated_scene",
    "expected_volume_increase_min": 3.0,
    "expected_volume_increase_max": 8.0,
    "expected_slice_coverage_min": 0.85,
    "centroid_tolerance_mm": 10.0,
    "scoring_weights": {
      "segmentation_modified": 20,
      "volume_increase_valid": 25,
      "slice_coverage_good": 20,
      "no_large_gaps": 15,
      "volume_within_bounds": 10,
      "centroid_consistent": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_interpolate_sparse_segmentation"
    }
  }
}
