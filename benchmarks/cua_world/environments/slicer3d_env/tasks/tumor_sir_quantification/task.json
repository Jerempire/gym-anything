{
  "id": "tumor_sir_quantification@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Quantify Signal Intensity Ratios (SIR) for the enhancing tumor relative to contralateral normal white matter on the provided brain MRI using mean signal intensities across T1, T1ce, T2, and FLAIR sequences. Save the ROI markups to ~/Documents/SlicerData/BraTS/sir_rois.mrk.json and a report containing tumor_roi, wm_roi, signal_intensities, sir_values, and interpretation to ~/Documents/SlicerData/BraTS/sir_report.json.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/tumor_sir_quantification/setup_task.sh",
    "post_task": "/workspace/tasks/tumor_sir_quantification/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_rois": "/home/ga/Documents/SlicerData/BraTS/sir_rois.mrk.json",
    "output_report": "/home/ga/Documents/SlicerData/BraTS/sir_report.json",
    "modalities": [
      "t1",
      "t1ce",
      "t2",
      "flair"
    ],
    "tumor_labels": {
      "necrotic": 1,
      "edema": 2,
      "enhancing": 4
    },
    "expected_sir_ranges": {
      "t1": [
        0.6,
        1.3
      ],
      "t1ce": [
        1.1,
        3.5
      ],
      "t2": [
        1.2,
        4.5
      ],
      "flair": [
        1.2,
        4.5
      ]
    },
    "passing_thresholds": {
      "tumor_roi_overlap_min": 0.3,
      "wm_roi_no_tumor_overlap": true,
      "sir_plausibility_required": 2
    },
    "scoring_weights": {
      "tumor_roi_placement": 20,
      "wm_roi_placement": 20,
      "t1ce_sir_accuracy": 15,
      "t2_sir_accuracy": 10,
      "flair_sir_accuracy": 10,
      "t1_sir_accuracy": 5,
      "roi_files_saved": 10,
      "report_completeness": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_tumor_sir_quantification"
    }
  }
}
