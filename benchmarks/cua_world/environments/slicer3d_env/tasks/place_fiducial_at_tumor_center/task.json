{
  "id": "place_fiducial_at_tumor_center@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Place a fiducial point at the center of the visible glioma tumor on this brain FLAIR MRI. Save to ~/Documents/SlicerData/BraTS/tumor_center.mrk.json",
  "difficulty": "very easy",
  "init": {
    "timeout_sec": 240,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/place_fiducial_at_tumor_center/setup_task.sh",
    "post_task": "/workspace/tasks/place_fiducial_at_tumor_center/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "output_fiducial": "/home/ga/Documents/SlicerData/BraTS/tumor_center.mrk.json",
    "tolerance_mm": 25.0,
    "scoring_weights": {
      "fiducial_exists": 35,
      "fiducial_on_tumor": 40,
      "file_saved": 15,
      "near_center": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_place_fiducial_at_tumor_center"
    }
  }
}
