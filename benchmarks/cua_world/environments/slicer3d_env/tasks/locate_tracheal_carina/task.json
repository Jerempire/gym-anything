{
  "id": "locate_tracheal_carina@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Place a fiducial marker named 'Carina' at the tracheal carina (the bifurcation point where the trachea splits into left and right main bronchi) on the loaded LIDC-IDRI chest CT scan.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/locate_tracheal_carina/setup_task.sh",
    "post_task": "/workspace/tasks/locate_tracheal_carina/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "lidc_dir": "/home/ga/Documents/SlicerData/LIDC",
    "ground_truth_path": "/var/lib/slicer/ground_truth/carina_location.json",
    "target_structure": "tracheal_carina",
    "expected_fiducial_name": "Carina",
    "tolerance_xy_mm": 15.0,
    "tolerance_z_mm": 20.0,
    "distance_threshold_excellent_mm": 10,
    "distance_threshold_good_mm": 15,
    "distance_threshold_acceptable_mm": 20,
    "scoring_weights": {
      "fiducial_exists": 20,
      "named_correctly": 10,
      "z_coordinate_valid": 20,
      "xy_coordinate_valid": 15,
      "airway_adjacent_vlm": 20,
      "distance_from_gt": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_locate_tracheal_carina"
    }
  }
}
