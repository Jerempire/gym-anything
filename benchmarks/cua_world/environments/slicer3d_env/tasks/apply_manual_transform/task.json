{
  "id": "apply_manual_transform@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create a LinearTransform with a rotation of approximately 15 degrees around the IS (Inferior-Superior) axis and apply it to the loaded MRHead brain MRI volume. Keep the transform as an association (not hardened). No file output is required.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/apply_manual_transform/setup_task.sh",
    "post_task": "/workspace/tasks/apply_manual_transform/export_result.sh"
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "expected_rotation_degrees": 15,
    "rotation_tolerance_degrees": 5,
    "expected_axis": "S",
    "scoring_weights": {
      "transform_exists": 25,
      "transform_non_identity": 15,
      "rotation_approximately_correct": 25,
      "correct_axis": 10,
      "volume_transformed": 20,
      "vlm_confirmation": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_apply_manual_transform"
    }
  }
}
