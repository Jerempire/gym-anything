{
  "id": "aorta_measurement@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the maximum outer diameter of the abdominal aorta on the provided CT scan and identify the vertebral level of maximum diameter. Classify the finding and save measurement markup to ~/Documents/SlicerData/AMOS/agent_measurement.mrk.json and report to ~/Documents/SlicerData/AMOS/aorta_report.json.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/aorta_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/aorta_measurement/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_measurement": "/home/ga/Documents/SlicerData/AMOS/agent_measurement.mrk.json",
    "output_report": "/home/ga/Documents/SlicerData/AMOS/aorta_report.json",
    "aorta_label": 10,
    "passing_thresholds": {
      "diameter_error_max_mm": 5.0,
      "classification_correct": true
    },
    "scoring_weights": {
      "diameter_accuracy": 35,
      "classification_correct": 25,
      "measurement_placed": 15,
      "vertebral_level": 10,
      "report_completeness": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_aorta_measurement"
    }
  }
}
