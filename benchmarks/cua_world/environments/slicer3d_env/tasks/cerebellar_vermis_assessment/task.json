{
  "id": "cerebellar_vermis_assessment@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the cerebellar vermis anteroposterior (AP) diameter on the provided brain MRI (FLAIR sequence) using the mid-sagittal plane. Save measurement markup to ~/Documents/SlicerData/BraTS/vermis_measurement.mrk.json and report to ~/Documents/SlicerData/BraTS/vermis_report.json with fields: ap_diameter (mm), morphology (string), classification (string).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/cerebellar_vermis_assessment/setup_task.sh",
    "post_task": "/workspace/tasks/cerebellar_vermis_assessment/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_measurement": "/home/ga/Documents/SlicerData/BraTS/vermis_measurement.mrk.json",
    "output_report": "/home/ga/Documents/SlicerData/BraTS/vermis_report.json",
    "passing_thresholds": {
      "diameter_error_max_mm": 5.0,
      "min_score": 60
    },
    "scoring_weights": {
      "ap_diameter_measurement": 30,
      "measurement_location_valid": 20,
      "sagittal_view_used": 15,
      "markup_file_saved": 10,
      "report_ap_diameter": 10,
      "report_morphology": 10,
      "report_classification": 5
    },
    "clinical_thresholds": {
      "normal_min_mm": 25,
      "borderline_min_mm": 18
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_cerebellar_vermis_assessment"
    }
  }
}