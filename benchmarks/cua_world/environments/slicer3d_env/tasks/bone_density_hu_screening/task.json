{
  "id": "bone_density_hu_screening@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Perform opportunistic bone density screening on the provided chest CT. Measure the mean HU within an ROI placed in the trabecular bone of a lower thoracic or upper lumbar vertebral body and classify the bone density status. Save the ROI to ~/Documents/SlicerData/LIDC/bone_density_roi.seg.nrrd and report the findings to ~/Documents/SlicerData/LIDC/bone_density_report.json with the following fields: vertebral_level, mean_hu, roi_area_mm2, classification, and clinical_notes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bone_density_hu_screening/setup_task.sh",
    "post_task": "/workspace/tasks/bone_density_hu_screening/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "lidc_dir": "/home/ga/Documents/SlicerData/LIDC",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_roi": "/home/ga/Documents/SlicerData/LIDC/bone_density_roi.seg.nrrd",
    "output_report": "/home/ga/Documents/SlicerData/LIDC/bone_density_report.json",
    "acceptable_levels": [
      "T12",
      "L1",
      "T11",
      "L2"
    ],
    "exact_levels": [
      "T12",
      "L1"
    ],
    "hu_tolerance": 25,
    "roi_area_min_mm2": 80,
    "roi_area_max_mm2": 300,
    "classification_thresholds": {
      "normal": 160,
      "osteopenia_low": 110
    },
    "scoring_weights": {
      "hu_measurement_accuracy": 30,
      "classification_correct": 20,
      "roi_placement_quality": 15,
      "roi_area_appropriate": 10,
      "vertebral_level_correct": 10,
      "report_completeness": 10,
      "screenshot_evidence": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bone_density_screening"
    }
  }
}
