{
  "id": "load_sample_data@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Load the MRHead sample MRI brain scan from ~/Documents/SlicerData/SampleData/MRHead.nrrd into 3D Slicer and ensure it is visible in the slice views.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 120,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/load_sample_data/setup_task.sh",
    "post_task": "/workspace/tasks/load_sample_data/export_result.sh"
  },
  "metadata": {
    "sample_file": "MRHead.nrrd",
    "sample_file_path": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "expected_data_type": "volume",
    "require_exact_match": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_load_sample_data"
    }
  }
}
