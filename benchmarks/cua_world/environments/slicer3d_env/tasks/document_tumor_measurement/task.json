{
  "id": "document_tumor_measurement@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the maximum transverse diameter of the brain tumor on the loaded FLAIR MRI axial view. Document the widest extent with a line markup and a text annotation formatted as \"Max diameter: XX.X mm\". Save a screenshot showing the tumor, measurement, and annotation to ~/Documents/SlicerData/Screenshots/tumor_measurement.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/document_tumor_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/document_tumor_measurement/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_screenshot": "/home/ga/Documents/SlicerData/Screenshots/tumor_measurement.png",
    "min_screenshot_size_kb": 50,
    "measurement_tolerance_percent": 15,
    "expected_diameter_range_mm": {
      "min": 15,
      "max": 80
    },
    "scoring_weights": {
      "screenshot_exists": 15,
      "screenshot_size_adequate": 5,
      "tumor_visible": 20,
      "measurement_line_present": 20,
      "text_annotation_present": 15,
      "measurement_accuracy": 25
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_document_tumor_measurement"
    }
  }
}
