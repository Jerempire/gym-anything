{
  "id": "verify_anatomical_orientation@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Verify the anatomical orientation of the pre-loaded abdominal CT by placing fiducial markers on the liver, spine, and heart. Name the markers such that they contain 'liver', 'spine', and 'heart' respectively (case-insensitive). Save the markups to ~/Documents/SlicerData/AMOS/orientation_markers.mrk.json.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/verify_anatomical_orientation/setup_task.sh",
    "post_task": "/workspace/tasks/verify_anatomical_orientation/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_markups": "/home/ga/Documents/SlicerData/AMOS/orientation_markers.mrk.json",
    "expected_fiducials": [
      "liver",
      "spine",
      "heart"
    ],
    "liver_label_id": 6,
    "aorta_label_id": 10,
    "scoring_weights": {
      "liver_fiducial_exists": 15,
      "liver_position_correct": 15,
      "spine_fiducial_exists": 15,
      "spine_position_correct": 15,
      "heart_fiducial_exists": 15,
      "heart_position_correct": 15,
      "spatial_relationships_correct": 10
    },
    "position_tolerance_mm": 30,
    "z_tolerance_mm": 50
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_anatomical_orientation"
    }
  }
}
