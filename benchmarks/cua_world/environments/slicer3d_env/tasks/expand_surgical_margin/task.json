{
  "id": "expand_surgical_margin@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create a 5.0mm surgical margin named 'SurgicalMargin' by expanding the 'EnhancingTumor' segment in 'TumorSegmentation'. Save the segmentation to ~/Documents/SlicerData/BraTS/surgical_margin_segmentation.seg.nrrd.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/expand_surgical_margin/setup_task.sh",
    "post_task": "/workspace/tasks/expand_surgical_margin/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "initial_segmentation": "/home/ga/Documents/SlicerData/BraTS/initial_tumor_segmentation.seg.nrrd",
    "expected_output_path": "/home/ga/Documents/SlicerData/BraTS/surgical_margin_segmentation.seg.nrrd",
    "margin_size_mm": 5.0,
    "margin_tolerance_mm": 1.5,
    "min_volume_ratio": 1.5,
    "max_volume_ratio": 8.0,
    "expected_surface_distance_mm": 5.0,
    "surface_distance_tolerance_mm": 2.0,
    "scoring_weights": {
      "output_file_exists": 15,
      "valid_segmentation": 15,
      "volume_increased": 20,
      "volume_ratio_correct": 20,
      "surface_distance_correct": 20,
      "vlm_visual_confirmation": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_expand_surgical_margin"
    }
  }
}
