{
  "id": "rename_volume_node@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Rename the loaded 'MRHead' brain MRI volume to exactly 'STUDY001_T1_Brain'. The volume must be renamed in place, not deleted and recreated.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rename_volume_node/setup_task.sh",
    "post_task": "/workspace/tasks/rename_volume_node/export_result.sh"
  },
  "metadata": {
    "original_volume_name": "MRHead",
    "expected_new_name": "STUDY001_T1_Brain",
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "result_file": "/tmp/rename_task_result.json",
    "scoring_weights": {
      "new_name_exists": 50,
      "original_name_gone": 25,
      "volume_count_unchanged": 10,
      "name_visible_in_ui": 15
    },
    "pass_threshold": 75
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rename_volume_node"
    }
  }
}