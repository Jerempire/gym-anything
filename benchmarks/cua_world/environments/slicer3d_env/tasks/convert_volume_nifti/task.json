{
  "id": "convert_volume_nifti@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Convert the brain MRI volume at ~/Documents/SlicerData/SampleData/MRHead.nrrd from NRRD format to compressed NIfTI format, preserving spatial properties (dimensions, voxel spacing, orientation). Save to ~/Documents/SlicerData/Exports/MRHead_converted.nii.gz.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/convert_volume_nifti/setup_task.sh",
    "post_task": "/workspace/tasks/convert_volume_nifti/export_result.sh"
  },
  "metadata": {
    "source_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "expected_output_path": "/home/ga/Documents/SlicerData/Exports/MRHead_converted.nii.gz",
    "expected_output_dir": "/home/ga/Documents/SlicerData/Exports",
    "min_file_size_bytes": 1000000,
    "max_file_size_bytes": 15000000,
    "expected_dimensions": [256, 256, 130],
    "dimension_tolerance": 10,
    "spacing_tolerance_percent": 1.0,
    "scoring_weights": {
      "source_loaded": 15,
      "output_exists": 20,
      "valid_nifti_format": 15,
      "matching_dimensions": 20,
      "matching_spacing": 15,
      "valid_content": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_convert_volume_nifti"
    }
  }
}