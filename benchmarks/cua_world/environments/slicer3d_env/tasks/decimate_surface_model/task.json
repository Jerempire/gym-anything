{
  "id": "decimate_surface_model@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Reduce the polygon count of the pre-loaded brain surface model by at least 50% while preserving recognizable anatomical shape. Save the model to /home/ga/Documents/SlicerData/Exports/brain_decimated.vtk.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/decimate_surface_model/setup_task.sh",
    "post_task": "/workspace/tasks/decimate_surface_model/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "original_model_path": "/home/ga/Documents/SlicerData/Models/brain_highres.vtk",
    "expected_output_path": "/home/ga/Documents/SlicerData/Exports/brain_decimated.vtk",
    "minimum_reduction_percent": 50,
    "original_polygon_estimate": 500000,
    "target_max_polygons": 250000,
    "min_valid_polygons": 5000,
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "scoring_weights": {
      "output_file_exists": 20,
      "file_created_during_task": 10,
      "polygon_reduction_sufficient": 30,
      "model_geometrically_valid": 15,
      "shape_preserved": 15,
      "file_size_reduced": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_decimate_surface_model"
    }
  }
}
