{
  "id": "capture_3d_view@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Perform a 3D volume rendering of the MRHead.nrrd volume (located at ~/Documents/SlicerData/SampleData/MRHead.nrrd) and save a screenshot of the rendered brain to ~/Documents/SlicerData/Screenshots/.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/capture_3d_view/setup_task.sh",
    "post_task": "/workspace/tasks/capture_3d_view/export_result.sh"
  },
  "metadata": {
    "sample_file": "MRHead.nrrd",
    "expected_module": "VolumeRendering",
    "min_screenshot_size_kb": 100
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_capture_3d_view"
    }
  }
}
