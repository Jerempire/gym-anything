{
  "id": "scroll_one_slice_measure_aorta@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the abdominal aorta diameter on the CT scan at a slice showing a circular cross-section. Save the measurement to ~/Documents/SlicerData/AMOS/aorta_diameter.mrk.json",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 360,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/scroll_one_slice_measure_aorta/setup_task.sh",
    "post_task": "/workspace/tasks/scroll_one_slice_measure_aorta/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "output_measurement": "/home/ga/Documents/SlicerData/AMOS/aorta_diameter.mrk.json",
    "ground_truth_diameter_mm": 25.0,
    "tolerance_mm": 10.0,
    "slices_to_scroll": 3,
    "scoring_weights": {
      "measurement_exists": 25,
      "scrolled_from_initial": 15,
      "diameter_accuracy": 30,
      "measurement_on_aorta": 20,
      "file_saved": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_scroll_one_slice_measure_aorta"
    }
  }
}
