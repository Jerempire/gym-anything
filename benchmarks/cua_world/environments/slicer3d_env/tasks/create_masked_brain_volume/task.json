{
  "id": "create_masked_brain_volume@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create a skull-stripped brain volume from ~/Documents/SlicerData/SampleData/MRHead.nrrd. The resulting volume should have all non-brain regions zeroed out. Save the output to ~/Documents/SlicerData/Exports/MRHead_brain_only.nrrd.",
  "difficulty": "intermediate",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_masked_brain_volume/setup_task.sh",
    "post_task": "/workspace/tasks/create_masked_brain_volume/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "expected_output_path": "/home/ga/Documents/SlicerData/Exports/MRHead_brain_only.nrrd",
    "expected_dimensions": [
      256,
      256,
      130
    ],
    "min_near_zero_percentage": 30,
    "min_file_size_kb": 500,
    "scoring_weights": {
      "output_file_exists": 25,
      "correct_dimensions": 15,
      "effective_masking": 25,
      "brain_preserved": 20,
      "file_created_during_task": 10,
      "visual_confirmation": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_masked_brain_volume"
    }
  }
}
