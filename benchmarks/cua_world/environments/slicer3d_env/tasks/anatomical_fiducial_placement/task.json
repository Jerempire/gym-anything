{
  "id": "anatomical_fiducial_placement@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Place fiducial markers at four anatomical landmarks on the loaded brain MRI: Nasion, Inion, Left_Tragus, and Right_Tragus. Create a Markups Point List named 'Navigation_Landmarks' with each point labeled by its anatomical name. Save the markup to ~/Documents/SlicerData/BraTS/navigation_landmarks.mrk.json and a screenshot to ~/Documents/SlicerData/BraTS/landmarks_screenshot.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/anatomical_fiducial_placement/setup_task.sh",
    "post_task": "/workspace/tasks/anatomical_fiducial_placement/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_markup": "/home/ga/Documents/SlicerData/BraTS/navigation_landmarks.mrk.json",
    "output_screenshot": "/home/ga/Documents/SlicerData/BraTS/landmarks_screenshot.png",
    "expected_landmarks": ["Nasion", "Inion", "Left_Tragus", "Right_Tragus"],
    "position_tolerance_mm": 20.0,
    "symmetry_tolerance_mm": 10.0,
    "scoring_weights": {
      "markup_file_created": 15,
      "four_points_present": 15,
      "points_labeled": 10,
      "nasion_accuracy": 15,
      "inion_accuracy": 15,
      "left_tragus_accuracy": 10,
      "right_tragus_accuracy": 10,
      "bilateral_symmetry": 8,
      "screenshot_created": 2
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_anatomical_fiducial_placement"
    }
  }
}