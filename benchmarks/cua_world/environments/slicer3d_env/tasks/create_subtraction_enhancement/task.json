{
  "id": "create_subtraction_enhancement@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create a subtraction enhancement map (T1ce minus T1) named 'EnhancementMap' using the BraTS brain MRI data at ~/Documents/SlicerData/BraTS/ (sample ID in /tmp/brats_sample_id). Export the result to ~/Documents/SlicerData/Exports/enhancement_map.nii.gz.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_subtraction_enhancement/setup_task.sh",
    "post_task": "/workspace/tasks/create_subtraction_enhancement/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "data_source": "BraTS 2021 dataset",
    "expected_output_path": "/home/ga/Documents/SlicerData/Exports/enhancement_map.nii.gz",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "min_output_size_kb": 100,
    "expected_correlation_threshold": 0.8,
    "enhancement_ratio_threshold": 1.5,
    "scoring_weights": {
      "output_exists": 15,
      "correct_dimensions": 15,
      "valid_subtraction": 20,
      "enhancement_detected": 25,
      "created_during_task": 10,
      "visual_confirmation": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_subtraction_enhancement"
    }
  }
}
