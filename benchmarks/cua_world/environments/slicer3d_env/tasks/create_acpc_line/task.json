{
  "id": "create_acpc_line@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Identify the anterior commissure (AC) and posterior commissure (PC) on the MRHead brain MRI (~/Documents/SlicerData/SampleData/MRHead.nrrd) at the midsagittal plane. Create fiducial points labeled 'AC' and 'PC' and a line markup connecting them. Save all markups to ~/Documents/SlicerData/Exports/ACPC_landmarks.mrk.json.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_acpc_line/setup_task.sh",
    "post_task": "/workspace/tasks/create_acpc_line/export_result.sh"
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "output_markups": "/home/ga/Documents/SlicerData/Exports/ACPC_landmarks.mrk.json",
    "reference_ac_ras": [
      -0.5,
      2.0,
      -4.0
    ],
    "reference_pc_ras": [
      -0.5,
      -23.0,
      -2.0
    ],
    "ac_tolerance_mm": 8.0,
    "pc_tolerance_mm": 8.0,
    "expected_acpc_distance_mm": 25.0,
    "acpc_distance_range_mm": {
      "min": 20.0,
      "max": 32.0
    },
    "midline_tolerance_mm": 10.0,
    "scoring_weights": {
      "markups_file_created": 15,
      "ac_fiducial_present": 10,
      "pc_fiducial_present": 10,
      "ac_location_accuracy": 20,
      "pc_location_accuracy": 20,
      "acpc_distance_valid": 15,
      "line_markup_created": 5,
      "correct_spatial_relationship": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_acpc_line"
    }
  }
}
