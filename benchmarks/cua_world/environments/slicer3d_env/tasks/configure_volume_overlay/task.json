{
  "id": "configure_volume_overlay@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create a blended overlay of the pre-loaded FLAIR (background) and T1ce (foreground) brain MRI sequences with 50% foreground opacity. Save a screenshot of the result to ~/Documents/SlicerData/Exports/overlay_result.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_volume_overlay/setup_task.sh",
    "post_task": "/workspace/tasks/configure_volume_overlay/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "expected_output_screenshot": "/home/ga/Documents/SlicerData/Exports/overlay_result.png",
    "expected_background_volume": "flair",
    "expected_foreground_volume": "t1ce",
    "expected_opacity_min": 0.4,
    "expected_opacity_max": 0.6,
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "scoring_weights": {
      "volumes_loaded": 15,
      "background_configured": 20,
      "foreground_configured": 20,
      "opacity_correct": 20,
      "screenshot_saved": 15,
      "vlm_verification": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_volume_overlay"
    }
  }
}
