{
  "id": "measure_visible_tumor_diameter@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the maximum diameter of the visible glioma tumor on this brain FLAIR MRI. Save the measurement to ~/Documents/SlicerData/BraTS/tumor_diameter.mrk.json",
  "difficulty": "very easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/measure_visible_tumor_diameter/setup_task.sh",
    "post_task": "/workspace/tasks/measure_visible_tumor_diameter/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "output_measurement": "/home/ga/Documents/SlicerData/BraTS/tumor_diameter.mrk.json",
    "ground_truth_diameter_mm": 45.0,
    "tolerance_mm": 20.0,
    "scoring_weights": {
      "measurement_exists": 30,
      "measurement_on_tumor": 35,
      "diameter_accuracy": 25,
      "file_saved": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_measure_visible_tumor_diameter"
    }
  }
}
