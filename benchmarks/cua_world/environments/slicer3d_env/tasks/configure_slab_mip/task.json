{
  "id": "configure_slab_mip@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Configure the axial slice view on the loaded abdominal CT to display a 10mm thick-slab Maximum Intensity Projection (MIP) for enhanced vessel visualization. The slab mode should be set to 'Max' with a thickness of 10mm.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_slab_mip/setup_task.sh",
    "post_task": "/workspace/tasks/configure_slab_mip/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_slab_mode": 2,
    "target_slab_mode_name": "Max",
    "target_thickness_mm_min": 8.0,
    "target_thickness_mm_max": 12.0,
    "target_slice_view": "Red",
    "data_source": "AMOS 2022 Abdominal CT",
    "scoring_weights": {
      "slab_mode_enabled": 25,
      "correct_mode_mip": 25,
      "thickness_in_range": 25,
      "correct_slice_view": 15,
      "vlm_vessel_enhancement": 10
    },
    "slab_modes": {
      "0": "None",
      "1": "Min",
      "2": "Max",
      "3": "Mean",
      "4": "Sum"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_slab_mip"
    }
  }
}
