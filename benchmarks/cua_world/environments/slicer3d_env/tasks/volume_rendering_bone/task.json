{
  "id": "volume_rendering_bone@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Visualize the skeletal structures of the pre-loaded abdominal CT scan using a bone volume rendering preset. Save a screenshot of the spine in the 3D view to ~/Documents/SlicerData/Screenshots/bone_rendering.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/volume_rendering_bone/setup_task.sh",
    "post_task": "/workspace/tasks/volume_rendering_bone/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_screenshot_path": "/home/ga/Documents/SlicerData/Screenshots/bone_rendering.png",
    "min_screenshot_size_kb": 50,
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "case_id": "amos_0001",
    "volume_file": "/home/ga/Documents/SlicerData/AMOS/amos_0001.nii.gz",
    "scoring_weights": {
      "screenshot_exists": 20,
      "screenshot_valid_size": 10,
      "screenshot_recent": 10,
      "vr_node_active": 15,
      "preset_applied": 10,
      "bones_visible_vlm": 20,
      "spine_clear_vlm": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_volume_rendering_bone"
    }
  }
}
