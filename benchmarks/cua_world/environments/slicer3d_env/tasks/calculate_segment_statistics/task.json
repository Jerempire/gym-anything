{
  "id": "calculate_segment_statistics@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Calculate quantitative statistics for the pre-loaded brain tumor segmentation (Necrotic, Edema, Enhancing segments) against the T1ce MRI volume. Export results as a CSV to ~/Documents/SlicerData/Exports/tumor_statistics.csv containing all three segments with volume measurements and at least one intensity statistic.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/calculate_segment_statistics/setup_task.sh",
    "post_task": "/workspace/tasks/calculate_segment_statistics/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "expected_output_path": "/home/ga/Documents/SlicerData/Exports/tumor_statistics.csv",
    "expected_segments": ["Necrotic", "Edema", "Enhancing"],
    "required_columns": ["Segment", "Volume"],
    "volume_tolerance_percent": 5,
    "scoring_weights": {
      "csv_exists": 20,
      "csv_structure_valid": 15,
      "all_segments_present": 20,
      "volume_values_valid": 15,
      "volume_accuracy": 15,
      "intensity_stats_present": 10,
      "file_timestamp_valid": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_calculate_segment_statistics"
    }
  }
}