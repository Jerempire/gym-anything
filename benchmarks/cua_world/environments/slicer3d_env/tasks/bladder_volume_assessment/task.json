{
  "id": "bladder_volume_assessment@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Segment the urinary bladder on the provided abdominal CT and measure its volume. Save segmentation to ~/Documents/SlicerData/AMOS/bladder_segmentation.nii.gz and report to ~/Documents/SlicerData/AMOS/bladder_report.json with fields: volume_ml, distension_status, clinical_significance.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bladder_volume_assessment/setup_task.sh",
    "post_task": "/workspace/tasks/bladder_volume_assessment/export_result.sh",
    "pre_task_timeout": 1200
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_segmentation": "/home/ga/Documents/SlicerData/AMOS/bladder_segmentation.nii.gz",
    "output_report": "/home/ga/Documents/SlicerData/AMOS/bladder_report.json",
    "bladder_label": 11,
    "passing_thresholds": {
      "dice_minimum": 0.5,
      "volume_error_max_percent": 40
    },
    "scoring_weights": {
      "dice_high": 30,
      "dice_moderate": 15,
      "volume_accurate": 20,
      "volume_reasonable": 10,
      "classification_correct": 15,
      "clinical_assessment": 10,
      "report_complete": 10,
      "single_component": 5,
      "pelvic_location": 5,
      "file_exists": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bladder_volume_assessment"
    }
  }
}