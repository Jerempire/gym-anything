{
  "id": "measure_splenic_length@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the craniocaudal length of the spleen on the provided abdominal CT scan and assess for splenomegaly. Save results to /home/ga/Documents/SlicerData/Exports/splenic_measurement.json with fields: length_mm, splenomegaly (boolean), and assessment. Save a screenshot showing the measurement to /home/ga/Documents/SlicerData/Exports/splenic_measurement.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/measure_splenic_length/setup_task.sh",
    "post_task": "/workspace/tasks/measure_splenic_length/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_measurement": "/home/ga/Documents/SlicerData/Exports/splenic_measurement.json",
    "screenshot_dir": "/home/ga/Documents/SlicerData/Screenshots",
    "spleen_label_value": 1,
    "splenomegaly_threshold_mm": 120,
    "mild_splenomegaly_threshold_mm": 150,
    "measurement_tolerance_percent": 15,
    "min_measurement_mm": 50,
    "max_measurement_mm": 300,
    "scoring_weights": {
      "json_file_created": 15,
      "required_fields_present": 10,
      "measurement_accuracy": 30,
      "classification_correct": 20,
      "screenshot_exists": 10,
      "vlm_spleen_verification": 10,
      "appropriate_view_used": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_splenic_length"
    }
  }
}
