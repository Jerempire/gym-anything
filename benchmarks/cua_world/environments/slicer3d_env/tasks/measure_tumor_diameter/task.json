{
  "id": "measure_tumor_diameter@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the maximum diameter of the brain tumor on the loaded FLAIR MRI at its widest cross-section on the axial slice. Save a screenshot showing the measurement to ~/Documents/SlicerData/Screenshots/tumor_measurement.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/measure_tumor_diameter/setup_task.sh",
    "post_task": "/workspace/tasks/measure_tumor_diameter/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "data_source": "BraTS 2021 (Kaggle)",
    "data_url": "https://www.kaggle.com/datasets/dschettler8845/brats-2021-task1",
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "screenshot_path": "/home/ga/Documents/SlicerData/Screenshots/tumor_measurement.png",
    "min_plausible_diameter_mm": 10,
    "max_plausible_diameter_mm": 150,
    "accuracy_tolerance_percent": 20,
    "min_screenshot_size_kb": 50,
    "scoring_weights": {
      "markup_created": 20,
      "measurement_recorded": 15,
      "reasonable_range": 15,
      "accuracy": 25,
      "screenshot_saved": 15,
      "visual_confirmation": 10
    },
    "pass_threshold": 55
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_measure_tumor_diameter"
    }
  }
}
