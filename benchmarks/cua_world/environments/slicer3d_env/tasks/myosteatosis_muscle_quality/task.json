{
  "id": "myosteatosis_muscle_quality@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Segment the skeletal muscle compartment (psoas and paraspinal muscles) at the L3 vertebral level on the loaded abdominal CT. Measure mean HU and assess for myosteatosis based on patient sex (see ~/Documents/SlicerData/AMOS/patient_info.txt). Save segmentation to ~/Documents/SlicerData/AMOS/muscle_segmentation.nii.gz and report to ~/Documents/SlicerData/AMOS/myosteatosis_report.json with fields: vertebral_level, muscle_area_cm2, mean_hu, std_hu, patient_sex, myosteatosis_threshold, myosteatosis_present, classification.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/myosteatosis_muscle_quality/setup_task.sh",
    "post_task": "/workspace/tasks/myosteatosis_muscle_quality/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_segmentation": "/home/ga/Documents/SlicerData/AMOS/muscle_segmentation.nii.gz",
    "output_report": "/home/ga/Documents/SlicerData/AMOS/myosteatosis_report.json",
    "muscle_hu_range": {
      "min": -29,
      "max": 150
    },
    "myosteatosis_thresholds": {
      "male": 41,
      "female": 33
    },
    "passing_thresholds": {
      "mean_hu_error_max": 5.0,
      "level_tolerance": 1,
      "area_min_cm2": 100,
      "area_max_cm2": 250
    },
    "scoring_weights": {
      "segmentation_exists": 10,
      "correct_vertebral_level": 15,
      "anatomical_location": 15,
      "mean_hu_accuracy": 25,
      "area_reasonable": 10,
      "classification_correct": 15,
      "report_complete": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_myosteatosis"
    }
  }
}