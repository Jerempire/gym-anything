{
  "id": "neuroanatomy_landmark_suite@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Identify and place fiducial markers on six neuroanatomical structures in the loaded MRHead brain MRI: lateral ventricle frontal horn, third ventricle, corpus callosum genu, corpus callosum splenium, pineal gland, and pons. Measure widths/thicknesses where applicable (frontal horn width, third ventricle width, genu thickness, splenium thickness, pons AP diameter). Save fiducials to ~/Documents/SlicerData/SampleData/neuroanatomy_landmarks.mrk.json and report to ~/Documents/SlicerData/SampleData/neuroanatomy_report.json with structure names, RAS coordinates, and measurements.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/neuroanatomy_landmark_suite/setup_task.sh",
    "post_task": "/workspace/tasks/neuroanatomy_landmark_suite/export_result.sh",
    "pre_task_timeout": 300
  },
  "metadata": {
    "sample_data_dir": "/home/ga/Documents/SlicerData/SampleData",
    "output_fiducials": "/home/ga/Documents/SlicerData/SampleData/neuroanatomy_landmarks.mrk.json",
    "output_report": "/home/ga/Documents/SlicerData/SampleData/neuroanatomy_report.json",
    "ground_truth_file": "/var/lib/slicer/ground_truth/neuroanatomy_gt.json",
    "required_structures": [
      "lateral_ventricle_frontal_horn",
      "third_ventricle",
      "corpus_callosum_genu",
      "corpus_callosum_splenium",
      "pineal_gland",
      "pons"
    ],
    "ground_truth": {
      "lateral_ventricle_frontal_horn_left": {
        "coordinates_ras": [-12.0, 22.0, 12.0],
        "tolerance_mm": 12.0
      },
      "lateral_ventricle_frontal_horn_right": {
        "coordinates_ras": [12.0, 22.0, 12.0],
        "tolerance_mm": 12.0
      },
      "third_ventricle": {
        "coordinates_ras": [0.0, -8.0, 8.0],
        "measurement_mm": 5.0,
        "tolerance_mm": 10.0,
        "measurement_tolerance": 3.0
      },
      "corpus_callosum_genu": {
        "coordinates_ras": [0.0, 28.0, 12.0],
        "measurement_mm": 11.0,
        "tolerance_mm": 10.0,
        "measurement_tolerance": 4.0
      },
      "corpus_callosum_splenium": {
        "coordinates_ras": [0.0, -38.0, 16.0],
        "measurement_mm": 12.0,
        "tolerance_mm": 10.0,
        "measurement_tolerance": 4.0
      },
      "pineal_gland": {
        "coordinates_ras": [0.0, -28.0, 6.0],
        "tolerance_mm": 8.0
      },
      "pons": {
        "coordinates_ras": [0.0, -28.0, -24.0],
        "measurement_mm": 24.0,
        "tolerance_mm": 10.0,
        "measurement_tolerance": 5.0
      }
    },
    "scoring_weights": {
      "lateral_ventricle_fiducial": 10,
      "third_ventricle_fiducial": 10,
      "cc_genu_fiducial": 10,
      "cc_splenium_fiducial": 10,
      "pineal_gland_fiducial": 10,
      "pons_fiducial": 10,
      "third_ventricle_measurement": 8,
      "cc_genu_measurement": 7,
      "cc_splenium_measurement": 7,
      "pons_measurement": 8,
      "documentation_completeness": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_neuroanatomy_landmarks"
    }
  }
}