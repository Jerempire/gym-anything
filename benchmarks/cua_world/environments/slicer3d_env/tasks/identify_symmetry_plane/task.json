{
  "id": "identify_symmetry_plane@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Place a Plane markup representing the midsagittal symmetry plane on the MRHead brain MRI. Name the plane with 'Midsagittal' in its name and orient it as a sagittal plane through midline structures. Save a screenshot showing the plane in 3D view to ~/Documents/SlicerData/Screenshots/midsagittal_plane.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/identify_symmetry_plane/setup_task.sh",
    "post_task": "/workspace/tasks/identify_symmetry_plane/export_result.sh"
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "expected_screenshot_path": "/home/ga/Documents/SlicerData/Screenshots/midsagittal_plane.png",
    "plane_name_pattern": "midsagittal",
    "orientation_tolerance_degrees": 15,
    "position_tolerance_mm": 10,
    "scoring_weights": {
      "plane_exists": 20,
      "correct_naming": 10,
      "sagittal_orientation": 30,
      "midline_position": 25,
      "screenshot_captured": 10,
      "vlm_visual_confirmation": 5
    },
    "pass_threshold": 70,
    "required_criteria": [
      "plane_exists",
      "sagittal_orientation"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_identify_symmetry_plane"
    }
  }
}
