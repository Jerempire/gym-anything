{
  "id": "measure_tumor_bbox@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Segment the brain tumor on the loaded FLAIR MRI (BraTS dataset) and measure its 3D bounding box dimensions (width, depth, height in mm) and bounding volume. Save measurements to ~/Documents/SlicerData/BraTS/tumor_bbox_measurements.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 360,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/measure_tumor_bbox/setup_task.sh",
    "post_task": "/workspace/tasks/measure_tumor_bbox/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_file": "/home/ga/Documents/SlicerData/BraTS/tumor_bbox_measurements.txt",
    "scoring_weights": {
      "segmentation_created": 20,
      "bbox_dimensions_reported": 25,
      "bbox_volume_calculated": 20,
      "dimensions_accuracy": 20,
      "output_file_exists": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_measure_tumor_bbox"
    }
  }
}
