{
  "id": "export_landmarks_csv@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Place four fiducial markers on the MRHead volume at the AC (anterior commissure), PC (posterior commissure), CC_Superior (most superior point of corpus callosum), and Frontal_Apex (most anterior frontal lobe cortex). Export the 'Anatomical_Landmarks' point list to ~/Documents/SlicerData/Exports/landmarks.csv as a CSV file with columns: label, r, a, s.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_landmarks_csv/setup_task.sh",
    "post_task": "/workspace/tasks/export_landmarks_csv/export_result.sh"
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "output_csv_path": "/home/ga/Documents/SlicerData/Exports/landmarks.csv",
    "expected_landmarks": [
      "AC",
      "PC",
      "CC_Superior",
      "Frontal_Apex"
    ],
    "num_landmarks": 4,
    "coordinate_bounds": {
      "R": {
        "min": -100,
        "max": 100
      },
      "A": {
        "min": -150,
        "max": 100
      },
      "S": {
        "min": -80,
        "max": 100
      }
    },
    "min_point_separation_mm": 5.0,
    "scoring_weights": {
      "csv_file_exists": 25,
      "four_landmarks": 25,
      "valid_coordinates": 20,
      "correct_format": 15,
      "fiducials_in_scene": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_landmarks_csv"
    }
  }
}
