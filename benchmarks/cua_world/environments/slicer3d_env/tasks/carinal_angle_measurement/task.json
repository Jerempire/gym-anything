{
  "id": "carinal_angle_measurement@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the carinal angle at the tracheal bifurcation on the provided chest CT using an angle markup with the vertex at the carina and arms along the right and left main bronchi. Save the markup to ~/Documents/SlicerData/Airway/carinal_angle.mrk.json and report to ~/Documents/SlicerData/Airway/carinal_report.json with the fields: measured_angle_degrees, classification, and vertebral_level.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/carinal_angle_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/carinal_angle_measurement/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "airway_dir": "/home/ga/Documents/SlicerData/Airway",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_measurement": "/home/ga/Documents/SlicerData/Airway/carinal_angle.mrk.json",
    "output_report": "/home/ga/Documents/SlicerData/Airway/carinal_report.json",
    "normal_angle_range": {
      "min": 50,
      "max": 100
    },
    "passing_thresholds": {
      "angle_error_max_degrees": 10.0,
      "z_position_error_max_mm": 15.0
    },
    "scoring_weights": {
      "angle_accuracy": 35,
      "correct_anatomical_level": 20,
      "markup_quality": 15,
      "classification_correct": 15,
      "report_completeness": 10,
      "vertebral_level_correct": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_carinal_angle"
    }
  }
}
