{
  "id": "locate_anterior_commissure@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Locate the anterior commissure (AC) on the MRHead brain MRI (~/Documents/SlicerData/SampleData/MRHead.nrrd) and place a fiducial marker at its center. The fiducial must be placed within 5mm of the true AC location.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/locate_anterior_commissure/setup_task.sh",
    "post_task": "/workspace/tasks/locate_anterior_commissure/export_result.sh"
  },
  "metadata": {
    "sample_file": "MRHead.nrrd",
    "sample_path": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "ground_truth_ac_ras": [
      0.0,
      1.5,
      -3.0
    ],
    "tolerance_5mm": 5.0,
    "tolerance_3mm": 3.0,
    "midline_tolerance_mm": 2.0,
    "scoring_weights": {
      "fiducial_exists": 25,
      "created_during_task": 15,
      "within_5mm": 35,
      "within_3mm_bonus": 15,
      "midline_placement": 10
    },
    "pass_threshold": 75
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_locate_anterior_commissure"
    }
  }
}
