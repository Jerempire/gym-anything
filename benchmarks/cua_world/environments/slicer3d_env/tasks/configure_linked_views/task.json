{
  "id": "configure_linked_views@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Configure a side-by-side layout displaying two different BraTS MRI sequences with linked scrolling. Save a screenshot of the dual-view configuration to ~/Documents/SlicerData/Exports/linked_views.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_linked_views/setup_task.sh",
    "post_task": "/workspace/tasks/configure_linked_views/export_task.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "data_source": "BraTS 2021 dataset",
    "expected_screenshot_path": "/home/ga/Documents/SlicerData/Exports/linked_views.png",
    "min_screenshot_size_kb": 50,
    "expected_sequences": [
      "flair",
      "t1",
      "t1ce",
      "t2"
    ],
    "default_layout_id": 1,
    "valid_multiview_layout_ids": [
      2,
      3,
      12,
      13,
      14,
      15,
      23,
      24,
      25,
      26,
      27,
      28,
      29,
      30
    ],
    "scoring_weights": {
      "multiview_layout_active": 20,
      "two_slice_views_visible": 15,
      "different_volumes_displayed": 25,
      "view_linking_enabled": 20,
      "offsets_synchronized": 10,
      "screenshot_saved": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_linked_views"
    }
  }
}
