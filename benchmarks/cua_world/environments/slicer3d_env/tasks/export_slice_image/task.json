{
  "id": "export_slice_image@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Export an axial slice from the loaded brain MRI (MRHead) that clearly shows both lateral ventricles as a PNG image (minimum 256x256 pixels). Export only the axial slice view, not the entire application window. Save to ~/Documents/SlicerData/Exports/ventricles_axial.png.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_slice_image/setup_task.sh",
    "post_task": "/workspace/tasks/export_slice_image/export_result.sh"
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "expected_output_path": "/home/ga/Documents/SlicerData/Exports/ventricles_axial.png",
    "min_file_size_kb": 30,
    "min_image_width": 256,
    "min_image_height": 256,
    "ventricle_slice_range": [125, 145],
    "scoring_weights": {
      "file_exists": 20,
      "valid_png": 15,
      "reasonable_size": 10,
      "created_during_task": 10,
      "vlm_brain_anatomy": 20,
      "vlm_ventricles_visible": 25
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_slice_image"
    }
  }
}