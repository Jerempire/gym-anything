{
  "id": "retroperitoneal_lymph_assessment@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Identify and measure retroperitoneal lymph nodes on the provided abdominal CT, recording short-axis diameters and anatomical stations. Save measurement markups to ~/Documents/SlicerData/AMOS/lymph_nodes.mrk.json and report to ~/Documents/SlicerData/AMOS/lymph_node_report.json with fields: total_nodes_identified, enlarged_nodes_count, largest_node_mm, largest_node_station, n_stage.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 420,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/retroperitoneal_lymph_assessment/setup_task.sh",
    "post_task": "/workspace/tasks/retroperitoneal_lymph_assessment/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_markups": "/home/ga/Documents/SlicerData/AMOS/lymph_nodes.mrk.json",
    "output_report": "/home/ga/Documents/SlicerData/AMOS/lymph_node_report.json",
    "lymph_node_threshold_mm": 10.0,
    "measurement_tolerance_mm": 3.0,
    "passing_thresholds": {
      "enlarged_detection_rate": 0.6,
      "measurement_error_max_mm": 3.0,
      "no_missed_enlarged": true
    },
    "scoring_weights": {
      "enlarged_node_detection": 25,
      "measurement_accuracy": 20,
      "no_missed_enlarged": 15,
      "correct_classification": 15,
      "station_assignment": 10,
      "largest_node_identified": 10,
      "report_completeness": 5
    },
    "lymph_node_stations": ["para-aortic", "paracaval", "aortocaval", "retrocaval", "retroaortic"]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_lymph_assessment"
    }
  }
}