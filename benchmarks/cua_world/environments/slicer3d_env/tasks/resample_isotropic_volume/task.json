{
  "id": "resample_isotropic_volume@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Resample the loaded abdominal CT volume to 1.0mm isotropic voxel spacing. Name the output volume 'CT_Isotropic'.",
  "difficulty": "intermediate",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/resample_isotropic_volume/setup_task.sh",
    "post_task": "/workspace/tasks/resample_isotropic_volume/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "data_script": "prepare_amos_data.sh",
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "target_spacing_mm": [
      1.0,
      1.0,
      1.0
    ],
    "spacing_tolerance_mm": 0.15,
    "expected_z_increase_factor": 2.0,
    "scoring_weights": {
      "output_volume_exists": 20,
      "spacing_x_correct": 15,
      "spacing_y_correct": 15,
      "spacing_z_correct": 20,
      "is_isotropic": 10,
      "dimensions_changed": 10,
      "visual_content_ok": 10
    },
    "pass_threshold": 70
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_resample_isotropic_volume"
    }
  }
}
