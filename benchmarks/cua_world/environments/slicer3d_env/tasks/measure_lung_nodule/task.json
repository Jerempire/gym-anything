{
  "id": "measure_lung_nodule@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the maximum diameter of the lung nodule indicated by the 'CAD_Nodule_Location' fiducial on the loaded LIDC-IDRI chest CT. Save the measurement to /home/ga/Documents/SlicerData/Exports/nodule_measurement.json with field: nodule_diameter_mm.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/measure_lung_nodule/setup_task.sh",
    "post_task": "/workspace/tasks/measure_lung_nodule/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "data_source": "LIDC-IDRI (Lung Image Database Consortium)",
    "patient_id": "LIDC-IDRI-0001",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_measurement_file": "/home/ga/Documents/SlicerData/Exports/nodule_measurement.json",
    "lidc_dir": "/home/ga/Documents/SlicerData/LIDC",
    "measurement_tolerance_mm": 3.0,
    "nodule_diameter_plausible_range_mm": {"min": 3, "max": 30},
    "scoring_weights": {
      "line_markup_created": 20,
      "measurement_exported": 15,
      "measurement_accuracy": 35,
      "line_position_valid": 15,
      "vlm_confirmation": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_measure_lung_nodule"
    }
  }
}