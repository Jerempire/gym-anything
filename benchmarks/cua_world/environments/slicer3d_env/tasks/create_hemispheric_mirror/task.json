{
  "id": "create_hemispheric_mirror@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Mirror the pre-loaded MRHead brain MRI along the LR (X) axis. Save the mirrored volume to /home/ga/Documents/SlicerData/Exports/MRHead_mirrored.nrrd and configure the workspace to show a comparison view of both the original and mirrored volumes.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_hemispheric_mirror/setup_task.sh",
    "post_task": "/workspace/tasks/create_hemispheric_mirror/export_result.sh"
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "expected_output_path": "/home/ga/Documents/SlicerData/Exports/MRHead_mirrored.nrrd",
    "min_file_size_kb": 1000,
    "expected_flip_axis": "LR",
    "scoring_weights": {
      "output_file_exists": 15,
      "file_valid_size": 10,
      "two_volumes_in_scene": 15,
      "correct_flip_axis": 25,
      "voxel_data_mirrored": 20,
      "comparison_view_setup": 15
    },
    "pass_threshold": 70,
    "key_criterion": "correct_flip_axis"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_hemispheric_mirror"
    }
  }
}
