{
  "id": "export_stl_3d_print@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Export the 'TumorSegmentation' segmentation from the loaded BraTS brain MRI as an STL (stereolithography) file for 3D printing. Save to ~/Documents/SlicerData/Exports/tumor_model.stl.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_stl_3d_print/setup_task.sh",
    "post_task": "/workspace/tasks/export_stl_3d_print/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/SlicerData/Exports/tumor_model.stl",
    "export_dir": "/home/ga/Documents/SlicerData/Exports",
    "min_file_size_kb": 10,
    "max_file_size_mb": 100,
    "min_triangle_count": 500,
    "min_bbox_mm": 5,
    "max_bbox_mm": 150,
    "data_source": "BraTS 2021 Brain Tumor Segmentation Challenge",
    "segmentation_name": "TumorSegmentation",
    "scoring_weights": {
      "stl_exists": 25,
      "created_during_task": 15,
      "valid_stl_format": 20,
      "sufficient_mesh_complexity": 20,
      "reasonable_dimensions": 10,
      "vlm_verification": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_stl_3d_print"
    }
  }
}