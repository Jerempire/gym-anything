{
  "id": "create_hollow_shell@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Hollow the pre-loaded 'Liver' segment (IRCADb dataset) using a 3.0 mm shell thickness and inside surface mode. Ensure the segment remains named 'Liver'. No files need to be saved.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_hollow_shell/setup_task.sh",
    "post_task": "/workspace/tasks/create_hollow_shell/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "ircadb_dir": "/home/ga/Documents/SlicerData/IRCADb",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "shell_thickness_mm": 3.0,
    "expected_volume_reduction_min": 0.35,
    "expected_volume_reduction_max": 0.7,
    "original_volume_range_ml": {
      "min": 800,
      "max": 2500
    },
    "final_volume_range_ml": {
      "min": 200,
      "max": 1200
    },
    "scoring_weights": {
      "segment_exists": 15,
      "volume_reduced": 25,
      "correct_reduction_range": 30,
      "shell_thickness_reasonable": 15,
      "vlm_hollow_appearance": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_hollow_shell"
    }
  }
}
