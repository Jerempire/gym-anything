{
  "id": "navigate_to_ras_coordinates@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Center the Axial, Sagittal, and Coronal slice views on RAS coordinates R=12, A=-8, S=35 (tolerance: +/-2mm per axis) in the loaded MRHead brain MRI.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/navigate_to_ras_coordinates/setup_task.sh",
    "post_task": "/workspace/tasks/navigate_to_ras_coordinates/export_result.sh"
  },
  "metadata": {
    "sample_file": "MRHead.nrrd",
    "sample_path": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "target_r": 12.0,
    "target_a": -8.0,
    "target_s": 35.0,
    "tolerance_mm": 2.0,
    "result_file": "/tmp/navigation_result.json",
    "scoring_weights": {
      "r_coordinate_correct": 25,
      "a_coordinate_correct": 25,
      "s_coordinate_correct": 25,
      "position_changed": 15,
      "vlm_verification": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_navigate_to_ras_coordinates"
    }
  }
}
