{
  "id": "cbd_diameter_measurement@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the common bile duct (CBD) internal diameter on the provided abdominal CT at the porta hepatis region. Save measurement markup to ~/Documents/SlicerData/AMOS/cbd_measurement.mrk.json and report to ~/Documents/SlicerData/AMOS/cbd_report.json with fields: diameter_mm, anatomical_level, classification, interpretation.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/cbd_diameter_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/cbd_diameter_measurement/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_measurement": "/home/ga/Documents/SlicerData/AMOS/cbd_measurement.mrk.json",
    "output_report": "/home/ga/Documents/SlicerData/AMOS/cbd_report.json",
    "cbd_diameter_range": {
      "min_physiological_mm": 2.0,
      "max_physiological_mm": 15.0,
      "normal_max_mm": 6.0,
      "borderline_max_mm": 8.0
    },
    "passing_thresholds": {
      "diameter_in_range": true,
      "classification_consistent": true
    },
    "scoring_weights": {
      "measurement_exists": 15,
      "correct_anatomical_region": 20,
      "diameter_accuracy": 25,
      "classification_correct": 15,
      "anatomical_level_documented": 10,
      "clinical_interpretation": 10,
      "report_completeness": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_cbd_measurement"
    }
  }
}