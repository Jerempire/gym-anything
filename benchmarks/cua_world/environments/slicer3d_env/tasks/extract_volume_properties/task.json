{
  "id": "extract_volume_properties@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Extract the spatial properties of the loaded MRHead brain MRI volume. Save to /home/ga/Documents/SlicerData/Exports/volume_properties.json with exact format: {\"volume_name\": \"MRHead\", \"dimensions\": [X, Y, Z], \"spacing_mm\": [X.XX, Y.YY, Z.ZZ], \"scalar_type\": \"type_name\", \"num_components\": N}.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/extract_volume_properties/setup_task.sh",
    "post_task": "/workspace/tasks/extract_volume_properties/export_result.sh"
  },
  "metadata": {
    "sample_file": "MRHead.nrrd",
    "expected_output_path": "/home/ga/Documents/SlicerData/Exports/volume_properties.json",
    "expected_volume_name": "MRHead",
    "ground_truth_path": "/var/lib/slicer/ground_truth/mrhead_properties.json",
    "dimension_tolerance": 0,
    "spacing_tolerance_mm": 0.01,
    "scoring_weights": {
      "file_exists": 15,
      "valid_json": 10,
      "volume_name_correct": 10,
      "dimensions_correct": 25,
      "spacing_correct": 25,
      "scalar_type_correct": 10,
      "num_components_correct": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_extract_volume_properties"
    }
  }
}