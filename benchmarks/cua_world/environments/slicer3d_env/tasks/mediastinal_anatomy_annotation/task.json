{
  "id": "mediastinal_anatomy_annotation@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Place fiducial markers at the center of six mediastinal structures on the loaded chest CT. Name each marker exactly (case-sensitive): 'AscendingAorta', 'DescendingAorta', 'PulmonaryArtery', 'Trachea', 'LeftAtrium', 'Esophagus'. Save landmarks to ~/Documents/SlicerData/LIDC/mediastinal_landmarks.mrk.json.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/mediastinal_anatomy_annotation/setup_task.sh",
    "post_task": "/workspace/tasks/mediastinal_anatomy_annotation/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "lidc_dir": "/home/ga/Documents/SlicerData/LIDC",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_landmarks": "/home/ga/Documents/SlicerData/LIDC/mediastinal_landmarks.mrk.json",
    "required_landmarks": [
      "AscendingAorta",
      "DescendingAorta",
      "PulmonaryArtery",
      "Trachea",
      "LeftAtrium",
      "Esophagus"
    ],
    "expected_hu_ranges": {
      "AscendingAorta": [-100, 200],
      "DescendingAorta": [-100, 200],
      "PulmonaryArtery": [-100, 200],
      "Trachea": [-1024, -700],
      "LeftAtrium": [-100, 200],
      "Esophagus": [-150, 150]
    },
    "scoring_weights": {
      "ascending_aorta": 14,
      "descending_aorta": 14,
      "pulmonary_artery": 14,
      "trachea": 14,
      "left_atrium": 12,
      "esophagus": 12,
      "spatial_relationships": 10,
      "file_validity": 10
    },
    "passing_threshold": 60
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mediastinal_anatomy"
    }
  }
}