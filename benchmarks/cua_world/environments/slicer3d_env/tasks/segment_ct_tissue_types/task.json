{
  "id": "segment_ct_tissue_types@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Segment the loaded abdominal CT into three segments: 'Bone' (HU > 300), 'Soft Tissue' (HU 0-100), and 'Air' (HU < -500). Save the segmentation to ~/Documents/SlicerData/Exports/tissue_segmentation.seg.nrrd.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/segment_ct_tissue_types/setup_task.sh",
    "post_task": "/workspace/tasks/segment_ct_tissue_types/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "output_segmentation": "/home/ga/Documents/SlicerData/Exports/tissue_segmentation.seg.nrrd",
    "output_dir": "/home/ga/Documents/SlicerData/Exports",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "expected_segments": {
      "bone": {
        "name_keywords": [
          "bone",
          "Bone",
          "BONE"
        ],
        "threshold_min": 300,
        "threshold_max": 3000,
        "expected_voxel_range": [
          5000,
          150000
        ]
      },
      "soft_tissue": {
        "name_keywords": [
          "soft",
          "Soft",
          "tissue",
          "Tissue",
          "SOFT",
          "TISSUE"
        ],
        "threshold_min": 0,
        "threshold_max": 100,
        "expected_voxel_range": [
          500000,
          3000000
        ]
      },
      "air": {
        "name_keywords": [
          "air",
          "Air",
          "AIR",
          "lung",
          "Lung"
        ],
        "threshold_min": -3000,
        "threshold_max": -500,
        "expected_voxel_range": [
          100000,
          2000000
        ]
      }
    },
    "scoring_weights": {
      "file_exists": 15,
      "file_recent": 10,
      "three_segments": 20,
      "correct_names": 15,
      "bone_valid": 10,
      "soft_tissue_valid": 10,
      "air_valid": 10,
      "vlm_visual": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_segment_ct_tissue_types"
    }
  }
}
