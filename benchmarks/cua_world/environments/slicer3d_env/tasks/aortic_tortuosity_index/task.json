{
  "id": "aortic_tortuosity_index@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Assess aortic tortuosity on the provided abdominal CT. Document the aortic centerline from the diaphragmatic hiatus to the bifurcation using fiducial points. Save the centerline fiducials to ~/Documents/SlicerData/AMOS/aorta_centerline.mrk.json. Report the chord_length_mm, arc_length_mm, tortuosity_index_percent, classification, and num_centerline_points to ~/Documents/SlicerData/AMOS/tortuosity_report.json.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 360,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/aortic_tortuosity_index/setup_task.sh",
    "post_task": "/workspace/tasks/aortic_tortuosity_index/export_result.sh",
    "pre_task_timeout": 1200
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_centerline": "/home/ga/Documents/SlicerData/AMOS/aorta_centerline.mrk.json",
    "output_report": "/home/ga/Documents/SlicerData/AMOS/tortuosity_report.json",
    "passing_thresholds": {
      "ti_error_max_percent": 5.0,
      "arc_length_error_max_percent": 15.0,
      "chord_length_error_max_percent": 10.0,
      "min_centerline_points": 8
    },
    "scoring_weights": {
      "tortuosity_index_accuracy": 30,
      "arc_length_accuracy": 20,
      "chord_length_accuracy": 15,
      "classification_correct": 15,
      "centerline_quality": 10,
      "report_completeness": 10
    },
    "classification_thresholds": {
      "normal_max": 10,
      "mild_max": 20,
      "moderate_max": 35
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_aortic_tortuosity"
    }
  }
}
