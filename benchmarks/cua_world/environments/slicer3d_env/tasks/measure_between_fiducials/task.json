{
  "id": "measure_between_fiducials@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the distance between the two existing fiducial points (Point_A and Point_B) on this brain MRI. Save the measurement to ~/Documents/SlicerData/BraTS/distance_measurement.mrk.json",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 240,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/measure_between_fiducials/setup_task.sh",
    "post_task": "/workspace/tasks/measure_between_fiducials/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "output_measurement": "/home/ga/Documents/SlicerData/BraTS/distance_measurement.mrk.json",
    "expected_distance_mm": 80.0,
    "tolerance_mm": 15.0,
    "scoring_weights": {
      "line_measurement_exists": 35,
      "distance_accuracy": 35,
      "file_saved": 15,
      "endpoints_near_fiducials": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_measure_between_fiducials"
    }
  }
}
