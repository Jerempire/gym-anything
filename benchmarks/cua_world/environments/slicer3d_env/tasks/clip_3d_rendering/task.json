{
  "id": "clip_3d_rendering@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create a clipped 3D volume rendering of the BraTS T1ce brain MRI (~/Documents/SlicerData/BraTS/) to reveal internal tumor structures. Use ROI cropping to remove 30-50% of the brain surface and save a screenshot of the cutaway rendering to ~/Documents/SlicerData/Screenshots/clipped_brain_rendering.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/clip_3d_rendering/setup_task.sh",
    "post_task": "/workspace/tasks/clip_3d_rendering/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "expected_output_path": "/home/ga/Documents/SlicerData/Screenshots/clipped_brain_rendering.png",
    "min_screenshot_size_kb": 100,
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "scoring_weights": {
      "volume_loaded": 15,
      "volume_rendering_active": 20,
      "roi_node_exists": 15,
      "clipping_enabled": 20,
      "meaningful_clip": 15,
      "screenshot_saved": 10,
      "vlm_cutaway_visible": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_clip_3d_rendering"
    }
  }
}
