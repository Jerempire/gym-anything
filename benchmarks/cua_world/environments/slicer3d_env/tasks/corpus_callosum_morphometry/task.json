{
  "id": "corpus_callosum_morphometry@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the corpus callosum on the MRHead brain MRI at the mid-sagittal plane: total genu-to-splenium length and thickness at the genu, body, and splenium. Save measurement markups to ~/Documents/SlicerData/SampleData/cc_measurements.mrk.json and a report to ~/Documents/SlicerData/SampleData/corpus_callosum_report.json with fields: total_length_mm, genu_thickness_mm, body_thickness_mm, splenium_thickness_mm, mid_sagittal_slice, atrophy_grade.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/corpus_callosum_morphometry/setup_task.sh",
    "post_task": "/workspace/tasks/corpus_callosum_morphometry/export_result.sh",
    "pre_task_timeout": 300
  },
  "metadata": {
    "sample_data_dir": "/home/ga/Documents/SlicerData/SampleData",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_measurement": "/home/ga/Documents/SlicerData/SampleData/cc_measurements.mrk.json",
    "output_report": "/home/ga/Documents/SlicerData/SampleData/corpus_callosum_report.json",
    "input_volume": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "passing_thresholds": {
      "length_error_max_mm": 8.0,
      "thickness_error_max_mm": 3.0,
      "min_measurements": 2
    },
    "scoring_weights": {
      "total_length_accuracy": 25,
      "genu_thickness_accuracy": 15,
      "body_thickness_accuracy": 15,
      "splenium_thickness_accuracy": 15,
      "mid_sagittal_navigation": 10,
      "atrophy_classification": 10,
      "report_completeness": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_corpus_callosum_morphometry"
    }
  }
}