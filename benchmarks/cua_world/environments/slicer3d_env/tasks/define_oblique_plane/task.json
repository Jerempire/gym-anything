{
  "id": "define_oblique_plane@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Define the AC-PC reference plane on the MRHead brain MRI using a plane markup with three control points: the anterior commissure (AC), the posterior commissure (PC), and a superior midline point. Save the plane markup to ~/Documents/SlicerData/acpc_plane.mrk.json.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/define_oblique_plane/setup_task.sh",
    "post_task": "/workspace/tasks/define_oblique_plane/export_result.sh"
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "output_plane_file": "/home/ga/Documents/SlicerData/acpc_plane.mrk.json",
    "ground_truth_file": "/var/lib/slicer/ground_truth/acpc_landmarks.json",
    "ac_ras_expected": [
      0.0,
      1.5,
      -4.0
    ],
    "pc_ras_expected": [
      0.0,
      -24.5,
      -2.0
    ],
    "ac_pc_distance_expected_mm": 26.0,
    "point_tolerance_mm": 5.0,
    "midline_tolerance_mm": 5.0,
    "plane_normal_tolerance_deg": 30.0,
    "scoring_weights": {
      "plane_markup_exists": 15,
      "three_control_points": 15,
      "ac_point_accurate": 20,
      "pc_point_accurate": 20,
      "superior_point_valid": 15,
      "plane_orientation_correct": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_define_oblique_plane"
    }
  }
}
