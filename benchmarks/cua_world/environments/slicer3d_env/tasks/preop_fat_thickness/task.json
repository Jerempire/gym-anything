{
  "id": "preop_fat_thickness@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the anterior abdominal wall subcutaneous fat thickness at the umbilical level on the provided abdominal CT, from skin surface to the anterior rectus sheath at the midline. Save the ruler markup to ~/Documents/SlicerData/AMOS/fat_thickness_measurement.mrk.json and report to ~/Documents/SlicerData/AMOS/surgical_planning_report.json with fields: fat_thickness_mm, vertebral_level, surgical_category.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/preop_fat_thickness/setup_task.sh",
    "post_task": "/workspace/tasks/preop_fat_thickness/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_measurement": "/home/ga/Documents/SlicerData/AMOS/fat_thickness_measurement.mrk.json",
    "output_report": "/home/ga/Documents/SlicerData/AMOS/surgical_planning_report.json",
    "acceptable_error_mm": 8.0,
    "plausible_range_mm": [5, 150],
    "passing_thresholds": {
      "measurement_error_max_mm": 8.0,
      "level_tolerance": 1
    },
    "scoring_weights": {
      "measurement_exists": 15,
      "anatomical_level": 15,
      "measurement_accuracy": 30,
      "measurement_plausible": 10,
      "category_correct": 15,
      "report_complete": 15
    },
    "surgical_categories": {
      "Thin": {"min": 0, "max": 20},
      "Average": {"min": 20, "max": 40},
      "Thick": {"min": 40, "max": 60},
      "Very Thick": {"min": 60, "max": 999}
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_preop_fat_thickness"
    }
  }
}