{
  "id": "mip_vessel_visualization@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create a coronal Maximum Intensity Projection (MIP) visualization of the abdominal aorta on the loaded CT scan with appropriate vessel contrast settings. Save the MIP screenshot to ~/Documents/SlicerData/AMOS/aorta_mip.png and the parameters (window_width, window_level, slab_thickness, projection, rendering_mode) to ~/Documents/SlicerData/AMOS/mip_parameters.json.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/mip_vessel_visualization/setup_task.sh",
    "post_task": "/workspace/tasks/mip_vessel_visualization/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_mip_image": "/home/ga/Documents/SlicerData/AMOS/aorta_mip.png",
    "output_parameters": "/home/ga/Documents/SlicerData/AMOS/mip_parameters.json",
    "min_image_size_kb": 100,
    "window_range": {
      "min": 300,
      "max": 800
    },
    "level_range": {
      "min": 100,
      "max": 300
    },
    "slab_thickness_range": {
      "min": 50,
      "max": 200
    },
    "scoring_weights": {
      "mip_image_exists": 15,
      "image_quality": 15,
      "vessel_visible": 20,
      "coronal_projection": 10,
      "mip_appearance": 10,
      "params_file_exists": 10,
      "window_level_appropriate": 10,
      "slab_thickness_documented": 5,
      "timestamp_valid": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mip_vessel_visualization"
    }
  }
}
