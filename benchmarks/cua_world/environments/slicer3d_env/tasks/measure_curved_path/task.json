{
  "id": "measure_curved_path@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the curved path length of the abdominal aorta from the renal artery level to the iliac bifurcation using the contrast-enhanced CT at ~/Documents/SlicerData/AMOS/amos_0001.nii.gz. Create a curve markup along the aorta centerline with at least 8 control points and export it to ~/Documents/SlicerData/AMOS/aorta_curve.mrk.json.",
  "difficulty": "intermediate",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/measure_curved_path/setup_task.sh",
    "post_task": "/workspace/tasks/measure_curved_path/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "case_id": "amos_0001",
    "output_curve_file": "/home/ga/Documents/SlicerData/AMOS/aorta_curve.mrk.json",
    "expected_length_range_mm": {
      "min": 80.0,
      "max": 160.0
    },
    "min_control_points": 8,
    "min_z_span_mm": 50.0,
    "max_xy_drift_mm": 50.0,
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "scoring_weights": {
      "curve_exists": 25,
      "sufficient_points": 20,
      "length_in_range": 25,
      "spatial_valid": 15,
      "curve_visible": 10,
      "follows_vessel": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_measure_curved_path"
    }
  }
}
