{
  "id": "export_dicom_series@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Export the loaded MRHead brain MRI volume as a DICOM series with Patient Name set to 'SlicerExportTest' and Study Description set to 'Brain MRI Export Task'. Save the DICOM files to ~/Documents/SlicerData/Exports/DICOM_Export/.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_dicom_series/setup_task.sh",
    "post_task": "/workspace/tasks/export_dicom_series/export_result.sh"
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "export_directory": "/home/ga/Documents/SlicerData/Exports/DICOM_Export",
    "expected_patient_name": "SlicerExportTest",
    "expected_study_description": "Brain MRI Export Task",
    "expected_slice_count_min": 50,
    "expected_slice_count_max": 200,
    "min_file_size_bytes": 1000000,
    "scoring_weights": {
      "export_dir_has_files": 15,
      "sufficient_file_count": 20,
      "files_valid_dicom": 20,
      "slice_count_matches": 10,
      "patient_name_correct": 15,
      "study_description_present": 10,
      "files_created_recently": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_dicom_series"
    }
  }
}