{
  "id": "caudate_rl_ratio@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the caudate-to-right-lobe (C/RL) ratio on the provided abdominal CT at the portal vein bifurcation level for cirrhosis assessment. Save the caudate measurement to ~/Documents/SlicerData/IRCADb/caudate_measurement.mrk.json, the right lobe measurement to ~/Documents/SlicerData/IRCADb/rightlobe_measurement.mrk.json, and the report to ~/Documents/SlicerData/IRCADb/crl_ratio_report.json. The report must include fields for caudate_width_mm, rightlobe_width_mm, crl_ratio, slice_level, classification, and supporting_findings.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/caudate_rl_ratio/setup_task.sh",
    "post_task": "/workspace/tasks/caudate_rl_ratio/export_result.sh",
    "pre_task_timeout": 1200
  },
  "metadata": {
    "ircadb_dir": "/home/ga/Documents/SlicerData/IRCADb",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_caudate_measurement": "/home/ga/Documents/SlicerData/IRCADb/caudate_measurement.mrk.json",
    "output_rightlobe_measurement": "/home/ga/Documents/SlicerData/IRCADb/rightlobe_measurement.mrk.json",
    "output_report": "/home/ga/Documents/SlicerData/IRCADb/crl_ratio_report.json",
    "passing_thresholds": {
      "caudate_tolerance_mm": 8.0,
      "rightlobe_tolerance_mm": 15.0,
      "slice_tolerance_mm": 20.0
    },
    "scoring_weights": {
      "caudate_accuracy": 25,
      "rightlobe_accuracy": 25,
      "correct_level": 15,
      "ratio_correct": 10,
      "classification_correct": 15,
      "report_completeness": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_caudate_rl_ratio"
    }
  }
}
