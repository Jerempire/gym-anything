{
  "id": "smooth_surface_model@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Smooth the pre-loaded 'TumorModel_Rough' surface model to remove stair-step artifacts while preserving the overall tumor shape. Save the smoothed model as 'TumorModel_Smoothed' to ~/Documents/SlicerData/BraTS/TumorModel_Smoothed.vtk.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/smooth_surface_model/setup_task.sh",
    "post_task": "/workspace/tasks/smooth_surface_model/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "input_model": "/home/ga/Documents/SlicerData/BraTS/TumorModel_Rough.vtk",
    "expected_output_model": "/home/ga/Documents/SlicerData/BraTS/TumorModel_Smoothed.vtk",
    "min_roughness_reduction_percent": 30,
    "max_volume_change_percent": 10,
    "max_bounds_change_percent": 5,
    "min_polygon_count": 1000,
    "scoring_weights": {
      "smoothed_model_exists": 20,
      "roughness_reduced": 25,
      "shape_preserved_volume": 15,
      "shape_preserved_bounds": 10,
      "polygon_count_valid": 10,
      "appropriate_naming": 5,
      "vlm_visual_quality": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_smooth_surface_model"
    }
  }
}