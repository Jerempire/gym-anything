{
  "id": "apply_color_lut@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Change the display colormap of the loaded MRHead brain MRI volume from the default grayscale to a color-based lookup table (e.g., Ocean, Hot, or Rainbow). The colormap must not be a grayscale variant. No file output is required.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/apply_color_lut/setup_task.sh",
    "post_task": "/workspace/tasks/apply_color_lut/export_result.sh"
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "initial_colormap": "Grey",
    "grayscale_colormaps": [
      "Grey",
      "Gray",
      "Grayscale",
      "Greyscale",
      "White",
      "Black"
    ],
    "valid_color_luts": [
      "Ocean",
      "Cool",
      "Warm",
      "Hot",
      "Cold",
      "Rainbow",
      "fMRI",
      "fMRIPA",
      "Spectrum",
      "PET-Heat",
      "PET-Rainbow",
      "Red",
      "Green",
      "Blue",
      "Yellow",
      "Cyan",
      "Magenta",
      "Labels"
    ],
    "scoring_weights": {
      "volume_loaded": 15,
      "display_node_exists": 15,
      "colormap_changed": 35,
      "valid_color_lut": 20,
      "vlm_color_visible": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_apply_color_lut"
    }
  }
}
