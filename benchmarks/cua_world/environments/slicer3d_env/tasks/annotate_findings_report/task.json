{
  "id": "annotate_findings_report@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the anterior-posterior length of the corpus callosum (genu to splenium) on a mid-sagittal slice of the MRHead brain MRI (~/Documents/SlicerData/SampleData/MRHead.nrrd). Include a ruler annotation for the measurement and a text annotation reading 'Corpus Callosum - Normal'. Save a screenshot showing both annotations to ~/Documents/SlicerData/Screenshots/annotated_cc_report.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/annotate_findings_report/setup_task.sh",
    "post_task": "/workspace/tasks/annotate_findings_report/export_result.sh"
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "expected_screenshot_path": "/home/ga/Documents/SlicerData/Screenshots/annotated_cc_report.png",
    "expected_ruler_length_mm": {
      "min": 50,
      "max": 100
    },
    "expected_text_content": "Corpus Callosum",
    "min_screenshot_size_kb": 50,
    "scoring_weights": {
      "ruler_created": 20,
      "ruler_valid_length": 15,
      "text_created": 20,
      "text_has_content": 10,
      "screenshot_exists": 15,
      "screenshot_has_content": 10,
      "correct_view": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_annotate_findings_report"
    }
  }
}
