{
  "id": "surgical_anatomy_briefing@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Identify and label 8 abdominal structures (Liver, Spleen, Right Kidney, Left Kidney, Aorta, IVC, Pancreas, and Portal Vein or Gallbladder) in a fiducial list named 'AnatomicalLandmarks'. Export the fiducials to ~/Documents/SlicerData/AMOS/anatomical_landmarks.mrk.json, save the scene to ~/Documents/SlicerData/AMOS/, and save axial, coronal, and sagittal screenshots to ~/Documents/SlicerData/AMOS/briefing_axial.png, briefing_coronal.png, and briefing_sagittal.png.",
  "difficulty": "intermediate",
  "init": {
    "timeout_sec": 420,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/surgical_anatomy_briefing/setup_task.sh",
    "post_task": "/workspace/tasks/surgical_anatomy_briefing/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_fiducials": "/home/ga/Documents/SlicerData/AMOS/anatomical_landmarks.mrk.json",
    "output_axial": "/home/ga/Documents/SlicerData/AMOS/briefing_axial.png",
    "output_coronal": "/home/ga/Documents/SlicerData/AMOS/briefing_coronal.png",
    "output_sagittal": "/home/ga/Documents/SlicerData/AMOS/briefing_sagittal.png",
    "required_structures": [
      "liver",
      "spleen",
      "right kidney",
      "left kidney",
      "aorta",
      "ivc",
      "pancreas"
    ],
    "amos_label_mapping": {
      "liver": 6,
      "spleen": 1,
      "right kidney": 2,
      "left kidney": 3,
      "aorta": 10,
      "ivc": 9,
      "pancreas": 11,
      "gallbladder": 5,
      "portal vein": 12
    },
    "scoring_weights": {
      "liver_fiducial": 10,
      "spleen_fiducial": 10,
      "right_kidney_fiducial": 10,
      "left_kidney_fiducial": 10,
      "aorta_fiducial": 8,
      "ivc_fiducial": 8,
      "pancreas_fiducial": 8,
      "eighth_structure": 6,
      "axial_screenshot": 5,
      "coronal_screenshot": 5,
      "sagittal_screenshot": 5,
      "fiducial_file_valid": 5,
      "scene_saved": 5,
      "label_quality": 5
    },
    "passing_threshold": 60
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_surgical_anatomy_briefing"
    }
  }
}
