{
  "id": "plan_biopsy_trajectory@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create a Line markup named 'Biopsy_Trajectory' representing a biopsy needle trajectory on the loaded brain MRI. The trajectory must connect a scalp entry location superior to the tumor to the target coordinates specified in /home/ga/Documents/SlicerData/BraTS/tumor_target.txt. Save the scene.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/plan_biopsy_trajectory/setup_task.sh",
    "post_task": "/workspace/tasks/plan_biopsy_trajectory/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "data_source": "BraTS 2021 Challenge (Kaggle)",
    "data_url": "https://www.kaggle.com/datasets/dschettler8845/brats-2021-task1",
    "expected_markup_name": "Biopsy_Trajectory",
    "expected_control_points": 2,
    "target_tolerance_mm": 15.0,
    "trajectory_length_range_mm": {
      "min": 30,
      "max": 120
    },
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_dir": "/home/ga/Documents/SlicerData/BraTS",
    "scoring_weights": {
      "markup_exists": 20,
      "correct_name": 15,
      "has_two_points": 15,
      "target_accuracy": 25,
      "valid_entry_point": 15,
      "reasonable_length": 5,
      "visual_confirmation": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_plan_biopsy_trajectory"
    }
  }
}
