{
  "id": "multimodal_tumor_localization@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Localize the brain tumor using the four pre-loaded MRI sequences (FLAIR, T1, T1ce, T2). Place a fiducial marker named 'TumorCenter' at the tumor center. Save the markup to ~/Documents/SlicerData/BraTS/tumor_center.mrk.json and report the RAS coordinates (R, A, S in mm), the most helpful modality, and observations to ~/Documents/SlicerData/BraTS/localization_report.json.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/multimodal_tumor_localization/setup_task.sh",
    "post_task": "/workspace/tasks/multimodal_tumor_localization/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_markup": "/home/ga/Documents/SlicerData/BraTS/tumor_center.mrk.json",
    "output_report": "/home/ga/Documents/SlicerData/BraTS/localization_report.json",
    "modalities": [
      "flair",
      "t1",
      "t1ce",
      "t2"
    ],
    "passing_thresholds": {
      "point_inside_tumor": true,
      "distance_to_centroid_max_mm": 15.0
    },
    "scoring_weights": {
      "point_inside_tumor": 30,
      "distance_threshold_15mm": 25,
      "distance_bonus_10mm": 10,
      "markup_exists": 10,
      "report_exists": 10,
      "report_has_coords": 5,
      "report_has_observations": 5,
      "coords_match": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_multimodal_tumor_localization"
    }
  }
}
