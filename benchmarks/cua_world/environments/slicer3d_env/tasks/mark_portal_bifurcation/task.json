{
  "id": "mark_portal_bifurcation@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Locate the portal vein bifurcation on the contrast-enhanced abdominal CT (IRCADb dataset). Place a fiducial marker named 'PortalBifurcation' at the point where the main portal vein divides into left and right branches and save the markup to ~/Documents/SlicerData/IRCADb/portal_bifurcation.mrk.json.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/mark_portal_bifurcation/setup_task.sh",
    "post_task": "/workspace/tasks/mark_portal_bifurcation/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "ircadb_dir": "/home/ga/Documents/SlicerData/IRCADb",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_fiducial": "/home/ga/Documents/SlicerData/IRCADb/portal_bifurcation.mrk.json",
    "expected_fiducial_name": "PortalBifurcation",
    "tolerance_mm": 8.0,
    "acceptable_tolerance_mm": 15.0,
    "region_tolerance_mm": 25.0,
    "scoring_weights": {
      "fiducial_exists": 15,
      "appropriate_name": 10,
      "correct_region": 20,
      "accurate_placement": 35,
      "near_accurate_placement": 20,
      "vlm_confirmation": 20
    },
    "data_source": "3D-IRCADb (Institut de Recherche contre les Cancers de l'Appareil Digestif)",
    "data_url": "https://www.ircad.fr/research/data-sets/liver-segmentation-3d-ircadb-01/"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mark_portal_bifurcation"
    }
  }
}
