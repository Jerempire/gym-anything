{
  "id": "dose_zone_margins@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create three concentric ring-shaped margin segments around the 'Tumor' segment on the BraTS brain MRI: 'Zone1_5mm' (red, 0-5mm), 'Zone2_10mm' (yellow, 5-10mm), and 'Zone3_15mm' (green, 10-15mm). Each zone must be a ring rather than a solid volume. Save the segmentation containing the tumor and all three rings to ~/Documents/SlicerData/BraTS/dose_zones.seg.nrrd.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 360,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/dose_zone_margins/setup_task.sh",
    "post_task": "/workspace/tasks/dose_zone_margins/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "expected_output_segmentation": "/home/ga/Documents/SlicerData/BraTS/dose_zones.seg.nrrd",
    "expected_segment_count": 4,
    "zone_margins_mm": [
      5,
      10,
      15
    ],
    "zone_colors": {
      "Zone1": [
        255,
        0,
        0
      ],
      "Zone2": [
        255,
        255,
        0
      ],
      "Zone3": [
        0,
        255,
        0
      ]
    },
    "color_tolerance": 30,
    "volume_ordering_required": true,
    "scoring_weights": {
      "four_segments_exist": 15,
      "correct_segment_names": 10,
      "zone1_correct": 15,
      "zone2_correct": 15,
      "zone3_correct": 15,
      "non_overlapping_zones": 10,
      "correct_color_coding": 10,
      "volume_ordering_valid": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_dose_zone_margins"
    }
  }
}
