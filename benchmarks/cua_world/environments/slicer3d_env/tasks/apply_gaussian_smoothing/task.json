{
  "id": "apply_gaussian_smoothing@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Apply Gaussian smoothing to the loaded MRHead brain MRI volume with a sigma of approximately 2.0 mm. Produce a new volume named 'MRHead_smoothed' and ensure the original MRHead volume remains unchanged.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/apply_gaussian_smoothing/setup_task.sh",
    "post_task": "/workspace/tasks/apply_gaussian_smoothing/export_result.sh",
    "pre_task_timeout": 300
  },
  "metadata": {
    "sample_file": "MRHead.nrrd",
    "sample_path": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "expected_output_name_pattern": "smooth",
    "expected_sigma_mm": 2.0,
    "sigma_tolerance_mm": 1.5,
    "min_output_file_size_bytes": 1000000,
    "scoring_weights": {
      "output_volume_exists": 25,
      "correct_dimensions": 15,
      "smoothing_detected": 30,
      "appropriate_sigma": 15,
      "visual_confirmation": 10,
      "original_preserved": 5
    },
    "smoothing_thresholds": {
      "laplacian_ratio_max": 0.9,
      "laplacian_ratio_min": 0.3,
      "std_ratio_max": 0.99
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_apply_gaussian_smoothing"
    }
  }
}
