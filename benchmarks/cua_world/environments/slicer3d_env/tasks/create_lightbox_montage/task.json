{
  "id": "create_lightbox_montage@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Generate a lightbox montage of the pre-loaded MRHead brain MRI with 5 columns and 4 rows (20 axial slices). Save the montage to /home/ga/Documents/SlicerData/Exports/brain_montage.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_lightbox_montage/setup_task.sh",
    "post_task": "/workspace/tasks/create_lightbox_montage/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/SlicerData/Exports/brain_montage.png",
    "sample_data_path": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "min_file_size_kb": 150,
    "min_width": 600,
    "min_height": 400,
    "expected_rows": 4,
    "expected_columns": 5,
    "expected_total_slices": 20,
    "scoring_weights": {
      "file_exists": 20,
      "file_size_adequate": 15,
      "valid_image_format": 10,
      "dimensions_suggest_montage": 15,
      "created_during_task": 10,
      "vlm_grid_layout": 15,
      "vlm_brain_content": 10,
      "vlm_multiple_levels": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_lightbox_montage"
    }
  }
}
