{
  "id": "merge_tumor_segments@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Merge the three pre-loaded tumor sub-segments (Necrotic_Core, Edema, and Enhancing_Tumor) into a single new segment named 'Total Tumor' while preserving the original segments. The BraTS brain MRI and segmentation are pre-loaded in 3D Slicer.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/merge_tumor_segments/setup_task.sh",
    "post_task": "/workspace/tasks/merge_tumor_segments/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "expected_segment_name": "Total Tumor",
    "original_segments": [
      "Necrotic_Core",
      "Edema",
      "Enhancing_Tumor"
    ],
    "volume_tolerance_percent": 10,
    "scoring_weights": {
      "total_tumor_exists": 30,
      "correct_name_format": 10,
      "volume_consistency": 25,
      "original_segments_preserved": 15,
      "segment_editor_used": 10,
      "vlm_confirms_merge": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_merge_tumor_segments"
    }
  }
}
