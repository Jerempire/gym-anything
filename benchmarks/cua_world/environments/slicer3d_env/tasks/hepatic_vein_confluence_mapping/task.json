{
  "id": "hepatic_vein_confluence_mapping@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Identify and mark the three major hepatic veins (RHV, MHV, LHV) at their IVC ostia on the contrast-enhanced abdominal CT. Place labeled fiducial markers, measure inter-vein distances, and classify the anatomical pattern. Save markup to ~/Documents/SlicerData/IRCADb/hepatic_vein_markups.mrk.json, screenshot to ~/Documents/SlicerData/Screenshots/hepatic_confluence.png, and report to ~/Documents/SlicerData/IRCADb/hepatic_vein_report.json with fields: patient_id, right_hepatic_vein, middle_hepatic_vein, left_hepatic_vein (each with identified, position_ras, ostium_diameter_mm),",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 420,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/hepatic_vein_confluence_mapping/setup_task.sh",
    "post_task": "/workspace/tasks/hepatic_vein_confluence_mapping/export_result.sh",
    "pre_task_timeout": 1200
  },
  "metadata": {
    "ircadb_dir": "/home/ga/Documents/SlicerData/IRCADb",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_markup": "/home/ga/Documents/SlicerData/IRCADb/hepatic_vein_markups.mrk.json",
    "output_screenshot": "/home/ga/Documents/SlicerData/Screenshots/hepatic_confluence.png",
    "output_report": "/home/ga/Documents/SlicerData/IRCADb/hepatic_vein_report.json",
    "hepatic_veins": [
      "RHV",
      "MHV",
      "LHV"
    ],
    "ivc_proximity_threshold_mm": 15.0,
    "inter_vein_distance_range_mm": [
      8,
      50
    ],
    "ostium_diameter_range_mm": [
      5,
      25
    ],
    "passing_thresholds": {
      "min_veins_identified": 2,
      "position_tolerance_mm": 20.0
    },
    "scoring_weights": {
      "rhv_identified": 15,
      "mhv_identified": 15,
      "lhv_identified": 15,
      "lateral_arrangement": 10,
      "distances_measured": 10,
      "pattern_classified": 10,
      "report_completeness": 10,
      "screenshot_evidence": 10,
      "labels_correct": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_hepatic_vein_confluence_mapping"
    }
  }
}
