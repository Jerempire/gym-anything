{
  "id": "record_slice_animation@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create an animated GIF sweeping through at least 30 axial slices of the MRHead brain MRI. Save the output to /home/ga/Documents/SlicerData/Exports/brain_axial_sweep.gif.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_slice_animation/setup_task.sh",
    "post_task": "/workspace/tasks/record_slice_animation/export_result.sh",
    "pre_task_timeout": 300
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/SlicerData/Exports/brain_axial_sweep.gif",
    "min_file_size_kb": 200,
    "min_frame_count": 20,
    "expected_view": "Red",
    "sample_data_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "scoring_weights": {
      "file_exists": 20,
      "valid_gif_format": 15,
      "sufficient_size": 15,
      "multiple_frames": 15,
      "recent_timestamp": 10,
      "brain_content_visible": 15,
      "animation_progression": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_slice_animation"
    }
  }
}
