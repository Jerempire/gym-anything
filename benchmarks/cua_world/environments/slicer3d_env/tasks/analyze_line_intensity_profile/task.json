{
  "id": "analyze_line_intensity_profile@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create a line markup spanning from the frontal lobe to the occipital lobe on the loaded MRHead brain MRI and export the intensity profile along this line to ~/Documents/SlicerData/Exports/line_profile_output.csv.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/analyze_line_intensity_profile/setup_task.sh",
    "post_task": "/workspace/tasks/analyze_line_intensity_profile/export_result.sh"
  },
  "metadata": {
    "sample_file": "MRHead.nrrd",
    "sample_path": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "output_csv_path": "/home/ga/Documents/SlicerData/Exports/line_profile_output.csv",
    "output_dir": "/home/ga/Documents/SlicerData/Exports",
    "expected_module": "LineProfile",
    "line_length_range_mm": {
      "min": 80,
      "max": 200
    },
    "min_profile_samples": 50,
    "min_intensity_stddev": 10,
    "mrhead_intensity_range": {
      "min": 0,
      "max": 1200
    },
    "scoring_weights": {
      "line_markup_exists": 20,
      "line_has_valid_endpoints": 15,
      "line_length_appropriate": 10,
      "output_csv_exists": 15,
      "csv_has_valid_data": 15,
      "profile_shows_variation": 15,
      "vlm_confirms_visualization": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_analyze_line_intensity_profile"
    }
  }
}
