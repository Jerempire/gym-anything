{
  "id": "measure_midline_distance@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the minimum distance from the tumor edge to the brain midline (interhemispheric fissure) on the loaded BraTS brain MRI (T1CE sequence) using a line markup. Save a screenshot showing the measurement to ~/Documents/SlicerData/Screenshots/midline_distance.png.",
  "difficulty": "intermediate",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/measure_midline_distance/setup_task.sh",
    "post_task": "/workspace/tasks/measure_midline_distance/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "expected_screenshot_path": "/home/ga/Documents/SlicerData/Screenshots/midline_distance.png",
    "midline_tolerance_mm": 10.0,
    "tumor_proximity_tolerance_mm": 15.0,
    "distance_tolerance_mm": 15.0,
    "plausible_distance_range_mm": {"min": 2.0, "max": 100.0},
    "scoring_weights": {
      "line_annotation_exists": 30,
      "endpoint_near_midline": 20,
      "endpoint_near_tumor": 15,
      "distance_plausible": 10,
      "distance_matches_gt": 15,
      "screenshot_saved": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_midline_distance"
    }
  }
}