{
  "id": "import_labelmap_segments@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Load the CT volume from ~/Documents/SlicerData/IRCADb/patient_5/ct_volume.nii.gz and the multi-label labelmap from ~/Documents/SlicerData/IRCADb/patient_5/combined_labels.nii.gz. Import the labelmap into a segmentation with three distinct segments: Liver, Tumor, and Portal Vein.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/import_labelmap_segments/setup_task.sh",
    "post_task": "/workspace/tasks/import_labelmap_segments/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "ircadb_dir": "/home/ga/Documents/SlicerData/IRCADb/patient_5",
    "ct_volume_path": "/home/ga/Documents/SlicerData/IRCADb/patient_5/ct_volume.nii.gz",
    "labelmap_path": "/home/ga/Documents/SlicerData/IRCADb/patient_5/combined_labels.nii.gz",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "expected_segment_count": 3,
    "label_mapping": {
      "1": "Liver",
      "2": "Tumor",
      "3": "Portal Vein"
    },
    "scoring_weights": {
      "ct_volume_loaded": 10,
      "labelmap_loaded": 10,
      "segmentation_node_created": 25,
      "three_segments_present": 25,
      "segments_have_content": 15,
      "visual_confirmation": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_import_labelmap_segments"
    }
  }
}
