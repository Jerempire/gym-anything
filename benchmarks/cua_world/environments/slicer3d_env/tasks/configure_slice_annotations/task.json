  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "expected_settings": {
      "orientation_markers_enabled": true,
      "patient_name_hidden": true,
      "study_date_hidden": true
    },
    "scoring_weights": {
      "orientation_markers_enabled": 30,
      "patient_name_hidden": 25,
      "study_date_hidden": 15,
      "all_views_configured": 15,
