{
  "id": "configure_slice_annotations@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Configure the slice view annotations for the MRHead brain MRI (~/Documents/SlicerData/SampleData/MRHead.nrrd). Enable the orientation marker labels (A/P, R/L, S/I) and hide the patient name and study date displays across the Red, Yellow, and Green slice views.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_slice_annotations/setup_task.sh",
    "post_task": "/workspace/tasks/configure_slice_annotations/export_result.sh"
