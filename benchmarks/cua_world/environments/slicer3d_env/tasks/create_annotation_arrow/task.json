{
  "id": "create_annotation_arrow@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create an arrow markup labeled 'Left Lateral Ventricle' pointing to the left lateral ventricle on the pre-loaded MRHead brain MRI at an axial slice where the ventricles are visible. Save a screenshot of the annotated view to ~/Documents/SlicerData/Screenshots/ventricle_annotation.png.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_annotation_arrow/setup_task.sh",
    "post_task": "/workspace/tasks/create_annotation_arrow/export_result.sh"
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "expected_screenshot_path": "/home/ga/Documents/SlicerData/Screenshots/ventricle_annotation.png",
    "expected_label_keywords": [
      "ventricle",
      "lateral"
    ],
    "min_screenshot_size_kb": 50,
    "brain_bounds_mm": {
      "x_min": -80,
      "x_max": 80,
      "y_min": -120,
      "y_max": 80,
      "z_min": -50,
      "z_max": 90
    },
    "ventricle_region_mm": {
      "x_min": -30,
      "x_max": 30,
      "y_min": -40,
      "y_max": 40,
      "z_min": 0,
      "z_max": 60
    },
    "scoring_weights": {
      "arrow_markup_exists": 25,
      "correct_label": 20,
      "anatomically_positioned": 20,
      "screenshot_saved": 15,
      "vlm_confirms_annotation": 10,
      "proper_slice_level": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_annotation_arrow"
    }
  }
}
