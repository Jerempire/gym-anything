{
  "id": "create_mip_visualization@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create a coronal Maximum Intensity Projection (MIP) visualization of the pre-loaded chest CT (CTChest.nrrd) using slab mode with at least 30mm thickness. Save a screenshot of the coronal MIP view to ~/Documents/SlicerData/Exports/chest_mip_coronal.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_mip_visualization/setup_task.sh",
    "post_task": "/workspace/tasks/create_mip_visualization/export_result.sh",
    "pre_task_timeout": 300
  },
  "metadata": {
    "sample_file": "CTChest.nrrd",
    "sample_path": "/home/ga/Documents/SlicerData/SampleData/CTChest.nrrd",
    "expected_output_path": "/home/ga/Documents/SlicerData/Exports/chest_mip_coronal.png",
    "min_file_size_kb": 100,
    "min_slab_thickness_mm": 30,
    "expected_slab_type": "Max",
    "expected_orientation": "coronal",
    "scoring_weights": {
      "screenshot_exists": 15,
      "valid_png_format": 10,
      "created_during_task": 15,
      "mip_mode_active": 25,
      "coronal_orientation": 15,
      "adequate_slab_thickness": 10,
      "vlm_confirms_mip": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_mip_visualization"
    }
  }
}