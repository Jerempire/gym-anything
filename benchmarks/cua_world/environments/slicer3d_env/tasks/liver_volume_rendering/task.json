{
  "id": "liver_volume_rendering@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Configure volume rendering on the loaded IRCADb contrast-enhanced abdominal CT to visualize the liver as semi-transparent tissue with visible portal vasculature. Save a screenshot of the visualization to /home/ga/Documents/SlicerData/Exports/liver_volume_rendering.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/liver_volume_rendering/setup_task.sh",
    "post_task": "/workspace/tasks/liver_volume_rendering/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "ircadb_dir": "/home/ga/Documents/SlicerData/IRCADb",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "expected_screenshot_path": "/home/ga/Documents/SlicerData/Exports/liver_volume_rendering.png",
    "min_screenshot_size_kb": 100,
    "patient_number": 5,
    "data_source": "3D-IRCADb (IRCAD France)",
    "modality": "contrast-enhanced CT",
    "scoring_weights": {
      "screenshot_exists": 15,
      "screenshot_size_valid": 10,
      "volume_rendering_enabled": 20,
      "soft_tissue_visible_vlm": 25,
      "vasculature_visible_vlm": 20,
      "appropriate_transparency_vlm": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_liver_volume_rendering"
    }
  }
}
