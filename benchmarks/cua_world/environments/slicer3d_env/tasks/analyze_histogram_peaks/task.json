{
  "id": "analyze_histogram_peaks@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Identify the intensity values for the three major peaks (background, low-intensity tissue, and high-intensity tissue) of the MRHead brain MRI volume (~/Documents/SlicerData/SampleData/MRHead.nrrd). Record the results in ascending order to /home/ga/Documents/SlicerData/histogram_analysis.json using the fields: volume_name, background_peak, low_tissue_peak, and high_tissue_peak.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/analyze_histogram_peaks/setup_task.sh",
    "post_task": "/workspace/tasks/analyze_histogram_peaks/export_result.sh"
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "output_file": "/home/ga/Documents/SlicerData/histogram_analysis.json",
    "expected_volume_name": "MRHead",
    "background_peak_range": {
      "min": 0,
      "max": 100
    },
    "low_tissue_peak_range": {
      "min": 200,
      "max": 600
    },
    "high_tissue_peak_range": {
      "min": 400,
      "max": 1000
    },
    "scoring_weights": {
      "json_exists": 15,
      "valid_structure": 10,
      "volume_loaded": 15,
      "background_valid": 15,
      "low_tissue_valid": 15,
      "high_tissue_valid": 15,
      "proper_ordering": 10,
      "vlm_evidence": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_analyze_histogram_peaks"
    }
  }
}
