{
  "id": "intensity_masked_segmentation@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Segment the subcutaneous fat on the loaded abdominal CT. The segment must be named 'SubcutaneousFat' and include only voxels within the intensity range of -150 to -50 HU. Save the segmentation to ~/Documents/SlicerData/Exports/fat_segmentation.seg.nrrd.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/intensity_masked_segmentation/setup_task.sh",
    "post_task": "/workspace/tasks/intensity_masked_segmentation/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "output_segmentation": "/home/ga/Documents/SlicerData/Exports/fat_segmentation.seg.nrrd",
    "intensity_range_min": -150,
    "intensity_range_max": -50,
    "min_voxel_count": 1000,
    "max_voxel_count": 500000,
    "intensity_compliance_threshold": 0.98,
    "expected_segment_name": "SubcutaneousFat",
    "scoring_weights": {
      "segmentation_exists": 15,
      "segment_named": 10,
      "min_voxel_count": 15,
      "max_voxel_count": 10,
      "intensity_compliance": 30,
      "spatial_location": 10,
      "vlm_verification": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_intensity_masked_segmentation"
    }
  }
}
