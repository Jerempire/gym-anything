{
  "id": "split_segment_scissors@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Split the pre-loaded 'Liver_Complete' segmentation into two segments named 'Liver_Right' and 'Liver_Left' representing the right and left hepatic lobes. Each segment must be 25-75% of the original volume, and their combined volume should approximately equal the original. Data location: ~/Documents/SlicerData/IRCADb/patient_5/.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 360,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/split_segment_scissors/setup_task.sh",
    "post_task": "/workspace/tasks/split_segment_scissors/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "ircadb_dir": "/home/ga/Documents/SlicerData/IRCADb",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "patient_num": "5",
    "min_split_ratio": 0.2,
    "max_split_ratio": 0.8,
    "volume_conservation_min": 0.8,
    "volume_conservation_max": 1.2,
    "max_overlap_fraction": 0.1,
    "scoring_weights": {
      "multiple_segments": 25,
      "reasonable_split": 25,
      "volume_conservation": 20,
      "minimal_overlap": 15,
      "visual_confirmation": 10,
      "proper_naming": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_split_segment_scissors"
    }
  }
}
