{
  "id": "create_fourpanel_comparison@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Set up a Four-Up layout displaying each of the four pre-loaded BraTS MRI sequences (T1, T1ce, T2, FLAIR) in a separate panel, linked at the same axial slice level with the tumor visible. Save a screenshot of the four-panel comparison to /home/ga/Documents/SlicerData/Screenshots/four_panel_comparison.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_fourpanel_comparison/setup_task.sh",
    "post_task": "/workspace/tasks/create_fourpanel_comparison/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "expected_screenshot_path": "/home/ga/Documents/SlicerData/Screenshots/four_panel_comparison.png",
    "min_screenshot_size_kb": 100,
    "expected_sequences": ["t1", "t1ce", "t2", "flair"],
    "expected_layout": "FourUp",
    "brats_sample_id": "BraTS2021_00000",
    "tumor_slice_range": {"min": 65, "max": 95},
    "data_source": "BraTS 2021 Kaggle Dataset",
    "scoring_weights": {
      "screenshot_exists": 15,
      "screenshot_size_valid": 10,
      "four_panels_visible": 25,
      "different_contrasts": 20,
      "brain_anatomy_present": 10,
      "same_slice_level": 10,
      "tumor_visible": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_fourpanel_comparison"
    }
  }
}