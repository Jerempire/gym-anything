{
  "id": "configure_camera_views@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Document the 3D volume rendering of MRHead.nrrd from ~/Documents/SlicerData/SampleData/ by capturing screenshots from the anterior, right lateral, and superior anatomical views. Save the images to ~/Documents/SlicerData/Screenshots/anterior_view.png, ~/Documents/SlicerData/Screenshots/lateral_view.png, and ~/Documents/SlicerData/Screenshots/superior_view.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_camera_views/setup_task.sh",
    "post_task": "/workspace/tasks/configure_camera_views/export_result.sh"
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "screenshot_dir": "/home/ga/Documents/SlicerData/Screenshots",
    "expected_screenshots": {
      "anterior": "anterior_view.png",
      "lateral": "lateral_view.png",
      "superior": "superior_view.png"
    },
    "min_screenshot_size_kb": 50,
    "scoring_weights": {
      "volume_rendering_active": 15,
      "anterior_exists": 10,
      "anterior_correct": 15,
      "lateral_exists": 10,
      "lateral_correct": 15,
      "superior_exists": 10,
      "superior_correct": 15,
      "views_orthogonal": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_camera_views"
    }
  }
}
