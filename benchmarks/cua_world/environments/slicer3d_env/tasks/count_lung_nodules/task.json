{
  "id": "count_lung_nodules@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Mark each visible lung nodule with a fiducial point on this chest CT. Save to ~/Documents/SlicerData/LIDC/nodule_markers.mrk.json",
  "difficulty": "very easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/count_lung_nodules/setup_task.sh",
    "post_task": "/workspace/tasks/count_lung_nodules/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "lidc_dir": "/home/ga/Documents/SlicerData/LIDC",
    "output_fiducials": "/home/ga/Documents/SlicerData/LIDC/nodule_markers.mrk.json",
    "expected_nodule_count": 3,
    "min_fiducials_to_pass": 2,
    "scoring_weights": {
      "fiducials_exist": 25,
      "correct_count": 30,
      "fiducials_on_nodules": 35,
      "file_saved": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_count_lung_nodules"
    }
  }
}
