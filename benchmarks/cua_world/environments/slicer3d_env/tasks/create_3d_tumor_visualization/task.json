{
  "id": "create_3d_tumor_visualization@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Render the pre-loaded 'TumorSegmentation' on the BraTS brain MRI in 3D. Save a screenshot of the 3D visualization to ~/Documents/SlicerData/Screenshots/tumor_3d_visualization.png.",
  "difficulty": "easy-medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_3d_tumor_visualization/setup_task.sh",
    "post_task": "/workspace/tasks/create_3d_tumor_visualization/export_result.sh",
    "pre_task_timeout": 900
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "expected_screenshot_path": "/home/ga/Documents/SlicerData/Screenshots/tumor_3d_visualization.png",
    "segmentation_name": "TumorSegmentation",
    "min_screenshot_size_kb": 50,
    "scoring_weights": {
      "segmentation_node_present": 15,
      "visibility_3d_enabled": 25,
      "threed_view_has_content": 20,
      "screenshot_file_exists": 15,
      "screenshot_has_content": 15,
      "screenshot_created_during_task": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_3d_tumor_visualization"
    }
  }
}
