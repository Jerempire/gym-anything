{
  "id": "measure_angle_markup@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create an angle markup with three control points on the MRHead brain MRI and save the measured angle in degrees to ~/Documents/SlicerData/Exports/angle_measurement.txt.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/measure_angle_markup/setup_task.sh",
    "post_task": "/workspace/tasks/measure_angle_markup/export_result.sh",
    "pre_task_timeout": 300
  },
  "metadata": {
    "sample_file": "MRHead.nrrd",
    "sample_path": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "output_file": "/home/ga/Documents/SlicerData/Exports/angle_measurement.txt",
    "exports_dir": "/home/ga/Documents/SlicerData/Exports",
    "valid_angle_min": 10.0,
    "valid_angle_max": 170.0,
    "min_control_points": 3,
    "scoring_weights": {
      "angle_markup_exists": 25,
      "three_points_defined": 20,
      "valid_angle_value": 15,
      "points_in_volume": 15,
      "export_file_exists": 10,
      "export_file_valid": 10,
      "vlm_confirmation": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_measure_angle_markup"
    }
  }
}
