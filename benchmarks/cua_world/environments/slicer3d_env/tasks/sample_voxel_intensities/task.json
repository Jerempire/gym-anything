{
  "id": "sample_voxel_intensities@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Sample voxel intensity values (Hounsfield Units) at three anatomical landmarks on the loaded abdominal CT: the aorta, liver parenchyma, and spleen. Save measurements to ~/Documents/SlicerData/intensity_measurements.txt using the format: 'Aorta: [value] HU', 'Liver: [value] HU', 'Spleen: [value] HU', 'Interpretation: [assessment]'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sample_voxel_intensities/setup_task.sh",
    "post_task": "/workspace/tasks/sample_voxel_intensities/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "amos_dir": "/home/ga/Documents/SlicerData/AMOS",
    "case_id": "amos_0001",
    "output_file": "/home/ga/Documents/SlicerData/intensity_measurements.txt",
    "ground_truth_file": "/var/lib/slicer/ground_truth/amos_0001_intensity_gt.json",
    "expected_ranges": {
      "aorta": {"min": 150, "max": 250, "tolerance": 30},
      "liver": {"min": 40, "max": 80, "tolerance": 30},
      "spleen": {"min": 40, "max": 60, "tolerance": 30}
    },
    "scoring_weights": {
      "output_file_exists": 15,
      "file_has_structure": 10,
      "aorta_correct": 20,
      "liver_correct": 20,
      "spleen_correct": 20,
      "data_probe_visible": 10,
      "interpretation_present": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_sample_voxel_intensities"
    }
  }
}