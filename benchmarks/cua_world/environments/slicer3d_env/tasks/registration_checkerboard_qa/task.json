{
  "id": "registration_checkerboard_qa@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Create a checkerboard visualization comparing the 'MRHead' and 'MRHead_Shifted' brain MRI volumes to assess registration quality. Save a screenshot to ~/Documents/SlicerData/Exports/registration_qa_checkerboard.png and a report to ~/Documents/SlicerData/Exports/registration_qa_report.json with fields: checkerboard_configured, alignment_quality, misalignment_detected, estimated_shift_mm, structures_examined.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/registration_checkerboard_qa/setup_task.sh",
    "post_task": "/workspace/tasks/registration_checkerboard_qa/export_result.sh",
    "pre_task_timeout": 300
  },
  "metadata": {
    "sample_data_dir": "/home/ga/Documents/SlicerData/SampleData",
    "exports_dir": "/home/ga/Documents/SlicerData/Exports",
    "output_screenshot": "/home/ga/Documents/SlicerData/Exports/registration_qa_checkerboard.png",
    "output_report": "/home/ga/Documents/SlicerData/Exports/registration_qa_report.json",
    "ground_truth_file": "/var/lib/slicer/ground_truth/registration_shift_gt.json",
    "known_shift_mm": 4.0,
    "shift_direction": "anterior",
    "min_screenshot_size_kb": 50,
    "scoring_weights": {
      "screenshot_exists": 15,
      "screenshot_shows_checkerboard": 25,
      "brain_anatomy_visible": 15,
      "report_file_exists": 15,
      "valid_report_structure": 10,
      "misalignment_correctly_detected": 20
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_registration_checkerboard_qa"
    }
  }
}
