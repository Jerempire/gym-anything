{
  "id": "bicaudate_index_measurement@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Measure the bicaudate index (BCI) on the provided T1-weighted brain MRI. Save the intercaudate distance measurement to ~/Documents/SlicerData/BraTS/intercaudate_measurement.mrk.json and the brain width measurement at the level of the frontal horns to ~/Documents/SlicerData/BraTS/brain_width_measurement.mrk.json. Record the results in a report at ~/Documents/SlicerData/BraTS/bicaudate_report.json including the fields: intercaudate_distance_mm, brain_width_mm, bicaudate_index, classification, and slice_number.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bicaudate_index_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/bicaudate_index_measurement/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "brats_dir": "/home/ga/Documents/SlicerData/BraTS",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_ic_measurement": "/home/ga/Documents/SlicerData/BraTS/intercaudate_measurement.mrk.json",
    "output_bw_measurement": "/home/ga/Documents/SlicerData/BraTS/brain_width_measurement.mrk.json",
    "output_report": "/home/ga/Documents/SlicerData/BraTS/bicaudate_report.json",
    "passing_thresholds": {
      "ic_error_max_mm": 3.0,
      "bw_error_max_mm": 5.0,
      "bci_error_max": 0.03,
      "slice_error_max": 3
    },
    "scoring_weights": {
      "intercaudate_accuracy": 25,
      "brain_width_accuracy": 20,
      "bci_accuracy": 20,
      "classification_correct": 15,
      "anatomical_level": 10,
      "report_completeness": 10
    },
    "clinical_thresholds": {
      "normal_max": 0.15,
      "borderline_max": 0.18
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bicaudate_index"
    }
  }
}
