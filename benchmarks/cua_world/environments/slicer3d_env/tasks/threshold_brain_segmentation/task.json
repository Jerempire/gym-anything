{
  "id": "threshold_brain_segmentation@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Segment the brain tissue (gray and white matter) from the MRHead.nrrd MRI using a threshold-based approach. Name the segment 'BrainTissue', ensuring it excludes skull, CSF, and background. Export the segmentation to ~/Documents/SlicerData/Exports/brain_segmentation.seg.nrrd.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/threshold_brain_segmentation/setup_task.sh",
    "post_task": "/workspace/tasks/threshold_brain_segmentation/export_result.sh"
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "expected_output_path": "/home/ga/Documents/SlicerData/Exports/brain_segmentation.seg.nrrd",
    "expected_segment_name": "BrainTissue",
    "min_file_size_kb": 100,
    "min_voxel_count": 50000,
    "max_voxel_count": 900000,
    "expected_intensity_range": {
      "min": 50,
      "max": 500
    },
    "scoring_weights": {
      "file_exists": 20,
      "file_size_valid": 10,
      "voxel_count_appropriate": 25,
      "spatial_location_correct": 20,
      "intensity_values_valid": 15,
      "vlm_confirms_workflow": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_threshold_brain_segmentation"
    }
  }
}
