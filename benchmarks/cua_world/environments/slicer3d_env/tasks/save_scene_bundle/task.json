{
  "id": "save_scene_bundle@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Annotate the brain MRI from ~/Documents/SlicerData/SampleData/MRHead.nrrd with two fiducials named 'Landmark_A' and 'Landmark_B' at distinct 3D locations. Save the complete scene as an MRB bundle to ~/Documents/SlicerData/Exports/annotated_brain_scene.mrb.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/save_scene_bundle/setup_task.sh",
    "post_task": "/workspace/tasks/save_scene_bundle/export_result.sh"
  },
  "metadata": {
    "sample_data_path": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "output_path": "/home/ga/Documents/SlicerData/Exports/annotated_brain_scene.mrb",
    "exports_dir": "/home/ga/Documents/SlicerData/Exports",
    "expected_fiducial_labels": [
      "Landmark_A",
      "Landmark_B"
    ],
    "min_mrb_size_bytes": 1000000,
    "min_fiducial_separation_mm": 5.0,
    "scoring_weights": {
      "mrb_file_exists": 15,
      "valid_archive": 15,
      "contains_mrml_scene": 15,
      "volume_data_bundled": 20,
      "two_fiducials_present": 15,
      "correct_fiducial_labels": 10,
      "distinct_coordinates": 10
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_save_scene_bundle"
    }
  }
}
