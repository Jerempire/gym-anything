{
  "id": "liver_surgical_planning@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Segment the liver, tumors, and portal vein on the loaded abdominal CT. Measure total tumor volume, count distinct tumors, and determine the minimum tumor-to-portal-vein distance. Save the multi-label segmentation (Label 1=liver, Label 2=tumor, Label 3=portal vein) to ~/Documents/SlicerData/IRCADb/agent_segmentation.nii.gz and the surgical report to ~/Documents/SlicerData/IRCADb/surgical_report.json.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/liver_surgical_planning/setup_task.sh",
    "post_task": "/workspace/tasks/liver_surgical_planning/export_result.sh",
    "pre_task_timeout": 1800
  },
  "metadata": {
    "ircadb_dir": "/home/ga/Documents/SlicerData/IRCADb",
    "ground_truth_dir": "/var/lib/slicer/ground_truth",
    "output_segmentation": "/home/ga/Documents/SlicerData/IRCADb/agent_segmentation.nii.gz",
    "output_report": "/home/ga/Documents/SlicerData/IRCADb/surgical_report.json",
    "segmentation_labels": {
      "background": 0,
      "liver": 1,
      "tumor": 2,
      "portal_vein": 3
    },
    "passing_thresholds": {
      "dice_liver": 0.85,
      "dice_tumor": 0.5,
      "invasion_correct": true,
      "distance_error_max_mm": 5.0,
      "volume_error_max_percent": 30
    },
    "scoring_weights": {
      "dice_liver": 20,
      "dice_tumor": 20,
      "dice_portal_vein": 10,
      "tumor_volume_accuracy": 10,
      "tumor_count_correct": 10,
      "distance_accuracy": 15,
      "invasion_correct": 10,
      "report_completeness": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_liver_surgical_planning"
    }
  }
}
