{
  "id": "crop_volume_roi@1",
  "version": "1.0",
  "env_id": "slicer3d_env@0.1",
  "description": "Crop the pre-loaded MRHead brain MRI to tightly enclose the brain region, removing empty background while preserving all brain tissue. Save the cropped volume to ~/Documents/SlicerData/Exports/MRHead_cropped.nrrd.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/crop_volume_roi/setup_task.sh",
    "post_task": "/workspace/tasks/crop_volume_roi/export_result.sh"
  },
  "metadata": {
    "sample_file": "/home/ga/Documents/SlicerData/SampleData/MRHead.nrrd",
    "expected_output_path": "/home/ga/Documents/SlicerData/Exports/MRHead_cropped.nrrd",
    "expected_module": "CropVolume",
    "original_dimensions_approx": [256, 256, 130],
    "min_cropped_dimension": 50,
    "min_dimension_reduction_percent": 10,
    "min_file_size_kb": 500,
    "scoring_weights": {
      "output_exists": 25,
      "volume_is_smaller": 25,
      "file_saved_correctly": 20,
      "brain_preserved": 15,
      "original_preserved": 10,
      "vlm_module_evidence": 5
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_crop_volume_roi"
    }
  }
}