{
  "id": "prevent_artifact_overwrite@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Configure the 'example-repo-local' repository in Artifactory (http://localhost:8082, admin/password) to prevent artifact overwrites (immutability). Verify that existing artifacts cannot be overwritten while new artifacts can still be deployed.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/prevent_artifact_overwrite/setup_task.sh",
    "post_task": "/workspace/tasks/prevent_artifact_overwrite/export_result.sh"
  },
  "metadata": {
    "repo_key": "example-repo-local",
    "test_artifact_path": "org/apache/commons/commons-io/2.15.1/commons-io-2.15.1.jar",
    "admin_user": "admin",
    "admin_pass": "password"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_prevent_artifact_overwrite"
    }
  }
}
