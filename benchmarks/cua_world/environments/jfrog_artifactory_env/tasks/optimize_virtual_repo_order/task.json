{
  "id": "optimize_virtual_repo_order@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Optimize the resolution order of the virtual repository 'team-virtual' to reduce network latency. Reconfigure the repository so that 'team-local' is prioritized over 'team-remote'. Log in with admin/password.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/optimize_virtual_repo_order/setup_task.sh",
    "post_task": "/workspace/tasks/optimize_virtual_repo_order/export_result.sh"
  },
  "metadata": {
    "target_repo": "team-virtual",
    "expected_first": "team-local",
    "expected_second": "team-remote",
    "artifactory_url": "http://localhost:8082"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_optimize_virtual_repo_order"
    }
  }
}
