{
  "id": "generate_maven_client_config@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Generate a Maven client configuration for the 'example-repo-local' repository in JFrog Artifactory. Save the resulting XML snippet to /home/ga/maven_settings.xml. The file must contain valid XML with the correct server and repository configuration.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_maven_client_config/setup_task.sh",
    "post_task": "/workspace/tasks/generate_maven_client_config/export_result.sh"
  },
  "metadata": {
    "expected_filename": "maven_settings.xml",
    "expected_path": "/home/ga/maven_settings.xml",
    "target_repo_key": "example-repo-local",
    "target_repo_url_part": "artifactory/example-repo-local",
    "artifactory_url": "http://localhost:8082"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_maven_client_config"
    }
  }
}
