{
  "id": "artifact_search_inventory@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Generate a report at '~/artifact_inventory_report.txt' listing all Apache Commons artifacts (commons-lang3 and commons-io) in the 'example-repo-local' repository. For each JAR and POM artifact, include the full repository path, file size in bytes, and SHA-256 checksum. Format each entry as:\n\nPath: <repo_path>\nSize: <bytes>\nSHA-256: <checksum>\n\nSeparate entries with a blank line.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/artifact_search_inventory/setup_task.sh",
    "post_task": "/workspace/tasks/artifact_search_inventory/export_result.sh"
  },
  "metadata": {
    "report_path": "/home/ga/artifact_inventory_report.txt",
    "required_artifacts": [
      {
        "name": "commons-lang3-3.14.0.jar",
        "partial_path": "commons-lang3/3.14.0/commons-lang3-3.14.0.jar"
      },
      {
        "name": "commons-lang3-3.14.0.pom",
        "partial_path": "commons-lang3/3.14.0/commons-lang3-3.14.0.pom"
      },
      {
        "name": "commons-io-2.15.1.jar",
        "partial_path": "commons-io/2.15.1/commons-io-2.15.1.jar"
      },
      {
        "name": "commons-io-2.15.1.pom",
        "partial_path": "commons-io/2.15.1/commons-io-2.15.1.pom"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_artifact_inventory"
    }
  }
}
