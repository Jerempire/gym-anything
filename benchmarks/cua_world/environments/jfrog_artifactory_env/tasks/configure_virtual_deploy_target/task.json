{
  "id": "configure_virtual_deploy_target@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Configure the 'Default Deployment Repository' for the virtual repository 'libs-virtual' to be 'example-repo-local'. Currently, 'libs-virtual' aggregates 'example-repo-local' but does not allow deployment because no target is selected. Access the system at http://localhost:8082 using credentials admin/password.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_virtual_deploy_target/setup_task.sh",
    "post_task": "/workspace/tasks/configure_virtual_deploy_target/export_result.sh"
  },
  "metadata": {
    "virtual_repo": "libs-virtual",
    "target_deploy_repo": "example-repo-local",
    "admin_user": "admin",
    "admin_pass": "password",
    "artifactory_url": "http://localhost:8082"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_virtual_deploy_target"
    }
  }
}
