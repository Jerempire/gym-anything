{
  "id": "configure_backup@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Configure a scheduled backup in JFrog Artifactory using the credentials admin/password. The backup must use the key 'nightly-backup', the cron expression '0 0 2 * * ?', and a retention period of 168 hours. Ensure the backup is enabled and includes all repositories.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_backup/setup_task.sh",
    "post_task": "/workspace/tasks/configure_backup/export_result.sh"
  },
  "metadata": {
    "expected_key": "nightly-backup",
    "expected_cron": "0 0 2 * * ?",
    "expected_retention_hours": 168,
    "admin_user": "admin",
    "admin_pass": "password",
    "artifactory_url": "http://localhost:8082"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_backup"
    }
  }
}
