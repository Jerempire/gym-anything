{
  "id": "retrieve_archive_entry@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Locate the 'config.properties' file within the 'app-bundle-v2.0.zip' artifact in 'example-repo-local' at 'com/acme/app/2.0/'. Save the content of 'config.properties' exactly as it appears to '/home/ga/recovered_config.properties' without downloading the entire zip archive.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/retrieve_archive_entry/setup_task.sh",
    "post_task": "/workspace/tasks/retrieve_archive_entry/export_result.sh"
  },
  "metadata": {
    "artifact_path": "example-repo-local/com/acme/app/2.0/app-bundle-v2.0.zip",
    "target_file_inside_zip": "config.properties",
    "output_file": "/home/ga/recovered_config.properties"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_retrieve_archive_entry"
    }
  }
}
