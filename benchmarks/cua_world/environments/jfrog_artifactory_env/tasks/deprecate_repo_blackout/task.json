{
  "id": "deprecate_repo_blackout@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Deprecate the 'example-repo-local' repository in Artifactory (http://localhost:8082, admin/password). Black out the repository and update its description to start with 'DEPRECATED: Migrated to new system'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/deprecate_repo_blackout/setup_task.sh",
    "post_task": "/workspace/tasks/deprecate_repo_blackout/export_result.sh"
  },
  "metadata": {
    "target_repo": "example-repo-local",
    "expected_description_prefix": "DEPRECATED: Migrated to new system",
    "expected_blacked_out": true,
    "admin_user": "admin",
    "admin_pass": "password"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_deprecate_repo_blackout"
    }
  }
}
