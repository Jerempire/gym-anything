{
  "id": "identify_large_artifacts@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Identify all artifacts in the 'example-repo-local' repository that are larger than 5 MB. Create a text file named 'large_artifacts.txt' at /home/ga/large_artifacts.txt and list the exact filenames of the artifacts that exceed 5 MB, one per line.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/identify_large_artifacts/setup_task.sh",
    "post_task": "/workspace/tasks/identify_large_artifacts/export_result.sh"
  },
  "metadata": {
    "threshold_bytes": 5242880,
    "threshold_desc": "5 MB",
    "output_file": "/home/ga/large_artifacts.txt",
    "repo_key": "example-repo-local"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_identify_large_artifacts"
    }
  }
}
