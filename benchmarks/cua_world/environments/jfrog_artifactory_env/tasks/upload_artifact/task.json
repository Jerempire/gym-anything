{
  "id": "upload_artifact@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Deploy the Apache Commons IO JAR artifact located at /home/ga/artifacts/commons-io/commons-io-2.15.1.jar to the 'example-repo-local' repository in JFrog Artifactory (http://localhost:8082). Use the username 'admin' and password 'password' for authentication.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/upload_artifact/setup_task.sh"
  },
  "metadata": {
    "artifact_file": "/home/ga/artifacts/commons-io/commons-io-2.15.1.jar",
    "target_repo": "example-repo-local",
    "artifact_name": "commons-io-2.15.1.jar",
    "admin_user": "admin",
    "admin_pass": "password",
    "artifactory_url": "http://localhost:8082"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_upload_artifact"
    }
  }
}
