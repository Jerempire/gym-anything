{
  "id": "create_browsable_remote_repo@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Create a Remote Maven Repository in JFrog Artifactory named 'maven-explorer' that proxies 'https://repo1.maven.org/maven2'. Set the public description to 'Proxy for browsing Maven Central' and enable the 'List Remote Folder Items' setting to allow browsing of the remote content. Log in using admin/password.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_browsable_remote_repo/setup_task.sh",
    "post_task": "/workspace/tasks/create_browsable_remote_repo/export_result.sh"
  },
  "metadata": {
    "expected_key": "maven-explorer",
    "expected_url": "https://repo1.maven.org/maven2",
    "expected_description": "Proxy for browsing Maven Central",
    "expected_list_remote_items": true
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_browsable_remote_repo"
    }
  }
}
