{
  "id": "import_repo_content@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Import the repository content from the filesystem directory '/home/ga/repo-import-data/' into the existing 'example-repo-local' repository in Artifactory (http://localhost:8082, admin/password). Verify that the artifacts commons-lang3 and commons-io are successfully imported and visible in the repository.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/import_repo_content/setup_task.sh",
    "post_task": "/workspace/tasks/import_repo_content/export_result.sh"
  },
  "metadata": {
    "target_repo": "example-repo-local",
    "import_source_path": "/home/ga/repo-import-data",
    "expected_artifacts": [
      "org/apache/commons/commons-lang3/3.14.0/commons-lang3-3.14.0.jar",
      "org/apache/commons/commons-lang3/3.14.0/commons-lang3-3.14.0.pom",
      "org/apache/commons/commons-io/2.15.1/commons-io-2.15.1.jar",
      "org/apache/commons/commons-io/2.15.1/commons-io-2.15.1.pom"
    ],
    "admin_user": "admin",
    "admin_pass": "password"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_import_repo_content"
    }
  }
}
