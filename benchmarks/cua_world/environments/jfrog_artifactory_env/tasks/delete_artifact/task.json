    "post_task": "/workspace/tasks/delete_artifact/export_result.sh"
  },
  "metadata": {
    "target_artifact_path": "example-repo-local/org/apache/commons/commons-lang3/3.14.0/commons-lang3-3.14.0.jar",
    "target_folder_path": "example-repo-local/org/apache/commons/commons-lang3/3.14.0/",
    "preserved_artifact_path": "example-repo-local/org/apache/commons/commons-io/2.15.1/commons-io-2.15.1.jar",
    "artifactory_url": "http://localhost:8082",
    "admin_user": "admin",
    "admin_pass": "password"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_delete_artifact"
    }
  }
