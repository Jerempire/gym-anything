{
  "id": "delete_artifact@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Delete the 'commons-lang3-3.14.0.jar' artifact and its version folder from the 'example-repo-local' repository in Artifactory (http://localhost:8082). Use credentials admin/password. Do not delete 'commons-io-2.15.1.jar' which is also in the repository.",
