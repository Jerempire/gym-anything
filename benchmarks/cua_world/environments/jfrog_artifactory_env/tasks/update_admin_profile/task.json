{
  "id": "update_admin_profile@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Update the 'admin' user profile in JFrog Artifactory (URL: http://localhost:8082, Username: admin, Password: password). Change the admin email address to 'admin@example.com' and save the admin's 'Encrypted Password' to /home/ga/encrypted_password.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_admin_profile/setup_task.sh",
    "post_task": "/workspace/tasks/update_admin_profile/export_result.sh"
  },
  "metadata": {
    "target_email": "admin@example.com",
    "output_file": "/home/ga/encrypted_password.txt",
    "admin_user": "admin",
    "admin_pass": "password"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_admin_profile"
    }
  }
}
