{
  "id": "delete_repository@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Delete the repository named 'helix-staging-local' from JFrog Artifactory (http://localhost:8082) using the credentials Username: 'admin' and Password: 'password'. This repository contains outdated staging artifacts from a completed project and needs to be decommissioned.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/delete_repository/setup_task.sh",
    "post_task": "/workspace/tasks/delete_repository/export_result.sh"
  },
  "metadata": {
    "target_repo": "helix-staging-local",
    "artifact_path": "org/apache/commons/commons-lang3/3.14.0/commons-lang3-3.14.0.jar",
    "default_repo": "example-repo-local"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_delete_repository"
    }
  }
}
