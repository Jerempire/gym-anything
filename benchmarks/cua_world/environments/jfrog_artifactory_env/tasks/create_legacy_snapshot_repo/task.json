{
  "id": "create_legacy_snapshot_repo@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Create a new local Maven repository in JFrog Artifactory named 'legacy-dev-local'. Configure the repository to support legacy build tools by enabling snapshot handling and setting the 'Maven Snapshot Version Behavior' to 'Non-unique'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_legacy_snapshot_repo/setup_task.sh",
    "post_task": "/workspace/tasks/create_legacy_snapshot_repo/export_result.sh"
  },
  "metadata": {
    "target_repo_key": "legacy-dev-local",
    "target_package_type": "maven",
    "required_snapshot_behavior": "non-unique",
    "admin_user": "admin",
    "admin_pass": "password"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_legacy_snapshot_repo"
    }
  }
}
