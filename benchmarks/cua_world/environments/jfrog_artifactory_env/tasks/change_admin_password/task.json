{
  "id": "change_admin_password@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Change the administrator password for the JFrog Artifactory instance at http://localhost:8082. Update the 'admin' user password from the current default 'password' to the new password 'SecureAdmin2024!'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/change_admin_password/setup_task.sh",
    "post_task": "/workspace/tasks/change_admin_password/export_result.sh"
  },
  "metadata": {
    "target_user": "admin",
    "old_password": "password",
    "new_password": "SecureAdmin2024!",
    "artifactory_url": "http://localhost:8082"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_change_admin_password"
    }
  }
}
