{
  "id": "restore_deleted_artifact@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Restore the accidentally deleted artifact 'commons-lang3-3.14.0.jar' to the 'example-repo-local' repository from the Artifactory Trash Can. Access Artifactory at http://localhost:8082 using username 'admin' and password 'password'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/restore_deleted_artifact/setup_task.sh",
    "post_task": "/workspace/tasks/restore_deleted_artifact/export_result.sh"
  },
  "metadata": {
    "artifact_name": "commons-lang3-3.14.0.jar",
    "repo_key": "example-repo-local",
    "artifact_path": "org/apache/commons/commons-lang3/3.14.0/commons-lang3-3.14.0.jar",
    "full_url": "http://localhost:8082/artifactory/example-repo-local/org/apache/commons/commons-lang3/3.14.0/commons-lang3-3.14.0.jar",
    "admin_user": "admin",
    "admin_pass": "password"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_restore_deleted_artifact"
    }
  }
}
