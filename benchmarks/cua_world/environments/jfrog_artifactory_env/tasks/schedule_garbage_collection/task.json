{
  "id": "schedule_garbage_collection@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Configure the Garbage Collection service in Artifactory (http://localhost:8082, admin/password) to run at 02:00 AM every Sunday using the cron expression '0 0 2 ? * SUN'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/schedule_garbage_collection/setup_task.sh",
    "post_task": "/workspace/tasks/schedule_garbage_collection/export_result.sh"
  },
  "metadata": {
    "target_cron": "0 0 2 ? * SUN",
    "admin_user": "admin",
    "admin_pass": "password",
    "config_endpoint": "/artifactory/api/system/configuration"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_schedule_garbage_collection"
    }
  }
}
