{
  "id": "rename_local_repository@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Rename the local repository 'legacy-dev-local' to 'module-core-local' in Artifactory, ensuring all artifacts (specifically the 'org' folder structure) are moved to the new repository and the original 'legacy-dev-local' repository is deleted. Login credentials are admin / password.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rename_local_repository/setup_task.sh",
    "post_task": "/workspace/tasks/rename_local_repository/export_result.sh"
  },
  "metadata": {
    "source_repo": "legacy-dev-local",
    "target_repo": "module-core-local",
    "artifact_path": "org/apache/commons/commons-lang3/3.14.0/commons-lang3-3.14.0.jar",
    "admin_user": "admin",
    "admin_pass": "password"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rename_local_repository"
    }
  }
}
