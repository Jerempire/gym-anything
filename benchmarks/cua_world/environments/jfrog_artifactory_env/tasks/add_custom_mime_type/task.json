{
  "id": "add_custom_mime_type@1",
  "version": "1.0",
  "env_id": "jfrog_artifactory_env@0.1",
  "description": "Configure Artifactory (http://localhost:8082, username 'admin', password 'password') to recognize the file extension 'datalog' as the MIME type 'application/vnd.company.datalog'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_custom_mime_type/setup_task.sh",
    "post_task": "/workspace/tasks/add_custom_mime_type/export_result.sh"
  },
  "metadata": {
    "target_mime_type": "application/vnd.company.datalog",
    "target_extension": "datalog",
    "admin_user": "admin",
    "admin_pass": "password",
    "artifactory_url": "http://localhost:8082"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_custom_mime_type"
    }
  }
}
