{
  "id": "utm_coordinate_navigation@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Configure Google Earth Pro to display coordinates in UTM (Universal Transverse Mercator) format, then navigate to Devils Tower National Monument, Wyoming using UTM coordinates 13T 534350mE 4940750mN. Devils Tower should be visible in the view with UTM coordinates displayed in the status bar.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/utm_coordinate_navigation/setup_task.sh",
    "post_task": "/workspace/tasks/utm_coordinate_navigation/export_result.sh"
  },
  "metadata": {
    "target_location": {
      "name": "Devils Tower National Monument",
      "lat": 44.5902,
      "lon": -104.7146,
      "utm_zone": "13T",
      "utm_easting": 534350,
      "utm_northing": 4940750,
      "tolerance_km": 5.0
    },
    "expected_config_setting": "UTM",
    "config_format_value": 2,
    "score_utm_enabled": 30,
    "score_config_modified": 10,
    "score_preferences_used": 10,
    "score_navigation_correct": 25,
    "score_vlm_devils_tower": 15,
    "score_vlm_utm_displayed": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_utm_coordinate_navigation"
    }
  }
}