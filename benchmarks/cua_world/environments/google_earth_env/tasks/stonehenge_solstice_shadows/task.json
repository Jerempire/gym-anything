{
  "id": "stonehenge_solstice_shadows@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Stonehenge (51.1789°N, 1.8262°W), enable sunlight simulation, and set the date/time to the summer solstice sunrise (June 21, early morning). Tilt the view to show the 3D shadows cast by the stones and save a screenshot to ~/Pictures/stonehenge_solstice.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/stonehenge_solstice_shadows/setup_task.sh",
    "post_task": "/workspace/tasks/stonehenge_solstice_shadows/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Pictures/stonehenge_solstice.png",
    "min_file_size_kb": 100,
    "target_location": "Stonehenge, UK",
    "target_coordinates": {
      "lat": 51.1789,
      "lon": -1.8262
    },
    "solstice_date": "June 21",
    "sunrise_time_range": "04:45-05:30",
    "scoring": {
      "file_exists": 10,
      "file_valid": 10,
      "stonehenge_visible": 25,
      "sunlight_active": 20,
      "long_shadows": 20,
      "perspective_3d": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_stonehenge_solstice_shadows"
    }
  }
}