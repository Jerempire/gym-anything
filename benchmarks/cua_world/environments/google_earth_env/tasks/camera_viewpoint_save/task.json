{
  "id": "camera_viewpoint_save@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Configure an oblique aerial viewpoint of Horseshoe Bend, Arizona (~36.8791°N, 111.5103°W) with heading 160-200°, tilt 60-80°, and altitude 800-2000 meters. Save the viewpoint as a placemark with 'Horseshoe' in the name to My Places.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/camera_viewpoint_save/setup_task.sh",
    "post_task": "/workspace/tasks/camera_viewpoint_save/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "target_latitude": 36.8791,
    "target_longitude": -111.5103,
    "coord_tolerance": 0.05,
    "heading_min": 160,
    "heading_max": 200,
    "tilt_min": 60,
    "tilt_max": 80,
    "range_min": 800,
    "range_max": 2000,
    "required_name_substring": "horseshoe",
    "myplaces_path": "/home/ga/.googleearth/myplaces.kml",
    "location_name": "Horseshoe Bend, Arizona"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_camera_viewpoint_save"
    }
  }
}