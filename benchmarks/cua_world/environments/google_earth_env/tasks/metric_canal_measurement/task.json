{
  "id": "metric_canal_measurement@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Configure Google Earth Pro to use metric units. Navigate to the Suez Canal at coordinates 30.5853°N, 32.2654°E and measure the canal width perpendicular to its flow. Save the measurement to My Places with the name 'Suez_Canal_Width_Metric'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/metric_canal_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/metric_canal_measurement/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "target_coordinates": {
      "lat": 30.5853,
      "lon": 32.2654
    },
    "expected_measurement_name": "Suez_Canal_Width_Metric",
    "expected_width_meters_min": 150,
    "expected_width_meters_max": 400,
    "expected_units": "metric",
    "myplaces_path": "/home/ga/.googleearth/myplaces.kml",
    "config_paths": [
      "/home/ga/.config/Google/GoogleEarthPro.conf",
      "/home/ga/.googleearth/GoogleEarth.conf"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_metric_canal_measurement"
    }
  }
}