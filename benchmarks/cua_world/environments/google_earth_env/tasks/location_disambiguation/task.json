{
  "id": "location_disambiguation@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Search for 'Cambridge' and disambiguate to select Cambridge, Massachusetts, USA. Navigate to Harvard Yard (~42.374°N, 71.117°W) and create a placemark named 'Cambridge MA Research Point' with the exact coordinates in the description (format: 'Coordinates: [latitude], [longitude]'). Export to ~/Documents/cambridge_research.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/location_disambiguation/setup_task.sh",
    "post_task": "/workspace/tasks/location_disambiguation/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/cambridge_research.kml",
    "expected_placemark_name": "Cambridge MA Research Point",
    "latitude_min": 42.350,
    "latitude_max": 42.400,
    "longitude_min": -71.150,
    "longitude_max": -71.080,
    "harvard_yard_lat": 42.374,
    "harvard_yard_lon": -71.117,
    "harvard_lat_min": 42.370,
    "harvard_lat_max": 42.380,
    "harvard_lon_min": -71.125,
    "harvard_lon_max": -71.110,
    "search_term": "Cambridge",
    "target_city": "Cambridge, Massachusetts, USA"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_location_disambiguation"
    }
  }
}