{
  "id": "lenfant_dc_overlay@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create an image overlay named 'L'Enfant Plan 1791' using the file ~/Documents/HistoricalMaps/lenfant_plan_1791.jpg. Position it over the National Mall area (~38.889°N, 77.035°W), scale it to cover from the Capitol to the Lincoln Memorial, and set transparency to approximately 50%. Save the overlay to My Places.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/lenfant_dc_overlay/setup_task.sh",
    "post_task": "/workspace/tasks/lenfant_dc_overlay/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "overlay_name": "L'Enfant Plan 1791",
    "overlay_name_patterns": ["l'enfant", "lenfant", "1791", "plan"],
    "image_path": "/home/ga/Documents/HistoricalMaps/lenfant_plan_1791.jpg",
    "image_filename": "lenfant_plan_1791.jpg",
    "center_lat": 38.889,
    "center_lon": -77.035,
    "tolerance_degrees": 0.05,
    "target_transparency_percent": 50,
    "transparency_tolerance": 20,
    "dc_bounds": {
      "north": 38.95,
      "south": 38.85,
      "east": -76.95,
      "west": -77.10
    },
    "data_source": "Wikimedia Commons - L'Enfant Plan (Public Domain, 1791)",
    "myplaces_path": "/home/ga/.googleearth/myplaces.kml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_lenfant_overlay"
    }
  }
}