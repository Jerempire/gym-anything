{
  "id": "central_park_perimeter@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Trace the complete perimeter of Central Park, New York City, using at least 20 points along the park boundary. Save the measurement path to My Places with the name 'Central_Park_Perimeter'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 150,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/central_park_perimeter/setup_task.sh",
    "post_task": "/workspace/tasks/central_park_perimeter/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_path_name": "Central_Park_Perimeter",
    "min_length_km": 9.5,
    "max_length_km": 10.5,
    "min_points": 20,
    "central_park_bounds": {
      "north": 40.801,
      "south": 40.764,
      "west": -73.982,
      "east": -73.949
    },
    "expected_output_file": "/home/ga/.googleearth/myplaces.kml",
    "location_name": "Central Park, New York City"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_central_park_perimeter"
    }
  }
}