{
  "id": "sky_mode_andromeda@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Switch to Sky mode, navigate to the Andromeda Galaxy (M31), and save a high-quality image centered on the galaxy to ~/Documents/andromeda_m31.jpg. The image must be JPEG format with at least 1920x1080 resolution.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sky_mode_andromeda/setup_task.sh",
    "post_task": "/workspace/tasks/sky_mode_andromeda/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "target_object": "Andromeda Galaxy",
    "alternate_names": ["M31", "Messier 31", "NGC 224"],
    "expected_output_path": "/home/ga/Documents/andromeda_m31.jpg",
    "min_resolution_width": 1920,
    "min_resolution_height": 1080,
    "min_file_size_kb": 100,
    "required_mode": "sky",
    "score_sky_mode": 15,
    "score_m31_located": 20,
    "score_file_created": 20,
    "score_resolution": 15,
    "score_content": 20,
    "score_timestamp": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_sky_mode_andromeda"
    }
  }
}