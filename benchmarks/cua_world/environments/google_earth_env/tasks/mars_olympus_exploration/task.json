{
  "id": "mars_olympus_exploration@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Switch to Mars view, navigate to Olympus Mons (~18.65°N, 226.2°E), and save a screenshot showing the volcanic caldera to /home/ga/Documents/olympus_mons.png (or .jpg).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/mars_olympus_exploration/setup_task.sh",
    "post_task": "/workspace/tasks/mars_olympus_exploration/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_dir": "/home/ga/Documents",
    "expected_filename_base": "olympus_mons",
    "valid_extensions": [".png", ".jpg", ".jpeg"],
    "min_file_size_kb": 50,
    "target_body": "Mars",
    "target_feature": "Olympus Mons",
    "target_coordinates": {
      "latitude": 18.65,
      "longitude": 226.2
    },
    "score_mars_view": 25,
    "score_olympus_region": 25,
    "score_caldera_visible": 20,
    "score_screenshot_saved": 20,
    "score_image_quality": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mars_olympus_exploration"
    }
  }
}