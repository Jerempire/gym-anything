{
  "id": "saddle_point_analysis@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Brenner Pass in the Alps (Austria-Italy border) and identify the saddle point. Create a placemark named 'Brenner Pass Saddle Point' with the elevation and a distance measurement to a nearby peak documented in the description. Save the placemark to ~/Documents/brenner_pass_saddle.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/saddle_point_analysis/setup_task.sh",
    "post_task": "/workspace/tasks/saddle_point_analysis/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/brenner_pass_saddle.kml",
    "target_latitude": 47.00,
    "target_longitude": 11.51,
    "coordinate_tolerance_tight": 0.02,
    "coordinate_tolerance_loose": 0.05,
    "elevation_min_meters": 1300,
    "elevation_max_meters": 1500,
    "elevation_min_feet": 4200,
    "elevation_max_feet": 4900,
    "location_name": "Brenner Pass",
    "data_source": "Austrian Federal Office of Metrology and Surveying (BEV)",
    "true_elevation_meters": 1370
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_saddle_point_analysis"
    }
  }
}