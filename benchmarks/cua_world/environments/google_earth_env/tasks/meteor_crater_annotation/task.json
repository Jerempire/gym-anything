{
  "id": "meteor_crater_annotation@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Meteor Crater (Barringer Crater) in Arizona (~35.028°N, 111.022°W) and create a polygon named 'Barringer Crater Rim' tracing the crater rim with a semi-transparent fill. Add a description noting it is an impact crater with its age and diameter. Export to /home/ga/Documents/meteor_crater.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/meteor_crater_annotation/setup_task.sh",
    "post_task": "/workspace/tasks/meteor_crater_annotation/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/meteor_crater.kml",
    "expected_polygon_name": "Barringer Crater Rim",
    "crater_center_lat": 35.028,
    "crater_center_lon": -111.022,
    "crater_diameter_km": 1.2,
    "crater_area_km2": 1.13,
    "acceptable_centroid_radius_km": 5.0,
    "acceptable_area_tolerance": 0.30,
    "min_vertices": 15,
    "max_vertices": 100,
    "description_keywords": ["impact", "crater", "meteor", "asteroid", "50000", "50,000", "years", "diameter", "km"]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_meteor_crater_annotation"
    }
  }
}