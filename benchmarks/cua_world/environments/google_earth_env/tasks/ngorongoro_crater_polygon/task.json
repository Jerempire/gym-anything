{
  "id": "ngorongoro_crater_polygon@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Ngorongoro Crater, Tanzania (~-3.17°, 35.59°) and create a polygon named 'Ngorongoro Crater Floor' tracing the inner crater floor boundary with at least 15 vertices. Style it with green fill at 30-40% opacity and red outline (width 2.0+). Export to ~/Documents/ngorongoro_habitat.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/ngorongoro_crater_polygon/setup_task.sh",
    "post_task": "/workspace/tasks/ngorongoro_crater_polygon/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/ngorongoro_habitat.kml",
    "expected_center_lat": -3.17,
    "expected_center_lon": 35.59,
    "coordinate_tolerance": 0.1,
    "expected_area_km2": 260,
    "area_tolerance_km2": 100,
    "min_vertices": 15,
    "location_name": "Ngorongoro Crater, Tanzania",
    "polygon_name": "Ngorongoro Crater Floor",
    "fill_color": "green",
    "line_color": "red",
    "fill_opacity_min": 0.3,
    "fill_opacity_max": 0.5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ngorongoro_crater_polygon"
    }
  }
}