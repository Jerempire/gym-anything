{
  "id": "latlong_grid_null_island@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Null Island (0°N, 0°E) in the Gulf of Guinea, enable the latitude/longitude grid overlay, and zoom out so multiple grid lines are visible. Save a screenshot showing the grid lines overlaid on the view to /home/ga/null_island_grid.png.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/latlong_grid_null_island/setup_task.sh",
    "post_task": "/workspace/tasks/latlong_grid_null_island/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/null_island_grid.png",
    "target_latitude": 0.0,
    "target_longitude": 0.0,
    "target_region": "Gulf of Guinea, Atlantic Ocean",
    "min_image_width": 1024,
    "min_image_height": 768,
    "feature_to_enable": "View > Grid",
    "geographic_context": "Null Island - intersection of Prime Meridian and Equator"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_latlong_grid_null_island"
    }
  }
}