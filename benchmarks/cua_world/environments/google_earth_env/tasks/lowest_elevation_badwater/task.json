{
  "id": "lowest_elevation_badwater@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Badwater Basin in Death Valley, California and create a placemark named 'Badwater Basin - North America's Lowest Point' at the lowest area. In the description, document the coordinates and the elevation reading from Google Earth. Export the placemark to /home/ga/Documents/badwater_basin.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/lowest_elevation_badwater/setup_task.sh",
    "post_task": "/workspace/tasks/lowest_elevation_badwater/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/badwater_basin.kml",
    "target_latitude": 36.2291,
    "target_longitude": -116.7677,
    "coordinate_tolerance": 0.02,
    "elevation_meters": -86,
    "elevation_feet": -282,
    "elevation_tolerance_m": 15,
    "location_name": "Badwater Basin",
    "region": "Death Valley, California",
    "data_source": "USGS National Geodetic Survey"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_lowest_elevation_badwater"
    }
  }
}