{
  "id": "animated_architecture_tour@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a folder named 'Modern Architecture Tour' in My Places with placemarks for 'Sydney Opera House', 'Burj Khalifa', and 'Guggenheim Bilbao'. Record an animated fly-through tour visiting these three locations. Export the folder with tour data as KMZ to /home/ga/Documents/architecture_tour.kmz.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/animated_architecture_tour/setup_task.sh",
    "post_task": "/workspace/tasks/animated_architecture_tour/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/architecture_tour.kmz",
    "alternate_output_path": "/home/ga/Documents/architecture_tour.kml",
    "expected_locations": {
      "sydney": {
        "name_patterns": ["sydney", "opera"],
        "lat": -33.857,
        "lon": 151.215,
        "tolerance": 0.1
      },
      "dubai": {
        "name_patterns": ["burj", "khalifa", "dubai"],
        "lat": 25.197,
        "lon": 55.274,
        "tolerance": 0.1
      },
      "bilbao": {
        "name_patterns": ["guggenheim", "bilbao"],
        "lat": 43.269,
        "lon": -2.934,
        "tolerance": 0.1
      }
    },
    "expected_folder_name": "Modern Architecture Tour"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_animated_architecture_tour"
    }
  }
}