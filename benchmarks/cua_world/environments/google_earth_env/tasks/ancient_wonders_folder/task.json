{
  "id": "ancient_wonders_folder@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a folder named 'Ancient Wonders' in My Places containing three placemarks: 'Great Pyramid of Giza' (~29.9792°N, 31.1342°E), 'Lighthouse of Alexandria' (~31.2139°N, 29.8853°E), and 'Temple of Artemis' (~37.9497°N, 27.3639°E). Each placemark must be inside the folder, not at the root level.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/ancient_wonders_folder/setup_task.sh",
    "post_task": "/workspace/tasks/ancient_wonders_folder/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "folder_name": "Ancient Wonders",
    "placemarks": [
      {
        "name": "Great Pyramid of Giza",
        "keywords": ["pyramid", "giza"],
        "lat": 29.9792,
        "lon": 31.1342,
        "tolerance_km": 2
      },
      {
        "name": "Lighthouse of Alexandria",
        "keywords": ["lighthouse", "alexandria"],
        "lat": 31.2139,
        "lon": 29.8853,
        "tolerance_km": 2
      },
      {
        "name": "Temple of Artemis",
        "keywords": ["temple", "artemis"],
        "lat": 37.9497,
        "lon": 27.3639,
        "tolerance_km": 2
      }
    ],
    "myplaces_paths": [
      "/home/ga/.googleearth/myplaces.kml",
      "/home/ga/.config/Google/googleearth/myplaces.kml"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ancient_wonders_folder"
    }
  }
}