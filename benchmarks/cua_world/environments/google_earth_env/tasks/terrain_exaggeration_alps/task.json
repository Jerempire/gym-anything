{
  "id": "terrain_exaggeration_alps@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Set terrain elevation exaggeration to 2.5x, navigate to the Matterhorn in Switzerland (45.9766°N, 7.6586°E), and tilt the view to show a 3D perspective emphasizing the exaggerated vertical relief. Save a screenshot to /home/ga/matterhorn_exaggerated.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/terrain_exaggeration_alps/setup_task.sh",
    "post_task": "/workspace/tasks/terrain_exaggeration_alps/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "target_exaggeration": 2.5,
    "exaggeration_tolerance": 0.2,
    "target_latitude": 45.9766,
    "target_longitude": 7.6586,
    "target_location_name": "Matterhorn, Switzerland",
    "expected_output_path": "/home/ga/matterhorn_exaggerated.png",
    "min_file_size_kb": 100,
    "score_config_correct": 30,
    "score_file_exists": 15,
    "score_file_created_during_task": 10,
    "score_vlm_mountain_visible": 15,
    "score_vlm_tilted_view": 15,
    "score_vlm_location_correct": 10,
    "score_vlm_exaggeration_visible": 5
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_terrain_exaggeration_alps"
    }
  }
}