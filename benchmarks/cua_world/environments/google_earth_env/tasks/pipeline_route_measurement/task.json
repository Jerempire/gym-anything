{
  "id": "pipeline_route_measurement@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure the Trans-Alaska Pipeline route from Fairbanks (64.84°N, 147.72°W) to the Valdez Marine Terminal (61.13°N, 146.35°W) by tracing the visible pipeline corridor with the path measurement tool. Save the path as /home/ga/Documents/TAPS_Fairbanks_Valdez.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/pipeline_route_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/pipeline_route_measurement/export_task.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/TAPS_Fairbanks_Valdez.kml",
    "expected_output_alternatives": [
      "/home/ga/Documents/TAPS_Fairbanks_Valdez.kmz",
      "/home/ga/.googleearth/myplaces.kml"
    ],
    "fairbanks_lat": 64.84,
    "fairbanks_lon": -147.72,
    "valdez_lat": 61.13,
    "valdez_lon": -146.35,
    "start_tolerance_km": 50,
    "end_tolerance_km": 30,
    "min_path_length_km": 500,
    "max_path_length_km": 700,
    "min_waypoints": 15,
    "intermediate_waypoints": [
      {"name": "Delta Junction", "lat": 64.15, "lon": -145.84, "tolerance_km": 40},
      {"name": "Isabel Pass", "lat": 63.18, "lon": -145.55, "tolerance_km": 40},
      {"name": "Gulkana", "lat": 62.27, "lon": -145.38, "tolerance_km": 40},
      {"name": "Thompson Pass", "lat": 61.13, "lon": -145.73, "tolerance_km": 40}
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_pipeline_route_measurement"
    }
  }
}