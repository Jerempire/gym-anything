{
  "id": "skyscraper_height_measurement@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to the Empire State Building (40.7484°N, 73.9857°W) and measure its height from ground to top using the 3D ruler. Create a placemark named 'Empire State Building Height' with the measured height in meters in the description.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/skyscraper_height_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/skyscraper_height_measurement/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "target_location": "Empire State Building, New York City",
    "target_latitude": 40.7484,
    "target_longitude": -73.9857,
    "location_tolerance_km": 1.0,
    "expected_placemark_name_keywords": ["empire", "state", "height"],
    "height_range_min_meters": 320,
    "height_range_max_meters": 480,
    "actual_height_roof_meters": 381,
    "actual_height_antenna_meters": 443
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_skyscraper_height_measurement"
    }
  }
}