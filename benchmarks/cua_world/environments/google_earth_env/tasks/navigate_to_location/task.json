{
  "id": "navigate_to_location@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate Google Earth to view the Eiffel Tower in Paris, France. Use the search functionality to find and fly to the Eiffel Tower location.",
  "init": {
    "timeout_sec": 120,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/navigate_to_location/setup_task.sh",
    "post_task": "/workspace/tasks/navigate_to_location/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_navigation"
    }
  }
}
