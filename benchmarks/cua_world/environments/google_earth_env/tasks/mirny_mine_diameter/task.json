{
  "id": "mirny_mine_diameter@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to the Mirny Diamond Mine in Sakha Republic, Russia (62.5294°N, 113.9953°E) and measure the open pit diameter from rim to rim. Save a screenshot showing the measurement to ~/mirny_measurement.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/mirny_mine_diameter/setup_task.sh",
    "post_task": "/workspace/tasks/mirny_mine_diameter/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/mirny_measurement.png",
    "location_name": "Mirny Diamond Mine",
    "target_latitude": 62.5294,
    "target_longitude": 113.9953,
    "coordinate_tolerance_degrees": 0.1,
    "expected_diameter_min_meters": 1100,
    "expected_diameter_max_meters": 1300,
    "expected_diameter_nominal_meters": 1200,
    "min_screenshot_size_bytes": 10000,
    "feature_description": "Large circular open-pit diamond mine with spiral terraces"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mirny_mine_diameter"
    }
  }
}