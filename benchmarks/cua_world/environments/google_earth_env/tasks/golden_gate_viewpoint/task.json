{
  "id": "golden_gate_viewpoint@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a placemark named 'Golden Gate Hero Shot' with description 'Marketing viewpoint - Marin Headlands perspective' centered on the Golden Gate Bridge (37.8199°N, 122.4783°W). Set the camera view to approximately 1500m range, 65° tilt, and 220° heading to capture a dramatic angle with San Francisco in the background. The placemark must save the camera view.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/golden_gate_viewpoint/setup_task.sh",
    "post_task": "/workspace/tasks/golden_gate_viewpoint/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "placemark_name": "Golden Gate Hero Shot",
    "description_contains": "Marketing viewpoint",
    "target_latitude": 37.8199,
    "target_longitude": -122.4783,
    "latitude_tolerance": 0.01,
    "longitude_tolerance": 0.01,
    "range_min": 1000,
    "range_max": 2000,
    "tilt_min": 50,
    "tilt_max": 80,
    "heading_min": 190,
    "heading_max": 250,
    "score_placemark_exists": 10,
    "score_description": 5,
    "score_view_saved": 5,
    "score_location": 30,
    "score_range": 15,
    "score_tilt": 20,
    "score_heading": 15
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_golden_gate_viewpoint"
    }
  }
}