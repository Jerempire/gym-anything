{
  "id": "victoria_falls_coordinates@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Victoria Falls on the Zambia-Zimbabwe border and locate the center point of the main waterfall curtain at the First Gorge. Record the precise coordinates in decimal degrees (negative for south) in the format 'Latitude: XX.XXXX, Longitude: XX.XXXX' to ~/Documents/victoria_falls_coords.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/victoria_falls_coordinates/setup_task.sh",
    "post_task": "/workspace/tasks/victoria_falls_coordinates/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "target_latitude": -17.9243,
    "target_longitude": 25.8572,
    "tolerance_degrees": 0.005,
    "output_file": "/home/ga/Documents/victoria_falls_coords.txt",
    "location_name": "Victoria Falls (Mosi-oa-Tunya)",
    "country": "Zambia-Zimbabwe border",
    "data_source": "UNESCO World Heritage coordinates",
    "score_file_exists": 15,
    "score_timestamp_valid": 10,
    "score_coordinates_parsed": 15,
    "score_lat_correct": 25,
    "score_lon_correct": 25,
    "score_vlm_verification": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_victoria_falls_coordinates"
    }
  }
}