{
  "id": "lake_perimeter_measurement@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure the shoreline perimeter of Crater Lake, Oregon by tracing its shoreline using a path measurement (not polygon/area). Save the path as 'crater_lake_perimeter' in My Places and export to ~/Documents/crater_lake_perimeter.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/lake_perimeter_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/lake_perimeter_measurement/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/crater_lake_perimeter.kml",
    "crater_lake_lat": 42.94,
    "crater_lake_lon": -122.10,
    "location_tolerance_km": 50,
    "min_perimeter_km": 25.0,
    "max_perimeter_km": 45.0,
    "min_path_points": 15,
    "reference_perimeter_km": 33.0,
    "data_source": "Crater Lake National Park, Oregon - USGS topographic data"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_lake_perimeter_measurement"
    }
  }
}