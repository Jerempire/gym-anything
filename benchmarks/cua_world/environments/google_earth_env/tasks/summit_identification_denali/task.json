{
  "id": "summit_identification_denali@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Denali National Park in Alaska and identify the highest elevation point (Mount Denali summit). Create a placemark named 'Denali Summit' positioned precisely at the peak, with the elevation included in the placemark description. Save the placemark to My Places.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/summit_identification_denali/setup_task.sh",
    "post_task": "/workspace/tasks/summit_identification_denali/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_placemark_name": "Denali Summit",
    "expected_lat": 63.0692,
    "expected_lon": -151.0070,
    "expected_elevation_ft": 20310,
    "expected_elevation_m": 6190,
    "coordinate_tolerance_km": 0.5,
    "elevation_tolerance_ft": 500,
    "peak_name": "Denali",
    "data_source": "USGS National Map, Google Earth terrain data"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_summit_identification"
    }
  }
}