{
  "id": "evacuation_zone_radius@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a circle with a 10-mile radius centered on Three Mile Island Nuclear Generating Station (40.153°N, 76.725°W) in Pennsylvania. Name the circle 'TMI Emergency Planning Zone' and export it as a KML file to /home/ga/evacuation_zone.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/evacuation_zone_radius/setup_task.sh",
    "post_task": "/workspace/tasks/evacuation_zone_radius/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/evacuation_zone.kml",
    "expected_center_lat": 40.153368,
    "expected_center_lon": -76.725006,
    "expected_radius_miles": 10.0,
    "coordinate_tolerance_deg": 0.05,
    "radius_tolerance_miles": 1.0,
    "location_name": "Three Mile Island Nuclear Generating Station",
    "state": "Pennsylvania, USA",
    "historical_note": "Site of 1979 partial nuclear meltdown"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_evacuation_zone_radius"
    }
  }
}