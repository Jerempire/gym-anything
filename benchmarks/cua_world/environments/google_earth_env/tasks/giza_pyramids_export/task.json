{
  "id": "giza_pyramids_export@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Save a high-resolution aerial image showing all three major Pyramids of Giza (29.976°N, 31.131°E) -- Khufu, Khafre, and Menkaure -- using a top-down or near-vertical viewing angle. Save the image to /home/ga/Desktop/giza_pyramids.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/giza_pyramids_export/setup_task.sh",
    "post_task": "/workspace/tasks/giza_pyramids_export/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Desktop/giza_pyramids.png",
    "min_width": 800,
    "min_height": 600,
    "min_file_size_kb": 50,
    "location_name": "Pyramids of Giza",
    "latitude": 29.976,
    "longitude": 31.131,
    "country": "Egypt",
    "search_terms": ["Pyramids of Giza", "Great Pyramid of Giza", "Giza Egypt"],
    "content_requirements": [
      "Shows Pyramids of Giza",
      "All three major pyramids visible",
      "Aerial/top-down perspective"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_giza_pyramids_export"
    }
  }
}