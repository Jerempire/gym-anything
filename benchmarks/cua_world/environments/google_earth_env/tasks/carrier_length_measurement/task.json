{
  "id": "carrier_length_measurement@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure the length of an aircraft carrier at Naval Station Norfolk, Virginia (~36.9465°N, 76.3304°W) from stern to bow in meters. Save the measurement as a path named 'Carrier_Length_Measurement'. Export as KML to /home/ga/Documents/carrier_measurement.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/carrier_length_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/carrier_length_measurement/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/carrier_measurement.kml",
    "measurement_range_min_meters": 315,
    "measurement_range_max_meters": 350,
    "target_carrier_length_meters": 333,
    "tolerance_meters": 15,
    "location_bounds": {
      "north": 36.95,
      "south": 36.94,
      "east": -76.32,
      "west": -76.34
    },
    "target_location": {
      "name": "Naval Station Norfolk Carrier Piers",
      "lat": 36.9465,
      "lon": -76.3304
    },
    "data_source": "US Navy official carrier specifications",
    "carrier_classes": ["Nimitz-class", "Ford-class"]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_carrier_length_measurement"
    }
  }
}