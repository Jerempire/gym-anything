{
  "id": "coordinate_format_documentation@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to the Mont Blanc summit (~45.83°N, 6.87°E) and document its coordinates in three formats: Decimal Degrees, Degrees Minutes Seconds, and Universal Transverse Mercator. Save all three representations with clear labels to /home/ga/Documents/mont_blanc_coordinates.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/coordinate_format_documentation/setup_task.sh",
    "post_task": "/workspace/tasks/coordinate_format_documentation/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/mont_blanc_coordinates.txt",
    "target_location": "Mont Blanc Summit",
    "ground_truth": {
      "decimal_lat": 45.8326,
      "decimal_lon": 6.8652,
      "decimal_tolerance": 0.005,
      "dms_lat_d": 45,
      "dms_lat_m": 49,
      "dms_lat_s": 57,
      "dms_lon_d": 6,
      "dms_lon_m": 51,
      "dms_lon_s": 55,
      "dms_tolerance_sec": 15,
      "utm_zone": "32T",
      "utm_easting": 343500,
      "utm_northing": 5078100,
      "utm_tolerance_m": 200
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_coordinate_format_documentation"
    }
  }
}