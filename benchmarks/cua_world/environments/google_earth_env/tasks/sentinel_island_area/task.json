{
  "id": "sentinel_island_area@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to North Sentinel Island (11.55°N, 92.24°E) and trace the island's coastline (not the outer reef) using the polygon measurement tool. Save the polygon as 'North_Sentinel_Island_Boundary' and export it to /home/ga/Documents/north_sentinel_boundary.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sentinel_island_area/setup_task.sh",
    "post_task": "/workspace/tasks/sentinel_island_area/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/north_sentinel_boundary.kml",
    "polygon_name": "North_Sentinel_Island_Boundary",
    "expected_latitude": 11.55,
    "expected_longitude": 92.24,
    "lat_tolerance": 0.15,
    "lon_tolerance": 0.15,
    "expected_area_km2_min": 40,
    "expected_area_km2_max": 100,
    "expected_area_km2_reference": 60,
    "min_vertices": 15,
    "location_name": "North Sentinel Island, Andaman and Nicobar Islands, India"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_sentinel_island_area"
    }
  }
}