{
  "id": "historical_imagery_dubai@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Palm Jumeirah, Dubai (25.1124°N, 55.1390°E) and enable Historical Imagery mode. Use the time slider to view imagery from 2002 or earlier showing the pre-construction coastline. Save a screenshot to /home/ga/Documents/palm_jumeirah_2002.jpg with the historical time slider visible and displaying a year of 2002 or earlier.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/historical_imagery_dubai/setup_task.sh",
    "post_task": "/workspace/tasks/historical_imagery_dubai/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/palm_jumeirah_2002.jpg",
    "min_file_size_kb": 50,
    "target_coordinates": {
      "latitude": 25.1124,
      "longitude": 55.1390,
      "tolerance_km": 15
    },
    "max_year": 2002,
    "location_name": "Palm Jumeirah, Dubai, UAE",
    "construction_start_year": 2001,
    "score_weights": {
      "file_exists_valid": 15,
      "file_created_during_task": 15,
      "location_correct": 20,
      "historical_mode_active": 20,
      "correct_year": 15,
      "no_palm_islands": 15
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_historical_imagery_dubai"
    }
  }
}