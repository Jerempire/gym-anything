{
  "id": "ocean_floor_bathymetry@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to the Mid-Atlantic Ridge (30°N, 42°W). Capture a screenshot with the water surface visible and save to ~/Documents/atlantic_surface.png. Then disable the Water Surface layer, capture a second screenshot showing the bathymetric terrain, and save to ~/Documents/atlantic_bathymetry.png. Create a placemark named 'Mid-Atlantic Rift Valley' on the central rift valley along the ridge crest.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/ocean_floor_bathymetry/setup_task.sh",
    "post_task": "/workspace/tasks/ocean_floor_bathymetry/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_surface_screenshot": "/home/ga/Documents/atlantic_surface.png",
    "expected_bathymetry_screenshot": "/home/ga/Documents/atlantic_bathymetry.png",
    "target_latitude": 30.0,
    "target_longitude": -42.0,
    "coordinate_tolerance_degrees": 5.0,
    "placemark_name_keywords": ["mid-atlantic", "rift", "valley", "ridge", "atlantic"],
    "placemark_bounds": {
      "min_lat": 28.0,
      "max_lat": 32.0,
      "min_lon": -45.0,
      "max_lon": -40.0
    },
    "min_file_size_kb": 100,
    "min_image_difference": 10.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ocean_floor_bathymetry"
    }
  }
}