{
  "id": "date_line_measurement@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure the coast-to-coast distance between Big Diomede Island (Russia, ~65.78°N, 169.06°W) and Little Diomede Island (USA, ~65.76°N, 168.93°W) in the Bering Strait. Create placemarks named 'Big Diomede (Russia)' and 'Little Diomede (USA)' on the respective islands, plus a third placemark named 'Diomede Distance' with the measured distance in kilometers in the description. Save all placemarks to /home/ga/Documents/diomede_measurement.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/date_line_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/date_line_measurement/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/diomede_measurement.kml",
    "big_diomede_lat_range": [65.70, 65.85],
    "big_diomede_lon_range": [-169.20, -168.90],
    "little_diomede_lat_range": [65.70, 65.82],
    "little_diomede_lon_range": [-169.00, -168.80],
    "expected_distance_km_min": 3.0,
    "expected_distance_km_max": 5.0,
    "expected_distance_km_typical": 3.8,
    "min_placemark_separation_deg": 0.03,
    "score_kml_exists": 15,
    "score_big_diomede_placemark": 20,
    "score_little_diomede_placemark": 20,
    "score_distance_placemark": 10,
    "score_distance_documented": 15,
    "score_distance_accurate": 20
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_date_line_measurement"
    }
  }
}