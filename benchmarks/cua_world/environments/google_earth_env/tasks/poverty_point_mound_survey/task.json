{
  "id": "poverty_point_mound_survey@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Poverty Point State Historic Site (32.6345°N, 91.4067°W). Create placemarks named 'Mound A - Bird Mound' at its summit and 'Central Plaza' at the center of the concentric ridge system. Measure the outer ring diameter, and create a path named 'Outer Ridge Arc' along the outermost concentric ridge. Save all features to /home/ga/Documents/poverty_point_survey.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/poverty_point_mound_survey/setup_task.sh",
    "post_task": "/workspace/tasks/poverty_point_mound_survey/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/poverty_point_survey.kml",
    "target_coordinates": {
      "mound_a": {"lat": 32.6369, "lon": -91.4131, "tolerance_m": 500},
      "central_plaza": {"lat": 32.6345, "lon": -91.4067, "tolerance_m": 300},
      "site_center": {"lat": 32.6345, "lon": -91.4067}
    },
    "expected_measurements": {
      "outer_ring_diameter_m": 1200,
      "tolerance_percent": 20
    },
    "site_bounds": {
      "north": 32.645,
      "south": 32.625,
      "east": -91.395,
      "west": -91.420
    },
    "site_name": "Poverty Point State Historic Site",
    "data_source": "UNESCO World Heritage Site, real archaeological coordinates"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_poverty_point_survey"
    }
  }
}