{
  "id": "hawaii_elevation_profile@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Create a path named 'Hawaii Cross-Section' across the Big Island of Hawaii from Hilo (east coast, ~19.73°N, 155.09°W) through Mauna Kea to Kailua-Kona (west coast, ~19.64°N, 156.00°W). Display the elevation profile for this path and save a screenshot showing both the path on the map and the elevation profile panel to /home/ga/hawaii_elevation_profile.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/hawaii_elevation_profile/setup_task.sh",
    "post_task": "/workspace/tasks/hawaii_elevation_profile/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/hawaii_elevation_profile.png",
    "min_file_size_kb": 100,
    "start_location": {
      "name": "Hilo",
      "lat": 19.7297,
      "lon": -155.09
    },
    "end_location": {
      "name": "Kailua-Kona",
      "lat": 19.64,
      "lon": -155.9969
    },
    "peak_location": {
      "name": "Mauna Kea",
      "elevation_ft": 13796,
      "elevation_m": 4205
    },
    "expected_peak_elevation_ft_min": 10000,
    "expected_peak_elevation_ft_max": 15000,
    "expected_distance_km_min": 100,
    "expected_distance_km_max": 160
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_hawaii_elevation_profile"
    }
  }
}