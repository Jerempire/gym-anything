{
  "id": "wildlife_corridor_crossing@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Measure the river width at a wildebeest crossing point on the Mara River (~1.48°S, 35.02°E). Create a placemark named 'Mara River Crossing Point' with the width in meters in the description. Export KML to /home/ga/Documents/mara_crossing.kml and save a screenshot to /home/ga/Documents/mara_crossing_view.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/wildlife_corridor_crossing/setup_task.sh",
    "post_task": "/workspace/tasks/wildlife_corridor_crossing/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_kml_path": "/home/ga/Documents/mara_crossing.kml",
    "expected_screenshot_path": "/home/ga/Documents/mara_crossing_view.png",
    "target_latitude_range": [-1.55, -1.42],
    "target_longitude_range": [34.95, 35.12],
    "expected_river_width_min": 25,
    "expected_river_width_max": 75,
    "expected_placemark_name": "Mara River Crossing Point",
    "known_crossing_points": [
      {"lat": -1.4833, "lon": 35.0167, "name": "Main Crossing"},
      {"lat": -1.4667, "lon": 35.0333, "name": "Northern Crossing"},
      {"lat": -1.5000, "lon": 35.0000, "name": "Southern Crossing"}
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_wildlife_corridor_crossing"
    }
  }
}