{
  "id": "pentagon_area_measurement@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to the Pentagon building in Arlington, Virginia, USA. Use the polygon measurement tool to trace the building's five outer corners and calculate its footprint area. Keep the Ruler dialog open showing the final area measurement.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/pentagon_area_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/pentagon_area_measurement/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "location_name": "Pentagon",
    "location_address": "Arlington, Virginia, USA",
    "target_latitude": 38.8719,
    "target_longitude": -77.0563,
    "expected_area_m2": 116000,
    "min_acceptable_area_m2": 90000,
    "max_acceptable_area_m2": 150000,
    "expected_area_acres": 29,
    "building_shape": "pentagon",
    "expected_vertices": 5,
    "tool_required": "polygon_ruler"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_pentagon_area_measurement"
    }
  }
}