{
  "id": "urban_shadow_assessment@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Enable sunlight visualization for Dubai Marina, UAE (25.0800°N, 55.1400°E) set to June 21st at 4:00 PM local time (UTC+4). Tilt the view to show 3D shadow patterns cast by the skyscrapers onto the marina area. Save a screenshot to /home/ga/shadow_assessment.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/urban_shadow_assessment/setup_task.sh",
    "post_task": "/workspace/tasks/urban_shadow_assessment/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/shadow_assessment.png",
    "location_name": "Dubai Marina",
    "latitude": 25.0800,
    "longitude": 55.1400,
    "target_date": "June 21",
    "target_time": "16:00",
    "timezone": "GST/UTC+4",
    "expected_shadow_direction": "WNW",
    "min_file_size_kb": 100,
    "score_file_exists": 10,
    "score_file_timestamp": 10,
    "score_resolution": 10,
    "score_location_correct": 20,
    "score_view_tilted": 15,
    "score_shadows_visible": 20,
    "score_shadow_direction": 15
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_urban_shadow_assessment"
    }
  }
}