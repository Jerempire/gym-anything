{
  "id": "cartographic_export_scalebar@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to the Nile Delta, Egypt (~31.0°N, 31.0°E) zoomed to show the entire delta. Set the view to north-up with no tilt, enable the scale bar overlay, and save the map image to /home/ga/Documents/nile_delta_map.jpg.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/cartographic_export_scalebar/setup_task.sh",
    "post_task": "/workspace/tasks/cartographic_export_scalebar/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/nile_delta_map.jpg",
    "min_file_size_kb": 100,
    "target_location": {
      "name": "Nile Delta, Egypt",
      "latitude": 31.0,
      "longitude": 31.0
    },
    "required_elements": ["scale_bar", "nile_delta", "north_orientation"],
    "score_file_exists": 15,
    "score_file_valid": 10,
    "score_file_timestamp": 10,
    "score_scale_bar": 25,
    "score_nile_delta": 20,
    "score_zoom_level": 10,
    "score_orientation": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_cartographic_export_scalebar"
    }
  }
}