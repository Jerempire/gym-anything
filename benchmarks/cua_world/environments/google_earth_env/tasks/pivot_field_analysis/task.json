{
  "id": "pivot_field_analysis@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to 37.9583, -100.6425 and measure the diameter of the center-pivot irrigation field at this location. Create a placemark named 'Pivot Field KC-2847' at the pivot point with the measured diameter in meters in the description. Save the placemark to ~/Documents/irrigation_pivot.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/pivot_field_analysis/setup_task.sh",
    "post_task": "/workspace/tasks/pivot_field_analysis/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "target_coordinates": {
      "latitude": 37.9583,
      "longitude": -100.6425
    },
    "coordinate_tolerance": 0.01,
    "expected_diameter_min": 700,
    "expected_diameter_max": 950,
    "expected_diameter_typical": 825,
    "expected_placemark_name": "Pivot Field KC-2847",
    "expected_output_path": "/home/ga/Documents/irrigation_pivot.kml",
    "alternative_output_path": "/home/ga/Documents/irrigation_pivot.kmz",
    "region": "Finney County, Kansas, USA",
    "feature_type": "center_pivot_irrigation"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_pivot_field_analysis"
    }
  }
}