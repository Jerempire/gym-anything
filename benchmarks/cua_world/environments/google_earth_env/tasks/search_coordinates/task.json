{
  "id": "search_coordinates@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Search for and navigate to specific GPS coordinates in Google Earth. Navigate to coordinates 40.7128, -74.0060 (New York City).",
  "init": {
    "timeout_sec": 120,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/search_coordinates/setup_task.sh",
    "post_task": "/workspace/tasks/search_coordinates/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_coordinates"
    }
  }
}
