{
  "id": "runway_heading_measurement@1",
  "version": "1.0",
  "env_id": "google_earth_env@0.1",
  "description": "Navigate to Denver International Airport (DEN) and measure the heading of Runway 34L from its threshold to the opposite end. Create a placemark named 'DEN Runway 34L Threshold' at the threshold location with the measured heading in format 'Heading: XXX°' in the description. Save the placemark to /home/ga/Documents/runway_34L_heading.kml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/runway_heading_measurement/setup_task.sh",
    "post_task": "/workspace/tasks/runway_heading_measurement/export_result.sh",
    "pre_task_timeout": 120
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/runway_34L_heading.kml",
    "airport_code": "DEN",
    "runway": "34L",
    "threshold_lat": 39.8279,
    "threshold_lon": -104.6647,
    "opposite_threshold_lat": 39.8591,
    "opposite_threshold_lon": -104.6572,
    "expected_heading": 345,
    "heading_tolerance": 6,
    "coordinate_tolerance": 0.01,
    "data_source": "FAA Airport Master Record"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_runway_heading_measurement"
    }
  }
}