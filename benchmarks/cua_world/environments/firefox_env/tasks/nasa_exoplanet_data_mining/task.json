{
  "id": "nasa_exoplanet_data_mining@1",
  "version": "1.0",
  "env_id": "firefox_env@0.1",
  "description": "Retrieve data for four exoplanet targets—TRAPPIST-1 e, K2-18 b, LHS 1140 b, and TOI-700 d—from the NASA Exoplanet Archive (exoplanetarchive.ipac.caltech.edu). For each planet, extract the Orbital Period (days), Planet Radius (Earth Radii), Equilibrium Temperature (Kelvin), and Discovery Year. Save the findings to ~/Documents/jwst_targets.json with the structure: {\"project\": \"JWST Target Characterization\", \"targets\": {\"TRAPPIST-1 e\": {\"period_days\": <number>, \"radius_earth_radii\": <number>, \"equilibrium_temp_k\": <number>, \"discovery_year\": <year>}, ...}}. Additionally, create a Firefox bookmark folder named 'Exoplanet Research' containing a link to the archive table.",
  "difficulty": "hard",
  "tags": [
    "firefox",
    "research",
    "data-mining",
    "science",
    "nasa",
    "json"
  ],
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/nasa_exoplanet_data_mining/setup_task.sh",
    "post_task": "/workspace/tasks/nasa_exoplanet_data_mining/export_result.sh"
  },
  "metadata": {
    "required_output_file": "/home/ga/Documents/jwst_targets.json",
    "required_bookmark_folder": "Exoplanet Research",
    "target_planets": [
      "TRAPPIST-1 e",
      "K2-18 b",
      "LHS 1140 b",
      "TOI-700 d"
    ],
    "ground_truth": {
      "TRAPPIST-1 e": {
        "period_range": [
          6.0,
          6.2
        ],
        "radius_range": [
          0.85,
          1.0
        ],
        "temp_range": [
          210,
          250
        ],
        "year": 2017
      },
      "K2-18 b": {
        "period_range": [
          32.5,
          33.5
        ],
        "radius_range": [
          2.0,
          2.8
        ],
        "temp_range": [
          230,
          320
        ],
        "year": 2015
      },
      "LHS 1140 b": {
        "period_range": [
          24.5,
          25.0
        ],
        "radius_range": [
          1.5,
          1.9
        ],
        "temp_range": [
          210,
          250
        ],
        "year": 2017
      },
      "TOI-700 d": {
        "period_range": [
          37.0,
          38.0
        ],
        "radius_range": [
          1.0,
          1.3
        ],
        "temp_range": [
          240,
          280
        ],
        "year": 2020
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_nasa_exoplanet_data_mining"
    }
  }
}
