{
  "id": "world_bank_dev_research@1",
  "version": "1.0",
  "env_id": "firefox_env@0.1",
  "description": "You are a development economist researching Sub-Saharan African economies. Using the World Bank Open Data portal (data.worldbank.org), research the most recent available data for Nigeria (NGA), Kenya (KEN), and South Africa (ZAF) regarding GDP (current US$ in billions), GDP per capita (current US$), life expectancy at birth (years), total population (in millions), and access to electricity (% of population). Create a Firefox bookmark folder named 'World Bank Research' containing at least four bookmarks from worldbank.org domains. Save a JSON report to '~/Documents/world_bank_africa_report.json' with the title 'Sub-Saharan Africa Comparative Economic Briefing' containing the indicators and the data year for each country. Round GDP and population values to one decimal place",
  "difficulty": "hard",
  "tags": [
    "firefox",
    "research",
    "data-entry",
    "json",
    "economics",
    "world-bank"
  ],
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/world_bank_dev_research/setup_task.sh",
    "post_task": "/workspace/tasks/world_bank_dev_research/export_result.sh"
  },
  "metadata": {
    "required_domains": [
      "data.worldbank.org",
      "worldbank.org"
    ],
    "required_countries": [
      "nigeria",
      "kenya",
      "south_africa"
    ],
    "required_bookmark_folder": "World Bank Research",
    "required_output_file": "/home/ga/Documents/world_bank_africa_report.json",
    "plausibility_ranges": {
      "nigeria": {
        "gdp_billions_usd": [
          250,
          650
        ],
        "gdp_per_capita_usd": [
          1000,
          3500
        ],
        "life_expectancy_years": [
          48,
          60
        ],
        "population_millions": [
          190,
          250
        ],
        "electricity_access_pct": [
          45,
          80
        ]
      },
      "kenya": {
        "gdp_billions_usd": [
          70,
          160
        ],
        "gdp_per_capita_usd": [
          1500,
          3000
        ],
        "life_expectancy_years": [
          55,
          70
        ],
        "population_millions": [
          45,
          65
        ],
        "electricity_access_pct": [
          60,
          90
        ]
      },
      "south_africa": {
        "gdp_billions_usd": [
          300,
          500
        ],
        "gdp_per_capita_usd": [
          5000,
          8000
        ],
        "life_expectancy_years": [
          58,
          70
        ],
        "population_millions": [
          55,
          68
        ],
        "electricity_access_pct": [
          80,
          100
        ]
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_world_bank_dev_research"
    }
  }
}
