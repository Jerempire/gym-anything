{
  "id": "add_bookmark@1",
  "version": "1.0",
  "env_id": "firefox_env@0.1",
  "description": "Firefox is already open. Bookmark Wikipedia's main page (https://www.wikipedia.org) in the Bookmarks Toolbar or Bookmarks Menu folder.",
  "difficulty": "easy",
  "tags": [
    "firefox",
    "bookmark",
    "navigation",
    "wikipedia"
  ],
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_bookmark/setup_task.sh",
    "post_task": "/workspace/tasks/add_bookmark/export_result.sh"
  },
  "metadata": {
    "target_url": "https://www.wikipedia.org",
    "expected_bookmark_url_pattern": "wikipedia.org",
    "expected_bookmark_title_pattern": "Wikipedia"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_bookmark"
    }
  }
}
