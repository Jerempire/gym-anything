{
  "id": "rfc_protocol_research@1",
  "version": "1.0",
  "env_id": "firefox_env@0.1",
  "description": "You are a network protocol developer. Research RFC 9113 (HTTP/2), RFC 8446 (TLS 1.3), and RFC 9110 (HTTP Semantics) using the RFC Editor (rfc-editor.org) or IETF Datatracker. Create a JSON file at ~/Documents/rfc_reference.json with entries for 'rfc9113', 'rfc8446', and 'rfc9110'. Each entry must include the 'title', 'publication_date' (YYYY-MM), 'authors' (list), 'status', and a short 'description'. Additionally, create a Firefox bookmark folder named 'RFC Research' containing bookmarks to the official pages for these three RFCs.",
  "difficulty": "hard",
  "tags": [
    "firefox",
    "research",
    "standards",
    "json",
    "developer"
  ],
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rfc_protocol_research/setup_task.sh",
    "post_task": "/workspace/tasks/rfc_protocol_research/export_result.sh"
  },
  "metadata": {
    "required_output_file": "/home/ga/Documents/rfc_reference.json",
    "required_rfcs": [
      "rfc9113",
      "rfc8446",
      "rfc9110"
    ],
    "ground_truth": {
      "rfc9113": {
        "title_keywords": [
          "HTTP/2"
        ],
        "date": "2022-06",
        "author_keyword": "Thomson",
        "status_keyword": "Standard"
      },
      "rfc8446": {
        "title_keywords": [
          "Transport Layer Security",
          "TLS",
          "1.3"
        ],
        "date": "2018-08",
        "author_keyword": "Rescorla",
        "status_keyword": "Standard"
      },
      "rfc9110": {
        "title_keywords": [
          "HTTP",
          "Semantics"
        ],
        "date": "2022-06",
        "author_keyword": "Fielding",
        "status_keyword": "Standard"
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rfc_protocol_research"
    }
  }
}
