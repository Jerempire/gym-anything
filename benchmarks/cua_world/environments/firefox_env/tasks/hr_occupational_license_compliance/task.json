{
  "id": "hr_occupational_license_compliance@1",
  "version": "1.0",
  "env_id": "firefox_env@0.1",
  "description": "Research Physical Therapist professional licensing requirements in Arizona, Maryland, and Washington using the CareerOneStop License Finder (careeronestop.org). Identify the Licensing Authority Name and Renewal Frequency for each state. Create a Firefox bookmark folder named 'State Boards' containing the license detail pages for these states. Save a JSON report to '~/Documents/pt_licensing_audit.json' with keys 'arizona', 'maryland', and 'washington', each containing 'authority_name', 'renewal_frequency', and 'website'.",
  "difficulty": "medium",
  "tags": [
    "firefox",
    "research",
    "compliance",
    "hr",
    "json",
    "bookmarks"
  ],
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/hr_occupational_license_compliance/setup_task.sh",
    "post_task": "/workspace/tasks/hr_occupational_license_compliance/export_result.sh"
  },
  "metadata": {
    "target_occupation": "Physical Therapist",
    "target_states": [
      "arizona",
      "maryland",
      "washington"
    ],
    "required_bookmark_folder": "State Boards",
    "required_domain": "careeronestop.org",
    "output_file": "/home/ga/Documents/pt_licensing_audit.json",
    "ground_truth_keywords": {
      "arizona": {
        "authority": [
          "Arizona",
          "Physical Therapy"
        ],
        "renewal": [
          "2",
          "two",
          "biennial"
        ]
      },
      "maryland": {
        "authority": [
          "Maryland",
          "Physical Therapy"
        ],
        "renewal": [
          "2",
          "two",
          "biennial"
        ]
      },
      "washington": {
        "authority": [
          "Washington",
          "Physical Therapy"
        ],
        "renewal": [
          "year",
          "annual",
          "birthday"
        ]
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_hr_license_compliance"
    }
  }
}
