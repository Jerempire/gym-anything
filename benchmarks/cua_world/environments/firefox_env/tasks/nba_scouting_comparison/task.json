{
  "id": "nba_scouting_comparison@1",
  "version": "1.0",
  "env_id": "firefox_env@0.1",
  "description": "Research career statistics for LeBron James, Stephen Curry, and Nikola Jokić on Basketball Reference (basketball-reference.com). Create a bookmark folder named 'NBA Scouting' containing the player page for each athlete. Generate a JSON file at ~/Documents/nba_comparison.json with keys 'lebron_james', 'stephen_curry', and 'nikola_jokic' containing their career regular-season averages for points (ppg), assists (apg), rebounds (rpg), total seasons played, and championships won.",
  "difficulty": "medium",
  "tags": [
    "firefox",
    "research",
    "data-entry",
    "bookmarks",
    "json"
  ],
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/nba_scouting_comparison/setup_task.sh",
    "post_task": "/workspace/tasks/nba_scouting_comparison/export_result.sh"
  },
  "metadata": {
    "required_output_file": "/home/ga/Documents/nba_comparison.json",
    "required_bookmark_folder": "NBA Scouting",
    "target_domain": "basketball-reference.com",
    "players": {
      "lebron_james": {
        "ppg_range": [
          24.0,
          30.0
        ],
        "apg_range": [
          6.0,
          9.0
        ],
        "rpg_range": [
          6.5,
          8.5
        ],
        "seasons_range": [
          20,
          25
        ],
        "championships_range": [
          4,
          4
        ]
      },
      "stephen_curry": {
        "ppg_range": [
          22.0,
          27.0
        ],
        "apg_range": [
          5.5,
          7.5
        ],
        "rpg_range": [
          3.5,
          6.0
        ],
        "seasons_range": [
          14,
          18
        ],
        "championships_range": [
          4,
          4
        ]
      },
      "nikola_jokic": {
        "ppg_range": [
          18.0,
          24.0
        ],
        "apg_range": [
          5.5,
          8.5
        ],
        "rpg_range": [
          9.0,
          13.0
        ],
        "seasons_range": [
          8,
          13
        ],
        "championships_range": [
          1,
          3
        ]
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_nba_scouting_comparison"
    }
  }
}
