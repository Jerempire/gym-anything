{
  "id": "fleet_maintenance_research@1",
  "version": "1.0",
  "env_id": "firefox_env@0.1",
  "description": "You are a fleet maintenance coordinator. Prepare a maintenance specification sheet for three fleet vehicles: a 2019 Ford F-150 (5.0L V8), a 2020 Toyota RAV4 Hybrid (2.5L), and a 2018 Honda Civic (1.5L Turbo). For each vehicle, identify the engine oil viscosity, engine oil capacity in quarts (with filter), and the WIX brand part numbers for both the oil filter and cabin air filter using RockAuto and web searches. Create a Firefox bookmark folder named 'Fleet Parts' containing direct links to the RockAuto catalog page for each vehicle. Save the collected data to ~/Documents/fleet_specs.json using the keys 'ford_f150', 'toyota_rav4', and 'honda_civic'.",
  "difficulty": "medium",
  "tags": [
    "research",
    "automotive",
    "data-entry",
    "firefox",
    "navigation"
  ],
  "init": {
    "timeout_sec": 900,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/fleet_maintenance_research/setup_task.sh",
    "post_task": "/workspace/tasks/fleet_maintenance_research/export_result.sh"
  },
  "metadata": {
    "output_file": "/home/ga/Documents/fleet_specs.json",
    "vehicles": {
      "ford_f150": {
        "engine": "5.0L V8",
        "oil_viscosity": [
          "5W-20",
          "5W20"
        ],
        "oil_capacity_qt": 8.8,
        "oil_capacity_tolerance": 0.5,
        "wix_oil_filters": [
          "57060",
          "57060XP",
          "WL10255"
        ],
        "wix_cabin_filters": [
          "24364",
          "24483",
          "WP10129"
        ]
      },
      "toyota_rav4": {
        "engine": "2.5L Hybrid",
        "oil_viscosity": [
          "0W-16",
          "0W16",
          "0W-20",
          "0W20"
        ],
        "oil_capacity_qt": 4.8,
        "oil_capacity_tolerance": 0.5,
        "wix_oil_filters": [
          "57047",
          "57047XP",
          "WL10387"
        ],
        "wix_cabin_filters": [
          "24483",
          "WP10168",
          "24488"
        ]
      },
      "honda_civic": {
        "engine": "1.5L Turbo",
        "oil_viscosity": [
          "0W-20",
          "0W20"
        ],
        "oil_capacity_qt": 3.7,
        "oil_capacity_tolerance": 0.4,
        "wix_oil_filters": [
          "57356",
          "57356XP",
          "51356",
          "51356XP"
        ],
        "wix_cabin_filters": [
          "24815",
          "WP10084",
          "24201"
        ]
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_fleet_maintenance_research"
    }
  }
}
