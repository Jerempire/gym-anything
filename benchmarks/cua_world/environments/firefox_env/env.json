{
  "id": "firefox_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Firefox browser environment for web browsing, bookmark management, and browser configuration tasks. Features a pre-configured Firefox profile with disabled first-run dialogs and common browser extensions.",
  "category": ["web", "browser"],
  "tags": ["firefox", "browser", "web", "bookmarks", "downloads", "settings"],
  "resources": {
    "cpu": 4,
    "mem_gb": 4,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "mounts": [
    {"source": "benchmarks/cua_world/environments/firefox_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/firefox_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/firefox_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/firefox_env/utils", "target": "/workspace/utils", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/firefox_env/assets", "target": "/workspace/assets", "mode": "rw"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_firefox.sh",
    "post_start": "/workspace/scripts/setup_firefox.sh"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true,
    "runtime": "sysbox-runc"
  },
  "recording": {
    "enable": true,
    "output_dir": "./artifacts",
    "video_fps": 10,
    "video_codec": "libx264",
    "video_crf": 23,
    "audio_rate": 16000,
    "audio_channels": 1,
    "audio_codec": "aac"
  },
  "vnc": {
    "enable": true,
    "host_port": 5901,
    "password": "password"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ],
  "diagnostics": true
}
