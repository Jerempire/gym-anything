{
  "id": "btcpay_server_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "BTCPay Server environment - self-hosted Bitcoin payment processor running in regtest mode with PostgreSQL, NBXplorer, and Bitcoin Core. Provides a fully functional payment processing interface for store management, invoice creation, payment requests, and Point of Sale applications.",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "diagnostics": true,
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/btcpay_server_env/artifacts",
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": false,
    "host_port": 5970,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/btcpay_server_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/btcpay_server_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/btcpay_server_env/data", "target": "/workspace/data", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/btcpay_server_env/tasks", "target": "/workspace/tasks", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_btcpay.sh",
    "post_start": "/workspace/scripts/setup_btcpay.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "shell": "/bin/bash",
        "groups": ["sudo", "audio", "video", "input", "docker"],
        "env_vars": {
          "DISPLAY": ":1"
        }
      }
    }
  ],
  "tags": ["linux", "web-application", "bitcoin", "payment-processor", "docker", "postgresql", "btcpay", "cryptocurrency", "regtest"]
}
