{
  "id": "seiscomp_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "SeisComP seismological software environment for earthquake monitoring, analysis, and configuration. Includes GUI tools (scolv, scconfig, scrttv, scmv) with real seismic data from GEOFON/IRIS FDSN services.",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080]
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "mounts": [
    {"source": "benchmarks/cua_world/environments/seiscomp_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/seiscomp_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/seiscomp_env/data", "target": "/workspace/data", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/seiscomp_env/tasks", "target": "/workspace/tasks", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_seiscomp.sh",
    "post_start": "/workspace/scripts/setup_seiscomp.sh"
  },
  "vnc": {
    "password": "password"
  },
  "security": {
    "user": "0:0",
    "privileged": true,
    "use_systemd": true,
    "cap_drop": ["ALL"]
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ]
}
