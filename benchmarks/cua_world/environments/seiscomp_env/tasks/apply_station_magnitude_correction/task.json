{
  "id": "apply_station_magnitude_correction@1",
  "version": "1.0",
  "env_id": "seiscomp_env@0.1",
  "description": "Configure a station-specific magnitude correction for station GE.TOLI to compensate for local site attenuation effects. Apply a static offset of +0.4 to the Local Magnitude (ML) calculations within the scmag module configuration.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/apply_station_magnitude_correction/setup_task.sh",
    "post_task": "/workspace/tasks/apply_station_magnitude_correction/export_result.sh"
  },
  "metadata": {
    "target_station": "GE.TOLI",
    "target_magnitude_type": "ML",
    "target_correction_value": 0.4,
    "target_module": "scmag"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_station_magnitude_correction"
    }
  }
}
