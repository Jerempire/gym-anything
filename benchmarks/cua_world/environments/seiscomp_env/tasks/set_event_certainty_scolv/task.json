{
  "id": "set_event_certainty_scolv@1",
  "version": "1.0",
  "env_id": "seiscomp_env@0.1",
  "description": "Update the Noto Peninsula, Japan earthquake (2024-01-01, M7.5) in scolv. Set the type certainty to 'known' and commit the change.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/set_event_certainty_scolv/setup_task.sh"
  },
  "metadata": {
    "target_event_region": "Noto Peninsula, Japan",
    "target_event_magnitude": 7.5,
    "expected_type_certainty": "known",
    "initial_type_certainty": "not set",
    "seiscomp_gui_app": "scolv"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_event_certainty"
    }
  }
}
