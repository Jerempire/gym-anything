{
  "id": "enable_scautopick_scconfig@1",
  "version": "1.0",
  "env_id": "seiscomp_env@0.1",
  "description": "Enable the scautopick module to start automatically with the SeisComP system and save the configuration.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/enable_scautopick_scconfig/setup_task.sh"
  },
  "metadata": {
    "target_module": "scautopick",
    "initial_state": "disabled",
    "expected_state": "enabled",
    "seiscomp_gui_app": "scconfig"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enable_scautopick"
    }
  }
}
