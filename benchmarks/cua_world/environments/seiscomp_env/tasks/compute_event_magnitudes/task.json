{
  "id": "compute_event_magnitudes@1",
  "version": "1.0",
  "env_id": "seiscomp_env@0.1",
  "description": "Calculate the mb (Body Wave) and MLv (Local) magnitudes for the 2024 Noto Peninsula earthquake event in the SeisComP database. Create a summary report at /home/ga/magnitude_report.txt using the following format:\n\nEventID: [PublicID]\nmb: [Value]\nMLv: [Value]",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/compute_event_magnitudes/setup_task.sh",
    "post_task": "/workspace/tasks/compute_event_magnitudes/export_result.sh"
  },
  "metadata": {
    "expected_report_path": "/home/ga/magnitude_report.txt",
    "target_magnitudes": [
      "mb",
      "MLv"
    ],
    "tolerance": 0.1
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_compute_event_magnitudes"
    }
  }
}
