{
  "id": "batch_import_legacy_events@1",
  "version": "1.0",
  "env_id": "seiscomp_env@0.1",
  "description": "Create a Python script at ~/Documents/csv_to_scml.py to convert the 2024 Noto Peninsula earthquake aftershock data from ~/Documents/legacy_events.csv into a SeisComP SCML file at ~/Documents/legacy_events.scml. Use the seiscomp.datamodel API to generate Event, Origin, and Magnitude objects with the creationInfo.agencyID set to 'LEGACY_IMPORT'. Import the resulting SCML file into the SeisComP database using the scdb tool. The legacy_events.csv contains 5 aftershocks from the 2024 Noto Peninsula earthquake.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/batch_import_legacy_events/setup_task.sh",
    "post_task": "/workspace/tasks/batch_import_legacy_events/export_result.sh"
  },
  "metadata": {
    "expected_agency_id": "LEGACY_IMPORT",
    "expected_event_count": 5,
    "expected_events": [
      {
        "lat": 37.204,
        "lon": 136.945,
        "depth": 10.0,
        "mag": 5.7
      },
      {
        "lat": 37.218,
        "lon": 136.852,
        "depth": 10.0,
        "mag": 4.9
      },
      {
        "lat": 37.362,
        "lon": 137.059,
        "depth": 10.0,
        "mag": 5.2
      },
      {
        "lat": 37.108,
        "lon": 136.68,
        "depth": 10.0,
        "mag": 5.6
      },
      {
        "lat": 37.379,
        "lon": 137.284,
        "depth": 10.0,
        "mag": 4.8
      }
    ],
    "script_path": "/home/ga/Documents/csv_to_scml.py",
    "csv_path": "/home/ga/Documents/legacy_events.csv",
    "scml_path": "/home/ga/Documents/legacy_events.scml"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_batch_import_legacy_events"
    }
  }
}
