{
  "id": "export_event_scxmldump@1",
  "version": "1.0",
  "env_id": "seiscomp_env@0.1",
  "description": "A collaborating institution has requested the event data for the 2024 Noto Peninsula earthquake stored in the SeisComP database (mysql://sysop:sysop@localhost/seiscomp). Export the complete earthquake event data, including the preferred origin (latitude, longitude, depth) and preferred magnitude, to /home/ga/Documents/noto_export.xml.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_event_scxmldump/setup_task.sh",
    "post_task": "/workspace/tasks/export_event_scxmldump/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/Documents/noto_export.xml",
    "db_connection": "mysql://sysop:sysop@localhost/seiscomp",
    "expected_lat_min": 36.5,
    "expected_lat_max": 38.5,
    "expected_lon_min": 136.0,
    "expected_lon_max": 138.0,
    "expected_mag_min": 7.0,
    "expected_mag_max": 8.0,
    "min_file_size_bytes": 500
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_event"
    }
  }
}
