{
  "id": "configure_picker_binding@1",
  "version": "1.0",
  "env_id": "seiscomp_env@0.1",
  "description": "The default detection settings are not optimal for the GE network stations. Create a new scautopick binding profile named 'broadband_opt' with the filter set to 'BW(3,0.7,4.0)' and timeCorrection set to '-0.5'. Apply this profile to all stations in the GE network (TOLI, GSI, KWP, SANI, BKB).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_picker_binding/setup_task.sh",
    "post_task": "/workspace/tasks/configure_picker_binding/export_result.sh"
  },
  "metadata": {
    "expected_profile_name": "broadband_opt",
    "expected_filter": "BW(3,0.7,4.0)",
    "expected_timecorrection": "-0.5",
    "target_stations": [
      "TOLI",
      "GSI",
      "KWP",
      "SANI",
      "BKB"
    ],
    "target_network": "GE",
    "target_module": "scautopick"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_picker_binding"
    }
  }
}
