{
  "id": "set_event_type_scolv@1",
  "version": "1.0",
  "env_id": "seiscomp_env@0.1",
  "description": "The Noto Peninsula, Japan earthquake (2024-01-01, M7.5) has been detected by the SeisComP system and is displayed in scolv. Confirm the event as tectonic by updating the event type to 'earthquake' and committing the update.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/set_event_type_scolv/setup_task.sh"
  },
  "metadata": {
    "target_event_region": "Noto Peninsula, Japan",
    "target_event_magnitude": 7.5,
    "expected_event_type": "earthquake",
    "initial_event_type": "not set",
    "seiscomp_gui_app": "scolv"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_event_type_scolv"
    }
  }
}
