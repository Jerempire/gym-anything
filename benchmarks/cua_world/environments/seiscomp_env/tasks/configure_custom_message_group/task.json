{
  "id": "configure_custom_message_group@1",
  "version": "1.0",
  "env_id": "seiscomp_env@0.1",
  "description": "Configure the SeisComP messaging server (scmaster) to support a new message group named `RISK` within the `production` queue. Ensure the new group is loaded and active in the running system.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_custom_message_group/setup_task.sh",
    "post_task": "/workspace/tasks/configure_custom_message_group/export_result.sh"
  },
  "metadata": {
    "target_group": "RISK",
    "target_queue": "production",
    "config_file": "/home/ga/seiscomp/etc/scmaster.cfg"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_custom_message_group"
    }
  }
}
