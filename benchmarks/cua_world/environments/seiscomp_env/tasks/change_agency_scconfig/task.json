{
  "id": "change_agency_scconfig@1",
  "version": "1.0",
  "env_id": "seiscomp_env@0.1",
  "description": "Update the global agencyID from 'GYM' to 'NIED' (National Research Institute for Earth Science and Disaster Resilience) in the SeisComP configuration (scconfig).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/change_agency_scconfig/setup_task.sh"
  },
  "metadata": {
    "target_parameter": "agencyID",
    "initial_value": "GYM",
    "expected_value": "NIED",
    "seiscomp_gui_app": "scconfig"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_change_agency"
    }
  }
}
