{
  "id": "relocate_event_manual_picks_scolv@1",
  "version": "1.0",
  "env_id": "seiscomp_env@0.1",
  "description": "You are the duty seismologist responsible for manual event review of the 2024 Noto Peninsula earthquake (M7.5, 2024-01-01). Refine the P-wave arrival picks for stations GE.GSI, GE.BKB, and GE.SANI. Commit the updated hypocenter solution to the database with the evaluation mode set to 'manual'.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 800,
    "max_steps": 90,
    "reward_type": "partial"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/relocate_event_manual_picks_scolv/setup_task.sh",
    "post_task": "/workspace/tasks/relocate_event_manual_picks_scolv/export_result.sh"
  },
  "metadata": {
    "target_event": "Noto Peninsula, Japan 2024-01-01 M7.5",
    "stations_with_waveforms": [
      "GE.GSI",
      "GE.BKB",
      "GE.SANI"
    ],
    "required_evaluation_mode": "manual",
    "required_phases": [
      "P"
    ],
    "seiscomp_gui_app": "scolv",
    "occupation": "Geoscientists (SOC 19-2042.00)",
    "task_type": "waveform_analysis_and_hypocenter_relocation"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_relocate_event_manual_picks_scolv"
    }
  }
}
