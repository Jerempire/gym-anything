{
  "id": "freelance_time_billing@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Process the freelance timesheet for invoice preparation. Calculate durations, billable amounts, client subtotals, and the grand total.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/freelance_time_billing/setup_task.sh",
    "post_task": "/workspace/tasks/freelance_time_billing/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_freelance_billing"
    }
  }
}
