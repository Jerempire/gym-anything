{
  "id": "contractor_quote_normalizer@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Normalize the contractor quotes into a standardized comparison format. Identify the best value and flag outliers. Save the final comparison to the designated output path.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/contractor_quote_normalizer/setup_task.sh",
    "post_task": "/workspace/tasks/contractor_quote_normalizer/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_contractor_quotes"
    }
  }
}
