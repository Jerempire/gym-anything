{
  "id": "circular_ref_debugger@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Fix the circular reference errors in the budget spreadsheet by breaking the dependency between Overhead, Net Income, and Total Expenses. Ensure all calculations remain correct.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/circular_ref_debugger/setup_task.sh",
    "post_task": "/workspace/tasks/circular_ref_debugger/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_circular_ref_fix"
    }
  }
}
