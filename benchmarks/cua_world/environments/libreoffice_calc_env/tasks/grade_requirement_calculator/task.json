{
  "id": "grade_requirement_calculator@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Calculate the scores required on the final exam and project for a student to achieve a final grade of 87% (B+).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 12,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/grade_requirement_calculator/setup_task.sh",
    "post_task": "/workspace/tasks/grade_requirement_calculator/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_grade_calculator"
    }
  }
}
