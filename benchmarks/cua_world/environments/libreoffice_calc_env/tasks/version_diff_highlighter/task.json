{
  "id": "version_diff_highlighter@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Compare product pricing data between versions and highlight all differences in the Version 2 sheet using background color formatting.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/version_diff_highlighter/setup_task.sh",
    "post_task": "/workspace/tasks/version_diff_highlighter/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_version_diff_highlighter"
    }
  }
}
