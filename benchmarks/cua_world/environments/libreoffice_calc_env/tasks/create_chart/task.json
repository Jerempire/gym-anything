{
  "id": "create_chart@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Create a bar chart from the provided sales data and save the output to ~/Documents/sales_chart.png.",
  "difficulty": "medium",
  "natural_language": {
    "prompt": "Create a bar chart showing monthly sales data from the provided dataset.",
    "language": "en"
  },
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_chart/setup_task.sh",
    "post_task": "/workspace/tasks/create_chart/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_create_chart"
    }
  }
}
