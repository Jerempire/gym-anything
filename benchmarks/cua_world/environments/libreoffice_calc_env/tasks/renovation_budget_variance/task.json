{
  "id": "renovation_budget_variance@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Perform a variance analysis on the home renovation budget. Calculate variances (Actual-Budget), percentages, and totals, and apply conditional formatting to highlight over-budget categories.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/renovation_budget_variance/setup_task.sh",
    "post_task": "/workspace/tasks/renovation_budget_variance/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_renovation_budget"
    }
  }
}
