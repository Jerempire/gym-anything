{
  "id": "poker_settlement@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Reconcile poker night finances by calculating total buy-ins and net positions for each player. Verify the zero-sum constraint and organize the data for settlement.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/poker_settlement/setup_task.sh",
    "post_task": "/workspace/tasks/poker_settlement/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_poker_settlement"
    }
  }
}
