{
  "id": "sourdough_starter_calculator@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Calculate sourdough starter metrics including hydration percentage, total weight, peak time estimation, and baking readiness. Use formulas and conditional logic to determine the results in the spreadsheet.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sourdough_starter_calculator/setup_task.sh",
    "post_task": "/workspace/tasks/sourdough_starter_calculator/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_sourdough_calculator"
    }
  }
}
