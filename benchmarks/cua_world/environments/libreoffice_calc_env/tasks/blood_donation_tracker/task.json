{
  "id": "blood_donation_tracker@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Calculate the next eligible blood donation dates for the donors based on medical waiting period requirements and update the donor records.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/blood_donation_tracker/setup_task.sh",
    "post_task": "/workspace/tasks/blood_donation_tracker/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_blood_donation_tracker"
    }
  }
}
