{
  "id": "timezone_meeting_finder@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Identify overlapping availability windows for a global team meeting across multiple timezones and record the optimal meeting times in UTC.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/timezone_meeting_finder/setup_task.sh",
    "post_task": "/workspace/tasks/timezone_meeting_finder/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_timezone_meeting_finder"
    }
  }
}
