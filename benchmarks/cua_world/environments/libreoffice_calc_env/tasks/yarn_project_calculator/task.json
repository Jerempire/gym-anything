{
  "id": "yarn_project_calculator@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Calculate yarn requirements for a knitting project including safety margins and compare costs across yarn options. Create a shopping list using cross-sheet formulas and the CEILING function for rounding.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/yarn_project_calculator/setup_task.sh",
    "post_task": "/workspace/tasks/yarn_project_calculator/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_yarn_calculator"
    }
  }
}
