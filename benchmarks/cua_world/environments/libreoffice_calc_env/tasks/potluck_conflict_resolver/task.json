{
  "id": "potluck_conflict_resolver@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Import the potluck sign-up CSV. Identify duplicate dishes within categories, flag allergen concerns, and calculate serving adequacy. Create a category distribution summary.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/potluck_conflict_resolver/setup_task.sh",
    "post_task": "/workspace/tasks/potluck_conflict_resolver/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_potluck_analysis"
    }
  }
}
