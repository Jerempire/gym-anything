{
  "id": "sort_data@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Sort the dataset by the 'Score' column in ascending order.",
  "difficulty": "easy",
  "natural_language": {
    "prompt": "Sort the provided dataset by the 'Score' column in ascending order (lowest to highest).",
    "language": "en"
  },
  "init": {
    "timeout_sec": 180,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/sort_data/setup_task.sh",
    "post_task": "/workspace/tasks/sort_data/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_sort_data"
    }
  }
}
