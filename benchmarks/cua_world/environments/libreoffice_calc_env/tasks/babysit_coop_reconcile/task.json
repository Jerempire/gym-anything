{
  "id": "babysit_coop_reconcile@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Clean and standardize the babysitting co-op transaction records. Calculate the credit balance for each family and flag any imbalanced accounts.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/babysit_coop_reconcile/setup_task.sh",
    "post_task": "/workspace/tasks/babysit_coop_reconcile/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_babysit_coop_reconcile"
    }
  }
}
