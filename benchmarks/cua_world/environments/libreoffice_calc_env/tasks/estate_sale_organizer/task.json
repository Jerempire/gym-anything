{
  "id": "estate_sale_organizer@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Generate a final estate sale inventory that consolidates all source data, resolves conflicting item assignments, distinguishes sellable items from keepsakes, and uses a uniform price format.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 240,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/estate_sale_organizer/setup_task.sh",
    "post_task": "/workspace/tasks/estate_sale_organizer/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_estate_sale_organizer"
    }
  }
}
