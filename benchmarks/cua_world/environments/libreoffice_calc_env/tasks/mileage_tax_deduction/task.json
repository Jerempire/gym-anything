    "pre_task": "/workspace/tasks/mileage_tax_deduction/setup_task.sh",
    "post_task": "/workspace/tasks/mileage_tax_deduction/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mileage_tax_deduction"
    }
  }
}
