{
  "id": "chili_cookoff_scorer@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Normalize judge scores from different scales (1-5 and 1-10), handle missing data, calculate rankings, and determine prize amounts for the community chili cook-off competition.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/chili_cookoff_scorer/setup_task.sh",
    "post_task": "/workspace/tasks/chili_cookoff_scorer/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_chili_cookoff_scorer"
    }
  }
}
