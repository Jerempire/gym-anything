{
  "id": "food_expiration_tracker@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Create a food expiration tracker that calculates expiration dates and the number of days remaining. The tracker should use conditional formatting to highlight urgent items and be sorted by urgency.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/food_expiration_tracker/setup_task.sh",
    "post_task": "/workspace/tasks/food_expiration_tracker/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_food_expiration_tracker"
    }
  }
}
