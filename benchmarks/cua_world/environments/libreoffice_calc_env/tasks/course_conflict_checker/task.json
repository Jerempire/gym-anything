{
  "id": "course_conflict_checker@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Identify time conflicts in the college course schedule, apply conditional formatting to highlight the conflicts, and calculate the total credit hours and enrollment status.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/course_conflict_checker/setup_task.sh",
    "post_task": "/workspace/tasks/course_conflict_checker/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_course_conflict_checker"
    }
  }
}
