{
  "id": "transaction_anomaly_detector@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Detect and flag suspicious transactions in the imported bank data, including duplicates, date errors, outliers, impossible amounts, and balance mismatches.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/transaction_anomaly_detector/setup_task.sh",
    "post_task": "/workspace/tasks/transaction_anomaly_detector/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_transaction_anomaly_detector"
    }
  }
}
