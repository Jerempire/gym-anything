{
  "id": "basic_formulas@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Populate cells A1 through A5 in LibreOffice Calc with the values 10, 20, 30, 40, and 50. Calculate the sum of these values in cell B1 and their average in cell B2.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 120,
    "max_steps": 10,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/basic_formulas/setup_task.sh",
    "post_task": "/workspace/tasks/basic_formulas/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_basic_formulas"
    }
  }
}
