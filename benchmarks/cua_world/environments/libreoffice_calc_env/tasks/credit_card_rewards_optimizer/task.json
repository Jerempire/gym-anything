{
  "id": "credit_card_rewards_optimizer@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Create a credit card rewards optimizer that calculates the best cashback for each spending category and recommends the optimal card choice for each.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/credit_card_rewards_optimizer/setup_task.sh",
    "post_task": "/workspace/tasks/credit_card_rewards_optimizer/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::check_credit_card_optimizer"
    }
  }
}
