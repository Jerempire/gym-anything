{
  "id": "backpacking_itinerary@1",
  "version": "1.0",
  "env_id": "libreoffice_calc_env@0.1",
  "description": "Plan a safe backpacking trip. The itinerary must include cumulative distances, hiking time estimates based on distance and elevation, and flags for any days exceeding safe limits.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 15,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/backpacking_itinerary/setup_task.sh",
    "post_task": "/workspace/tasks/backpacking_itinerary/export_result.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_backpacking_itinerary"
    }
  }
}
