{
  "id": "pymol_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "PyMOL molecular visualization environment for structural biology tasks including protein visualization, measurement, and publication-quality rendering",
  "category": ["science", "molecular-biology"],
  "tags": ["linux", "science", "biology", "molecular", "visualization", "pdb", "protein", "desktop"],
  "resources": {
    "cpu": 4,
    "mem_gb": 6,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "resolution": [1920, 1080],
      "fps": 10,
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "vnc": {
    "enable": true,
    "password": "password"
  },
  "synchronous": true,
  "step_cycle_ms": 200,
  "mounts": [
    {"source": "benchmarks/cua_world/environments/pymol_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/pymol_env/tasks", "target": "/workspace/tasks", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_pymol.sh",
    "post_start": "/workspace/scripts/setup_pymol.sh"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {
          "DISPLAY": ":1",
          "PYMOL_USER": "ga"
        }
      }
    }
  ]
}
