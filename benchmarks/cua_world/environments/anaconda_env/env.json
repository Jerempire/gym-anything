{
  "id": "anaconda_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Anaconda Navigator environment for conda environment management, package installation, and data science workflows using Jupyter Notebook",
  "category": ["data-science", "development"],
  "tags": [
    "linux",
    "anaconda",
    "conda",
    "navigator",
    "jupyter",
    "python",
    "data-science",
    "desktop"
  ],
  "licence": "BSD-3-Clause",
  "upstream_url": "https://www.anaconda.com/products/navigator",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/anaconda_env/artifacts",
    "video_fps": 10,
    "video_resolution": [1920, 1080],
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": false,
    "host_port": 5964,
    "container_port": 5900,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/anaconda_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/anaconda_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/anaconda_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/anaconda_env/data", "target": "/workspace/data", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_anaconda.sh",
    "post_start": "/workspace/scripts/setup_anaconda.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "data-scientist",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "ANACONDA_HOME": "/home/ga/anaconda3"
        }
      }
    }
  ]
}
