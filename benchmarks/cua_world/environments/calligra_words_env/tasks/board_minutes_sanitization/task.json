{
  "id": "board_minutes_sanitization@1",
  "version": "1.0",
  "env_id": "calligra_words_env@0.1",
  "description": "You are the Corporate Secretary at Meridian Technologies Inc. Apply the sanitization policy found at /home/ga/Desktop/sanitization_policy.txt to the Q4 2025 Board of Directors meeting minutes located at /home/ga/Documents/board_minutes_q4.odt. Redact all identified categories of sensitive information while preserving legitimate public-facing content, document structure, and formatting. Save the changes to /home/ga/Documents/board_minutes_q4.odt.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/board_minutes_sanitization/setup_task.sh",
    "post_task": "/workspace/tasks/board_minutes_sanitization/export_result.sh"
  },
  "metadata": {
    "document_path": "/home/ga/Documents/board_minutes_q4.odt",
    "policy_path": "/home/ga/Desktop/sanitization_policy.txt",
    "confidential_phrases_must_be_absent": [
      "60% probability of adverse outcome",
      "settling for $4.2 million",
      "CloudNest Systems",
      "$78 million acquisition",
      "base salary of $875,000",
      "annual bonus of $1.2 million",
      "RSU grant of 50,000 shares",
      "preliminary Q4 revenue of $412 million",
      "Project Falcon"
    ],
    "legitimate_phrases_must_be_present": [
      "Board of Directors",
      "Meridian Technologies",
      "quarterly dividend of $0.35 per share",
      "2026 capital expenditure budget",
      "Chief Technology Officer",
      "Ernst & Young",
      "Annual Meeting of Shareholders",
      "cybersecurity improvements"
    ],
    "expected_redaction_replacement": "REDACTED",
    "section_headings": [
      "Call to Order",
      "Approval of Previous Minutes",
      "Financial Report",
      "Strategic Initiatives",
      "Legal and Compliance Update",
      "Human Resources and Compensation",
      "New Business",
      "Adjournment"
    ],
    "source": "Original corporate board minutes content"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_board_minutes_sanitization"
    }
  }
}
