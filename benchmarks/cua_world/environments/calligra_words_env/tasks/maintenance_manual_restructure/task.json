{
  "id": "maintenance_manual_restructure@1",
  "version": "1.0",
  "env_id": "calligra_words_env@0.1",
  "description": "You are a facilities maintenance manager. The engineering team migrated an HVAC preventive maintenance manual to a new system, but the export scrambled all the sections and ruined the heading hierarchy. Using the restructuring guide at /home/ga/Desktop/manual_restructuring_guide.txt, rearrange the 8 main sections in /home/ga/Documents/hvac_maintenance_manual.odt to match the correct sequence. Format the 8 main section titles as Heading 1 and all maintenance sub-tasks as Heading 2. At the end of the 'System Overview' section, create a summary table with 4 columns and at least 6 rows using the schedule data provided in the guide. Save the updated document.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/maintenance_manual_restructure/setup_task.sh",
    "post_task": "/workspace/tasks/maintenance_manual_restructure/export_result.sh"
  },
  "metadata": {
    "document_path": "/home/ga/Documents/hvac_maintenance_manual.odt",
    "guide_path": "/home/ga/Desktop/manual_restructuring_guide.txt",
    "expected_first_half": [
      "Introduction and Safety Precautions",
      "System Overview and Specifications",
      "Monthly Inspection Procedures",
      "Quarterly Maintenance Procedures"
    ],
    "expected_second_half": [
      "Semi-Annual Maintenance Procedures",
      "Annual Maintenance Procedures",
      "Troubleshooting Guide",
      "Parts and Supplies Reference"
    ],
    "scrambled_order": [
      "Quarterly Maintenance Procedures",
      "Annual Maintenance Procedures",
      "Introduction and Safety Precautions",
      "Troubleshooting Guide",
      "Monthly Inspection Procedures",
      "System Overview and Specifications",
      "Parts and Supplies Reference",
      "Semi-Annual Maintenance Procedures"
    ],
    "subsections": [
      "Filter Inspection",
      "Refrigerant Level Check",
      "Coil Cleaning Procedure",
      "Belt and Bearing Inspection",
      "Electrical Component Testing"
    ],
    "content_keywords": [
      "MERV",
      "R-410A",
      "refrigerant",
      "compressor",
      "evaporator",
      "condenser",
      "thermostat",
      "ASHRAE",
      "lockout/tagout"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_maintenance_manual_restructure"
    }
  }
}
