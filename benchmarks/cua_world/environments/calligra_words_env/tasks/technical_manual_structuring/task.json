{
  "id": "technical_manual_structuring@1",
  "version": "1.0",
  "env_id": "calligra_words_env@0.1",
  "description": "You are a senior technical writer at Nexus Systems Corp. Transform the raw documentation for the NetWatch Pro v3.2 system in /home/ga/Documents/netwatch_manual.odt into a professional technical manual. The manual must include a title page, a table of contents, hierarchical heading styles, formatted tables for system requirements, configuration parameters, and error codes, and monospace formatting for command-line examples. Ensure a consistent page layout and save the document to /home/ga/Documents/netwatch_manual.odt.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/technical_manual_structuring/setup_task.sh",
    "post_task": "/workspace/tasks/technical_manual_structuring/export_result.sh"
  },
  "metadata": {
    "document_path": "/home/ga/Documents/netwatch_manual.odt",
    "expected_h1_sections": [
      "Introduction",
      "System Requirements",
      "Installation",
      "Configuration",
      "Command Reference",
      "Troubleshooting",
      "API Reference",
      "Appendix"
    ],
    "expected_h2_subsections": [
      "Hardware Requirements",
      "Software Requirements",
      "Linux Installation",
      "Windows Installation",
      "Global Configuration",
      "Alert Configuration",
      "Network Discovery Commands",
      "Monitoring Commands",
      "Common Error Codes",
      "Performance Tuning"
    ],
    "expected_tables_keywords": [
      "CPU",
      "RAM",
      "Disk",
      "nw.scan.interval",
      "nw.alert.threshold",
      "E001",
      "E002"
    ],
    "expected_monospace_commands": [
      "netwatch --discover",
      "netwatch --monitor",
      "nw-config --set",
      "nw-service restart"
    ],
    "body_alignment_samples": [
      "NetWatch Pro is an enterprise-grade network monitoring",
      "The discovery engine uses a combination of ICMP",
      "Configure alert thresholds to match your organization"
    ],
    "content_keywords": [
      "NetWatch Pro",
      "network monitoring",
      "SNMP",
      "ICMP",
      "bandwidth utilization",
      "latency threshold",
      "REST API",
      "JSON payload"
    ],
    "title_text": "NetWatch Pro v3.2",
    "subtitle_text": "Administrator Manual",
    "source": "Original technical documentation content"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_technical_manual_structuring"
    }
  }
}
