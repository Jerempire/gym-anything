{
  "id": "terminology_standardization@1",
  "version": "1.0",
  "env_id": "calligra_words_env@0.1",
  "description": "You are a Regulatory Affairs Manager preparing a Phase III Clinical Study Report for FDA submission. Standardize the terminology in the report located at /home/ga/Documents/clinical_study_report.odt by replacing all incorrect variants with the terms specified in the glossary at /home/ga/Desktop/terminology_glossary.txt, matching the exact capitalization. Apply 'Heading 1' style to all main section titles (e.g., Synopsis, Introduction) and 'Heading 2' style to all subsection titles (e.g., Primary Objective, Study Design). Save the changes to the original file. The document is already open in Calligra Words.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 480,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/terminology_standardization/setup_task.sh",
    "post_task": "/workspace/tasks/terminology_standardization/export_result.sh"
  },
  "metadata": {
    "document_path": "/home/ga/Documents/clinical_study_report.odt",
    "expected_h1_sections": [
      "Synopsis",
      "Introduction",
      "Study Objectives",
      "Investigational Plan",
      "Study Patients",
      "Efficacy Evaluation",
      "Safety Evaluation",
      "Discussion and Conclusions"
    ],
    "expected_h2_subsections": [
      "Primary Objective",
      "Secondary Objectives",
      "Study Design",
      "Study Population",
      "Treatments Administered",
      "Disposition of Patients",
      "Protocol Deviations",
      "Primary Efficacy Endpoint",
      "Secondary Efficacy Endpoints",
      "Adverse Events",
      "Clinical Laboratory Evaluations"
    ],
    "content_keywords": [
      "randomized, double-blind",
      "placebo-controlled",
      "intention-to-treat",
      "adverse events",
      "95% confidence interval",
      "statistically significant",
      "informed consent",
      "washout period"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_terminology_standardization"
    }
  }
}
