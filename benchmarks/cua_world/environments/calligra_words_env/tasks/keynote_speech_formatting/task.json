{
  "id": "keynote_speech_formatting@1",
  "version": "1.0",
  "env_id": "calligra_words_env@0.1",
  "description": "You are a Speechwriter preparing an executive keynote. Using the specification at /home/ga/Desktop/reading_script_spec.txt, format the draft speech at /home/ga/Documents/keynote_draft.odt into a 'reading script' (podium copy). Apply all required formatting, including 2.0-inch margins for eye-tracking, double spacing, 18pt font size, footer text, Bold and Italic styling for bracketed stage cues, and manual page breaks. Save the document when complete.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/keynote_speech_formatting/setup_task.sh",
    "post_task": "/workspace/tasks/keynote_speech_formatting/export_result.sh"
  },
  "metadata": {
    "document_path": "/home/ga/Documents/keynote_draft.odt",
    "spec_path": "/home/ga/Desktop/reading_script_spec.txt",
    "stage_cues": [
      "[Pause for applause]",
      "[Look at camera]",
      "[Gesture with right hand]",
      "[Look left]",
      "[Lean forward]",
      "[Point to stadium]",
      "[Wait for laughter]",
      "[Raise voice]",
      "[Slow down]",
      "[Final pause]"
    ],
    "section_markers": [
      "SECTION: The New Ocean",
      "SECTION: The Choice",
      "SECTION: The Future"
    ],
    "footer_text": "EMBARGOED DRAFT",
    "expected_margin_inches": 2.0,
    "expected_font_pt": 18.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_keynote_speech_formatting"
    }
  }
}
