{
  "id": "recipe_book_standardization@1",
  "version": "1.0",
  "env_id": "calligra_words_env@0.1",
  "description": "You are an Executive Chef standardizing a raw text recipe manual into the new corporate format. The raw document is located at /home/ga/Documents/recipe_manual_raw.odt. Following the style guide at /home/ga/Desktop/recipe_style_guide.txt, apply the required formatting for the main title, Table of Contents, headings, recipe metadata tables, ingredient/instruction lists, and allergen warnings. Save the updated document.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/recipe_book_standardization/setup_task.sh",
    "post_task": "/workspace/tasks/recipe_book_standardization/export_result.sh"
  },
  "metadata": {
    "document_path": "/home/ga/Documents/recipe_manual_raw.odt",
    "style_guide_path": "/home/ga/Desktop/recipe_style_guide.txt",
    "main_title": "LUMIÈRE BISTRO: STANDARDIZED RECIPE MANUAL",
    "recipe_titles": [
      "Bouillabaisse",
      "Duck Confit",
      "Beef Bourguignon",
      "Ratatouille"
    ],
    "section_titles": [
      "Ingredients",
      "Instructions",
      "Allergens"
    ],
    "allergen_phrases": [
      "Allergens: Fish, Shellfish, Allium",
      "Allergens: Allium",
      "Allergens: Allium, Sulfites",
      "Allergens: Allium, Nightshades"
    ],
    "content_keywords": [
      "Bouillabaisse",
      "Duck Confit",
      "Beef Bourguignon",
      "Ratatouille",
      "Yield",
      "Prep Time",
      "Cook Time",
      "mussels",
      "duck fat",
      "Burgundy wine",
      "eggplants",
      "Allergens"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_recipe_book_standardization"
    }
  }
}
