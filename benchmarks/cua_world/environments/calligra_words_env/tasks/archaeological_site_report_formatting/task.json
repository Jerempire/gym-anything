{
  "id": "archaeological_site_report_formatting@1",
  "version": "1.0",
  "env_id": "calligra_words_env@0.1",
  "description": "You are a field archaeologist finalizing a site report draft for submission. Format the document /home/ga/Documents/site_report_draft.odt (already open in Calligra Words) according to the specifications in /home/ga/Desktop/formatting_requirements.txt. Requirements include applying heading hierarchies, inserting images from ~/Desktop/Field_Photos/, creating and populating a radiocarbon results table, and italicizing all biological taxa names. Save the final version to /home/ga/Documents/site_report_draft.odt.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 480,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/archaeological_site_report_formatting/setup_task.sh",
    "post_task": "/workspace/tasks/archaeological_site_report_formatting/export_result.sh"
  },
  "metadata": {
    "document_path": "/home/ga/Documents/site_report_draft.odt",
    "expected_h1_sections": [
      "Introduction",
      "Stratigraphic Context",
      "Artifact Assemblage",
      "Chronometric Dating",
      "Conclusions"
    ],
    "expected_h2_subsections": [
      "Lithics",
      "Ceramics",
      "Faunal Remains",
      "Archaeobotanical Remains"
    ],
    "expected_taxa": [
      "Zea mays",
      "Phaseolus vulgaris",
      "Odocoileus hemionus",
      "Meleagris gallopavo"
    ],
    "table_data_keywords": [
      "beta-12345",
      "beta-12346",
      "beta-12347",
      "1250",
      "1310",
      "1280"
    ],
    "content_keywords": [
      "ancestral puebloan",
      "excavations",
      "stratigraphy",
      "chert",
      "corrugated"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_archaeological_site_report"
    }
  }
}
