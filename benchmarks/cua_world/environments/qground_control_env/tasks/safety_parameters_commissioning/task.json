{
  "id": "safety_parameters_commissioning@1",
  "version": "1.0",
  "env_id": "qground_control_env@0.1",
  "name": "Pre-Deployment Safety Parameters Commissioning",
  "description": "You are a Drone Safety Officer performing a pre-deployment safety audit on an ArduCopter vehicle. Configure the vehicle's safety parameters (FS_BATT_ENABLE, RTL_ALT, FENCE_ENABLE, FENCE_ALT_MAX, FS_GCS_ENABLE, and LAND_SPEED_HIGH) using the values specified in the commissioning checklist at /home/ga/Documents/QGC/safety_checklist.txt.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "dense"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/safety_parameters_commissioning/setup_task.sh",
    "post_task": "/workspace/tasks/safety_parameters_commissioning/export_result.sh"
  },
  "metadata": {
    "checklist": "/home/ga/Documents/QGC/safety_checklist.txt",
    "result_file": "/tmp/task_result.json",
    "required_params": {
      "FS_BATT_ENABLE": 2,
      "RTL_ALT": 2500,
      "FENCE_ENABLE": 1,
      "FENCE_ALT_MAX": 8000,
      "FS_GCS_ENABLE": 1,
      "LAND_SPEED_HIGH": 150
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_safety_parameters_commissioning"
    }
  },
  "tags": [
    "parameters",
    "safety",
    "commissioning",
    "ardupilot",
    "hard"
  ]
}
