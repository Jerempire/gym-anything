{
  "id": "hexacopter_motor_reconfig@1",
  "version": "1.0",
  "env_id": "qground_control_env@0.1",
  "name": "Frame and Motor Reconfiguration for Heavy-Lift Hexacopter",
  "description": "You are an Agricultural Technician. A new heavy-lift hexacopter frame has arrived to replace an old quadcopter for multispectral crop sensing. Reconfigure the flight controller parameters in QGroundControl to match the 8 motor, frame, and battery specifications found in /home/ga/Documents/QGC/hexframe_spec.txt.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "dense"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/hexacopter_motor_reconfig/setup_task.sh",
    "post_task": "/workspace/tasks/hexacopter_motor_reconfig/export_result.sh"
  },
  "metadata": {
    "spec_path": "/home/ga/Documents/QGC/hexframe_spec.txt",
    "result_file": "/tmp/task_result.json",
    "target_parameters": {
      "FRAME_CLASS": 2,
      "MOT_SPIN_ARM": 0.08,
      "MOT_SPIN_MIN": 0.12,
      "MOT_BAT_VOLT_MAX": 25.2,
      "MOT_BAT_VOLT_MIN": 19.8,
      "MOT_THST_EXPO": 0.55,
      "MOT_THST_HOVER": 0.42,
      "BATT_CAPACITY": 16000
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_hexacopter_motor_reconfig"
    }
  },
  "tags": [
    "parameters",
    "hardware",
    "motors",
    "agriculture",
    "medium"
  ]
}
