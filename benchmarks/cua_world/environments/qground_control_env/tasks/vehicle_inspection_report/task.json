{
  "id": "vehicle_inspection_report@1",
  "version": "1.0",
  "env_id": "qground_control_env@0.1",
  "name": "Fleet Vehicle Inspection and Flight Mode Configuration",
  "description": "You are a UAV Fleet Manager commissioning vehicle AC-SITL-007. Complete the commissioning inspection as specified in the template on the workstation. Configure the vehicle's flight modes and controller tuning parameters to fleet standards, verify live telemetry, and document all findings in an airworthiness report. Save the report to /home/ga/Documents/QGC/inspection_report.txt.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 800,
    "max_steps": 80,
    "reward_type": "dense"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/vehicle_inspection_report/setup_task.sh",
    "post_task": "/workspace/tasks/vehicle_inspection_report/export_result.sh"
  },
  "metadata": {
    "report_path": "/home/ga/Documents/QGC/inspection_report.txt",
    "result_file": "/tmp/task_result.json",
    "inspection_template": "/home/ga/Documents/QGC/inspection_template.txt",
    "required_flight_modes": {
      "FLTMODE1": 2,
      "FLTMODE2": 5,
      "FLTMODE3": 3,
      "FLTMODE4": 6,
      "FLTMODE5": 9,
      "FLTMODE6": 16
    },
    "atc_gain_target": 4.0,
    "atc_gain_tolerance": 0.2,
    "mode_names": {
      "2": "AltHold",
      "3": "Auto",
      "5": "Loiter",
      "6": "RTL",
      "9": "Land",
      "16": "PosHold"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_vehicle_inspection_report"
    }
  },
  "tags": [
    "flight-modes",
    "inspection",
    "mavlink",
    "report",
    "very_hard"
  ]
}
