{
  "id": "wildlife_silent_flight_tuning@1",
  "version": "1.0",
  "env_id": "qground_control_env@0.1",
  "name": "Wildlife Surveillance Silent Flight Tuning",
  "description": "You are a UAV operator supporting a Wildlife Biologist team conducting a population count near a protected eagle nesting site. To comply with the USFW permit, you must tune the ArduCopter to operate in a 'stealth/silent' acoustic mitigation mode to prevent sudden motor revving. Read the operations memorandum located at /home/ga/Documents/QGC/silent_flight_memo.txt and configure the 6 ArduPilot parameters to the exact values specified in the document.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "dense"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/wildlife_silent_flight_tuning/setup_task.sh",
    "post_task": "/workspace/tasks/wildlife_silent_flight_tuning/export_result.sh"
  },
  "metadata": {
    "memo_path": "/home/ga/Documents/QGC/silent_flight_memo.txt",
    "result_file": "/tmp/task_result.json",
    "required_params": {
      "MOT_SPIN_MAX": {
        "value": 0.8,
        "tolerance": 0.02,
        "points": 16
      },
      "ATC_ACCEL_P_MAX": {
        "value": 40000,
        "tolerance": 500,
        "points": 17
      },
      "ATC_ACCEL_R_MAX": {
        "value": 40000,
        "tolerance": 500,
        "points": 17
      },
      "ATC_ACCEL_Y_MAX": {
        "value": 15000,
        "tolerance": 500,
        "points": 17
      },
      "WPNAV_ACCEL": {
        "value": 100,
        "tolerance": 10,
        "points": 16
      },
      "ANGLE_MAX": {
        "value": 2500,
        "tolerance": 50,
        "points": 17
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_wildlife_silent_flight_tuning"
    }
  },
  "tags": [
    "parameters",
    "tuning",
    "wildlife",
    "acoustic-mitigation",
    "hard"
  ]
}
