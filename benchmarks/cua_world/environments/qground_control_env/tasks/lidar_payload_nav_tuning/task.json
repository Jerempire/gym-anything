{
  "id": "lidar_payload_nav_tuning@1",
  "version": "1.0",
  "env_id": "qground_control_env@0.1",
  "name": "LiDAR Payload Navigation Tuning",
  "description": "You are a Remote Sensing Scientist preparing a hexacopter for a LiDAR topographic survey. A heavy Velodyne Puck LiDAR (1.8 kg) has just been mounted, requiring all waypoint navigation parameters to be retuned for smooth, artifact-free flight dynamics. Configure the 7 ArduPilot navigation parameters in the WPNAV, LOIT, and RTL families using the values specified in /home/ga/Documents/QGC/lidar_payload_spec.txt. All values in the specification differ from the factory defaults and must be updated. No file output is required; the parameters are set live on the connected vehicle. Do not reboot the vehicle.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "dense"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/lidar_payload_nav_tuning/setup_task.sh",
    "post_task": "/workspace/tasks/lidar_payload_nav_tuning/export_result.sh"
  },
  "metadata": {
    "spec_path": "/home/ga/Documents/QGC/lidar_payload_spec.txt",
    "result_file": "/tmp/task_result.json",
    "required_params": {
      "WPNAV_SPEED": {
        "target": 800.0,
        "tol": 15.0,
        "default": 500.0,
        "points": 15
      },
      "WPNAV_SPEED_UP": {
        "target": 150.0,
        "tol": 15.0,
        "default": 250.0,
        "points": 15
      },
      "WPNAV_SPEED_DN": {
        "target": 100.0,
        "tol": 15.0,
        "default": 150.0,
        "points": 15
      },
      "WPNAV_ACCEL": {
        "target": 200.0,
        "tol": 15.0,
        "default": 100.0,
        "points": 14
      },
      "WPNAV_RADIUS": {
        "target": 300.0,
        "tol": 25.0,
        "default": 200.0,
        "points": 14
      },
      "LOIT_SPEED": {
        "target": 800.0,
        "tol": 15.0,
        "default": 1250.0,
        "points": 14
      },
      "RTL_SPEED": {
        "target": 500.0,
        "tol": 15.0,
        "default": 0.0,
        "points": 13
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_lidar_payload_nav_tuning"
    }
  },
  "tags": [
    "parameters",
    "navigation",
    "remote-sensing",
    "payload-integration",
    "medium"
  ]
}
