{
  "id": "autotune_heavylift_prep@1",
  "version": "1.0",
  "env_id": "qground_control_env@0.1",
  "name": "Heavy-Lift AutoTune Flight Preparation",
  "description": "You are a Flight Test Engineer configuring a custom 1200mm heavy-lift octocopter for its maiden AutoTune flight. Using the tuning specification document at /home/ga/Documents/QGC/autotune_spec.txt, identify and set the 6 required ArduPilot parameters in QGroundControl to prevent destructive oscillations during flight.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "dense"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/autotune_heavylift_prep/setup_task.sh",
    "post_task": "/workspace/tasks/autotune_heavylift_prep/export_result.sh"
  },
  "metadata": {
    "spec_doc": "/home/ga/Documents/QGC/autotune_spec.txt",
    "result_file": "/tmp/task_result.json",
    "required_params": {
      "AUTOTUNE_AGGR": {
        "value": 0.05,
        "pts": 20,
        "tolerance": 0.005
      },
      "AUTOTUNE_AXES": {
        "value": 3.0,
        "pts": 15,
        "tolerance": 0.4
      },
      "RC7_OPTION": {
        "value": 17.0,
        "pts": 15,
        "tolerance": 0.4
      },
      "ATC_RAT_RLL_FLTT": {
        "value": 10.0,
        "pts": 15,
        "tolerance": 0.5
      },
      "ATC_RAT_PIT_FLTT": {
        "value": 10.0,
        "pts": 15,
        "tolerance": 0.5
      },
      "INS_GYRO_FILTER": {
        "value": 20.0,
        "pts": 20,
        "tolerance": 0.5
      }
    },
    "pass_threshold": 70
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_autotune_heavylift_prep"
    }
  },
  "tags": [
    "parameters",
    "tuning",
    "ardupilot",
    "safety",
    "hard"
  ]
}
