{
  "id": "radial_array_modifier_setup@1",
  "version": "1.0",
  "env_id": "blender3d_env@0.1",
  "description": "Create a 6-blade radial fan assembly using the Array modifier with Object Offset. The assembly should form a radially symmetric propeller shape elevated above the ground (Z > 2m). Save the project to /home/ga/BlenderProjects/fan_assembly.blend.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/radial_array_modifier_setup/setup_task.sh",
    "post_task": "/workspace/tasks/radial_array_modifier_setup/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/BlenderProjects/fan_assembly.blend",
    "expected_array_count": 6,
    "expected_rotation_degrees": 60,
    "rotation_tolerance": 5.0,
    "blade_aspect_ratio_min": 2.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_radial_array"
    }
  }
}
