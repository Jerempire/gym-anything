{
  "id": "chroma_key_compositing@1",
  "version": "1.0",
  "env_id": "blender3d_env@0.1",
  "description": "Perform a green screen removal (chroma keying) on the raw footage plate located at /home/ga/assets/greenscreen_plate.jpg. Export the result as a PNG with transparency to /home/ga/BlenderProjects/keyed_subject.png and save the Blender project to /home/ga/BlenderProjects/chroma_key.blend.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/chroma_key_compositing/setup_task.sh",
    "post_task": "/workspace/tasks/chroma_key_compositing/export_result.sh"
  },
  "metadata": {
    "input_image": "/home/ga/assets/greenscreen_plate.jpg",
    "expected_blend": "/home/ga/BlenderProjects/chroma_key.blend",
    "expected_render": "/home/ga/BlenderProjects/keyed_subject.png",
    "subject_region": [
      960,
      540
    ],
    "background_region": [
      100,
      100
    ],
    "min_alpha_subject": 200,
    "max_alpha_background": 20
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_chroma_key_compositing"
    }
  }
}
