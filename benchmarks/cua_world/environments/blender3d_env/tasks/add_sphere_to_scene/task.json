{
  "id": "add_sphere_to_scene@1",
  "version": "1.0",
  "env_id": "blender3d_env@0.1",
  "description": "Add a UV sphere with a radius of 1 unit at coordinates (0, -3, 2) to the scene. Save the Blender file to /home/ga/BlenderProjects/scene_with_sphere.blend.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_sphere_to_scene/setup_task.sh",
    "post_task": "/workspace/tasks/add_sphere_to_scene/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/BlenderProjects/scene_with_sphere.blend",
    "expected_sphere_name_pattern": "Sphere",
    "expected_location": [
      0,
      -3,
      2
    ],
    "location_tolerance": 1.0,
    "source_blend": "/home/ga/BlenderProjects/sample_scene.blend"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_sphere"
    }
  }
}
