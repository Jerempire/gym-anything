{
  "id": "mesh_cleanup_repair@1",
  "version": "1.0",
  "env_id": "blender3d_env@0.1",
  "description": "A 3D asset (BMW car body) has been imported with severe topology errors. Clean up the mesh 'BMW_Body_Corrupted' by removing duplicate vertices, loose vertices, and degenerate faces, and correcting inconsistent normals. Save the repaired file to /home/ga/BlenderProjects/bmw_cleaned.blend. Blender is open with the corrupted file loaded.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/mesh_cleanup_repair/setup_task.sh",
    "post_task": "/workspace/tasks/mesh_cleanup_repair/export_result.sh"
  },
  "metadata": {
    "source_file": "/home/ga/BlenderDemos/BMW27.blend",
    "corrupted_file": "/home/ga/BlenderProjects/bmw_corrupted.blend",
    "expected_output": "/home/ga/BlenderProjects/bmw_cleaned.blend",
    "thresholds": {
      "max_duplicates": 5,
      "max_loose": 0,
      "max_degenerate": 2,
      "max_inconsistent_normals_percent": 2.0
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_mesh_cleanup"
    }
  }
}
