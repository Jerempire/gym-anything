{
  "id": "blender3d_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Blender 3D environment for 3D modeling, animation, rendering, compositing, and video editing tasks with virtio GPU support",
  "category": "3d_graphics",
  "tags": [
    "linux",
    "3d",
    "modeling",
    "animation",
    "rendering",
    "blender",
    "desktop",
    "gpu",
    "creative"
  ],
  "licence": "GPL-3.0",
  "authors": [
    "gym-anything team"
  ],
  "upstream_url": "https://www.blender.org",
  "resources": {
    "cpu": 8,
    "mem_gb": 16,
    "gpu": 1,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [
        1920,
        1080
      ],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": true,
  "step_cycle_ms": 300,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/blender3d_env/artifacts",
    "video_fps": 10,
    "video_resolution": [
      1920,
      1080
    ],
    "video_codec": "libx264",
    "video_crf": 23,
    "audio_rate": 44100,
    "audio_channels": 2,
    "audio_codec": "aac"
  },
  "vnc": {
    "enable": false,
    "host_port": 5961,
    "container_port": 5900,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": [
      "ALL"
    ],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true,
    "runtime": "sysbox-runc",
    "devices": [
      "/dev/dri"
    ]
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/blender3d_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/blender3d_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/blender3d_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/blender3d_env/utils",
      "target": "/workspace/utils",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/blender3d_env/assets",
      "target": "/workspace/assets",
      "mode": "rw"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_blender.sh",
    "post_start": "/workspace/scripts/setup_blender.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": [
          "sudo",
          "audio",
          "video",
          "input",
          "render"
        ],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "BLENDER_USER_CONFIG": "/home/ga/.config/blender",
          "BLENDER_USER_SCRIPTS": "/home/ga/.config/blender/scripts"
        }
      }
    }
  ]
}
