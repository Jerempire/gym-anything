{
  "id": "extract_bolivia_raster@1",
  "version": "1.0",
  "env_id": "gvsig_desktop_env@0.1",
  "description": "Clip the global Natural Earth physical raster (~/gvsig_data/raster/NE1_HR_LC_SR_W_DR.tif) to the boundary of Bolivia using the countries vector layer (~/gvsig_data/countries/ne_110m_admin_0_countries.shp). Export the resulting clipped raster to ~/gvsig_data/exports/bolivia_relief.tif.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/extract_bolivia_raster/setup_task.sh",
    "post_task": "/workspace/tasks/extract_bolivia_raster/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "input_raster": "/home/ga/gvsig_data/raster/NE1_HR_LC_SR_W_DR.tif",
    "input_vector": "/home/ga/gvsig_data/countries/ne_110m_admin_0_countries.shp",
    "expected_output_path": "/home/ga/gvsig_data/exports/bolivia_relief.tif",
    "min_dimension": 200,
    "max_dimension": 1000,
    "min_std_dev": 500
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_extract_bolivia_raster"
    }
  }
}
