{
  "id": "filter_and_export_features@1",
  "version": "1.0",
  "env_id": "gvsig_desktop_env@0.1",
  "description": "You are working with the Natural Earth 110m countries layer in gvSIG Desktop. Select all countries where the `POP_EST` field is greater than 100,000,000 and export only these selected features to a new shapefile at /home/ga/gvsig_data/exports/populous_countries.shp.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/filter_and_export_features/setup_task.sh",
    "post_task": "/workspace/tasks/filter_and_export_features/export_result.sh"
  },
  "metadata": {
    "output_path": "/home/ga/gvsig_data/exports/populous_countries.shp",
    "min_expected_count": 10,
    "max_expected_count": 18,
    "target_pop_threshold": 100000000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_filter_and_export_features"
    }
  }
}
