{
  "id": "change_layer_symbology@1",
  "version": "1.0",
  "env_id": "gvsig_desktop_env@0.1",
  "description": "gvSIG is already open with a View that contains the Natural Earth countries layer (ne_110m_admin_0_countries). Change the fill color of the 'ne_110m_admin_0_countries' layer to bright red (RGB: 255, 0, 0).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 35,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/change_layer_symbology/setup_task.sh"
  },
  "metadata": {
    "layer_name": "ne_110m_admin_0_countries",
    "target_fill_color": "#FF0000",
    "target_fill_r": 255,
    "target_fill_g": 0,
    "target_fill_b": 0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_change_layer_symbology"
    }
  }
}
