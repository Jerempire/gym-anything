{
  "id": "generate_vector_grid_overlay@1",
  "version": "1.0",
  "env_id": "gvsig_desktop_env@0.1",
  "description": "Generate a vector grid overlay for spatial analysis of the Australian continent with the 'countries_base' project loaded. Create a 5-degree polygon grid covering the extent of Australia (approximately 112°E to 155°E, 45°S to 10°S) and export the resulting shapefile to /home/ga/gvsig_data/exports/australia_grid.shp.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_vector_grid_overlay/setup_task.sh",
    "post_task": "/workspace/tasks/generate_vector_grid_overlay/export_result.sh"
  },
  "metadata": {
    "output_path": "/home/ga/gvsig_data/exports/australia_grid.shp",
    "zip_path": "/tmp/australia_grid.zip",
    "expected_cell_size": 5.0,
    "target_region_bbox": [
      110,
      -45,
      155,
      -10
    ],
    "min_feature_count": 30,
    "max_feature_count": 100
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_vector_grid_overlay"
    }
  }
}
