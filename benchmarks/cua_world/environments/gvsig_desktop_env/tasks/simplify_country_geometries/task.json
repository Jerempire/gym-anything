{
  "id": "simplify_country_geometries@1",
  "version": "1.0",
  "env_id": "gvsig_desktop_env@0.1",
  "description": "Simplify the geometries of the 'ne_110m_admin_0_countries' layer in gvSIG Desktop to reduce file size and complexity. Use the Douglas-Peucker method with a tolerance of 0.5 degrees. Save the resulting simplified shapefile to /home/ga/gvsig_data/exports/countries_simplified.shp.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/simplify_country_geometries/setup_task.sh",
    "post_task": "/workspace/tasks/simplify_country_geometries/export_result.sh"
  },
  "metadata": {
    "input_layer_path": "/home/ga/gvsig_data/countries/ne_110m_admin_0_countries.shp",
    "output_layer_path": "/home/ga/gvsig_data/exports/countries_simplified.shp",
    "tolerance": 0.5,
    "expected_reduction_min_percent": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_simplify_country_geometries"
    }
  }
}
