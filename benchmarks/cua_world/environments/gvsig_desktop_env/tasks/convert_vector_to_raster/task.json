{
  "id": "convert_vector_to_raster@1",
  "version": "1.0",
  "env_id": "gvsig_desktop_env@0.1",
  "description": "Convert the 'ne_110m_admin_0_countries' vector layer into a raster grid (GeoTIFF) where pixel values correspond to the 'MAPCOLOR7' attribute. Set the cell size to 1.0 and the extent to fit the input layer. Export the resulting raster to /home/ga/gvsig_data/exports/country_grid.tif.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 480,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/convert_vector_to_raster/setup_task.sh",
    "post_task": "/workspace/tasks/convert_vector_to_raster/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/gvsig_data/exports/country_grid.tif",
    "expected_width_approx": 360,
    "expected_height_approx": 180,
    "expected_values_min": 1,
    "expected_values_max": 7,
    "target_resolution": 1.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_convert_vector_to_raster"
    }
  }
}
