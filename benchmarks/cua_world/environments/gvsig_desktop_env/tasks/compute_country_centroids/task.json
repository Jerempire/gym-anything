{
  "id": "compute_country_centroids@1",
  "version": "1.0",
  "env_id": "gvsig_desktop_env@0.1",
  "description": "Compute the geometric centroids of all countries in the Natural Earth dataset using gvSIG's geoprocessing tools. Using the loaded 'ne_110m_admin_0_countries' layer, generate a point layer representing the centers of mass for each country and save the result to /home/ga/gvsig_data/exports/country_centroids.shp.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/compute_country_centroids/setup_task.sh",
    "post_task": "/workspace/tasks/compute_country_centroids/export_result.sh"
  },
  "metadata": {
    "input_layer": "ne_110m_admin_0_countries",
    "output_path": "/home/ga/gvsig_data/exports/country_centroids.shp",
    "expected_feature_count_min": 150,
    "expected_feature_count_max": 200,
    "expected_shape_types": [
      1,
      11,
      21
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_compute_country_centroids"
    }
  }
}
