{
  "id": "extract_kenya_utm_projection@1",
  "version": "1.0",
  "env_id": "gvsig_desktop_env@0.1",
  "description": "Select the country of Kenya from the 'ne_110m_admin_0_countries' layer in gvSIG Desktop. Export the selected feature to a new shapefile at /home/ga/gvsig_data/exports/kenya_utm.shp, ensuring the output is projected in WGS 84 / UTM zone 37S (EPSG:32737).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/extract_kenya_utm_projection/setup_task.sh",
    "post_task": "/workspace/tasks/extract_kenya_utm_projection/export_result.sh"
  },
  "metadata": {
    "target_country": "Kenya",
    "expected_output_path": "/home/ga/gvsig_data/exports/kenya_utm.shp",
    "target_epsg": "32737",
    "target_crs_name": "WGS 84 / UTM zone 37S"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_extract_kenya_utm"
    }
  }
}
