{
  "id": "generate_country_bounding_boxes@1",
  "version": "1.0",
  "env_id": "gvsig_desktop_env@0.1",
  "description": "Generate a bounding box (envelope) layer for all countries in the provided ne_110m_admin_0_countries dataset. Create a new shapefile containing the rectangular extents of these countries and export the result to /home/ga/gvsig_data/exports/country_bboxes.shp.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_country_bounding_boxes/setup_task.sh",
    "post_task": "/workspace/tasks/generate_country_bounding_boxes/export_result.sh"
  },
  "metadata": {
    "expected_output_path": "/home/ga/gvsig_data/exports/country_bboxes.shp",
    "expected_dbf_path": "/home/ga/gvsig_data/exports/country_bboxes.dbf",
    "expected_feature_count": 177,
    "max_file_size_bytes": 500000,
    "min_file_size_bytes": 1000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bounding_boxes"
    }
  }
}
