{
  "id": "generate_topographic_contours@1",
  "version": "1.0",
  "env_id": "gvsig_desktop_env@0.1",
  "description": "Generate topographic contour lines with a 5-meter interval from the Digital Elevation Model (DEM) located at /home/ga/gvsig_data/raster/Helsinki_DEM.tif. Save the resulting vector layer as a shapefile to /home/ga/gvsig_data/exports/helsinki_contours.shp.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/generate_topographic_contours/setup_task.sh",
    "post_task": "/workspace/tasks/generate_topographic_contours/export_result.sh"
  },
  "metadata": {
    "input_raster": "/home/ga/gvsig_data/raster/Helsinki_DEM.tif",
    "expected_output_path": "/home/ga/gvsig_data/exports/helsinki_contours.shp",
    "expected_interval": 5,
    "min_feature_count": 50,
    "max_feature_count": 2000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_topographic_contours"
    }
  }
}
