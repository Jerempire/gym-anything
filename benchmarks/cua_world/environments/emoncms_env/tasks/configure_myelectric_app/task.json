{
  "id": "configure_myelectric_app@1",
  "version": "1.0",
  "env_id": "emoncms_env@0.1",
  "description": "Configure the 'My Electric' app in Emoncms for a home energy setup. Use 'house_power' (W) for the power feed, 'house_energy_kwh' (kWh) for the energy feed, and set the unit cost to 0.245 per kWh. Save the configuration to enable the power dial and energy history display.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_myelectric_app/setup_task.sh",
    "post_task": "/workspace/tasks/configure_myelectric_app/export_result.sh"
  },
  "metadata": {
    "expected_app": "myelectric",
    "expected_feed_power_name": "house_power",
    "expected_feed_energy_name": "house_energy_kwh",
    "expected_unit_cost": 0.245,
    "tolerance_cost": 0.001
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_myelectric_app"
    }
  }
}
