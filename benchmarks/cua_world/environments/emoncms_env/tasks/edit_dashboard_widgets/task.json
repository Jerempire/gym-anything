{
  "id": "edit_dashboard_widgets@1",
  "version": "1.0",
  "env_id": "emoncms_env@0.1",
  "description": "The dashboard 'Server Room Overview' is currently displaying data from decommissioned UPS sensors. Reconfigure the widgets to show the correct Server Room feeds: set the Power Dial to 'server_power' (max 5000, label 'Server Power (W)'), the Temperature Dial to 'server_temp' (min 10, max 45, label 'Temperature (°C)'), and the Humidity Value display to 'server_humidity' (label 'Humidity (%RH)'). Save the updated dashboard.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/edit_dashboard_widgets/setup_task.sh",
    "post_task": "/workspace/tasks/edit_dashboard_widgets/export_result.sh"
  },
  "metadata": {
    "dashboard_name": "Server Room Overview",
    "target_feeds": {
      "power": "server_power",
      "temp": "server_temp",
      "humidity": "server_humidity"
    },
    "widget_requirements": [
      {
        "type": "dial",
        "feed_tag": "server_room",
        "feed_name": "server_power",
        "label_contains": [
          "Server Power",
          "(W)"
        ],
        "max": 5000
      },
      {
        "type": "dial",
        "feed_tag": "server_room",
        "feed_name": "server_temp",
        "label_contains": [
          "Temperature",
          "°C"
        ],
        "min": 10,
        "max": 45
      },
      {
        "type": "value",
        "feed_tag": "server_room",
        "feed_name": "server_humidity",
        "label_contains": [
          "Humidity",
          "%RH"
        ]
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_edit_dashboard_widgets"
    }
  }
}
