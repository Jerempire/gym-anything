{
  "id": "create_dashboard_navigation@1",
  "version": "1.0",
  "env_id": "emoncms_env@0.1",
  "description": "The facility manager needs a central landing page to navigate between different energy systems. Update the 'Facility Overview' dashboard to include navigation links to the 'HVAC Detail', 'Lighting Detail', and 'Solar Detail' dashboards.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_dashboard_navigation/setup_task.sh",
    "post_task": "/workspace/tasks/create_dashboard_navigation/export_result.sh"
  },
  "metadata": {
    "landing_dashboard_name": "Facility Overview",
    "target_dashboards": [
      "HVAC Detail",
      "Lighting Detail",
      "Solar Detail"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_dashboard_navigation"
    }
  }
}
