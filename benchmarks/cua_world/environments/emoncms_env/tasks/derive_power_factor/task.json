{
  "id": "derive_power_factor@1",
  "version": "1.0",
  "env_id": "emoncms_env@0.1",
  "description": "Configure an input processing chain in Emoncms to calculate Power Factor (PF) from the raw sensor inputs 'motor_power_W', 'motor_voltage_V', and 'motor_current_A' using the formula PF = W / (V * I). Log the calculated result to a new feed named 'motor_PF'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/derive_power_factor/setup_task.sh",
    "post_task": "/workspace/tasks/derive_power_factor/export_result.sh"
  },
  "metadata": {
    "node_name": "Compressor",
    "input_power": "motor_power_W",
    "input_voltage": "motor_voltage_V",
    "input_current": "motor_current_A",
    "target_feed": "motor_PF",
    "expected_pf_range": [
      0.75,
      0.95
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_derive_power_factor"
    }
  }
}
