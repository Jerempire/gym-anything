{
  "id": "business_capability_heatmap@1",
  "version": "1.0",
  "env_id": "diagrams_net_env@0.1",
  "description": "As an Enterprise Architect, create a Business Capability Heatmap in diagrams.net using the data from '~/Desktop/retail_capabilities.csv'. The visualization must represent the Domain-to-Capability hierarchy with Capabilities nested within their respective Domains. Color-code the Capability shapes based on their Status: Healthy (#d5e8d4), At Risk (#fff2cc), and Critical (#f8cecc). Ensure all text labels match the CSV exactly. Save the diagram to '~/Diagrams/capability_map.drawio' and export it as a PDF to '~/Diagrams/capability_map.pdf'.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/business_capability_heatmap/setup_task.sh",
    "post_task": "/workspace/tasks/business_capability_heatmap/export_result.sh"
  },
  "metadata": {
    "csv_path": "/home/ga/Desktop/retail_capabilities.csv",
    "output_path": "/home/ga/Diagrams/capability_map.drawio",
    "export_path": "/home/ga/Diagrams/capability_map.pdf",
    "domains": [
      "Supply Chain",
      "Sales & Marketing",
      "HR & Support",
      "Finance"
    ],
    "capabilities": {
      "Procurement": {
        "domain": "Supply Chain",
        "status": "Healthy"
      },
      "Inventory Management": {
        "domain": "Supply Chain",
        "status": "Critical"
      },
      "Logistics & Fulfillment": {
        "domain": "Supply Chain",
        "status": "At Risk"
      },
      "Campaign Management": {
        "domain": "Sales & Marketing",
        "status": "Healthy"
      },
      "Customer 360": {
        "domain": "Sales & Marketing",
        "status": "Critical"
      },
      "E-Commerce Storefront": {
        "domain": "Sales & Marketing",
        "status": "Healthy"
      },
      "Talent Acquisition": {
        "domain": "HR & Support",
        "status": "At Risk"
      },
      "Payroll & Benefits": {
        "domain": "HR & Support",
        "status": "Healthy"
      },
      "Financial Planning": {
        "domain": "Finance",
        "status": "At Risk"
      },
      "General Ledger": {
        "domain": "Finance",
        "status": "Healthy"
      }
    },
    "colors": {
      "Healthy": [
        "#d5e8d4",
        "#82b366",
        "green"
      ],
      "At Risk": [
        "#fff2cc",
        "#d6b656",
        "yellow",
        "orange"
      ],
      "Critical": [
        "#f8cecc",
        "#b85450",
        "red"
      ]
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_business_capability_heatmap"
    }
  }
}
