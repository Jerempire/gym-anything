{
  "id": "bsc_hospital_digital_strategy@1",
  "version": "1.0",
  "env_id": "diagrams_net_env@0.1",
  "description": "Create a Balanced Scorecard (BSC) strategy map for a hospital's digital transformation using the template at '~/Diagrams/hospital_strategy_map.drawio' and the strategic plan at '~/Desktop/strategic_plan.txt'. Add the 16 strategic objectives to the correct perspective lanes (Financial, Customer, Internal Processes, Learning & Growth) using rounded rectangles labeled exactly as listed in the plan. Include the 17 cause-and-effect arrows specified and color-code the shapes by perspective (Gold, Blue, Green, Orange). Export the final diagram as a PDF to '~/Diagrams/hospital_strategy_map.pdf'.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/bsc_hospital_digital_strategy/setup_task.sh",
    "post_task": "/workspace/tasks/bsc_hospital_digital_strategy/export_result.sh"
  },
  "metadata": {
    "diagram_path": "/home/ga/Diagrams/hospital_strategy_map.drawio",
    "pdf_path": "/home/ga/Diagrams/hospital_strategy_map.pdf",
    "expected_objectives": [
      "Increase Operating Margin",
      "Grow Revenue from Digital Services",
      "Reduce Cost per Patient Encounter",
      "Improve Patient Satisfaction",
      "Reduce Patient Wait Times",
      "Expand Telehealth Access",
      "Enhance Patient Portal Adoption",
      "Integrate Electronic Health Records",
      "Automate Clinical Workflows",
      "Strengthen Cybersecurity Posture",
      "Optimize Supply Chain Management",
      "Reduce Hospital-Acquired Infections",
      "Develop Digital Literacy Training",
      "Recruit Health Informatics Talent",
      "Foster Innovation Culture",
      "Upgrade IT Infrastructure"
    ],
    "expected_colors": {
      "Financial": "#FFD700",
      "Customer": "#4DA6FF",
      "Internal Processes": "#66CC66",
      "Learning": "#FF9966"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_bsc_strategy_map"
    }
  }
}
