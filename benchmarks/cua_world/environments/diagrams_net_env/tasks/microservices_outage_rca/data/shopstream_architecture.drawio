        <!-- Critical sync dependency: Order Processing -> Payment Service -->
        <mxCell id="e5" value="HTTP/REST" style="endArrow=classic;html=1;strokeColor=#6c8ebf;fontSize=9;fontColor=#6c8ebf;strokeWidth=2;" edge="1" source="order-processing" target="payment-service" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Shopping Cart -> Order Processing (sync) -->
        <mxCell id="e6" value="HTTP/REST" style="endArrow=classic;html=1;strokeColor=#6c8ebf;fontSize=9;fontColor=#6c8ebf;" edge="1" source="shopping-cart" target="order-processing" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DB connections -->
        <mxCell id="e7" value="PostgreSQL" style="endArrow=classic;html=1;strokeColor=#666666;fontSize=9;fontColor=#666666;" edge="1" source="order-processing" target="orders-db" parent="1">
