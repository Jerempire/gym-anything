          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== Edges: Asynchronous (dashed arrows to RabbitMQ) ===== -->

        <!-- Order Processing -> RabbitMQ (inventory events) -->
        <mxCell id="e10" value="AMQP (async)" style="endArrow=classic;html=1;strokeColor=#9673a6;fontSize=9;fontColor=#9673a6;dashed=1;" edge="1" source="order-processing" target="rabbitmq" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Inventory Service -> RabbitMQ (consume events) -->
