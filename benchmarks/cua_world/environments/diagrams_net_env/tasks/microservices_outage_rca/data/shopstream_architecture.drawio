        <!-- ===== Edges: Synchronous (solid arrows) ===== -->

        <!-- API Gateway to services -->
        <mxCell id="e1" value="HTTP/REST" style="endArrow=classic;html=1;strokeColor=#6c8ebf;fontSize=9;fontColor=#6c8ebf;" edge="1" source="api-gateway" target="product-catalog" parent="1">
