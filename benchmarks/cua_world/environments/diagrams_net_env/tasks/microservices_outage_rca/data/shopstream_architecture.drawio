        <mxCell id="e4" value="HTTP/REST" style="endArrow=classic;html=1;strokeColor=#6c8ebf;fontSize=9;fontColor=#6c8ebf;" edge="1" source="api-gateway" target="user-auth" parent="1">
          <mxGeometry relative="1" as="geometry"/>
