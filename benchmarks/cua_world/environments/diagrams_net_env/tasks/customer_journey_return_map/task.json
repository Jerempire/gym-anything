{
  "id": "customer_journey_return_map@1",
  "version": "1.0",
  "env_id": "diagrams_net_env@0.1",
  "description": "Populate the customer journey map at ~/Diagrams/return_journey.drawio with the touchpoints, actions, emotional states, pain points, and opportunities detailed in ~/Desktop/return_journey_spec.txt. This journey data is based on published Baymard Institute and Narvar e-commerce return research. Fill all 25 content cells in the grid (5 stages × 5 rows). Color-code the Emotional State row using #d5e8d4 for positive, #fff2cc for neutral, and #f8cecc for negative/frustrated states. Add at least 5 dependency arrows connecting related Pain Points to their corresponding Opportunities as listed in the specification. Save the diagram and export the completed map as a PNG to ~/Diagrams/exports/return_journey.png.",
  "category": "ux_design",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/customer_journey_return_map/setup_task.sh",
    "post_task": "/workspace/tasks/customer_journey_return_map/export_result.sh"
  },
  "metadata": {
    "diagram_file": "/home/ga/Diagrams/return_journey.drawio",
    "spec_file": "/home/ga/Desktop/return_journey_spec.txt",
    "export_file": "/home/ga/Diagrams/exports/return_journey.png",
    "colors": {
      "positive": "#d5e8d4",
      "neutral": "#fff2cc",
      "negative": "#f8cecc"
    },
    "stages": [
      "Discover Return Policy",
      "Initiate Return",
      "Prepare & Ship",
      "Await Processing",
      "Receive Resolution"
    ],
    "key_phrases": {
      "stage1": [
        "return policy",
        "restocking",
        "return window",
        "product page",
        "footer",
        "free return",
        "67%",
        "narvar",
        "cautious"
      ],
      "stage2": [
        "order history",
        "reason for return",
        "refund",
        "exchange",
        "store credit",
        "account dashboard",
        "46%",
        "baymard",
        "frustrated",
        "one-click",
        "eligibility"
      ],
      "stage3": [
        "shipping label",
        "repackage",
        "carrier",
        "drop off",
        "pickup",
        "qr code",
        "label-free",
        "printer",
        "packaging",
        "inconvenience"
      ],
      "stage4": [
        "track",
        "warehouse",
        "refund status",
        "carrier tracking",
        "sms",
        "5-10 business",
        "anxious",
        "proactive",
        "milestone",
        "no confirmation",
        "dashboard"
      ],
      "stage5": [
        "refund notification",
        "payment statement",
        "repurchase",
        "92%",
        "narvar",
        "relieved",
        "restocking fee",
        "store credit",
        "loyalty",
        "survey",
        "transparent"
      ]
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_customer_journey_return_map"
    }
  }
}
