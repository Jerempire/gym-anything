{
  "id": "agile_user_story_mapping@1",
  "version": "1.0",
  "env_id": "diagrams_net_env@0.1",
  "description": "You are a Product Manager for 'Lumina', a smart home lighting startup. Visualize the product roadmap by creating a User Story Map in Diagrams.net based on the requirements in '~/Desktop/lumina_requirements.txt'. The diagram must feature a horizontal backbone of 'User Activities' and vertical release slices for 'MVP', 'Release 1.5', and 'Future'. Use distinct colors for the backbone headers versus the story cards. Save the diagram to '~/Diagrams/lumina_story_map.drawio' and export it as a PNG to '~/Diagrams/lumina_story_map.png'.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 900,
    "max_steps": 100,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/agile_user_story_mapping/setup_task.sh",
    "post_task": "/workspace/tasks/agile_user_story_mapping/export_result.sh"
  },
  "metadata": {
    "requirements_file": "/home/ga/Desktop/lumina_requirements.txt",
    "output_drawio": "/home/ga/Diagrams/lumina_story_map.drawio",
    "output_png": "/home/ga/Diagrams/lumina_story_map.png",
    "activities": [
      "Onboarding",
      "Device Control",
      "Automation",
      "System Settings"
    ],
    "releases": [
      "MVP",
      "Release 1.5",
      "Future"
    ],
    "features_map": {
      "Onboarding": [
        "Create Account",
        "Pair First Hub",
        "Social Login"
      ],
      "Device Control": [
        "Toggle Light",
        "Adjust Brightness",
        "Color Temperature",
        "Music Sync"
      ],
      "Automation": [
        "Daily Schedule",
        "Vacation Mode",
        "Geofencing"
      ],
      "System Settings": [
        "View App Version",
        "Manage Guest Access",
        "Energy Usage"
      ]
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_agile_user_story_mapping"
    }
  }
}
