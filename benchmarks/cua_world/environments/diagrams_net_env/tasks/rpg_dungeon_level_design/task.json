{
  "id": "rpg_dungeon_level_design@1",
  "version": "1.0",
  "env_id": "diagrams_net_env@0.1",
  "description": "You are a Level Designer. Create a dungeon map in Diagrams.net based on the design document found at '~/Desktop/level_design_doc.txt'. Use rectangles for rooms and arrows for connections, labeling rooms exactly as named in the document. Place specific shapes (Circle, Square, Triangle, Star) inside the rooms as indicated to represent items and ensure the spatial layout matches the descriptions provided in the document (e.g., North/South/East/West). Export the result as a PNG image to '~/Diagrams/dungeon_map.png' and save the diagram file to '~/Diagrams/dungeon_map.drawio'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/rpg_dungeon_level_design/setup_task.sh",
    "post_task": "/workspace/tasks/rpg_dungeon_level_design/export_result.sh"
  },
  "metadata": {
    "design_doc_path": "/home/ga/Desktop/level_design_doc.txt",
    "expected_drawio": "/home/ga/Diagrams/dungeon_map.drawio",
    "expected_png": "/home/ga/Diagrams/dungeon_map.png",
    "required_rooms": [
      "Entry Chamber",
      "Grand Hall",
      "Armory",
      "Library",
      "Hidden Vault",
      "Throne Room"
    ],
    "spatial_rules": [
      {
        "source": "Grand Hall",
        "target": "Entry Chamber",
        "relation": "north"
      },
      {
        "source": "Armory",
        "target": "Grand Hall",
        "relation": "west"
      },
      {
        "source": "Library",
        "target": "Grand Hall",
        "relation": "east"
      },
      {
        "source": "Throne Room",
        "target": "Grand Hall",
        "relation": "north"
      },
      {
        "source": "Hidden Vault",
        "target": "Library",
        "relation": "north"
      }
    ],
    "containment_rules": [
      {
        "room": "Grand Hall",
        "item_type": "fountain"
      },
      {
        "room": "Armory",
        "item_type": "rack"
      },
      {
        "room": "Hidden Vault",
        "item_type": "key"
      },
      {
        "room": "Throne Room",
        "item_type": "boss"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_rpg_dungeon_level_design"
    }
  }
}
