{
  "id": "create_case_add_image@1",
  "version": "1.0",
  "env_id": "example.autopsy_env@0.1",
  "description": "Create a forensic case in Autopsy named 'USB_Investigation_2024' with case number 'CASE-2024-001'. Add the disk image at /home/ga/evidence/ntfs_undel.dd to the case without running any ingest modules.",
