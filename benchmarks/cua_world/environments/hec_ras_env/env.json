{
  "id": "hec_ras_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "HEC-RAS 6.6 Linux environment for hydraulic modeling and river analysis using USACE compute engines",
  "resources": {
    "cpu": 4,
    "mem_gb": 6,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/hec_ras_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/hec_ras_env/data", "target": "/workspace/data", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/hec_ras_env/tasks", "target": "/workspace/tasks", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_hec_ras.sh",
    "post_start": "/workspace/scripts/setup_hec_ras.sh"
  },
  "vnc": {
    "password": "password"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ]
}
