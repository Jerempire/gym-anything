{
  "id": "openkm_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "OpenKM Community Edition document management system for document upload, search, organization, and metadata tagging",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "vnc": {"password": "password"},
  "mounts": [
    {"source": "benchmarks/cua_world/environments/openkm_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/openkm_env/tasks",   "target": "/workspace/tasks",   "mode": "ro"}
  ],
  "hooks": {
    "pre_start":  "/workspace/scripts/install_openkm.sh",
    "post_start": "/workspace/scripts/setup_openkm.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "env_vars": {"DISPLAY": ":1"}
      }
    }
  ]
}
