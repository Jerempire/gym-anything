{
  "id": "configure_tax_inclusive_pricing@1",
  "version": "1.0",
  "env_id": "copper_point_of_sale_env@0.1",
  "description": "Configure Copper POS to use inclusive (VAT style) tax settings with a 20% tax rate named 'VAT'. Process a cash sale for one 'Premium Wool Scarf' (Price: 120.00) to verify that the tax is calculated as inclusive within the total price. Save a screenshot of the receipt or transaction success screen to C:\\Users\\Docker\\Documents\\vat_test_receipt.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_tax_inclusive_pricing\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_tax_inclusive_pricing\\export_result.ps1"
  },
  "metadata": {
    "expected_total": "120.00",
    "expected_tax": "20.00",
    "item_name": "Premium Wool Scarf",
    "receipt_path": "C:\\Users\\Docker\\Documents\\vat_test_receipt.png",
    "config_registry_key": "HKCU:\\Software\\NCH Software\\Copper"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_tax_inclusive_pricing"
    }
  }
}
