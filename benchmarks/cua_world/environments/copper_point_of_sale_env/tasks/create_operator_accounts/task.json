{
  "id": "create_operator_accounts@1",
  "version": "1.0",
  "env_id": "copper_point_of_sale_env@0.1",
  "description": "Create two new staff accounts in Copper Point of Sale for Emily Rodriguez and James Nakamura. Ensure both accounts are saved and appear in the operator list. Only the names are required; no passwords or additional details need to be set.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_operator_accounts\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_operator_accounts\\export_result.ps1"
  },
  "metadata": {
    "operator_1_name": "Emily Rodriguez",
    "operator_2_name": "James Nakamura",
    "expected_data_path_patterns": [
      "C:\\ProgramData\\NCH Software\\Copper\\Shared\\*",
      "C:\\Users\\*\\AppData\\Roaming\\NCH Software\\Copper\\*"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_operator_accounts"
    }
  }
