        "final_price": "15.00"
      },
      {
        "original_name": "Thermal Base Layer",
        "final_name": "Thermal Base Layer [CLEARANCE]",
        "final_price": "25.00"
      }
    ]
  },
  "success": {
    "mode": "program",
