{
  "id": "configure_store_details@1",
  "version": "1.0",
  "env_id": "copper_point_of_sale_env@0.1",
  "description": "Configure the business profile for 'Hawthorne & Vine General Store' in NCH Copper Point of Sale with the following information:\n\nStore Name: Hawthorne & Vine General Store\nAddress: 2847 SE Hawthorne Blvd\nCity: Portland\nState: OR\nZip: 97214\nCountry: United States\nPhone: (503) 555-0178\nEmail: hello@hawthornevine.com\nWebsite: www.hawthornevine.com\nTax ID: 93-4821057",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_store_details\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_store_details\\export_result.ps1"
  },
  "metadata": {
    "expected_name": "Hawthorne & Vine General Store",
    "expected_address": "2847 SE Hawthorne Blvd",
    "expected_city": "Portland",
    "expected_state": "OR",
    "expected_zip": "97214",
    "expected_country": "United States",
    "expected_phone": "(503) 555-0178",
    "expected_email": "hello@hawthornevine.com",
    "expected_website": "www.hawthornevine.com",
    "expected_tax_id": "93-4821057",
    "registry_path_base": "HKCU:\\Software\\NCH Software\\Copper"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_store_details"
    }
  }
}
