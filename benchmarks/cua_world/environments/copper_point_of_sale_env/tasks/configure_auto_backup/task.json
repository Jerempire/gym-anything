{
  "id": "configure_auto_backup@1",
  "version": "1.0",
  "env_id": "copper_point_of_sale_env@0.1",
  "description": "Configure NCH Copper Point of Sale to automatically back up data to C:\\CopperBackups whenever the application exits.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_auto_backup\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_auto_backup\\export_result.ps1"
  },
  "metadata": {
    "expected_backup_path": "C:\\CopperBackups",
    "registry_path": "HKCU:\\Software\\NCH Software\\Copper",
    "app_name": "Copper Point of Sale"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_auto_backup"
    }
  }
}
