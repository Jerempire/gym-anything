{
  "id": "configure_tax_rate@1",
  "version": "1.0",
  "env_id": "copper_point_of_sale_env@0.1",
  "description": "Configure a new sales tax rate in NCH Copper Point of Sale named 'TX Sales Tax' with a rate of 8.25%. Ensure the configuration is saved and appears in the tax settings list.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_tax_rate\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_tax_rate\\export_result.ps1"
  },
  "metadata": {
    "expected_tax_name": "TX Sales Tax",
    "expected_tax_rate": "8.25",
    "app_data_path": "C:\\ProgramData\\NCH Software\\Copper",
    "user_data_path": "C:\\Users\\Docker\\AppData\\Roaming\\NCH Software\\Copper"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_tax_rate"
    }
  }
}
