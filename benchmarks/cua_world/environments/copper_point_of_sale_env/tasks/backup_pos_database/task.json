{
  "id": "backup_pos_database@1",
  "version": "1.0",
  "env_id": "copper_point_of_sale_env@0.1",
  "description": "Perform a full database backup of the NCH Copper Point of Sale system. Save the resulting backup file to C:\\Users\\Docker\\Desktop\\POS_Backup\\.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\backup_pos_database\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\backup_pos_database\\export_result.ps1"
  },
  "metadata": {
    "backup_dir": "C:\\Users\\Docker\\Desktop\\POS_Backup",
    "min_size_bytes": 1024,
    "valid_extensions": [
      ".zip",
      ".bak",
      ".db",
      ".sqlite",
      ".cpb",
      ".dat"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_backup_pos_database"
    }
  }
}
