{
  "id": "create_service_items@1",
  "version": "1.0",
  "env_id": "copper_point_of_sale_env@0.1",
  "description": "Configure three new 'service' items in NCH Copper Point of Sale that do not track inventory quantities. Create 'Virus Removal' (Code: VR01, Price: $89.00), 'System Tune-up' (Code: ST01, Price: $49.99), and 'Data Transfer' (Code: DT01, Price: $60.00). Ensure Stock Management/Inventory Tracking is disabled for each item.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_service_items/setup_task.sh",
    "post_task": "/workspace/tasks/create_service_items/export_result.sh"
  },
  "metadata": {
    "items": [
      {
        "name": "Virus Removal",
        "code": "VR01",
        "price": 89.0
      },
      {
        "name": "System Tune-up",
        "code": "ST01",
        "price": 49.99
      },
      {
        "name": "Data Transfer",
        "code": "DT01",
        "price": 60.0
      }
    ],
    "db_search_paths": [
      "C:\\ProgramData\\NCH Software\\Copper\\Shared\\copper.db",
      "C:\\Users\\Docker\\AppData\\Roaming\\NCH Software\\Copper\\Shared\\copper.db",
      "C:\\ProgramData\\NCH Software\\Copper\\Shared\\Items.db"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_service_items"
    }
  }
}
