    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\create_redeem_coupon\\export_result.ps1"
  },
  "metadata": {
    "expected_item_code": "VASE-001",
    "expected_coupon_code": "NEW2025",
    "expected_discount_amount": "10.00",
    "expected_item_price": "45.00",
    "app_data_path": "C:\\ProgramData\\NCH Software\\Copper"
