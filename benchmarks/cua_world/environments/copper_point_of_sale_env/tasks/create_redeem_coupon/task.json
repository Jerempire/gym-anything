{
  "id": "create_redeem_coupon@1",
  "version": "1.0",
  "env_id": "copper_point_of_sale_env@0.1",
  "description": "Create a new item with Description 'Ceramic Vase', Item Code 'VASE-001', and Price '$45.00' in NCH Copper Point of Sale. Configure an active coupon with Code 'NEW2025' for a fixed discount amount of '$10.00'. Process a transaction for the 'Ceramic Vase' using the 'NEW2025' coupon and complete the sale using 'Cash' as the payment method.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
