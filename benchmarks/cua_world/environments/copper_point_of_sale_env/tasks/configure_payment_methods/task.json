{
  "id": "configure_payment_methods@1",
  "version": "1.0",
  "env_id": "copper_point_of_sale_env@0.1",
  "description": "Configure the payment methods for the store in NCH Copper Point of Sale. Ensure that 'Cash', 'Credit Card', and 'Check' are the only pre-existing methods enabled, and add a new enabled payment method named 'Store Credit'. Verify that these four methods are available for selection during a sale.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_payment_methods\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_payment_methods\\export_result.ps1"
  },
  "metadata": {
    "required_methods": [
      "Cash",
      "Credit Card",
      "Check",
      "Store Credit"
    ],
    "forbidden_methods": [
      "EFTPOS"
    ],
    "output_file": "C:\\tmp\\payment_config.json"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_payment_methods"
    }
  }
}
