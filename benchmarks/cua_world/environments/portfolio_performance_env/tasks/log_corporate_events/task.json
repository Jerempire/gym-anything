{
  "id": "log_corporate_events@1",
  "version": "1.0",
  "env_id": "portfolio_performance_env@0.1",
  "description": "Log a corporate event in Portfolio Performance to annotate the historical price chart for 'Tesla Inc' (TSLA) in the portfolio file '/home/ga/Documents/PortfolioData/tesla_analysis.xml'. Add an event note dated 2024-10-10 with the label 'Cybercab Reveal Event' and save the changes to the portfolio.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/log_corporate_events/setup_task.sh",
    "post_task": "/workspace/tasks/log_corporate_events/export_result.sh"
  },
  "metadata": {
    "portfolio_file": "tesla_analysis.xml",
    "target_isin": "US88160R1014",
    "target_name": "Tesla Inc",
    "expected_date": "2024-10-10",
    "expected_keywords": [
      "Cybercab",
      "Robot",
      "Taxi",
      "Event"
    ],
    "save_directory": "/home/ga/Documents/PortfolioData"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_log_corporate_events"
    }
  }
}
