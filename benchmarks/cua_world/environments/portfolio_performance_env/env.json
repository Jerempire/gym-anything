{
  "id": "portfolio_performance_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Portfolio Performance investment tracking environment for managing securities portfolios, recording transactions, and analyzing investment returns",
  "category": ["finance", "desktop"],
  "tags": ["java", "desktop", "finance", "investment", "portfolio", "eclipse-rcp"],
  "licence": "EPL-1.0",
  "upstream_url": "https://www.portfolio-performance.info/",
  "resources": {
    "cpu": 4,
    "mem_gb": 6,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {"type": "mouse"},
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/portfolio_performance_env/artifacts",
    "video_fps": 10,
    "video_resolution": [1920, 1080],
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true,
    "runtime": "sysbox-runc"
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/portfolio_performance_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/portfolio_performance_env/config", "target": "/workspace/config", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/portfolio_performance_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/portfolio_performance_env/data", "target": "/workspace/data", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_portfolio_performance.sh",
    "post_start": "/workspace/scripts/setup_portfolio_performance.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "investor",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1"
        }
      }
    }
  ]
}
