{
  "id": "manageengine_adaudit_plus_env@0.1",
  "version": "0.1",
  "base": "windows-11",
  "description": "ManageEngine ADAudit Plus environment for security auditing configuration and administration tasks",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "vnc": {
    "enable": true,
    "password": "password",
    "view_only": false
  },
  "mounts": [
    {"source": "benchmarks/cua_world/environments/manageengine_adaudit_plus_env/scripts", "target": "C:\\workspace\\scripts", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/manageengine_adaudit_plus_env/data", "target": "C:\\workspace\\data", "mode": "ro"},
    {"source": "benchmarks/cua_world/environments/manageengine_adaudit_plus_env/tasks", "target": "C:\\workspace\\tasks", "mode": "ro"}
  ],
  "hooks": {
    "pre_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\install_adaudit_plus.ps1",
    "post_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\setup_adaudit_plus.ps1"
  },
  "user_accounts": [
    {
      "name": "Docker",
      "password": "GymAnything123!",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["Administrators"],
        "env_vars": {}
      }
    }
  ]
}
