{
  "id": "customize_report_columns@1",
  "version": "1.0",
  "env_id": "manageengine_adaudit_plus_env@0.1",
  "description": "As an administrator in ManageEngine ADAudit Plus, customize the 'User Logon Failures' report columns to show 'User Name', 'Client IP Address', 'Failure Reason', and 'Logon Time', and hide 'Domain Name' and 'Logon Type'. Save a screenshot of the configured report grid to 'C:\\workspace\\custom_columns.png' and export the report to 'C:\\workspace\\report_layout.pdf'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\customize_report_columns\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\customize_report_columns\\export_result.ps1",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_screenshot": "C:\\workspace\\custom_columns.png",
    "expected_pdf": "C:\\workspace\\report_layout.pdf",
    "required_columns": [
      "User Name",
      "Client IP Address",
      "Failure Reason",
      "Logon Time"
    ],
    "forbidden_columns": [
      "Domain Name",
      "Logon Type"
    ],
    "login_url": "http://localhost:8081",
    "credentials": {
      "username": "admin",
      "password": "Admin@2024"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_customize_report_columns"
    }
  }
}
