{
  "id": "configure_ip_location_mapping@1",
  "version": "1.0",
  "env_id": "manageengine_adaudit_plus_env@0.1",
  "description": "The organization has opened a new 'Austin Innovation Hub'. Configure IP-to-Location mapping in ManageEngine ADAudit Plus (http://localhost:8081) using credentials admin/Admin@2024 so audit logs show the location name instead of raw IPs. Add a new location named 'Austin Innovation Hub' with the description 'New R&D Facility - Bldg 4' for the IP range 10.55.0.0 to 10.55.255.255.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_ip_location_mapping\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_ip_location_mapping\\export_result.ps1"
  },
  "metadata": {
    "location_name": "Austin Innovation Hub",
    "ip_start": "10.55.0.0",
    "ip_end": "10.55.255.255",
    "description": "New R&D Facility - Bldg 4",
    "expected_screenshot_path": "C:\\workspace\\tasks\\configure_ip_location_mapping\\final_screenshot.png"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_ip_location_mapping"
    }
  }
}
