{
  "id": "configure_process_exclusion@1",
  "version": "1.0",
  "env_id": "manageengine_adaudit_plus_env@0.1",
  "description": "The ManageEngine ADAudit Plus login page is open in Microsoft Edge. Using the credentials 'admin' and 'Admin@2024', configure a Process Audit Exclusion for the noisy backup agent 'titan_backup.exe' to prevent the system from logging its events.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_process_exclusion\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_process_exclusion\\export_result.ps1",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_process": "titan_backup.exe",
    "user": "admin",
    "password": "Admin@2024"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_process_exclusion"
    }
  }
}
