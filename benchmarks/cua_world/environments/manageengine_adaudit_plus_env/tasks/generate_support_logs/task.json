{
  "id": "generate_support_logs@1",
  "version": "1.0",
  "env_id": "manageengine_adaudit_plus_env@0.1",
  "description": "Generate a Support Information File in ManageEngine ADAudit Plus (http://localhost:8081) for troubleshooting purposes. Log in using username 'admin' and password 'Admin@2024'. The generated support file must exclude 'Database Logs'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\generate_support_logs\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\generate_support_logs\\export_result.ps1",
    "pre_task_timeout": 600
  },
  "metadata": {
    "login_url": "http://localhost:8081",
    "username": "admin",
    "password": "Admin@2024",
    "expected_zip_pattern": "Support_*.zip",
    "forbidden_log_content": "pgsql_log"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_generate_support_logs"
    }
  }
}
