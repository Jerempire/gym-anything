{
  "id": "configure_discovery_exclusion@1",
  "version": "1.0",
  "env_id": "manageengine_adaudit_plus_env@0.1",
  "description": "A legacy CNC controller at IP '192.168.100.50' is crashing due to network scans. Your task is to exclude this IP address from ADAudit Plus (http://localhost:8081) network discovery. Use the credentials username 'admin' and password 'Admin@2024'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_discovery_exclusion\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_discovery_exclusion\\export_result.ps1",
    "pre_task_timeout": 600
  },
  "metadata": {
    "target_ip": "192.168.100.50",
    "login_url": "http://localhost:8081",
    "admin_user": "admin"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_discovery_exclusion"
    }
  }
}
