{
  "id": "configure_system_health_alerts@1",
  "version": "1.0",
  "env_id": "manageengine_adaudit_plus_env@0.1",
  "description": "Configure the 'Alert Me' system health notifications in ManageEngine ADAudit Plus (http://localhost:8081) using the credentials 'admin' and 'Admin@2024'. Ensure administrators are alerted if disk space falls below 2 GB or if data collection stops. Set the email recipient for these system health alerts to 'soc-alerts@bank.local' and save the settings.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_system_health_alerts\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_system_health_alerts\\export_result.ps1",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_disk_threshold": "2048",
    "expected_email": "soc-alerts@bank.local",
    "settings_url_part": "alertMe",
    "admin_user": "admin",
    "admin_pass": "Admin@2024"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_system_health_alerts"
    }
  }
}
