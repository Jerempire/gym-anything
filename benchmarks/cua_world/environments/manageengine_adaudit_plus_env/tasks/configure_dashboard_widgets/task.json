{
  "id": "configure_dashboard_widgets@1",
  "version": "1.0",
  "env_id": "manageengine_adaudit_plus_env@0.1",
  "description": "Log in to ManageEngine ADAudit Plus (username 'admin', password 'Admin@2024') and customize the dashboard to focus on security threats. The dashboard must include 'Recent Logon Failures' and 'User Account Lockouts' widgets, with the 'Getting Started' or 'Overview' widget removed. Save the layout and export a screenshot of the customized dashboard to C:\\workspace\\dashboard_final.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_dashboard_widgets\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_dashboard_widgets\\export_result.ps1",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_screenshot_path": "C:\\workspace\\dashboard_final.png",
    "required_widgets": [
      "Logon Failures",
      "Account Lockout"
    ],
    "forbidden_widgets": [
      "Getting Started",
      "Overview"
    ],
    "min_file_size_kb": 50
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_dashboard_widgets"
    }
  }
}
