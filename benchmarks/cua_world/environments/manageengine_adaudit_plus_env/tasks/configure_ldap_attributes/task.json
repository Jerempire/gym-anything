{
  "id": "configure_ldap_attributes@1",
  "version": "1.0",
  "env_id": "manageengine_adaudit_plus_env@0.1",
  "description": "Log in to the ADAudit Plus console (admin / Admin@2024). Configure the LDAP attributes to include 'department', 'title', and 'physicalDeliveryOfficeName'. Set the display name for 'physicalDeliveryOfficeName' to 'Office Location' and save the configuration.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_ldap_attributes\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_ldap_attributes\\export_result.ps1",
    "pre_task_timeout": 600
  },
  "metadata": {
    "required_attributes": [
      "department",
      "title",
      "physicalDeliveryOfficeName"
    ],
    "custom_display_name": "Office Location",
    "target_attribute_mapping": "physicalDeliveryOfficeName",
    "admin_user": "admin",
    "admin_pass": "Admin@2024"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_ldap_attributes"
    }
  }
}
