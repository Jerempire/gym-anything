{
  "id": "configure_login_security_policy@1",
  "version": "1.0",
  "env_id": "manageengine_adaudit_plus_env@0.1",
  "description": "Log in to ManageEngine ADAudit Plus using username 'admin' and password 'Admin@2024'. Update the Logon Settings to set the Session Expiry Time to 20 minutes, the Account Lockout Threshold to 3 invalid attempts, and the Account Lockout Duration to 30 minutes. Ensure the changes are saved.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_login_security_policy\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\configure_login_security_policy\\export_result.ps1",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_session_timeout": "20",
    "expected_lockout_threshold": "3",
    "expected_lockout_duration": "30",
    "admin_url": "http://localhost:8081/webclient/index.html#/admin/logon-settings"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_login_security_policy"
    }
  }
}
