{
  "id": "configure_database_backup@1",
  "version": "1.0",
  "env_id": "manageengine_adaudit_plus_env@0.1",
  "description": "Configure the database backup settings in ManageEngine ADAudit Plus (http://localhost:8081) using credentials 'admin' and 'Admin@2024'. Enable scheduled daily backups at 02:00 hours, set the backup storage path to 'C:\\ADAuditBackups', and set the retention policy to maintain the last 30 backups.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_database_backup/setup_task.sh",
    "post_task": "/workspace/tasks/configure_database_backup/export_result.sh",
    "pre_task_timeout": 600
  },
  "metadata": {
    "expected_path": "C:\\ADAuditBackups",
    "expected_frequency": "Daily",
    "expected_time": "02:00",
    "expected_retention": "30",
    "conf_dir": "C:\\Program Files\\ManageEngine\\ADAudit Plus\\conf",
    "backup_dir_win": "C:\\ADAuditBackups"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_database_backup"
    }
  }
}
