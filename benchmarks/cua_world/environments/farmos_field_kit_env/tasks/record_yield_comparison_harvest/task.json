{
  "id": "record_yield_comparison_harvest@1",
  "version": "1.0",
  "env_id": "example.farmos_field_kit_env@0.1",
  "description": "Create a single Harvest log in farmOS Field Kit dated July 15, 2025, to compare garlic yields from two trial plots. The log should include the note 'Garlic harvest trial. Comparing output between Upper and Lower fields.' and two distinct quantities: 450 bulbs with the label 'Upper Field' and 320 bulbs with the label 'Lower Field'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/record_yield_comparison_harvest/setup_task.sh",
    "post_task": "sh /sdcard/tasks/record_yield_comparison_harvest/export_result.sh"
  },
  "metadata": {
    "expected_date": "2025-07-15",
    "expected_notes_keyword": "Garlic harvest trial",
    "quantities": [
      {
        "value": 450,
        "unit": "bulbs",
        "label": "Upper Field"
      },
      {
        "value": 320,
        "unit": "bulbs",
        "label": "Lower Field"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_yield_comparison"
    }
  }
}
