{
  "id": "record_vineyard_maturity_sampling@1",
  "version": "1.0",
  "env_id": "example.farmos_field_kit_env@0.1",
  "description": "Record a vineyard maturity check for 'Block 9 Pinot Noir' dated September 14, 2024. Include the note: 'Pre-harvest maturity sample. Berries fully colored, seeds brown, skins softening. Flavor profile shows red fruit notes.' Record the following measurements: Sugar Content (24.2 Brix), Acidity (3.55 pH), and Titratable Acidity (5.8 g/L).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "sh /sdcard/tasks/record_vineyard_maturity_sampling/setup_task.sh",
    "post_task": "sh /sdcard/tasks/record_vineyard_maturity_sampling/export_result.sh"
  },
  "metadata": {
    "expected_date": "2024-09-14",
    "expected_type": "observation",
    "expected_notes_keywords": [
      "Pre-harvest",
      "colored",
      "brown",
      "softening",
      "red fruit"
    ],
    "expected_quantities": [
      {
        "value": "24.2",
        "unit": "Brix",
        "label": "Sugar Content"
      },
      {
        "value": "3.55",
        "unit": "pH",
        "label": "Acidity"
      },
      {
        "value": "5.8",
        "unit": "g/L",
        "label": "Titratable Acidity"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_vineyard_maturity"
    }
  }
}
