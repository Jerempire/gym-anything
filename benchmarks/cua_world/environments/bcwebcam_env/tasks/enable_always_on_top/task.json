{
  "id": "enable_always_on_top@1",
  "version": "1.0",
  "env_id": "bcwebcam_env@0.1",
  "description": "Configure bcWebCam so that its application window stays always on top of all other windows. Open bcWebCam's Options dialog by clicking the gear icon in the bottom toolbar. Find the 'Always on top' checkbox, check it to enable the feature, and click OK to apply the change.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 180,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\enable_always_on_top\\setup_task.ps1",
    "post_task": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\tasks\\enable_always_on_top\\export_result.ps1"
  },
  "metadata": {
    "expected_window_style_flag": 8,
    "gwl_exstyle": -20
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_enable_always_on_top"
    }
  }
}