{
  "id": "visallo_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "runner": "qemu",
  "description": "Visallo graph analytics environment for investigative link analysis tasks. Runs Visallo in embedded development mode (H2 + Elasticsearch) with Java 8 and Maven. Pre-loaded with ICIJ Offshore Leaks data for realistic investigative scenarios. Uses Firefox for GUI interaction.",
  "resources": {
    "cpu": 4,
    "mem_gb": 10,
    "gpu": 0,
    "net": true
  },
  "diagnostics": true,
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [1920, 1080],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/visallo_env/artifacts",
    "video_fps": 10,
    "video_resolution": [1920, 1080],
    "video_codec": "libx264",
    "video_crf": 23
  },
  "vnc": {
    "enable": false,
    "host_port": 5981,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/visallo_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/visallo_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/visallo_env/data",
      "target": "/workspace/data",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/visallo_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_visallo.sh",
    "post_start": "/workspace/scripts/setup_visallo.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {
          "DISPLAY": ":1",
          "VISALLO_URL": "http://localhost:8080"
        }
      }
    }
  ],
  "tags": [
    "linux",
    "visallo",
    "web-application",
    "graph-analytics",
    "java",
    "link-analysis",
    "investigation"
  ]
}
