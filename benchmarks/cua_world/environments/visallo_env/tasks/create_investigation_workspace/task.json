{
  "id": "create_investigation_workspace@1",
  "version": "1.0",
  "env_id": "visallo_env@0.1",
  "description": "Log in to Visallo as user 'analyst' (username-only auth — just type the username and press Enter). Once logged in, create a new workspace named 'Panama Papers BVI Investigation'.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 300,
    "max_steps": 30,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_investigation_workspace/setup_task.sh"
  },
  "metadata": {
    "workspace_name": "Panama Papers BVI Investigation",
    "login_username": "analyst"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_investigation_workspace"
    }
  }
}
