{
  "id": "add_emg_widget@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Start a Synthetic session in the OpenBCI GUI. Add the EMG widget to the dashboard and configure its uV Limit to 200. Ensure the synthetic data stream is active and the EMG widget displays signal activity.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_emg_widget/setup_task.sh",
    "post_task": "/workspace/tasks/add_emg_widget/export_result.sh"
  },
  "metadata": {
    "target_widget": "EMG",
    "target_uv_limit": "200",
    "data_mode": "SYNTHETIC"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_emg_widget"
    }
  },
  "tags": [
    "openbci",
    "widget",
    "emg",
    "configuration",
    "gui"
  ]
}
