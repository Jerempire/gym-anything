{
  "id": "configure_band_power_alpha_isolation@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Configure the Band Power widget in OpenBCI GUI to isolate the Alpha frequency band during a synthetic session. Ensure the data stream is active and that only the Alpha band is enabled in the widget settings, with Delta, Theta, Beta, and Gamma disabled.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_band_power_alpha_isolation/setup_task.sh",
    "post_task": "/workspace/tasks/configure_band_power_alpha_isolation/export_result.sh"
  },
  "metadata": {
    "target_band": "Alpha",
    "hidden_bands": [
      "Delta",
      "Theta",
      "Beta",
      "Gamma"
    ],
    "widget_name": "Band Power"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_band_power_alpha"
    }
  }
}
