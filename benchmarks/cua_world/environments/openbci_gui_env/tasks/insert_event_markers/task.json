{
  "id": "insert_event_markers@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Configure an EEG experiment workflow by starting a Synthetic session. Record a data file to ~/Documents/OpenBCI_GUI/Recordings/ containing at least three distinct, temporally separated event markers with values 1, 2, and 3.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/insert_event_markers/setup_task.sh",
    "post_task": "/workspace/tasks/insert_event_markers/export_result.sh"
  },
  "metadata": {
    "recording_dir": "/home/ga/Documents/OpenBCI_GUI/Recordings",
    "required_markers": [
      1,
      2,
      3
    ],
    "min_separation_samples": 100,
    "min_file_size_kb": 10
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_insert_event_markers"
    }
  }
}
