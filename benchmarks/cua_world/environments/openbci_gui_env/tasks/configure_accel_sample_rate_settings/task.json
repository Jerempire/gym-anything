{
  "id": "configure_accel_sample_rate_settings@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Configure the OpenBCI Cyton accelerometer sample rate to 25Hz within the Hardware Settings. Ensure the settings panel remains visible and save a screenshot of the configuration to /home/ga/Documents/OpenBCI_GUI/Screenshots/accel_config.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 25,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_accel_sample_rate_settings/setup_task.sh",
    "post_task": "/workspace/tasks/configure_accel_sample_rate_settings/export_result.sh"
  },
  "metadata": {
    "target_sample_rate": "25Hz",
    "expected_screenshot_path": "/home/ga/Documents/OpenBCI_GUI/Screenshots/accel_config.png",
    "verification_criteria": [
      "Settings panel is visible",
      "Sample rate is set to 25Hz",
      "Screenshot file exists"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_accel_settings"
    }
  }
}
