{
  "id": "extract_eeg_clip@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "You have a long EEG recording file, but you only need a short segment for analysis. Create a new 10-20 second recording clip by playing back 'OpenBCI-EEG-S001-MotorImagery.txt' from the Recordings directory. Ensure the resulting file is saved in the Recordings directory.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/extract_eeg_clip/setup_task.sh",
    "post_task": "/workspace/tasks/extract_eeg_clip/export_result.sh"
  },
  "metadata": {
    "source_file": "OpenBCI-EEG-S001-MotorImagery.txt",
    "min_duration_sec": 10,
    "max_duration_sec": 20,
    "sample_rate": 250,
    "min_samples": 2500,
    "max_samples": 5000
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_extract_eeg_clip"
    }
  }
}
