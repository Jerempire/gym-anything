{
  "id": "configure_timeseries_scale@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Configure the OpenBCI GUI Time Series widget for a live demonstration using a Synthetic (Cyton) session. Set the Vertical Scale to 200 uV and the Time Window to 10 seconds. Save a screenshot of the configuration to /home/ga/Documents/OpenBCI_GUI/Screenshots/timeseries_config.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_timeseries_scale/setup_task.sh",
    "post_task": "/workspace/tasks/configure_timeseries_scale/export_result.sh"
  },
  "metadata": {
    "target_vertical_scale": "200 uV",
    "target_time_window": "10 sec",
    "screenshot_path": "/home/ga/Documents/OpenBCI_GUI/Screenshots/timeseries_config.png",
    "process_name": "OpenBCI_GUI"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_timeseries_config"
    }
  },
  "tags": [
    "openbci",
    "configuration",
    "visualization",
    "gui",
    "time-series"
  ]
}
