{
  "id": "power_down_channels_hardware@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Configure the OpenBCI Cyton board hardware settings to power down Channels 1, 2, and 3 while keeping Channels 4 through 8 enabled to reduce noise. Perform this configuration within a 'SYNTHETIC (live)' session and save the settings to ~/Documents/OpenBCI_GUI/Settings/PartialMontage.json.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/power_down_channels_hardware/setup_task.sh",
    "post_task": "/workspace/tasks/power_down_channels_hardware/export_result.sh"
  },
  "metadata": {
    "target_file": "PartialMontage.json",
    "settings_dir": "/home/ga/Documents/OpenBCI_GUI/Settings",
    "channels_to_disable": [
      0,
      1,
      2
    ],
    "channels_to_enable": [
      3,
      4,
      5,
      6,
      7
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_power_down_channels"
    }
  }
}
