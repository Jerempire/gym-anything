{
  "id": "disable_channels_5_to_8@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Start a synthetic session in the OpenBCI GUI and configure the Time Series widget to display only channels 1, 2, 3, and 4. Save a screenshot of this 4-channel configuration as 'four_channel_display.png' to ~/Documents/OpenBCI_GUI/Screenshots/.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/disable_channels_5_to_8/setup_task.sh",
    "post_task": "/workspace/tasks/disable_channels_5_to_8/export_result.sh"
  },
  "metadata": {
    "expected_active_channels": [
      1,
      2,
      3,
      4
    ],
    "expected_disabled_channels": [
      5,
      6,
      7,
      8
    ],
    "output_filename": "four_channel_display.png",
    "output_dir": "/home/ga/Documents/OpenBCI_GUI/Screenshots",
    "full_output_path": "/home/ga/Documents/OpenBCI_GUI/Screenshots/four_channel_display.png"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_disable_channels"
    }
  },
  "tags": [
    "openbci",
    "channels",
    "configuration",
    "synthetic",
    "ui-interaction"
  ]
}
