{
  "id": "configure_ganglion_4ch_synthetic@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Switch the OpenBCI GUI data source to the Ganglion board (4-channel) in Synthetic mode and start the session. Verify that the Time Series widget displays 4 channels and save a screenshot of the active display to /home/ga/Documents/OpenBCI_GUI/Screenshots/ganglion_4ch_display.png.",
