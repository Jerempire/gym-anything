  },
  "metadata": {
    "expected_screenshot_path": "/home/ga/Documents/OpenBCI_GUI/Screenshots/ganglion_4ch_display.png",
    "target_board": "Ganglion",
    "channel_count": 4,
    "data_mode": "Synthetic"
