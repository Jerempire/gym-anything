{
  "id": "stream_lsl_custom_name@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Configure the OpenBCI GUI to stream playback data from 'Documents/OpenBCI_GUI/Recordings/OpenBCI-EEG-S001-EyesOpen.txt' over a Lab Streaming Layer (LSL) connection. Set the LSL stream name to 'OpenBCI_Station_A' and ensure both the data playback and the LSL broadcast are active.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/stream_lsl_custom_name/setup_task.sh",
    "post_task": "/workspace/tasks/stream_lsl_custom_name/export_result.sh"
  },
  "metadata": {
    "target_stream_name": "OpenBCI_Station_A",
    "target_stream_type": "EEG",
    "recording_file": "OpenBCI-EEG-S001-EyesOpen.txt",
    "expected_protocol": "LSL",
    "required_packages": [
      "pylsl"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_stream_lsl_custom_name"
    }
  }
}
