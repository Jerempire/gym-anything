{
  "id": "set_recording_format_bdf@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Configure the OpenBCI GUI to save recordings in BDF+ format using the 'SYNTHETIC (Live)' data source. Record data for at least 5 seconds and ensure the resulting .bdf file is saved to the default recordings directory.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/set_recording_format_bdf/setup_task.sh",
    "post_task": "/workspace/tasks/set_recording_format_bdf/export_result.sh"
  },
  "metadata": {
    "expected_extension": ".bdf",
    "min_duration_seconds": 5,
    "min_file_size_bytes": 10240,
    "header_signature_hex": "FF",
    "header_signature_text": "BIOSEMI",
    "recordings_dir": "/home/ga/Documents/OpenBCI_GUI/Recordings"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_set_recording_format_bdf"
    }
  },
  "tags": [
    "openbci",
    "recording",
    "bdf",
    "configuration",
    "data-acquisition"
  ]
}
