{
  "id": "take_gui_screenshot@1",
  "name": "Take a Screenshot of the OpenBCI GUI Using Expert Mode",
  "description": "The OpenBCI GUI is running an active Synthetic EEG session with Expert Mode already enabled. Save a screenshot of the current GUI state to the ~/Documents/OpenBCI_GUI/Screenshots/ folder.",
  "init": {
    "timeout_sec": 90,
    "max_steps": 20,
    "reward_type": "sparse"
  },
  "metadata": {
    "application": "OpenBCI GUI v5.2.2",
    "feature": "Screenshot in Expert Mode",
    "keyboard_shortcut": "m",
    "output_location": "~/Documents/OpenBCI_GUI/",
    "difficulty": "easy"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/take_gui_screenshot/setup_task.sh"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_take_gui_screenshot"
    }
  },
  "tags": [
    "openbci",
    "screenshot",
    "expert-mode",
    "keyboard-shortcut"
  ]
}
