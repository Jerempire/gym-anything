{
  "id": "configure_ganglion_multimodal_dashboard@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Configure a Ganglion (4-channel) synthetic session with a multimodal dashboard. Set up a 4-pane layout displaying the Time Series, FFT Plot, Band Power, and EMG widgets. Ensure all widgets are active with live data and save a screenshot of the configured dashboard to /home/ga/Documents/OpenBCI_GUI/Screenshots/ganglion_dashboard.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_ganglion_multimodal_dashboard/setup_task.sh",
    "post_task": "/workspace/tasks/configure_ganglion_multimodal_dashboard/export_result.sh"
  },
  "metadata": {
    "expected_screenshot_path": "/home/ga/Documents/OpenBCI_GUI/Screenshots/ganglion_dashboard.png",
    "required_widgets": [
      "Time Series",
      "FFT Plot",
      "Band Power",
      "EMG"
    ],
    "board_type": "Ganglion",
    "channel_count": 4
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ganglion_dashboard"
    }
  }
}
