{
  "id": "record_and_archive_calibration@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Perform a data acquisition and archiving workflow. Using the playback file 'OpenBCI-EEG-S001-EyesOpen.txt', record a new session segment of at least 5 seconds. Rename the resulting recording file in '~/Documents/OpenBCI_GUI/Recordings/' to 'alpha_calibration.txt'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_and_archive_calibration/setup_task.sh",
    "post_task": "/workspace/tasks/record_and_archive_calibration/export_result.sh"
  },
  "metadata": {
    "target_filename": "alpha_calibration.txt",
    "target_dir": "/home/ga/Documents/OpenBCI_GUI/Recordings",
    "source_file": "OpenBCI-EEG-S001-EyesOpen.txt",
    "min_duration_seconds": 5,
    "min_rows": 1000,
    "sample_rate": 250
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_calibration_recording"
    }
  }
}
