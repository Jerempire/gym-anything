{
  "id": "configure_test_signal_channels@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Configure the OpenBCI GUI for a hardware signal test. Start an 8-channel Synthetic session and set Channels 1, 2, 3, and 4 to 'TESTSIG' input type with 'x8' gain. Maintain default settings (Normal, x24) for Channels 5 through 8 and save the configuration.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_test_signal_channels/setup_task.sh",
    "post_task": "/workspace/tasks/configure_test_signal_channels/export_result.sh"
  },
  "metadata": {
    "settings_dir": "/home/ga/Documents/OpenBCI_GUI/Settings",
    "target_channels": [
      0,
      1,
      2,
      3
    ],
    "target_input_type": [
      "TEST",
      "TESTSIG"
    ],
    "target_gain": 8,
    "default_channels": [
      4,
      5,
      6,
      7
    ],
    "default_input_type": [
      "NORMAL"
    ],
    "default_gain": 24,
    "app_process": "OpenBCI_GUI"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_test_signal_channels"
    }
  }
}
