{
  "id": "record_synthetic_session@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Start a Synthetic EEG session and record at least 10 seconds of data. The recording must be saved to the default location at ~/Documents/OpenBCI_GUI/Recordings/.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_synthetic_session/setup_task.sh",
    "post_task": "/workspace/tasks/record_synthetic_session/export_result.sh"
  },
  "metadata": {
    "expected_directory_base": "/home/ga/Documents/OpenBCI_GUI/Recordings",
    "min_duration_seconds": 10,
    "min_data_rows": 2000,
    "min_file_size_kb": 50,
    "sample_rate": 250,
    "expected_channels": 8
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_synthetic_session"
    }
  },
  "tags": [
    "openbci",
    "recording",
    "data-acquisition",
    "synthetic",
    "workflow"
  ]
}
