{
  "id": "configure_focus_widget_channel_specific@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Configure the Focus widget for a neurofeedback protocol using only Channel 1 (with Channels 2-8 inactive) within a Synthetic (Algorithmic) session. Ensure the widget's hardware configuration settings remain visible on the dashboard.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_focus_widget_channel_specific/setup_task.sh",
    "post_task": "/workspace/tasks/configure_focus_widget_channel_specific/export_result.sh"
  },
  "metadata": {
    "target_channel": 1,
    "excluded_channels": [
      2,
      3,
      4,
      5,
      6,
      7,
      8
    ],
    "widget_name": "Focus",
    "verification_criteria": [
      "OpenBCI GUI session is active (streaming)",
      "Focus widget is present in the layout",
      "Focus widget settings/hardware panel is open/visible",
      "Channel 1 is toggled ON",
      "Channels 2-8 are toggled OFF"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_focus_widget"
    }
  }
}
