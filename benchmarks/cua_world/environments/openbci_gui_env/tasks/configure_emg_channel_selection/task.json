{
  "id": "configure_emg_channel_selection@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Configure the OpenBCI GUI for a jaw-clench EMG experiment. Using a 'SYNTHETIC (algorithmic)' session with 8 channels, start the data stream and isolate Channels 7 and 8 within the EMG widget by disabling Channels 1 through 6.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_emg_channel_selection/setup_task.sh",
    "post_task": "/workspace/tasks/configure_emg_channel_selection/export_result.sh"
  },
  "metadata": {
    "target_widget": "EMG",
    "active_channels": [
      7,
      8
    ],
    "inactive_channels": [
      1,
      2,
      3,
      4,
      5,
      6
    ],
    "expected_bar_count": 2
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_emg_channel_selection"
    }
  }
}
