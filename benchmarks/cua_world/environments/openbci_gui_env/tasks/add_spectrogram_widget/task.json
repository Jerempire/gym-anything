{
  "id": "add_spectrogram_widget@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Start a Synthetic (PC) session in the OpenBCI GUI and display the 'Spectrogram' widget configured for Channel 2.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_spectrogram_widget/setup_task.sh",
    "post_task": "/workspace/tasks/add_spectrogram_widget/export_result.sh"
  },
  "metadata": {
    "target_widget": "Spectrogram",
    "target_channel": "2",
    "target_channel_label": "Channel 2",
    "data_source": "Synthetic (PC)",
    "visual_cues": [
      "2D heatmap",
      "Frequency vs Time",
      "Color gradient"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_spectrogram_widget"
    }
  }
}
