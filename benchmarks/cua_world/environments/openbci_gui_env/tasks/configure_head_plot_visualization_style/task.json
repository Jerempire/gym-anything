{
  "id": "configure_head_plot_visualization_style@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Start a synthetic OpenBCI session using the Cyton board. Configure the Head Plot visualization to use a 'Smoothed' or 'Contours' plot type with the 'Viridis' colormap. Save a screenshot of the configured Head Plot to /home/ga/Documents/OpenBCI_GUI/Screenshots/head_plot_viridis.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_head_plot_visualization_style/setup_task.sh",
    "post_task": "/workspace/tasks/configure_head_plot_visualization_style/export_result.sh"
  },
  "metadata": {
    "expected_screenshot_path": "/home/ga/Documents/OpenBCI_GUI/Screenshots/head_plot_viridis.png",
    "target_colormap": "Viridis",
    "target_plot_type": "Smoothed",
    "required_widget": "Head Plot"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_head_plot_style"
    }
  }
}
