{
  "id": "add_focus_widget@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "You are preparing a neurofeedback experiment. While a synthetic board session is streaming in the OpenBCI GUI, add the Focus Widget to the dashboard. Ensure the widget is visible and displaying active Attention and Relaxation metrics without stopping the data stream.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/add_focus_widget/setup_task.sh",
    "post_task": "/workspace/tasks/add_focus_widget/export_result.sh"
  },
  "metadata": {
    "widget_name": "Focus",
    "visual_features": [
      "circular gauge",
      "Attention",
      "Relaxation",
      "neurofeedback"
    ],
    "process_name": "OpenBCI_GUI"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_add_focus_widget"
    }
  },
  "tags": [
    "openbci",
    "neurofeedback",
    "widget",
    "gui-config",
    "visualization"
  ]
}
