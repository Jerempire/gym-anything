{
  "id": "configure_bipolar_srb2_montage@1",
  "version": "1.0",
  "env_id": "openbci_gui_env@0.1",
  "description": "Configure the OpenBCI GUI for a bipolar montage during a live Synthetic session by modifying the SRB2 hardware settings. Disable SRB2 for all odd channels (1, 3, 5, 7) and ensure SRB2 is enabled for all even channels (2, 4, 6, 8). Save a screenshot of the configuration to /home/ga/Documents/OpenBCI_GUI/Screenshots/srb2_config.png.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 180,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_bipolar_srb2_montage/setup_task.sh",
    "post_task": "/workspace/tasks/configure_bipolar_srb2_montage/export_result.sh"
  },
  "metadata": {
    "expected_screenshot_path": "/home/ga/Documents/OpenBCI_GUI/Screenshots/srb2_config.png",
    "target_srb2_state": {
      "ch1": false,
      "ch2": true,
      "ch3": false,
      "ch4": true,
      "ch5": false,
      "ch6": true,
      "ch7": false,
      "ch8": true
    },
    "columns_visible": [
      "POWER",
      "GAIN",
      "INPUT TYPE",
      "BIAS",
      "SRB2",
      "SRB1"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_bipolar_srb2_montage"
    }
  },
  "tags": [
    "openbci",
    "hardware-settings",
    "montage",
    "srb2",
    "configuration"
  ]
}
