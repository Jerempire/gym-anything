{
  "id": "configure_pos_terminal@1",
  "version": "1.0",
  "env_id": "idempiere_env@0.1",
  "description": "Create a new POS Terminal configuration named \"Express Lane 1\" in iDempiere for a new retail lane. The configuration must use the HQ Organization, GardenAdmin as the Sales Representative, Sale Price List, HQ Warehouse, and HQ Cash as the Cash Book. Ensure the Modify Price option is disabled.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_pos_terminal/setup_task.sh",
    "post_task": "/workspace/tasks/configure_pos_terminal/export_result.sh"
  },
  "metadata": {
    "expected_name": "Express Lane 1",
    "expected_org": "HQ",
    "expected_warehouse": "HQ Warehouse",
    "expected_pricelist": "Sale Price List",
    "expected_cashbook": "HQ Cash",
    "expected_modify_price": "N"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_pos_terminal"
    }
  }
}
