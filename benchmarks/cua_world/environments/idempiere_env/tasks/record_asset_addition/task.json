{
  "id": "record_asset_addition@1",
  "version": "1.0",
  "env_id": "idempiere_env@0.1",
  "description": "Record a capital addition of $2,500.00 for the fixed asset 'Company Delivery Van' (Search Key: VAN-001) for the installation of a 'Hydraulic Lift Gate'. Use 'Hydraulic Lift Gate Installation' as the description for the addition record.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/record_asset_addition/setup_task.sh",
    "post_task": "/workspace/tasks/record_asset_addition/export_result.sh"
  },
  "metadata": {
    "target_asset_value": "VAN-001",
    "target_amount": 2500.0,
    "required_description_keywords": [
      "Lift",
      "Gate",
      "Hydraulic"
    ],
    "tolerance_amount": 0.01
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_record_asset_addition"
    }
  }
}
