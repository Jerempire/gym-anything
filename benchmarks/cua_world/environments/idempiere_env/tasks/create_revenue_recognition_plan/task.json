{
  "id": "create_revenue_recognition_plan@1",
  "version": "1.0",
  "env_id": "idempiere_env@0.1",
  "description": "Create a Revenue Recognition Rule for a new subscription service for the GardenWorld client. The rule should be named '12 Month Subscription' with the description 'Ratable recognition over 1 year period'. It must be time-based with a recognition frequency of 'Month'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_revenue_recognition_plan/setup_task.sh",
    "post_task": "/workspace/tasks/create_revenue_recognition_plan/export_result.sh"
  },
  "metadata": {
    "expected_name": "12 Month Subscription",
    "expected_frequency": "M",
    "expected_istimebased": "Y",
    "expected_description_part": "Ratable recognition"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_revenue_recognition_plan"
    }
  }
}
