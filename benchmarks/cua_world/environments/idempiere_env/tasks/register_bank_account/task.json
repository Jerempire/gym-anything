{
  "id": "register_bank_account@1",
  "version": "1.0",
  "env_id": "idempiere_env@0.1",
  "description": "Register a new bank and checking account in iDempiere for payroll processing. Create a bank record named 'Metro City Bank' with Routing No '021000021'. For this bank, create a 'Checking' account named 'Payroll Checking' with Account No '888999000' in 'USD' currency.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/register_bank_account/setup_task.sh",
    "post_task": "/workspace/tasks/register_bank_account/export_result.sh"
  },
  "metadata": {
    "expected_bank_name": "Metro City Bank",
    "expected_routing_no": "021000021",
    "expected_account_name": "Payroll Checking",
    "expected_account_no": "888999000",
    "expected_account_type": "C",
    "expected_currency_iso": "USD"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_register_bank_account"
    }
  }
}
