{
  "id": "create_warehouse@1",
  "version": "1.0",
  "env_id": "idempiere_env@0.1",
  "description": "Create a new warehouse for the HQ organization named 'West Distribution Center' with the search key 'GW-WDC' and a valid location address. Configure three storage locators for this warehouse: 'A01-01-01' (Aisle: A01, Bin: 01, Level: 01) set as the default, 'A01-02-01' (Aisle: A01, Bin: 02, Level: 01), and 'B01-01-01' (Aisle: B01, Bin: 01, Level: 01).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_warehouse/setup_task.sh",
    "post_task": "/workspace/tasks/create_warehouse/export_result.sh"
  },
  "metadata": {
    "expected_warehouse_key": "GW-WDC",
    "expected_warehouse_name": "West Distribution Center",
    "expected_locators": [
      {
        "value": "A01-01-01",
        "x": "A01",
        "y": "01",
        "z": "01",
        "default": true
      },
      {
        "value": "A01-02-01",
        "x": "A01",
        "y": "02",
        "z": "01",
        "default": false
      },
      {
        "value": "B01-01-01",
        "x": "B01",
        "y": "01",
        "z": "01",
        "default": false
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_warehouse"
    }
  }
}
