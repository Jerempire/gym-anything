{
  "id": "configure_product_replenishment@1",
  "version": "1.0",
  "env_id": "idempiere_env@0.1",
  "description": "Configure the replenishment settings for the product 'Elm Tree' at the 'HQ Warehouse'. Set the Replenish Type to 'Reorder below Minimum Level' with a Minimum Level of 25 and a Maximum Level of 100.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_product_replenishment/setup_task.sh",
    "post_task": "/workspace/tasks/configure_product_replenishment/export_result.sh"
  },
  "metadata": {
    "product_name": "Elm Tree",
    "warehouse_name": "HQ Warehouse",
    "expected_level_min": 25,
    "expected_level_max": 100,
    "expected_type_code": "1"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_replenishment"
    }
  }
}
