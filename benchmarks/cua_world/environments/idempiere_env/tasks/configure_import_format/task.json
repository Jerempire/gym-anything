{
  "id": "configure_import_format@1",
  "version": "1.0",
  "env_id": "idempiere_env@0.1",
  "description": "Configure a new Import Format named 'Legacy Customer Import' in iDempiere to enable the migration of legacy customer data. The format must map to the Business Partner Import table (I_BPartner) using a Comma Separated format. Include the following field mappings: Seq 10 for 'Search Key' (String), Seq 20 for 'Name' (String), Seq 30 for 'Tax ID' (String), and Seq 40 for 'Description' (String).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_import_format/setup_task.sh",
    "post_task": "/workspace/tasks/configure_import_format/export_result.sh"
  },
  "metadata": {
    "expected_name": "Legacy Customer Import",
    "expected_table": "I_BPartner",
    "expected_format_type": "C",
    "expected_fields": [
      {
        "seq": 10,
        "column": "Value",
        "type": "String"
      },
      {
        "seq": 20,
        "column": "Name",
        "type": "String"
      },
      {
        "seq": 30,
        "column": "TaxID",
        "type": "String"
      },
      {
        "seq": 40,
        "column": "Description",
        "type": "String"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_import_format"
    }
  }
}
