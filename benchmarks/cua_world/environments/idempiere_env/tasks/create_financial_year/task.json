{
  "id": "create_financial_year@1",
  "version": "1.0",
  "env_id": "idempiere_env@0.1",
  "description": "Create a financial year record for 2030 within the 'Standard' calendar. Set the Name and Fiscal Year to '2030' and generate the 12 standard monthly accounting periods for that year.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_financial_year/setup_task.sh",
    "post_task": "/workspace/tasks/create_financial_year/export_result.sh"
  },
  "metadata": {
    "target_year": "2030",
    "target_calendar": "Standard",
    "expected_period_count": 12
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_financial_year"
    }
  }
}
