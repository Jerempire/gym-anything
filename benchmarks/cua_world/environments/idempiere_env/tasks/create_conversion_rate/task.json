{
  "id": "create_conversion_rate@1",
  "version": "1.0",
  "env_id": "idempiere_env@0.1",
  "description": "Configure a new 'Spot' currency conversion rate for the GardenWorld client in iDempiere. Create a record for EUR (Euro) to USD (US Dollar) with a Multiply Rate of 1.085000, effective from January 1, 2025, to December 31, 2025.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_conversion_rate/setup_task.sh",
    "post_task": "/workspace/tasks/create_conversion_rate/export_result.sh"
  },
  "metadata": {
    "expected_currency_from": "EUR",
    "expected_currency_to": "USD",
    "expected_type": "Spot",
    "expected_multiply_rate": 1.085,
    "rate_tolerance": 0.001,
    "expected_valid_from": "2025-01-01",
    "expected_valid_to": "2025-12-31"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_conversion_rate"
    }
  }
}
