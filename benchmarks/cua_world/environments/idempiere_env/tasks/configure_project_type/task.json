{
  "id": "configure_project_type@1",
  "version": "1.0",
  "env_id": "idempiere_env@0.1",
  "description": "Configure a new Project Type in iDempiere named 'Winter Garden Prep' to serve as a template for winterization services. The project type must include three standard phases: 'Pruning' (Sequence 10, Standard Qty 1), 'Mulching' (Sequence 20, Standard Qty 1), and 'Covering' (Sequence 30, Standard Qty 1).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_project_type/setup_task.sh",
    "post_task": "/workspace/tasks/configure_project_type/export_result.sh"
  },
  "metadata": {
    "expected_name": "Winter Garden Prep",
    "expected_phases": [
      {
        "name": "Pruning",
        "seq": 10
      },
      {
        "name": "Mulching",
        "seq": 20
      },
      {
        "name": "Covering",
        "seq": 30
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_project_type"
    }
  }
}
