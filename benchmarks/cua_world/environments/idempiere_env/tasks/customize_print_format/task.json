{
  "id": "customize_print_format@1",
  "version": "1.0",
  "env_id": "idempiere_env@0.1",
  "description": "Create a new Print Format named 'Customer Proposal' based on the existing 'Standard Order' format for the Order table. In this new format, change the header title text to 'PROPOSAL' and hide the 'Line No' column so it does not appear on the printed document.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/customize_print_format/setup_task.sh",
    "post_task": "/workspace/tasks/customize_print_format/export_result.sh"
  },
  "metadata": {
    "target_format_name": "Customer Proposal",
    "source_format_name": "Standard Order",
    "target_text": "PROPOSAL",
    "hidden_column_name": "Line",
    "table_name": "C_Order"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_customize_print_format"
    }
  }
}
