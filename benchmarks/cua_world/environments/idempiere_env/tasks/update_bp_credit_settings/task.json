{
  "id": "update_bp_credit_settings@1",
  "version": "1.0",
  "env_id": "idempiere_env@0.1",
  "description": "GardenWorld's sales director has approved a strategic partnership with Seed Farm Inc. The accounting team needs to update their credit management configuration. Update the business partner 'Seed Farm Inc.' with the following credit settings: set the SO Credit Limit to 75,000.00, the SO Credit Status to 'Credit Watch', and the Payment Rule to 'On Credit'. Save the changes to the record.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/update_bp_credit_settings/setup_task.sh",
    "post_task": "/workspace/tasks/update_bp_credit_settings/export_result.sh"
  },
  "metadata": {
    "target_bp_name": "Seed Farm Inc.",
    "expected_credit_limit": 75000.0,
    "expected_credit_status": "W",
    "expected_payment_rule": "P",
    "credit_status_map": {
      "W": "Credit Watch",
      "H": "Credit Hold",
      "O": "Credit OK",
      "S": "Credit Stop"
    },
    "payment_rule_map": {
      "P": "On Credit",
      "C": "Cash",
      "K": "Credit Card",
      "D": "Direct Debit"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_update_bp_credit_settings"
    }
  }
}
