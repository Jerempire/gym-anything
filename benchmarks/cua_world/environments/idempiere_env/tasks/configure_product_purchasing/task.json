{
  "id": "configure_product_purchasing@1",
  "version": "1.0",
  "env_id": "idempiere_env@0.1",
  "description": "Configure the purchasing terms for the product 'Heavy Duty Tarp' with the vendor 'Industrial Supply Co'. Set the Minimum Order Quantity to 50, Promised Delivery Time to 7 days, and both the List Price and Price/Limit Price to 45.00.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_product_purchasing/setup_task.sh",
    "post_task": "/workspace/tasks/configure_product_purchasing/export_result.sh"
  },
  "metadata": {
    "product_name": "Heavy Duty Tarp",
    "vendor_name": "Industrial Supply Co",
    "expected_moq": 50,
    "expected_delivery_days": 7,
    "expected_price": 45.0
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_product_purchasing"
    }
  }
}
