{
  "id": "configure_product_substitute@1",
  "version": "1.0",
  "env_id": "idempiere_env@0.1",
  "description": "Configure a product substitution rule in iDempiere for the GardenWorld client. Set the product 'Hoe' as a substitute for the product 'Spade'. The substitution record must be named 'Alternative for Spring' and include the description 'Suggest when Spade is out of stock'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_product_substitute/setup_task.sh",
    "post_task": "/workspace/tasks/configure_product_substitute/export_result.sh"
  },
  "metadata": {
    "parent_product_name": "Spade",
    "substitute_product_name": "Hoe",
    "expected_name": "Alternative for Spring",
    "expected_description_part": "out of stock"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_product_substitute"
    }
  }
}
