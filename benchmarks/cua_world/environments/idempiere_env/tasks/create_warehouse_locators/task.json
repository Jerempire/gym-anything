{
  "id": "create_warehouse_locators@1",
  "version": "1.0",
  "env_id": "idempiere_env@0.1",
  "description": "Configure the warehouse infrastructure by adding three new active storage locators to the 'HQ Warehouse' to represent a new Overstock Zone. The locators must use the following Search Key/Values and coordinates: 'OV-01-01' (X:1, Y:1, Z:1), 'OV-01-02' (X:1, Y:1, Z:2), and 'OV-01-03' (X:1, Y:1, Z:3).",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_warehouse_locators/setup_task.sh",
    "post_task": "/workspace/tasks/create_warehouse_locators/export_result.sh"
  },
  "metadata": {
    "warehouse_name": "HQ Warehouse",
    "locators": [
      {
        "value": "OV-01-01",
        "x": "1",
        "y": "1",
        "z": "1"
      },
      {
        "value": "OV-01-02",
        "x": "1",
        "y": "1",
        "z": "2"
      },
      {
        "value": "OV-01-03",
        "x": "1",
        "y": "1",
        "z": "3"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_warehouse_locators"
    }
  }
}
