{
  "id": "configure_custom_editorial_roles@1",
  "version": "1.0",
  "env_id": "wordpress_env@0.1",
  "description": "Create a custom WordPress user role named \"Freelance Writer\" (internal slug: freelance_writer). This role must be granted the capabilities edit_posts, read, and upload_files, but must not have the publish_posts capability. Reassign the users sam_taylor, alex_rivera, and jordan_lee from the \"Author\" role to the new \"Freelance Writer\" role.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_custom_editorial_roles/setup_task.sh",
    "post_task": "/workspace/tasks/configure_custom_editorial_roles/export_result.sh"
  },
  "metadata": {
    "expected_role_slug": "freelance_writer",
    "required_capabilities": [
      "edit_posts",
      "read",
      "upload_files"
    ],
    "forbidden_capabilities": [
      "publish_posts"
    ],
    "target_users": [
      "sam_taylor",
      "alex_rivera",
      "jordan_lee"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_configure_custom_editorial_roles"
    }
  }
}
