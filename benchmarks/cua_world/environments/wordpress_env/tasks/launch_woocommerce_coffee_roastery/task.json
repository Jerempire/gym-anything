{
  "id": "launch_woocommerce_coffee_roastery@1",
  "version": "1.0",
  "env_id": "wordpress_env@0.1",
  "description": "You are launching the online store for \"Summit Roasters,\" a specialty coffee roastery. WooCommerce is installed but inactive. The store configuration is at ~/Documents/Store_Launch/store_brief.txt and the product catalog is at ~/Documents/Store_Launch/product_catalog.csv.\n\nActivate WooCommerce and configure all store settings from the brief, including store address, currency, tax rate, a shipping zone with its methods, and a promotional coupon. Create the product category hierarchy from the CSV with proper parent-child relationships, and create the product attribute described in the brief.\n\nAdd all 6 products from the CSV with their exact names, SKUs, descriptions, and correct categories. Coffee products marked \"variable\" must be created as WooCommerce Variable Products with the attribute as variations, using the per-size prices from the CSV. Equipment products marked \"simple\" use regular pricing.",
  "difficulty": "very_hard",
  "init": {
    "timeout_sec": 1800,
    "max_steps": 300,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/launch_woocommerce_coffee_roastery/setup_task.sh",
    "post_task": "/workspace/tasks/launch_woocommerce_coffee_roastery/export_result.sh"
  },
  "metadata": {
    "store_config": {
      "address": "415 Westlake Avenue",
      "city": "Seattle",
      "state": "WA",
      "postcode": "98109",
      "country": "US",
      "currency": "USD"
    },
    "tax": {
      "enabled": true,
      "rate": "6.5000",
      "state": "WA",
      "name": "WA Sales Tax"
    },
    "categories": {
      "Single Origin": {"children": ["African", "Americas"]},
      "Blends": {"children": []},
      "Equipment": {"children": []}
    },
    "attribute": {
      "name": "Bag Size",
      "slug": "bag-size",
      "terms": ["250g", "500g", "1kg"]
    },
    "products": {
      "variable": [
        {
          "name": "Ethiopian Yirgacheffe",
          "sku": "SR-ETH-001",
          "category": "African",
          "prices": {"250g": "14.99", "500g": "26.99", "1kg": "48.99"}
        },
        {
          "name": "Colombian Supremo",
          "sku": "SR-COL-002",
          "category": "Americas",
          "prices": {"250g": "13.99", "500g": "24.99", "1kg": "44.99"}
        },
        {
          "name": "Morning Symphony",
          "sku": "SR-BLD-001",
          "category": "Blends",
          "prices": {"250g": "12.99", "500g": "22.99", "1kg": "41.99"}
        }
      ],
      "simple": [
        {"name": "Hario V60 Dripper", "sku": "SR-EQP-001", "price": "32.00", "category": "Equipment"},
        {"name": "Baratza Encore Grinder", "sku": "SR-EQP-002", "price": "169.99", "category": "Equipment"},
        {"name": "Fellow Stagg Kettle", "sku": "SR-EQP-003", "price": "89.95", "category": "Equipment"}
      ]
    },
    "shipping": {
      "zone_name": "Domestic US",
      "flat_rate": "5.99",
      "free_shipping_min": "75"
    },
    "coupon": {
      "code": "GRANDOPENING",
      "discount_type": "percent",
      "amount": "20",
      "usage_limit": 500,
      "expiry": "2026-12-31"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_launch_woocommerce_coffee_roastery"
    }
  }
}
