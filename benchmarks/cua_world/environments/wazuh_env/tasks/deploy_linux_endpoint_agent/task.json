{
  "id": "deploy_linux_endpoint_agent@1",
  "version": "1.0",
  "env_id": "wazuh_env@0.1",
  "description": "Install and enroll the Wazuh agent on this Linux workstation to register it with the local Wazuh Manager at 127.0.0.1. Configure the agent with the name 'production-db-01' and ensure the service is active and successfully connected to the manager.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 600,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/deploy_linux_endpoint_agent/setup_task.sh",
    "post_task": "/workspace/tasks/deploy_linux_endpoint_agent/export_result.sh"
  },
  "metadata": {
    "agent_name": "production-db-01",
    "manager_ip": "127.0.0.1",
    "expected_status": "active"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_deploy_linux_endpoint_agent"
    }
  }
}
