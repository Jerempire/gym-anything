{
  "id": "example.user_permissions_demo@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd",
  "description": "Demonstration of user permissions and access controls",
  "observation": [
    {"type": "rgb_screen", "fps": 10, "resolution": [1280, 720], "inline": false}
  ],
  "action": [
    {"type": "mouse"}, 
    {"type": "keyboard"}
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": true, 
    "output_dir": "benchmarks/cua_world/environments/user_permissions_demo/artifacts"
  },
  "vnc": {
    "enable": true,
    "host_port": 20340,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": ["ALL"],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "role": "admin",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "docker", "audio", "video", "input"],
        "shell": "/bin/bash",
        "env_vars": {
          "GA_ADMIN": "true",
          "DEBUG_LEVEL": "verbose"
        }
      }
    },
    {
      "name": "admin",
      "password": "secure123",
      "uid": 1010,
      "role": "admin",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": ["sudo", "docker", "audio", "video", "input"],
        "shell": "/bin/bash",
        "home_permissions": "700",
        "env_vars": {
          "ADMIN_MODE": "true",
          "DEBUG_LEVEL": "verbose"
        }
      }
    },
    {
      "name": "developer", 
      "password": "password123",
      "uid": 1002,
      "role": "developer",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": false,
        "groups": ["docker", "audio", "video", "input"],
        "shell": "/bin/bash",
        "max_processes": 100,
        "env_vars": {
          "DEV_ENV": "container",
          "NODE_ENV": "development"
        }
      }
    },
    {
      "name": "guest",
      "password": "#ac#cess123",
      "uid": 1003,
      "role": "guest",
      "permissions": {
        "sudo": false,
        "groups": ["audio", "video"],
        "shell": "/bin/bash",
        "max_processes": 50,
        "max_memory": "512M",
        "home_permissions": "755"
      }
    },
    {
      "name": "service_worker",
      "uid": 998,
      "role": "service",
      "permissions": {
        "sudo": false,
        "system_user": true,
        "login_shell": false,
        "create_home": false,
        "shell": "/bin/false",
        "groups": ["nogroup"]
      }
    }
  ],
  "tags": ["linux", "vision", "offline", "multi-user"]
}
