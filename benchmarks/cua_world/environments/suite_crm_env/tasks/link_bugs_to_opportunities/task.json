{
  "id": "link_bugs_to_opportunities@1",
  "version": "1.0",
  "env_id": "suite_crm_env@0.1",
  "description": "Create a Many-to-Many relationship between the Opportunities and Bugs modules. Link the Bug record 'Login page timeout error' to the Opportunity record 'GlobalMedia - 1000 Licenses' using the resulting subpanel.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 480,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/link_bugs_to_opportunities/setup_task.sh",
    "post_task": "/workspace/tasks/link_bugs_to_opportunities/export_result.sh"
  },
  "metadata": {
    "opportunity_name": "GlobalMedia - 1000 Licenses",
    "bug_name": "Login page timeout error",
    "relationship_type": "many-to-many"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_link_bugs"
    }
  }
}
