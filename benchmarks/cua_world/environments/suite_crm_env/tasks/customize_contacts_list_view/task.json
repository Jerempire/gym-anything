{
  "id": "customize_contacts_list_view@1",
  "version": "1.0",
  "env_id": "suite_crm_env@0.1",
  "description": "Modify the Contacts List View layout in SuiteCRM's Studio to include 'Do Not Call' and 'Department' columns in the default view, and remove the 'Title' column from the default view. Deploy the changes to apply them to the system.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/customize_contacts_list_view/setup_task.sh",
    "post_task": "/workspace/tasks/customize_contacts_list_view/export_result.sh"
  },
  "metadata": {
    "expected_added_fields": [
      "DEPARTMENT",
      "DO_NOT_CALL"
    ],
    "expected_removed_fields": [
      "TITLE"
    ],
    "required_preserved_fields": [
      "NAME"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_customize_contacts_list_view"
    }
  }
}
