{
  "id": "create_custom_relationship_m2m@1",
  "version": "1.0",
  "env_id": "suite_crm_env@0.1",
  "description": "Create a Many-to-Many relationship between the Opportunities and Bugs modules. Once the relationship is established, link the bug record named 'UI unresponsive on mobile' to the opportunity record named 'Enterprise License - Meridian Tech'.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 480,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_custom_relationship_m2m/setup_task.sh",
    "post_task": "/workspace/tasks/create_custom_relationship_m2m/export_result.sh"
  },
  "metadata": {
    "target_opportunity": "Enterprise License - Meridian Tech",
    "target_bug": "UI unresponsive on mobile",
    "opp_id": "opp-meridian-1234",
    "bug_id": "bug-mobile-5678"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_custom_relationship"
    }
  }
}
