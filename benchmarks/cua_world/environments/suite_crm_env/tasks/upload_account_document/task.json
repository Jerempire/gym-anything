{
  "id": "upload_account_document@1",
  "version": "1.0",
  "env_id": "suite_crm_env@0.1",
  "description": "Upload the signed NDA PDF located at ~/Documents/Apex_NDA_Signed.pdf to the 'Apex Industrial Solutions' account in SuiteCRM. The document should be named 'Apex NDA 2026' with the category 'Sales', status 'Active', and publish date '03/01/2026'. Include the description: 'Signed mutual NDA for Q1 2026 discussions.'",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/upload_account_document/setup_task.sh",
    "post_task": "/workspace/tasks/upload_account_document/export_result.sh"
  },
  "metadata": {
    "expected_document_name": "Apex NDA 2026",
    "expected_category": "Sales",
    "expected_status": "Active",
    "expected_date": "2026-03-01",
    "expected_filename": "Apex_NDA_Signed.pdf",
    "expected_account": "Apex Industrial Solutions"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_upload_account_document"
    }
  }
}
