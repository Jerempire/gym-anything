{
  "id": "configure_regional_sales_settings@1",
  "version": "1.0",
  "env_id": "suite_crm_env@0.1",
  "description": "Configure regional sales settings for a Canadian expansion in SuiteCRM. Create three tax rates: 'GST - Canada' (Value: 5%, Status: Active), 'PST - British Columbia' (Value: 7%, Status: Active), and 'HST - Ontario' (Value: 13%, Status: Active). Additionally, create two shipping providers named 'Canada Post' and 'Purolator', both with the status 'Active'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/configure_regional_sales_settings/setup_task.sh",
    "post_task": "/workspace/tasks/configure_regional_sales_settings/export_result.sh"
  },
  "metadata": {
    "expected_tax_rates": [
      {
        "name": "GST - Canada",
        "value": 5.0,
        "status": "Active"
      },
      {
        "name": "PST - British Columbia",
        "value": 7.0,
        "status": "Active"
      },
      {
        "name": "HST - Ontario",
        "value": 13.0,
        "status": "Active"
      }
    ],
    "expected_shippers": [
      {
        "name": "Canada Post",
        "status": "Active"
      },
      {
        "name": "Purolator",
        "status": "Active"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_regional_sales_settings"
    }
  }
}
