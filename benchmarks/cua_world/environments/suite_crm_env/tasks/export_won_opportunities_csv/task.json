{
  "id": "export_won_opportunities_csv@1",
  "version": "1.0",
  "env_id": "suite_crm_env@0.1",
  "description": "Filter the Opportunities module to show only 'Closed Won' deals. Export the resulting records to a CSV file and save it to /home/ga/Documents/closed_won_deals.csv. Ensure no 'Prospecting' or 'Closed Lost' deals are included in the final file.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_won_opportunities_csv/setup_task.sh",
    "post_task": "/workspace/tasks/export_won_opportunities_csv/export_result.sh"
  },
  "metadata": {
    "expected_file_path": "/home/ga/Documents/closed_won_deals.csv",
    "target_deals": [
      "Q3 Server Rack Expansion - NexusHealth",
      "Bulk Cable Procurement - OmegaCorp",
      "Office Network Upgrade - TechCorp",
      "Enterprise License Renewal - Globex",
      "Consulting Services - Initech",
      "Hardware Refresh - Umbrella Corp",
      "Cloud Migration - Stark Industries",
      "Security Audit - Wayne Enterprises"
    ],
    "noise_deals": [
      "Initial Consultation - Delta Logistics",
      "Lost: Pricing - TechFlow Systems",
      "Q4 Software Rollout - CyberDyne",
      "Server Maintenance - Massive Dynamic",
      "Employee Laptops - Dunder Mifflin",
      "Router Replacement - Pied Piper",
      "Security System - Hooli",
      "Database Migration - Aviato",
      "Cloud Storage - Erlich Bachman",
      "Data Center Cooling - Tyrell Corp",
      "Lost: Competitor - Weyland-Yutani",
      "Network Cabling - Oscorp",
      "Backup Servers - InGen",
      "Telecom Setup - Virtucon",
      "VoIP Implementation - Initrode",
      "Lost: Budget - Soylent Corp",
      "Fiber Optic Install - BNL"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export"
    }
  }
}
