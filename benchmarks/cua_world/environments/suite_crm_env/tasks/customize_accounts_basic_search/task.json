{
  "id": "customize_accounts_basic_search@1",
  "version": "1.0",
  "env_id": "suite_crm_env@0.1",
  "description": "Customize the Accounts module's search layout in SuiteCRM to improve the efficiency of the sales team. Add the \"Type\" (account_type) and \"Industry\" (industry) fields to the Basic Search layout for the Accounts module.\n\nSuiteCRM Login - Username: admin / Password: Admin1234!",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/customize_accounts_basic_search/setup_task.sh",
    "post_task": "/workspace/tasks/customize_accounts_basic_search/export_result.sh"
  },
  "metadata": {
    "expected_fields": [
      "account_type",
      "industry"
    ],
    "target_module": "Accounts",
    "target_layout": "basic_search"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_customize_accounts_basic_search"
    }
  }
}
