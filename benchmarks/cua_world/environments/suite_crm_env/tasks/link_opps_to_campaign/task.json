{
  "id": "link_opps_to_campaign@1",
  "version": "1.0",
  "env_id": "suite_crm_env@0.1",
  "description": "Update the 'Spring Tech Conference' campaign's Actual Cost to $4,500.00 and link the existing opportunities 'Alpha Tech Upgrade', 'Beta Corp License', and 'Gamma LLC Support' to this campaign for ROI tracking.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/link_opps_to_campaign/setup_task.sh",
    "post_task": "/workspace/tasks/link_opps_to_campaign/export_result.sh"
  },
  "metadata": {
    "target_campaign": "Spring Tech Conference",
    "expected_cost": 4500.0,
    "target_opp_1": "Alpha Tech Upgrade",
    "target_opp_2": "Beta Corp License",
    "target_opp_3": "Gamma LLC Support"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_link_opps"
    }
  }
}
