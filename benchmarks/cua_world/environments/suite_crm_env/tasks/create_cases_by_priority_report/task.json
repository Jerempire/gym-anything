{
  "id": "create_cases_by_priority_report@1",
  "version": "1.0",
  "env_id": "suite_crm_env@0.1",
  "description": "Create a report in the SuiteCRM Advanced OpenReports module named 'Active Cases by Priority' for the 'Cases' module. The report should filter for cases where the status is not 'Closed' and include columns for Number, Subject, Priority, and Status. Include a pie chart titled 'Case Priority Distribution' that displays the record count grouped by priority. Save the report.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_cases_by_priority_report/setup_task.sh",
    "post_task": "/workspace/tasks/create_cases_by_priority_report/export_result.sh"
  },
  "metadata": {
    "expected_name": "Active Cases by Priority",
    "expected_module": "Cases",
    "expected_condition_field": "status",
    "expected_condition_value": "Closed",
    "expected_fields": [
      "case_number",
      "name",
      "priority",
      "status"
    ],
    "expected_chart_title": "Case Priority Distribution",
    "expected_chart_type": "Pie",
    "expected_chart_x_field": "priority"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_cases_by_priority_report"
    }
  }
}
