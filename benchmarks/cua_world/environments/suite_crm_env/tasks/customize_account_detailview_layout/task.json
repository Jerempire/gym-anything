{
  "id": "customize_account_detailview_layout@1",
  "version": "1.0",
  "env_id": "suite_crm_env@0.1",
  "description": "Use SuiteCRM Studio to customize the Accounts DetailView. Create a new panel named 'Financial Details' and add the 'Annual Revenue', 'Ticker Symbol', and 'Employees' fields to it. Save and deploy the updated layout.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/customize_account_detailview_layout/setup_task.sh",
    "post_task": "/workspace/tasks/customize_account_detailview_layout/export_result.sh"
  },
  "metadata": {
    "expected_fields": [
      "annual_revenue",
      "ticker_symbol",
      "employees"
    ],
    "expected_panel_label": "Financial Details"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_customize_account_detailview_layout"
    }
  }
}
