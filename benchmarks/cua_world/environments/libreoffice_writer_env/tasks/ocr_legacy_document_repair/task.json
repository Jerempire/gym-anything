{
  "id": "ocr_legacy_document_repair@1",
  "version": "1.0",
  "env_id": "libreoffice_writer_env@0.1",
  "description": "Repair the OCR formatting in '/home/ga/Documents/udhr_ocr_scan.docx', which contains the Universal Declaration of Human Rights (Preamble and Articles 1-5). Restore natural paragraph flow by joining broken lines and rejoining split hyphenated words. Apply the 'Title' style to the first line, 'Heading 1' to 'Preamble', and 'Heading 2' to 'Article 1' through 'Article 5'. Save the restored document to '/home/ga/Documents/udhr_restored.docx'.",
  "difficulty": "hard",
  "init": {
    "timeout_sec": 600,
    "max_steps": 80,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/ocr_legacy_document_repair/setup_task.sh",
    "post_task": "/workspace/tasks/ocr_legacy_document_repair/export_result.sh"
  },
  "metadata": {
    "source_path": "/home/ga/Documents/udhr_ocr_scan.docx",
    "output_path": "/home/ga/Documents/udhr_restored.docx",
    "target_paragraph_count_min": 10,
    "target_paragraph_count_max": 25,
    "broken_words_to_fix": [
      "declaration",
      "fundamental",
      "jurisdiction",
      "distinction",
      "proclamation",
      "inalienable",
      "conscience",
      "brotherhood"
    ],
    "headings": {
      "Universal Declaration of Human Rights": "Title",
      "Preamble": "Heading 1",
      "Article 1": "Heading 2",
      "Article 2": "Heading 2",
      "Article 3": "Heading 2",
      "Article 4": "Heading 2",
      "Article 5": "Heading 2"
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_ocr_repair"
    }
  }
}
