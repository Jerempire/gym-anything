{
  "id": "outline_numbering_handbook@1",
  "version": "1.0",
  "env_id": "libreoffice_writer_env@0.1",
  "description": "Format the employee handbook at /home/ga/Documents/employee_handbook.docx. Replace manual formatting with proper document structure by applying 'Heading 1' to main section titles, 'Heading 2' to subsection titles, and 'Heading 3' to sub-subsection titles. Configure the document so that all headings are automatically numbered in a hierarchical format (e.g., 1., 1.1., 1.1.1.). Save the result as /home/ga/Documents/handbook_numbered.docx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/outline_numbering_handbook/setup_task.sh",
    "post_task": "/workspace/tasks/outline_numbering_handbook/export_result.sh"
  },
  "metadata": {
    "input_path": "/home/ga/Documents/employee_handbook.docx",
    "output_path": "/home/ga/Documents/handbook_numbered.docx",
    "txt_export_path": "/home/ga/Documents/handbook_numbered.txt",
    "heading_structure": {
      "Heading 1": [
        "General Employment Policies",
        "Compensation and Benefits",
        "Time Off and Leave Policies",
        "Workplace Conduct and Ethics",
        "Health Safety and Security",
        "Separation and Termination"
      ],
      "Heading 2": [
        "Equal Opportunity Employment",
        "Employment Classifications",
        "Pay Structure and Schedule",
        "Insurance and Retirement Benefits",
        "Annual Leave",
        "Sick Leave",
        "Family and Medical Leave",
        "Standards of Professional Conduct",
        "Anti Harassment Policy",
        "Workplace Safety Program",
        "Emergency Procedures",
        "Voluntary and Involuntary Separation"
      ],
      "Heading 3": [
        "Reasonable Accommodations",
        "Overtime Compensation",
        "Health Insurance",
        "Retirement Plans",
        "Leave Donation Program",
        "Electronic Communications Policy",
        "Fire Evacuation Plan",
        "Return of Company Property"
      ]
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_outline_numbering"
    }
  }
}
