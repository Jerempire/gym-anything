{
  "id": "handbook_find_replace@1",
  "version": "1.0",
  "env_id": "libreoffice_writer_env@0.1",
  "description": "Update the employee handbook at /home/ga/Documents/employee_handbook.docx by replacing all double spaces with single spaces, standardizing \"Greenfield industries\" to \"Greenfield Industries\", updating the email domain from \"@greenfield-ind.com\" to \"@greenfieldind.com\", expanding \"dept.\" (case-insensitive) to \"Department\", and updating the policy year from \"2019\" to \"2024\". Save the corrected document as a new file at /home/ga/Documents/employee_handbook_corrected.docx.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 420,
    "max_steps": 60,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/handbook_find_replace/setup_task.sh",
    "post_task": "/workspace/tasks/handbook_find_replace/export_result.sh"
  },
  "metadata": {
    "source_path": "/home/ga/Documents/employee_handbook.docx",
    "output_path": "/home/ga/Documents/employee_handbook_corrected.docx",
    "checks": {
      "double_spaces": {
        "pattern": "  ",
        "target": 0
      },
      "company_casing_bad": {
        "pattern": "Greenfield industries",
        "target": 0
      },
      "company_casing_good": {
        "pattern": "Greenfield Industries",
        "min_count": 8
      },
      "old_email": {
        "pattern": "@greenfield-ind.com",
        "target": 0
      },
      "new_email": {
        "pattern": "@greenfieldind.com",
        "min_count": 5
      },
      "abbrev_dept": {
        "pattern": "dept.",
        "target": 0,
        "case_insensitive": true
      },
      "full_dept": {
        "pattern": "Department",
        "min_count": 7
      },
      "old_year": {
        "pattern": "2019",
        "target": 0
      },
      "new_year": {
        "pattern": "2024",
        "min_count": 4
      }
    }
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_handbook_corrections"
    }
  }
}
