{
  "id": "catalog_physical_archive_locations@1",
  "version": "1.0",
  "env_id": "zotero_env@0.1",
  "description": "A research lab maintains a physical archive of seminal papers in labeled boxes. Update the Zotero library to map digital records to these physical locations using the 'Call Number' field. Assign 'BOX-TURING' to the two papers by Alan Turing, 'BOX-SHANNON' to the two papers by Claude Shannon (including the one co-authored with Weaver), and 'BOX-RELATIVITY' to the paper by Albert Einstein. For papers with multiple authors, file based on the first author.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 50,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/catalog_physical_archive_locations/setup_task.sh",
    "post_task": "/workspace/tasks/catalog_physical_archive_locations/export_result.sh"
  },
  "metadata": {
    "expected_assignments": {
      "Turing": "BOX-TURING",
      "Shannon": "BOX-SHANNON",
      "Einstein": "BOX-RELATIVITY"
    },
    "targets": [
      {
        "author": "Turing",
        "title_part": "Computable Numbers"
      },
      {
        "author": "Turing",
        "title_part": "Computing Machinery"
      },
      {
        "author": "Shannon",
        "title_part": "A Mathematical Theory"
      },
      {
        "author": "Shannon",
        "title_part": "The Mathematical Theory"
      },
      {
        "author": "Einstein",
        "title_part": "Electrodynamics"
      }
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_catalog_physical_archive_locations"
    }
  }
}
