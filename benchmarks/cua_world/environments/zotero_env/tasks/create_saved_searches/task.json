{
  "id": "create_saved_searches@1",
  "version": "1.0",
  "env_id": "zotero_env@0.1",
  "description": "Create two saved searches in your Zotero library to filter your papers dynamically. Create a saved search named 'Pre-1960 Classics' (case-sensitive) that finds all papers published before the year 1960. Create a second saved search named 'Nature Publications' (case-sensitive) that finds all papers published in the journal 'Nature'.",
  "difficulty": "medium",
  "init": {
    "timeout_sec": 300,
    "max_steps": 40,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/create_saved_searches/setup_task.sh",
    "post_task": "/workspace/tasks/create_saved_searches/export_result.sh"
  },
  "metadata": {
    "search1_name": "Pre-1960 Classics",
    "search1_field_variants": [
      "date",
      "year"
    ],
    "search1_operator_variants": [
      "isBefore",
      "is before",
      "less than"
    ],
    "search1_value": "1960",
    "search2_name": "Nature Publications",
    "search2_field_variants": [
      "publicationTitle",
      "publication",
      "journalArticle"
    ],
    "search2_operator_variants": [
      "contains",
      "is"
    ],
    "search2_value": "Nature"
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_create_saved_searches"
    }
  }
}
