{
  "id": "export_collection_bibtex@1",
  "version": "1.0",
  "env_id": "zotero_env@0.1",
  "description": "You are a researcher preparing a manuscript submission and need to provide your bibliography in BibTeX format for your LaTeX document. Your Zotero library contains a collection called 'ML References' with foundational deep learning papers. Export the 'ML References' collection as a BibTeX file to /home/ga/Desktop/ml_bibliography.bib.",
  "difficulty": "easy",
  "init": {
    "timeout_sec": 240,
    "max_steps": 35,
    "reward_type": "sparse"
  },
  "hooks": {
    "pre_task": "/workspace/tasks/export_collection_bibtex/setup_task.sh",
    "post_task": "/workspace/tasks/export_collection_bibtex/export_result.sh"
  },
  "metadata": {
    "collection_name": "ML References",
    "expected_output_path": "/home/ga/Desktop/ml_bibliography.bib",
    "expected_min_entries": 5,
    "expected_authors": [
      "Vaswani",
      "Devlin",
      "Brown",
      "Krizhevsky",
      "He",
      "Goodfellow",
      "LeCun",
      "Silver"
    ]
  },
  "success": {
    "mode": "program",
    "spec": {
      "program": "verifier.py::verify_export_collection_bibtex"
    }
  }
}
